    la kommandohistorikk_bruk_knapp: heltall = gui.knapp(kommandohistorikk_handling, "Bruk valgt")
    la kommandohistorikk_tøm_knapp: heltall = gui.knapp(kommandohistorikk_handling, "Tøm")
    la work_panel: heltall = gui.panel(work_row)
    la arbeidsflate_tittel: heltall = gui.etikett(work_panel, "Arbeidsflate | hovedområde")
    la faner_id: heltall = gui.knapp(work_panel, "Faner | ingen åpne filer")
    la toolbar: heltall = gui.rad(work_panel)
    la sti_etikett: heltall = gui.etikett(toolbar, "Filsti")
    la sti_felt: heltall = gui.tekstfelt(toolbar, "")
    la ny_knapp: heltall = gui.knapp(toolbar, "Ny")
    la apne_knapp: heltall = gui.knapp(toolbar, "Åpne")
    la lagre_knapp: heltall = gui.knapp(toolbar, "Lagre")
    la lagre_som_knapp: heltall = gui.knapp(toolbar, "Lagre som")
    la kjor_knapp: heltall = gui.knapp(toolbar, "Kjør")
    la sjekk_knapp: heltall = gui.knapp(toolbar, "Sjekk")
    la linje_etikett: heltall = gui.etikett(toolbar, "Linje")
    la linje_felt: heltall = gui.tekstfelt(toolbar, "")
    la linje_knapp: heltall = gui.knapp(toolbar, "Hopp")
    la def_knapp: heltall = gui.knapp(toolbar, "Def")
    la bruk_knapp: heltall = gui.knapp(toolbar, "Bruk")
    la sok_etikett: heltall = gui.etikett(toolbar, "Søk")
    la sok_felt: heltall = gui.tekstfelt(toolbar, "")
    la sok_knapp: heltall = gui.knapp(toolbar, "Finn")
    la erstatt_etikett: heltall = gui.etikett(toolbar, "Erstatt")
    la erstatt_felt: heltall = gui.tekstfelt(toolbar, "")
    la erstatt_knapp: heltall = gui.knapp(toolbar, "Bytt")
    la nyttnavn_etikett: heltall = gui.etikett(toolbar, "Nytt navn")
    la nyttnavn_felt: heltall = gui.tekstfelt(toolbar, "")
    la nyttnavn_knapp: heltall = gui.knapp(toolbar, "Navn")
    la tester_knapp: heltall = gui.knapp(toolbar, "Test")
    la kommando_etikett: heltall = gui.etikett(toolbar, "Kommando")
    la kommando_felt: heltall = gui.tekstfelt(toolbar, "norscode test")
    la kommando_knapp: heltall = gui.knapp(toolbar, "Kjør")
    la kilde_panel: heltall = gui.panel(work_panel)
    la kilde_tittel: heltall = gui.etikett(kilde_panel, "Kildekode | aktiv fil")
    la editor_status: heltall = gui.tekst(kilde_panel, "Fil: Ny buffer | Linje: 1 | Kolonne: 1 | Symbol: ingen | Ulagret")
    la kilde_rad: heltall = gui.rad(kilde_panel)
    la linje_id: heltall = gui.tekst(kilde_rad, "1")
    la kilde_id: heltall = gui.editor(
        kilde_rad,
        "bruk std.gui som gui\n\nfunksjon start() -> heltall {\n    skriv(\"Hei fra Norscode Studio\")\n    returner 0\n}\n"
    )
    la autocomplete_panel: heltall = gui.panel(kilde_panel)
    la autocomplete_tittel: heltall = gui.etikett(autocomplete_panel, "Autocomplete | forslag")
    la autocomplete_liste_id: heltall = gui.liste(autocomplete_panel)
    la autocomplete_handling: heltall = gui.rad(autocomplete_panel)
    la autocomplete_sett_inn_knapp: heltall = gui.knapp(autocomplete_handling, "Sett inn valgt")
    la autocomplete_oppdater_knapp: heltall = gui.knapp(autocomplete_handling, "Oppdater")
    la utdata_panel: heltall = gui.panel(work_panel)
    la utdata_tittel: heltall = gui.etikett(utdata_panel, "Output | kjøring og sjekk")
    la utdata_id: heltall = gui.editor(utdata_panel, "")
    la diagnose_panel: heltall = gui.panel(work_panel)
    la diagnose_tittel: heltall = gui.etikett(diagnose_panel, "Diagnose | detaljer")
    la diagnose_id: heltall = gui.editor(diagnose_panel, "Klar for feilsøking")
    la terminal_panel: heltall = gui.panel(work_panel)
    la terminal_tittel: heltall = gui.etikett(terminal_panel, "Terminal | historikk")
    la terminal_id: heltall = gui.editor(terminal_panel, "Terminal klar")
    la bruktreff_panel: heltall = gui.panel(work_panel)
    la bruktreff_tittel: heltall = gui.etikett(bruktreff_panel, "Bruk treff | 0")
    la bruktreff_liste: heltall = gui.liste(bruktreff_panel)
    la bruktreff_handling: heltall = gui.rad(bruktreff_panel)
    la bruktreff_åpne_knapp: heltall = gui.knapp(bruktreff_handling, "Åpne valgt")
    la bruktreff_tøm_knapp: heltall = gui.knapp(bruktreff_handling, "Tøm")
    la status_panel: heltall = gui.rad(hoved_panel)
    la status_id: heltall = gui.tekst(status_panel, "Klar")
    la tips_id: heltall = gui.tekst(status_panel, "Snarvei: Åpne, Lagre, Kjør, Sjekk")

    gui.på_klikk(apne_knapp, "apne_fil")
    gui.på_klikk(ny_knapp, "ny_fil")
    gui.på_klikk(lagre_knapp, "lagre_fil")
    gui.på_klikk(lagre_som_knapp, "lagre_som_ny_fil")
    gui.på_klikk(kjor_knapp, "kjor_fil")
    gui.på_klikk(sjekk_knapp, "sjekk_fil")
    gui.på_klikk(linje_knapp, "hopp_til_linje")
    gui.på_klikk(def_knapp, "finn_definisjon")
    gui.på_klikk(bruk_knapp, "finn_bruk")
    gui.på_klikk(nyttnavn_knapp, "gi_navn")
    gui.på_klikk(tester_knapp, "kjør_tester")
    gui.på_klikk(kommando_knapp, "kjør_kommando_fra_felt")
    gui.på_klikk(sok_knapp, "sok_i_kilde")
    gui.på_klikk(erstatt_knapp, "erstatt_i_kilde")
    gui.på_klikk(autocomplete_sett_inn_knapp, "bruk_autocomplete_forslag")
    gui.på_klikk(autocomplete_oppdater_knapp, "oppdater_autocomplete")
    gui.på_endring(autocomplete_liste_id, "oppdater_autocomplete_valgt")
    gui.på_tast(kilde_id, "Tab", "bruk_autocomplete_forslag")
    gui.på_tast(kilde_id, "Enter", "bruk_autocomplete_forslag")
    gui.på_tast(kilde_id, "Ctrl+Space", "oppdater_autocomplete")
    gui.på_tast(kilde_id, "Left", "oppdater_kildeoversikt")
    gui.på_tast(kilde_id, "Right", "oppdater_kildeoversikt")
    gui.på_tast(kilde_id, "Up", "oppdater_kildeoversikt")
    gui.på_tast(kilde_id, "Down", "oppdater_kildeoversikt")
    gui.på_tast(kilde_id, "Home", "oppdater_kildeoversikt")
    gui.på_tast(kilde_id, "End", "oppdater_kildeoversikt")
    gui.på_klikk(studio_knapp, "apne_studio_fil")
    gui.på_klikk(todo_knapp, "apne_todo_fil")
    gui.på_klikk(demo_knapp, "apne_gui_demo_fil")
    gui.på_klikk(test_knapp, "apne_test_gui_fil")
    gui.på_klikk(apne_lukket_knapp, "apne_valgt_lukket_fil")
    gui.på_klikk(tøm_lukket_knapp, "tøm_lukket_historikk")
    gui.på_klikk(bootstrap_knapp, "opprett_bootstrap_startside")
    gui.på_klikk(css_knapp, "opprett_css_startside")
    gui.på_klikk(sass_knapp, "opprett_sass_startside")
    gui.på_klikk(kommandohistorikk_bruk_knapp, "bruk_valgt_kommando")
    gui.på_klikk(kommandohistorikk_tøm_knapp, "tøm_kommandohistorikk")
    gui.på_klikk(bruktreff_åpne_knapp, "åpne_valgt_bruktreff")
    gui.på_klikk(bruktreff_tøm_knapp, "tøm_bruktreff")
    gui.på_klikk(apne_valgt_knapp, "apne_valgt_fil")
    gui.på_klikk(apne_valgt_fil_knapp, "apne_valgt_åpen_fil")
    gui.på_klikk(lukk_valgt_fil_knapp, "lukk_valgt_åpen_fil")
    gui.på_klikk(lukk_andre_fil_knapp, "lukk_andre_åpne_filer")
    gui.på_klikk(lukk_alle_fil_knapp, "lukk_alle_åpne_filer")
    gui.på_klikk(oppdater_knapp, "oppdater_prosjektliste")
    gui.på_endring(prosjekt_liste_id, "apne_valgt_fil")
    gui.på_endring(apne_liste_id, "apne_valgt_åpen_fil")
    gui.på_endring(lukket_liste_id, "apne_valgt_lukket_fil")
    gui.på_endring(sok_felt, "sok_i_kilde")
    gui.på_endring(erstatt_felt, "erstatt_i_kilde")
    gui.på_endring(sti_felt, "oppdater_kildeoversikt")
    gui.på_endring(kilde_id, "oppdater_kildeoversikt")
    gui.på_endring(kilde_id, "oppdater_autocomplete")
    gui.på_endring(kommandohistorikk_liste, "bruk_valgt_kommando")
    gui.på_endring(bruktreff_liste, "åpne_valgt_bruktreff")
    gui.på_klikk(faner_id, "aktiver_fane")

    la oppstartsargumenter: liste_tekst = argv()
    la oppstartsfil: tekst = ""
    hvis lengde(oppstartsargumenter) > 0 da {
        oppstartsfil = oppstartsargumenter[0]
    } ellers {
        oppstartsfil = les_miljo("NORSCODE_STUDIO_OPEN")
    }
    hvis oppstartsfil != "" da {
        gui.sett_tekst(sti_felt, oppstartsfil)
        apne_fil(apne_knapp)
    }

    fyll_prosjektliste(vindu_id)
    oppdater_faner(vindu_id)
    oppdater_autocomplete(vindu_id)
    oppdater_kildeoversikt(vindu_id)
    oppdater_lukketittel(vindu_id)
    oppdater_kommandohistorikk_tittel(vindu_id)
    oppdater_bruktreff_tittel(vindu_id)
    oppdater_terminal(vindu_id, "Terminal klar")
    oppdater_diagnose(vindu_id, "Klar for feilsøking.\nÅpne, lagre eller kjør en fil for å se detaljer her.")
    gui.sett_tekst(oversikt_id, "Start med en filsti eller arbeid i en midlertidig buffer")
    gui.sett_tekst(tips_id, "Sjekk er tryggest når du vil verifisere før kjøring")
    gui.vis(vindu_id)
    returner 0
}
