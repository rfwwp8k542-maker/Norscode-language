bruk std.gui som gui
bruk std.web som web
bruk std.tekst som txt

funksjon studio_rot(widget_id: heltall) -> heltall {
    la n: heltall = widget_id
    mens (gui.foresatt(n) != 0) {
        n = gui.foresatt(n)
    }
    hvis gui.barn(n, 0) != 0 da {
        returner gui.barn(n, 0)
    }
    returner n
}

funksjon studio_stifelt(widget_id: heltall) -> heltall {
    la rot_id: heltall = studio_rot(widget_id)
    la work_row: heltall = gui.barn(rot_id, 3)
    la work_panel: heltall = gui.barn(work_row, 1)
    la toolbar: heltall = gui.barn(work_panel, 2)
    returner gui.barn(toolbar, 1)
}

