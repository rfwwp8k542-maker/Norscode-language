funksjon studio_v2_gui_session_lagre_tool_window(rot: tekst, tool_window: tekst) -> heltall {
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la aktiv_fil: tekst = workspace.studio_v2_state_aktiv_fil(rot)
    la aktiv_tab: tekst = workspace.studio_v2_state_session_aktiv_tab(session_data)
    hvis aktiv_tab == "" da {
        aktiv_tab = aktiv_fil
    }
    la split_fokus: tekst = workspace.studio_v2_state_session_split_fokus(session_data)
    la run_config: tekst = workspace.studio_v2_state_session_run_config(session_data)
    la palette_open: tekst = workspace.studio_v2_state_session_palette_status(session_data)
    la sist_navigasjon: tekst = workspace.studio_v2_state_session_sist_navigasjon(session_data)
    la tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data)
    returner workspace.studio_v2_state_session_lagre_med_tilstand(rot, aktiv_fil, aktiv_tab, split_fokus, tool_window, run_config, palette_open, sist_navigasjon, tree_fold)
}

funksjon studio_v2_gui_session_lagre_fokus(rot: tekst, fokus: tekst) -> heltall {
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la aktiv_fil: tekst = workspace.studio_v2_state_aktiv_fil(rot)
    la aktiv_tab: tekst = workspace.studio_v2_state_session_aktiv_tab(session_data)
    hvis aktiv_tab == "" da {
        aktiv_tab = aktiv_fil
    }
    la tool_window: tekst = workspace.studio_v2_state_session_tool_window(session_data)
    la run_config: tekst = workspace.studio_v2_state_session_run_config(session_data)
    la palette_open: tekst = workspace.studio_v2_state_session_palette_status(session_data)
    la sist_navigasjon: tekst = workspace.studio_v2_state_session_sist_navigasjon(session_data)
    la tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data)
    returner workspace.studio_v2_state_session_lagre_med_tilstand(rot, aktiv_fil, aktiv_tab, fokus, tool_window, run_config, palette_open, sist_navigasjon, tree_fold)
}

funksjon studio_v2_gui_fokus_neste(fokus: tekst) -> tekst {
    la normalisert_fokus: tekst = studio_v2_gui_fokus_etikett(fokus)
    hvis normalisert_fokus == ui.studio_v2_ui_label_project() da {
        returner ui.studio_v2_ui_label_editor()
    }
    hvis normalisert_fokus == ui.studio_v2_ui_label_editor() da {
        returner ui.studio_v2_ui_label_inspect()
    }
    returner ui.studio_v2_ui_label_project()
}

funksjon studio_v2_gui_fokus_forrige(fokus: tekst) -> tekst {
    la normalisert_fokus: tekst = studio_v2_gui_fokus_etikett(fokus)
    hvis normalisert_fokus == ui.studio_v2_ui_label_project() da {
        returner ui.studio_v2_ui_label_inspect()
    }
    hvis normalisert_fokus == ui.studio_v2_ui_label_editor() da {
        returner ui.studio_v2_ui_label_project()
    }
    returner ui.studio_v2_ui_label_editor()
}

funksjon studio_v2_gui_tool_window_neste(tool_window: tekst) -> tekst {
    la normalisert_tool_window: tekst = studio_v2_gui_tool_window_etikett(tool_window)
    hvis normalisert_tool_window == "Problems" da {
        returner "References"
    }
    hvis normalisert_tool_window == "References" da {
        returner "Structure"
    }
    hvis normalisert_tool_window == "Structure" da {
        returner "Terminal"
    }
    returner "Problems"
}

funksjon studio_v2_gui_tool_window_forrige(tool_window: tekst) -> tekst {
    la normalisert_tool_window: tekst = studio_v2_gui_tool_window_etikett(tool_window)
    hvis normalisert_tool_window == "Problems" da {
        returner "Terminal"
    }
    hvis normalisert_tool_window == "References" da {
        returner "Problems"
    }
    hvis normalisert_tool_window == "Structure" da {
        returner "References"
    }
    returner "Structure"
}

funksjon studio_v2_gui_fokus_sett(widget_id: heltall, fokus: tekst) -> heltall {
    la status_widget: heltall = studio_v2_gui_fokus_status_widget(widget_id)
    hvis status_widget > 0 da {
        gui.sett_tekst(status_widget, studio_v2_gui_fokus_tekst(studio_v2_gui_fokus_etikett(fokus)))
    }
    studio_v2_gui_session_lagre_fokus(workspace.studio_v2_state_rot(argv()), fokus)
    returner widget_id
}

funksjon studio_v2_gui_fokus_project(widget_id: heltall) -> heltall {
    returner studio_v2_gui_fokus_sett(widget_id, ui.studio_v2_ui_label_project())
}

funksjon studio_v2_gui_fokus_editor(widget_id: heltall) -> heltall {
