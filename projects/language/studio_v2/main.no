    returner widget_id
}

funksjon studio_v2_gui_markert_valg(tekstverdi: tekst) -> tekst {
    hvis tekst_starter_med(tekstverdi, "⛔ ") da {
        returner tekst_erstatt(tekstverdi, "⛔ ", "")
    }
    hvis tekst_starter_med(tekstverdi, "⚠ ") da {
        returner tekst_erstatt(tekstverdi, "⚠ ", "")
    }
    hvis tekst_starter_med(tekstverdi, "ℹ ") da {
        returner tekst_erstatt(tekstverdi, "ℹ ", "")
    }
    hvis tekst_starter_med(tekstverdi, "▶ ") da {
        returner tekst_erstatt(tekstverdi, "▶ ", "")
    }
    hvis tekst_starter_med(tekstverdi, "· ") da {
        returner tekst_erstatt(tekstverdi, "· ", "")
    }
    hvis tekst_starter_med(tekstverdi, "● ") da {
        returner tekst_erstatt(tekstverdi, "● ", "")
    }
    hvis tekst_starter_med(tekstverdi, "★ ") da {
        returner tekst_erstatt(tekstverdi, "★ ", "")
    }
    returner tekstverdi
}

funksjon studio_v2_gui_diagnostikk_detalj(oppføring: tekst) -> tekst {
    la ren: tekst = studio_v2_gui_markert_valg(oppføring)
    la deler: liste_tekst = tekst_del_på(ren, "\t")
    la slag: tekst = ""
    la fil: tekst = ""
    la linje: heltall = 0
    la melding: tekst = ""
    hvis lengde(deler) > 0 da {
        slag = deler[0]
    }
    hvis lengde(deler) > 1 da {
        fil = deler[1]
    }
    hvis lengde(deler) > 2 da {
        linje = heltall_fra_tekst(deler[2])
    }
    hvis lengde(deler) > 3 da {
        melding = deler[3]
    }
    la severity: tekst = diagnostics.studio_v2_diagnostics_alvorlighet_fra_slag(slag)
    la sted: tekst = fil
    hvis linje > 0 da {
        sted = sted + ":" + tekst_fra_heltall(linje)
    }
    la kolonne_detalj: tekst = ""
    la kolonne_deler: liste_tekst = tekst_del_på(melding, "@kolonne ")
    hvis lengde(kolonne_deler) > 1 da {
        kolonne_detalj = kolonne_deler[1]
    }
    hvis kolonne_detalj != "" da {
        sted = sted + ":" + kolonne_detalj
    }
    hvis severity != "unknown" da {
        returner severity + " · " + sted + " · " + melding
    }
    returner sted + " · " + melding
}

funksjon studio_v2_gui_prosjekt_tre_linje_er_fil(linje: tekst) -> bool {
    la ren: tekst = studio_v2_gui_markert_valg(linje)
    returner tekst_starter_med(ren, "  ")
}

funksjon studio_v2_gui_sok_status(query: tekst, forslag: tekst) -> tekst {
    la tittel: tekst = ui.studio_v2_ui_label_search_everywhere()
    hvis query == "" da {
        returner tittel + ": skriv for å hoppe"
    }
    hvis forslag == "" da {
        returner tittel + ": ingen treff for " + query
    }
    la filsti: tekst = studio_v2_gui_trekk_ut_fil(forslag)
    la linje: heltall = studio_v2_gui_trekk_ut_linje(forslag)
    la kolonne: heltall = studio_v2_gui_trekk_ut_kolonne(forslag)
    hvis filsti == "" da {
        returner tittel + ": " + forslag
    }
    hvis kolonne > 0 da {
        returner tittel + ": " + filsti + ":" + tekst_fra_heltall(linje) + ":" + tekst_fra_heltall(kolonne)
    }
    returner tittel + ": " + filsti + ":" + tekst_fra_heltall(linje)
}

funksjon studio_v2_gui_sok_resultat_type(oppføring: tekst) -> tekst {
    hvis tekst_starter_med(oppføring, "★ recent · ") da {
        returner "recent"
    }
    hvis tekst_starter_med(oppføring, "· file · ") da {
        returner "file"
    }
    hvis tekst_starter_med(oppføring, "· command · ") da {
        returner "command"
    }
    hvis tekst_starter_med(oppføring, "· symbol · ") da {
        returner "symbol"
    }
    returner "other"
}

funksjon studio_v2_gui_sok_resultat_verdi(oppføring: tekst) -> tekst {
    hvis tekst_starter_med(oppføring, "★ recent · ") da {
        returner tekst_erstatt(oppføring, "★ recent · ", "")
    }
    hvis tekst_starter_med(oppføring, "· file · ") da {
        returner tekst_erstatt(oppføring, "· file · ", "")
    }
    hvis tekst_starter_med(oppføring, "· command · ") da {
        returner tekst_erstatt(oppføring, "· command · ", "")
    }
    hvis tekst_starter_med(oppføring, "· symbol · ") da {
        returner tekst_erstatt(oppføring, "· symbol · ", "")
    }
    returner oppføring
}

funksjon studio_v2_gui_sok_resultat_finn(resultater: liste_tekst, oppføring: tekst) -> bool {
    la indeks: heltall = 0
    mens (indeks < lengde(resultater)) {
        hvis resultater[indeks] == oppføring da {
            returner sann
        }
        indeks = indeks + 1
    }
    returner usann
}

funksjon studio_v2_gui_sok_resultat_score(oppføring: tekst, query: tekst) -> heltall {
    la verdi: tekst = studio_v2_gui_sok_resultat_verdi(oppføring)
    hvis studio_v2_gui_sok_resultat_type(oppføring) == "recent" da {
        hvis tekst_starter_med(verdi, query) da {
            returner 0
        }
        returner 1
    }
    hvis studio_v2_gui_sok_resultat_type(oppføring) == "file" da {
        hvis tekst_starter_med(verdi, query) da {
            returner 10
        }
        returner 11
    }
    hvis studio_v2_gui_sok_resultat_type(oppføring) == "command" da {
        hvis tekst_starter_med(verdi, query) da {
            returner 12
        }
        returner 13
    }
    hvis studio_v2_gui_sok_resultat_type(oppføring) == "symbol" da {
        returner 20
    }
    returner 30
}

funksjon studio_v2_gui_sok_resultat_sett(resultater: liste_tekst, oppføring: tekst, query: tekst) -> liste_tekst {
    hvis oppføring == "" eller studio_v2_gui_sok_resultat_finn(resultater, oppføring) da {
        returner resultater
    }
    la score: heltall = studio_v2_gui_sok_resultat_score(oppføring, query)
    la resultat: liste_tekst = []
    la lagt_til: bool = usann
    la indeks: heltall = 0
    mens (indeks < lengde(resultater)) {
        la gjeldende: tekst = resultater[indeks]
        la gjeldende_score: heltall = studio_v2_gui_sok_resultat_score(gjeldende, query)
        hvis ikke lagt_til og score < gjeldende_score da {
            legg_til(resultat, oppføring)
            lagt_til = sann
        }
        legg_til(resultat, gjeldende)
        indeks = indeks + 1
    }
    hvis ikke lagt_til da {
        legg_til(resultat, oppføring)
    }
    returner resultat
}

funksjon studio_v2_gui_sok_resultat_sammendrag(resultater: liste_tekst) -> tekst {
    la recent: heltall = 0
    la filer: heltall = 0
    la kommandoer: heltall = 0
    la symboler: heltall = 0
    la indeks: heltall = 0
    mens (indeks < lengde(resultater)) {
        la type: tekst = studio_v2_gui_sok_resultat_type(resultater[indeks])
        hvis type == "recent" da {
            recent = recent + 1
        } ellers hvis type == "file" da {
            filer = filer + 1
        } ellers hvis type == "command" da {
            kommandoer = kommandoer + 1
        } ellers hvis type == "symbol" da {
            symboler = symboler + 1
        }
        indeks = indeks + 1
    }
    returner "Recent: " + tekst_fra_heltall(recent) + " · Files: " + tekst_fra_heltall(filer) + " · Commands: " + tekst_fra_heltall(kommandoer) + " · Symbols: " + tekst_fra_heltall(symboler)
}

funksjon studio_v2_gui_sok_resultater(rot: tekst, query: tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    hvis query == "" da {
        returner resultat
    }
    la recent_projects: liste_tekst = workspace.studio_v2_state_session_recent_for_workspace(rot)
    la i: heltall = 0
    mens (i < lengde(recent_projects)) {
        la prosjekt: tekst = recent_projects[i]
        hvis tekst_inneholder(prosjekt, query) da {
            resultat = studio_v2_gui_sok_resultat_sett(resultat, "★ recent · " + prosjekt, query)
        }
        i = i + 1
    }
    la workspace_filer: liste_tekst = workspace.studio_v2_state_workspace_filer(rot)
    i = 0
    mens (i < lengde(workspace_filer)) {
        la sti: tekst = workspace_filer[i]
        hvis tekst_inneholder(sti, query) da {
            resultat = studio_v2_gui_sok_resultat_sett(resultat, "· file · " + sti, query)
        }
        i = i + 1
    }
    la kommandoer: liste_tekst = actions.studio_v2_actions_palett()
    i = 0
    mens (i < lengde(kommandoer)) {
        la kommando: tekst = kommandoer[i]
        hvis tekst_inneholder(kommando, query) da {
            resultat = studio_v2_gui_sok_resultat_sett(resultat, "· command · " + kommando, query)
        }
        i = i + 1
    }
    la symbol_treff: tekst = symbol.studio_v2_symbol_navigasjon_forslag(rot, query)
    hvis symbol_treff != "" da {
        la filsti: tekst = studio_v2_gui_trekk_ut_fil(symbol_treff)
        la linje: heltall = studio_v2_gui_trekk_ut_linje(symbol_treff)
        la kolonne: heltall = studio_v2_gui_trekk_ut_kolonne(symbol_treff)
        hvis filsti == "" da {
            filsti = symbol_treff
            linje = 1
        }
        hvis kolonne > 0 da {
            resultat = studio_v2_gui_sok_resultat_sett(resultat, "· symbol · " + filsti + ":" + tekst_fra_heltall(linje) + ":" + tekst_fra_heltall(kolonne), query)
        } ellers {
            resultat = studio_v2_gui_sok_resultat_sett(resultat, "· symbol · " + filsti + ":" + tekst_fra_heltall(linje), query)
        }
    }
    returner resultat
}

funksjon studio_v2_gui_sok_resultat_valg(tekstverdi: tekst) -> tekst {
    la ren: tekst = studio_v2_gui_markert_valg(tekstverdi)
    hvis tekst_starter_med(ren, "★ recent · ") da {
        returner tekst_erstatt(ren, "★ recent · ", "")
    }
    hvis tekst_starter_med(ren, "· file · ") da {
        returner tekst_erstatt(ren, "· file · ", "")
    }
    hvis tekst_starter_med(ren, "· command · ") da {
        returner tekst_erstatt(ren, "· command · ", "")
    }
    hvis tekst_starter_med(ren, "· symbol · ") da {
        la symbol_del: tekst = tekst_erstatt(ren, "· symbol · ", "")
        la symbol_deler: liste_tekst = tekst_del_på(symbol_del, ":")
        hvis lengde(symbol_deler) >= 2 da {
            la resultat: tekst = symbol_deler[0] + "\t" + symbol_deler[1]
            hvis lengde(symbol_deler) >= 3 da {
                resultat = resultat + "\t" + symbol_deler[2]
            }
            returner resultat
        }
        returner symbol_del
    }
    returner ren
}

funksjon studio_v2_gui_sok_resultat_linje(resultater: liste_tekst) -> liste_tekst {
    returner resultater
}

funksjon studio_v2_gui_sok_tom_visning(query: tekst) -> tekst {
    la tittel: tekst = ui.studio_v2_ui_label_search_everywhere()
    hvis query == "" da {
        returner tittel + ": skriv for å hoppe"
    }
    returner tittel + ": ingen treff for " + query
}

funksjon studio_v2_gui_oppdater_sok_resultat(widget_id: heltall) -> heltall {
    la query_felt: heltall = widget_id
    la søk_panel: heltall = gui.foresatt(query_felt)
    la resultat_widget: heltall = studio_v2_gui_sok_status_widget(søk_panel)
    la resultat_liste: heltall = studio_v2_gui_sok_liste_widget(søk_panel)
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la query: tekst = gui.hent_tekst(query_felt)
    workspace.studio_v2_state_session_search_query_skriv_med_tilstand(rot, query)
    la resultater: liste_tekst = studio_v2_gui_sok_resultater(rot, query)
    hvis query == "" da {
        gui.sett_tekst(resultat_widget, studio_v2_gui_sok_tom_visning(query))
        studio_v2_gui_liste_sett(resultat_liste, [])
    } ellers hvis lengde(resultater) > 0 da {
        gui.sett_tekst(resultat_widget, studio_v2_gui_sok_status(query, studio_v2_gui_sok_resultat_valg(resultater[0])) + " · " + studio_v2_gui_sok_resultat_sammendrag(resultater))
        studio_v2_gui_liste_sett(resultat_liste, studio_v2_gui_sok_resultat_linje(resultater))
        gui.liste_velg(resultat_liste, 0)
    } ellers {
        gui.sett_tekst(resultat_widget, studio_v2_gui_sok_tom_visning(query))
        studio_v2_gui_liste_sett(resultat_liste, [])
    }
    returner widget_id
}

funksjon studio_v2_gui_oppdater_sok_navigasjon(widget_id: heltall) -> heltall {
    la valgt_resultat: tekst = gui.liste_valgt(widget_id)
    la valgt_type: tekst = studio_v2_gui_sok_resultat_type(valgt_resultat)
    la valgt: tekst = studio_v2_gui_sok_resultat_valg(valgt_resultat)
    hvis valgt == "" da {
        returner widget_id
    }
    la søk_panel: heltall = gui.foresatt(widget_id)
    la query_felt: heltall = gui.barn(søk_panel, 1)
    la resultat_text: heltall = studio_v2_gui_sok_status_widget(søk_panel)
    la resultat_liste: heltall = studio_v2_gui_sok_liste_widget(søk_panel)
    la query: tekst = gui.hent_tekst(query_felt)
    workspace.studio_v2_state_session_search_query_skriv_med_tilstand(workspace.studio_v2_state_rot(argv()), query)
    la resultater: liste_tekst = studio_v2_gui_sok_resultater(workspace.studio_v2_state_rot(argv()), query)
    gui.sett_tekst(resultat_text, studio_v2_gui_sok_status(query, valgt) + " · " + studio_v2_gui_sok_resultat_sammendrag(resultater))
    studio_v2_gui_liste_sett(resultat_liste, studio_v2_gui_sok_resultat_linje(resultater))
    hvis valgt_type == "command" da {
        la rot: tekst = workspace.studio_v2_state_rot(argv())
        la kommando_resultat: tekst = studio_v2_gui_kjor_handling_rot(rot, valgt)
        gui.sett_tekst(resultat_text, studio_v2_gui_sok_status(query, valgt) + " · " + kommando_resultat)
        skriv(kommando_resultat)
        returner widget_id
    }
    la rot_panel: heltall = studio_v2_gui_steg_opp(widget_id, 2)
    la midten: heltall = studio_v2_gui_hovedrad_midten_widget(rot_panel)
    la venstre_panel: heltall = studio_v2_gui_hovedrad_venstre_widget(rot_panel)
    la filer_liste: heltall = studio_v2_gui_venstre_filer_liste_widget(venstre_panel)
    la aktiv_tekst: heltall = studio_v2_gui_venstre_aktiv_tekst_widget(venstre_panel)
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data)
    la valgt_resultat: tekst = gui.liste_valgt(widget_id)
    la filsti: tekst = studio_v2_gui_sok_resultat_valg(valgt_resultat)
    la linje: heltall = studio_v2_gui_trekk_ut_linje(filsti)
    la resultater: liste_tekst = studio_v2_gui_sok_resultater(rot, query)
    hvis linje <= 0 da {
        linje = 1
    }
    hvis filsti == "" da {
        returner widget_id
    }
    la workspace_filer: liste_tekst = workspace.studio_v2_state_workspace_filer(rot)
    la apne_filer: liste_tekst = workspace.studio_v2_state_apne_filer(rot, filsti)
    la tabs: liste_tekst = editor.studio_v2_editor_tabs_fra_apne_filer(apne_filer)
    studio_v2_gui_liste_sett(filer_liste, studio_v2_gui_begrens_liste_med_anker(studio_v2_gui_prosjekt_tre(workspace_filer, filsti, tree_fold), studio_v2_gui_prosjekt_tre_maks_fra_filer(workspace_filer), filsti))
    gui.sett_tekst(aktiv_tekst, ui.studio_v2_ui_status_chip("Aktiv", filsti))
    studio_v2_gui_liste_sett(studio_v2_gui_midten_tabs_liste_widget(midten), studio_v2_gui_tab_linje(tabs, filsti))
    workspace.studio_v2_state_session_lagre_med_tilstand(rot, filsti, filsti, workspace.studio_v2_state_session_split_fokus(session_data), workspace.studio_v2_state_session_tool_window(session_data), workspace.studio_v2_state_session_run_config(session_data), workspace.studio_v2_state_session_palette_status(session_data), filsti, tree_fold)
    studio_v2_gui_oppdater_editor(midten, rot, filsti, linje)
    returner widget_id
}

funksjon studio_v2_gui_midten_fra_widget(widget_id: heltall) -> heltall {
    la rot_panel: heltall = studio_v2_gui_steg_opp(widget_id, 2)
    returner studio_v2_gui_hovedrad_midten_widget(rot_panel)
}

funksjon studio_v2_gui_oppdater_editor(midten: heltall, rot: tekst, filsti: tekst, linje: heltall) -> heltall {
    la aktiv_fil_tekst: heltall = gui.barn(midten, 1)
    la tabs_tekst: heltall = gui.barn(midten, 2)
    la aktiv_tab_tekst: heltall = gui.barn(midten, 3)
    la status_tekst: heltall = gui.barn(midten, 4)
    la sok_tekst: heltall = gui.barn(midten, 5)
    la symbol_tekst: heltall = gui.barn(midten, 6)
    la session_tekst: heltall = gui.barn(midten, 7)
    la editor_widget: heltall = gui.barn(midten, 8)
    la split_status_tekst: heltall = gui.barn(midten, 9)
    la split_liste: heltall = gui.barn(midten, 10)
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la split_fokus: tekst = workspace.studio_v2_state_session_split_fokus(session_data)
    la apne_filer: liste_tekst = workspace.studio_v2_state_apne_filer(rot, filsti)
    la tabs: liste_tekst = editor.studio_v2_editor_tabs_fra_apne_filer(apne_filer)
    la aktiv_tab: tekst = editor.studio_v2_editor_tab_nåværende(tabs, filsti)
    la neste_tab: tekst = editor.studio_v2_editor_tab_neste(tabs, filsti)
    la forrige_tab: tekst = editor.studio_v2_editor_tab_forrige(tabs, filsti)
    la split_mål: tekst = studio_v2_gui_split_mål(tabs, aktiv_tab, split_fokus)
    la innhold: tekst = workspace.studio_v2_state_fil_innhold(rot, filsti)
    la buffer: liste_tekst = editor.studio_v2_editor_åpne(innhold)
    la symbol_info: tekst = editor.studio_v2_editor_hurtiginfo_fra_aktiv_linje(rot, buffer, linje)
    gui.sett_tekst(aktiv_fil_tekst, "Aktiv fil: " + filsti)
    gui.sett_tekst(tabs_tekst, "Tabs: " + tekst_fra_heltall(lengde(tabs)) + " · Split: " + editor.studio_v2_editor_split_status(tabs))
    gui.sett_tekst(aktiv_tab_tekst, "Aktiv/Neste/Forrige: " + aktiv_tab + " · " + neste_tab + " · " + forrige_tab)
    gui.sett_tekst(status_tekst, ui.studio_v2_ui_status_chip("Buffer", tekst_fra_heltall(editor.studio_v2_editor_buffer_antall_linje(buffer))) + " · " + ui.studio_v2_ui_status_chip("Line", tekst_fra_heltall(linje)))
    gui.sett_tekst(sok_tekst, "Søk/erstatt: " + editor.studio_v2_editor_sok_status(buffer, "returner") + " / " + editor.studio_v2_editor_erstatt_status(buffer, "returner"))
    hvis symbol_info != "" da {
        gui.sett_tekst(symbol_tekst, "Symbol/referanse: " + symbol.studio_v2_symbol_navigasjon_forslag(rot, filsti) + " · " + symbol_info)
    } ellers {
        gui.sett_tekst(symbol_tekst, "Symbol/referanse: " + symbol.studio_v2_symbol_navigasjon_forslag(rot, filsti))
    }
    gui.sett_tekst(session_tekst, "Sist navigasjon: " + filsti + " · rot: " + rot)
    gui.sett_tekst(editor_widget, innhold)
    gui.sett_tekst(split_status_tekst, ui.studio_v2_ui_status_chip("Target", split_mål) + " · " + ui.studio_v2_ui_status_chip("Focus", split_fokus))
    hvis split_mål != "" og split_mål != filsti da {
        la split_innhold: tekst = workspace.studio_v2_state_fil_innhold(rot, split_mål)
        studio_v2_gui_liste_sett(split_liste, studio_v2_gui_begrens_liste(editor.studio_v2_editor_åpne(split_innhold), 5))
    } ellers {
        studio_v2_gui_liste_sett(split_liste, [ui.studio_v2_ui_tomt_split()])
    }
    hvis linje > 0 da {
        gui.editor_hopp_til(editor_widget, linje)
    }
    returner editor_widget
}

funksjon studio_v2_gui_oppdater_sok(widget_id: heltall) -> heltall {
    la query: tekst = gui.hent_tekst(widget_id)
    la søk_panel: heltall = gui.foresatt(widget_id)
    la resultat_tekst: heltall = studio_v2_gui_sok_status_widget(søk_panel)
    la rot_panel: heltall = studio_v2_gui_steg_opp(widget_id, 2)
    la midten: heltall = studio_v2_gui_hovedrad_midten_widget(rot_panel)
    la venstre_panel: heltall = studio_v2_gui_hovedrad_venstre_widget(rot_panel)
    la filer_liste: heltall = studio_v2_gui_venstre_filer_liste_widget(venstre_panel)
    la aktiv_tekst: heltall = studio_v2_gui_venstre_aktiv_tekst_widget(venstre_panel)
    workspace.studio_v2_state_session_search_query_skriv_med_tilstand(workspace.studio_v2_state_rot(argv()), query)
    hvis query == "" da {
        gui.sett_tekst(resultat_tekst, ui.studio_v2_ui_tomt_sok())
        returner widget_id
    }
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la forslag: tekst = symbol.studio_v2_symbol_navigasjon_forslag(rot, query)
    hvis forslag == "" da {
        gui.sett_tekst(resultat_tekst, studio_v2_gui_sok_status(query, forslag))
        returner widget_id
    }
    la filsti: tekst = studio_v2_gui_trekk_ut_fil(forslag)
    la linje: heltall = studio_v2_gui_trekk_ut_linje(forslag)
    hvis filsti == "" da {
        filsti = forslag
        linje = 1
    }
    gui.sett_tekst(resultat_tekst, studio_v2_gui_sok_status(query, forslag))
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data)
    la apne_filer_resultat: liste_tekst = workspace.studio_v2_state_apne_filer(rot, filsti)
    la tabs_resultat: liste_tekst = editor.studio_v2_editor_tabs_fra_apne_filer(apne_filer_resultat)
    studio_v2_gui_liste_sett(filer_liste, studio_v2_gui_begrens_liste_med_anker(studio_v2_gui_prosjekt_tre(workspace.studio_v2_state_workspace_filer(rot), filsti, tree_fold), studio_v2_gui_prosjekt_tre_maks_fra_filer(workspace.studio_v2_state_workspace_filer(rot)), filsti))
    gui.sett_tekst(aktiv_tekst, ui.studio_v2_ui_status_chip("Aktiv", filsti))
    studio_v2_gui_liste_sett(studio_v2_gui_midten_tabs_liste_widget(midten), studio_v2_gui_tab_linje(tabs_resultat, filsti))
    workspace.studio_v2_state_session_lagre_med_tilstand(rot, filsti, filsti, workspace.studio_v2_state_session_split_fokus(session_data), workspace.studio_v2_state_session_tool_window(session_data), workspace.studio_v2_state_session_run_config(session_data), workspace.studio_v2_state_session_palette_status(session_data), workspace.studio_v2_state_session_sist_navigasjon(session_data), tree_fold)
    studio_v2_gui_oppdater_editor(midten, rot, filsti, linje)
    returner widget_id
}

funksjon studio_v2_gui_oppdater_filvalg(widget_id: heltall) -> heltall {
    la venstre_panel: heltall = gui.foresatt(widget_id)
    la filer_liste: heltall = studio_v2_gui_venstre_filer_liste_widget(venstre_panel)
    la aktiv_tekst: heltall = studio_v2_gui_venstre_aktiv_tekst_widget(venstre_panel)
    la detalj_tekst: heltall = gui.barn(venstre_panel, 4)
    la rot_panel: heltall = studio_v2_gui_steg_opp(widget_id, 2)
    la midten: heltall = studio_v2_gui_hovedrad_midten_widget(rot_panel)
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data)
    la valgt_mappe: tekst = studio_v2_gui_prosjekt_tre_mappe_valg(gui.liste_valgt(widget_id))
    hvis valgt_mappe != "" da {
        la ny_tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold_oppdatert(session_data, valgt_mappe)
        la aktiv_fil: tekst = workspace.studio_v2_state_aktiv_fil(rot)
        la aktiv_tab: tekst = workspace.studio_v2_state_session_aktiv_tab(session_data)
        hvis aktiv_tab == "" da {
            aktiv_tab = aktiv_fil
        }
        la split_fokus: tekst = workspace.studio_v2_state_session_split_fokus(session_data)
        la tool_window: tekst = workspace.studio_v2_state_session_tool_window(session_data)
        la sist_navigasjon: tekst = workspace.studio_v2_state_session_sist_navigasjon(session_data)
        la workspace_filer_toggle: liste_tekst = workspace.studio_v2_state_workspace_filer(rot)
        workspace.studio_v2_state_session_project_tree_anchor_skriv_med_tilstand(rot, valgt_mappe)
        workspace.studio_v2_state_session_lagre_med_tilstand(rot, aktiv_fil, aktiv_tab, split_fokus, tool_window, workspace.studio_v2_state_session_run_config(session_data), workspace.studio_v2_state_session_palette_status(session_data), valgt_mappe, ny_tree_fold)
        studio_v2_gui_liste_sett(filer_liste, studio_v2_gui_begrens_liste_med_anker(studio_v2_gui_prosjekt_tre(workspace_filer_toggle, aktiv_fil, ny_tree_fold), studio_v2_gui_prosjekt_tre_maks_fra_filer(workspace_filer_toggle), aktiv_fil))
        gui.sett_tekst(aktiv_tekst, ui.studio_v2_ui_status_chip("Aktiv", aktiv_fil))
        gui.sett_tekst(detalj_tekst, "Mappevalg: " + valgt_mappe)
        returner widget_id
    }
    la valgt_fil: tekst = studio_v2_gui_prosjekt_tre_valg(gui.liste_valgt(widget_id))
    hvis valgt_fil == "" da {
        returner widget_id
    }
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data)
    la workspace_filer: liste_tekst = workspace.studio_v2_state_workspace_filer(rot)
    la apne_filer: liste_tekst = workspace.studio_v2_state_apne_filer(rot, valgt_fil)
    la tabs: liste_tekst = editor.studio_v2_editor_tabs_fra_apne_filer(apne_filer)
    la aktiv_tab: tekst = editor.studio_v2_editor_tab_nåværende(tabs, valgt_fil)
    workspace.studio_v2_state_session_project_tree_anchor_skriv_med_tilstand(rot, valgt_fil)
    studio_v2_gui_liste_sett(filer_liste, studio_v2_gui_begrens_liste_med_anker(studio_v2_gui_prosjekt_tre(workspace_filer, valgt_fil, tree_fold), studio_v2_gui_prosjekt_tre_maks_fra_filer(workspace_filer), valgt_fil))
    gui.sett_tekst(aktiv_tekst, ui.studio_v2_ui_status_chip("Aktiv", valgt_fil))
    gui.sett_tekst(detalj_tekst, "Filvalg: " + valgt_fil)
    studio_v2_gui_liste_sett(studio_v2_gui_midten_tabs_liste_widget(midten), studio_v2_gui_tab_linje(tabs, aktiv_tab))
    workspace.studio_v2_state_session_lagre_med_tilstand(rot, valgt_fil, aktiv_tab, workspace.studio_v2_state_session_split_fokus(session_data), workspace.studio_v2_state_session_tool_window(session_data), workspace.studio_v2_state_session_run_config(session_data), workspace.studio_v2_state_session_palette_status(session_data), valgt_fil, tree_fold)
    studio_v2_gui_oppdater_editor(midten, rot, valgt_fil, 1)
    returner widget_id
}

funksjon studio_v2_gui_oppdater_referansevalg(widget_id: heltall) -> heltall {
    la valgt_referanse: tekst = studio_v2_gui_markert_valg(gui.liste_valgt(widget_id))
    hvis valgt_referanse == "" da {
        returner widget_id
    }
    la høyre_panel: heltall = gui.foresatt(widget_id)
    la detalj_tekst: heltall = gui.barn(høyre_panel, 16)
    la filsti: tekst = symbol.studio_v2_symbol_oppføring_fil(valgt_referanse)
    la linje: heltall = symbol.studio_v2_symbol_oppføring_linje(valgt_referanse)
    la kolonne: heltall = symbol.studio_v2_symbol_oppføring_kolonne(valgt_referanse)
    la rot_panel: heltall = studio_v2_gui_steg_opp(widget_id, 2)
    la midten: heltall = studio_v2_gui_hovedrad_midten_widget(rot_panel)
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data)
    la workspace_filer: liste_tekst = workspace.studio_v2_state_workspace_filer(rot)
    la apne_filer: liste_tekst = workspace.studio_v2_state_apne_filer(rot, filsti)
    la tabs: liste_tekst = editor.studio_v2_editor_tabs_fra_apne_filer(apne_filer)
    la aktiv_tab: tekst = editor.studio_v2_editor_tab_nåværende(tabs, filsti)
    la venstre_panel: heltall = studio_v2_gui_hovedrad_venstre_widget(rot_panel)
    la filer_liste: heltall = studio_v2_gui_venstre_filer_liste_widget(venstre_panel)
    la aktiv_tekst: heltall = studio_v2_gui_venstre_aktiv_tekst_widget(venstre_panel)
    hvis kolonne > 0 da {
        gui.sett_tekst(detalj_tekst, "Referansevalg: " + filsti + ":" + tekst_fra_heltall(linje) + ":" + tekst_fra_heltall(kolonne))
    } ellers {
        gui.sett_tekst(detalj_tekst, "Referansevalg: " + filsti + ":" + tekst_fra_heltall(linje))
    }
    studio_v2_gui_liste_sett(filer_liste, studio_v2_gui_begrens_liste_med_anker(studio_v2_gui_prosjekt_tre(workspace_filer, filsti, tree_fold), studio_v2_gui_prosjekt_tre_maks_fra_filer(workspace_filer), filsti))
    gui.sett_tekst(aktiv_tekst, ui.studio_v2_ui_status_chip("Aktiv", filsti))
    studio_v2_gui_liste_sett(studio_v2_gui_midten_tabs_liste_widget(midten), studio_v2_gui_tab_linje(tabs, aktiv_tab))
    hvis filsti != "" da {
        workspace.studio_v2_state_session_project_tree_anchor_skriv_med_tilstand(rot, filsti)
        workspace.studio_v2_state_session_lagre_med_tilstand(rot, filsti, aktiv_tab, workspace.studio_v2_state_session_split_fokus(session_data), workspace.studio_v2_state_session_tool_window(session_data), workspace.studio_v2_state_session_run_config(session_data), workspace.studio_v2_state_session_palette_status(session_data), filsti, tree_fold)
        studio_v2_gui_oppdater_editor(midten, rot, filsti, linje)
    }
    returner widget_id
}

funksjon studio_v2_gui_oppdater_diagnostikkvalg(widget_id: heltall) -> heltall {
    la valgt_diagnostikk: tekst = studio_v2_gui_markert_valg(gui.liste_valgt(widget_id))
    hvis valgt_diagnostikk == "" da {
        returner widget_id
    }
    skriv("Diagnostikk valgt: " + valgt_diagnostikk)
    la høyre_panel: heltall = gui.foresatt(widget_id)
    la detalj_tekst: heltall = gui.barn(høyre_panel, 10)
    la filsti: tekst = studio_v2_gui_trekk_ut_fil(valgt_diagnostikk)
    la linje: heltall = studio_v2_gui_trekk_ut_linje(valgt_diagnostikk)
    la melding: tekst = studio_v2_gui_trekk_ut_melding(valgt_diagnostikk)
    gui.sett_tekst(detalj_tekst, studio_v2_gui_diagnostikk_detalj(valgt_diagnostikk))
    hvis filsti == "" da {
        returner widget_id
    }
    hvis linje <= 0 da {
        linje = 1
    }
    la rot_panel: heltall = studio_v2_gui_steg_opp(widget_id, 2)
    la midten: heltall = studio_v2_gui_hovedrad_midten_widget(rot_panel)
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data)
    la workspace_filer: liste_tekst = workspace.studio_v2_state_workspace_filer(rot)
    la apne_filer: liste_tekst = workspace.studio_v2_state_apne_filer(rot, filsti)
    la tabs: liste_tekst = editor.studio_v2_editor_tabs_fra_apne_filer(apne_filer)
    la aktiv_tab: tekst = editor.studio_v2_editor_tab_nåværende(tabs, filsti)
    la venstre_panel: heltall = studio_v2_gui_hovedrad_venstre_widget(rot_panel)
    la filer_liste: heltall = studio_v2_gui_venstre_filer_liste_widget(venstre_panel)
    la aktiv_tekst: heltall = studio_v2_gui_venstre_aktiv_tekst_widget(venstre_panel)
    gui.sett_tekst(aktiv_tekst, ui.studio_v2_ui_status_chip("Aktiv", filsti))
    studio_v2_gui_liste_sett(filer_liste, studio_v2_gui_begrens_liste_med_anker(studio_v2_gui_prosjekt_tre(workspace_filer, filsti, tree_fold), studio_v2_gui_prosjekt_tre_maks_fra_filer(workspace_filer), filsti))
    studio_v2_gui_liste_sett(studio_v2_gui_midten_tabs_liste_widget(midten), studio_v2_gui_tab_linje(tabs, aktiv_tab))
    workspace.studio_v2_state_session_lagre_med_tilstand(rot, filsti, aktiv_tab, workspace.studio_v2_state_session_split_fokus(session_data), workspace.studio_v2_state_session_tool_window(session_data), workspace.studio_v2_state_session_run_config(session_data), workspace.studio_v2_state_session_palette_status(session_data), filsti, tree_fold)
    studio_v2_gui_oppdater_editor(midten, rot, filsti, linje)
    returner widget_id
}

funksjon studio_v2_gui_referanse_linje(referanser: liste_tekst, valgt_referanse: tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(referanser)) {
        la referanse: tekst = referanser[indeks]
        hvis referanse == valgt_referanse da {
            legg_til(resultat, "▶ " + referanse)
        } ellers {
            legg_til(resultat, "· " + referanse)
        }
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_rename_linje(preview: liste_tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(preview)) {
        la linje: tekst = preview[indeks]
        hvis indeks == 0 da {
            legg_til(resultat, "▶ " + linje)
        } ellers {
            legg_til(resultat, "· " + linje)
        }
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_split_mål(tabs: liste_tekst, aktiv_tab: tekst, split_fokus: tekst) -> tekst {
    returner editor.studio_v2_editor_split_fokus_valgt(tabs, aktiv_tab, split_fokus)
}

funksjon studio_v2_gui_begrens_liste(elementer: liste_tekst, maks: heltall) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(elementer) og indeks < maks) {
        legg_til(resultat, elementer[indeks])
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_begrens_liste_med_anker(elementer: liste_tekst, maks: heltall, anker: tekst) -> liste_tekst {
    hvis lengde(elementer) <= maks eller maks <= 0 da {
        returner studio_v2_gui_begrens_liste(elementer, maks)
    }
    la anker_indeks: heltall = 0
    la funnet: bool = usann
    la normalisert_anker: tekst = studio_v2_gui_markert_valg(anker)
    la indeks: heltall = 0
    mens (indeks < lengde(elementer)) {
        la kandidat: tekst = studio_v2_gui_markert_valg(elementer[indeks])
        hvis kandidat == normalisert_anker da {
            anker_indeks = indeks
            funnet = sann
            bryt
        }
        indeks = indeks + 1
    }
    hvis ikke funnet da {
        anker_indeks = 0
    }
    la start: heltall = anker_indeks - (maks / 2)
    hvis start < 0 da {
        start = 0
    }
    hvis start + maks > lengde(elementer) da {
        start = lengde(elementer) - maks
    }
    hvis start < 0 da {
        start = 0
    }
    la resultat: liste_tekst = []
    la i: heltall = start
    mens (i < lengde(elementer) og lengde(resultat) < maks) {
        legg_til(resultat, elementer[i])
        i = i + 1
    }
    returner resultat
}

funksjon studio_v2_gui_diagnostikk_linjer(diagnose: liste_tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(diagnose)) {
        la linje: tekst = diagnose[indeks]
        la deler: liste_tekst = tekst_del_på(linje, "\t")
        hvis lengde(deler) > 0 da {
            la severity: tekst = diagnostics.studio_v2_diagnostics_alvorlighet_fra_slag(deler[0])
            hvis severity == "error" da {
                legg_til(resultat, "⛔ " + linje)
            } ellers hvis severity == "warning" da {
                legg_til(resultat, "⚠ " + linje)
            } ellers hvis severity == "info" da {
                legg_til(resultat, "ℹ " + linje)
            } ellers {
                legg_til(resultat, linje)
            }
        } ellers {
            legg_til(resultat, linje)
        }
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_diagnostikk_tomtilstand(diagnose: liste_tekst) -> tekst {
    hvis lengde(diagnose) == 0 da {
        returner "No problems yet"
    }
    returner ui.studio_v2_ui_problems_hint()
}

funksjon studio_v2_gui_oppdater_tabvalg(widget_id: heltall) -> heltall {
    la valgt_tab: tekst = studio_v2_gui_tab_valg(gui.liste_valgt(widget_id))
    hvis valgt_tab == "" da {
        returner widget_id
    }
    la rot_panel: heltall = studio_v2_gui_steg_opp(widget_id, 2)
    la midten: heltall = studio_v2_gui_hovedrad_midten_widget(rot_panel)
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data)
    la workspace_filer: liste_tekst = workspace.studio_v2_state_workspace_filer(rot)
    la apne_filer: liste_tekst = workspace.studio_v2_state_apne_filer(rot, valgt_tab)
    la tabs: liste_tekst = editor.studio_v2_editor_tabs_fra_apne_filer(apne_filer)
    la venstre_panel: heltall = studio_v2_gui_hovedrad_venstre_widget(rot_panel)
    la filer_liste: heltall = studio_v2_gui_venstre_filer_liste_widget(venstre_panel)
    la aktiv_tekst: heltall = studio_v2_gui_venstre_aktiv_tekst_widget(venstre_panel)
    studio_v2_gui_liste_sett(filer_liste, studio_v2_gui_begrens_liste_med_anker(studio_v2_gui_prosjekt_tre(workspace_filer, valgt_tab, tree_fold), studio_v2_gui_prosjekt_tre_maks_fra_filer(workspace_filer), valgt_tab))
    gui.sett_tekst(aktiv_tekst, ui.studio_v2_ui_status_chip("Aktiv", valgt_tab))
    studio_v2_gui_liste_sett(widget_id, studio_v2_gui_tab_linje(tabs, valgt_tab))
    workspace.studio_v2_state_session_lagre_med_tilstand(rot, valgt_tab, valgt_tab, workspace.studio_v2_state_session_split_fokus(session_data), workspace.studio_v2_state_session_tool_window(session_data), workspace.studio_v2_state_session_run_config(session_data), workspace.studio_v2_state_session_palette_status(session_data), valgt_tab, tree_fold)
    studio_v2_gui_oppdater_editor(midten, rot, valgt_tab, 1)
    returner widget_id
}

funksjon studio_v2_gui_run_config_linje(configs: liste_tekst, aktiv_config: tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(configs)) {
        la config: tekst = configs[indeks]
        hvis config == aktiv_config da {
            legg_til(resultat, "▶ " + config)
        } ellers {
            legg_til(resultat, "· " + config)
        }
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_run_config_valg(tekstverdi: tekst) -> tekst {
    la ren: tekst = tekstverdi
    hvis tekst_starter_med(ren, "▶ ") da {
        ren = tekst_erstatt(ren, "▶ ", "")
    }
    hvis tekst_starter_med(ren, "· ") da {
        ren = tekst_erstatt(ren, "· ", "")
    }
    la deler: liste_tekst = tekst_del_på(ren, "\t")
    hvis lengde(deler) > 0 da {
        returner deler[0]
    }
    returner ren
}

funksjon studio_v2_gui_palette_linje(configs: liste_tekst, aktiv_config: tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(configs)) {
        la config: tekst = configs[indeks]
        hvis config == aktiv_config da {
            legg_til(resultat, "▶ " + config)
        } ellers {
            legg_til(resultat, "· " + config)
        }
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_palette_filtrert(configs: liste_tekst, query: tekst) -> liste_tekst {
    hvis query == "" da {
        returner configs
    }
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(configs)) {
        la config: tekst = configs[indeks]
        hvis tekst_inneholder(config, query) da {
            legg_til(resultat, config)
        }
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_palette_kommandoer() -> liste_tekst {
    returner [
        ui.studio_v2_ui_label_project(),
        ui.studio_v2_ui_label_editor(),
        ui.studio_v2_ui_label_inspect(),
        ui.studio_v2_ui_label_run(),
        "Check",
        "Test",
        "Debug",
        "CI",
        ui.studio_v2_ui_label_troubleshooting_guide(),
        "Close Palette"
    ]
}

funksjon studio_v2_gui_palette_valg(tekstverdi: tekst) -> tekst {
    hvis tekst_starter_med(tekstverdi, "▶ ") da {
        returner tekst_erstatt(tekstverdi, "▶ ", "")
    }
    hvis tekst_starter_med(tekstverdi, "· ") da {
        returner tekst_erstatt(tekstverdi, "· ", "")
    }
    returner tekstverdi
}

funksjon studio_v2_gui_palette_widget(widget_id: heltall, tekstverdi: tekst) -> heltall {
    gui.sett_tekst(widget_id, tekstverdi)
    returner widget_id
}

funksjon studio_v2_gui_troubleshooting_guide(rot: tekst, aktiv_fil: tekst, run_config: tekst) -> liste_tekst {
    hvis run_config == "" da {
        run_config = "run"
    }
    hvis aktiv_fil == "" da {
        aktiv_fil = "<ingen aktiv fil>"
    }
    returner [
        "Teknisk feilsokingsguide",
        "Arbeidskontekst:",
        "- Workspace: " + rot,
        "- Aktiv fil: " + aktiv_fil,
        "- Kjøring: " + run_config,
        "- Opprettet: __dato__ / __tidspunkt__",
        "",
        "Steg 1 — Dokumentasjon av symptom",
        "- Symptom: ",
        "- Når oppstår dette (frekvens/steget): ",
        "- Forventet oppførsel: ",
        "- Faktisk oppførsel: ",
        "",
        "Steg 2 — Minimalt reproduksjonsscenario",
        "- Beskriv reproduksjon i miniatyr: ",
        "- Minimal input/data: ",
        "- Reproduserbar i 1–2 kommandoer: ",
        "",
        "Steg 3 — Standarddiagnose",
        "- Kjør: Run",
        "- Kjør: Check",
        "- Kjør: Test",
        "- Noter output (stdout + stderr): ",
        "",
        "Steg 4 — Miljø- og kontekstsporing",
        "- Runtime/versjon: ",
        "- Branch/tag: ",
        "- Nylig endret fil/commit: ",
        "- Avvik fra siste fungerende versjon: ",
        "",
        "Steg 5 — Feilanalyse",
        "- Feilmelding / stackspor: ",
        "- Første tegn på feilen i koden: ",
        "- Om mulig: identifiser minste endring som fikser: ",
        "",
        "Steg 6 — Isolasjon",
        "- Gjenta uten sideeffekter: ",
        "- Legg til midlertidig logging (hvis mulig): ",
        "- Bekreft hvilken linje/tilstand som bryter: ",
        "",
        "Steg 7 — Varig løsning",
        "- Permanent fix-forslag: ",
        "- Endre kode / konfigurering: ",
        "- Valider med Run/Check/Test på nytt: ",
        "",
        "Steg 8 — Oppsummering",
        "- Årsak: ",
        "- Fikser: ",
        "- Nye/oppdaterte tester: ",
        "- Løsningsstatus: ",
        "Når ferdig: lim dette tilbake i kodekommentar, PR-beskrivelse eller teknisk logg."
    ]
}

funksjon studio_v2_gui_generer_technical_guide(rot: tekst) -> tekst {
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la aktiv_fil: tekst = workspace.studio_v2_state_aktiv_fil(rot)
    la run_config: tekst = workspace.studio_v2_state_session_run_config(session_data)
    la guide_linjer: liste_tekst = studio_v2_gui_troubleshooting_guide(rot, aktiv_fil, run_config)
    workspace.studio_v2_state_session_output_skriv_med_tilstand(rot, "technical", "technical-guide", "0", guide_linjer, [])
    returner "Teknisk feilsøking generert i Output"
}

funksjon studio_v2_gui_palette_panel_status(palette_panel: heltall, rot: tekst) -> heltall {
    hvis palette_panel == 0 da {
        returner 0
    }
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la status_widget: heltall = gui.barn(palette_panel, 1)
    la knapp_widget: heltall = gui.barn(palette_panel, 2)
    hvis status_widget == 0 eller knapp_widget == 0 da {
        returner palette_panel
    }
    la palette_status: tekst = workspace.studio_v2_state_session_palette_status(session_data)
    hvis palette_status == "åpen" da {
        studio_v2_gui_sett_tekst_sikkert(knapp_widget, "Close Palette")
        la query_widget: heltall = gui.barn(palette_panel, 3)
        la liste_widget: heltall = gui.barn(palette_panel, 4)
        hvis query_widget == 0 eller liste_widget == 0 da {
            studio_v2_gui_sett_tekst_sikkert(status_widget, ui.studio_v2_ui_deloverskrift("Navigation") + " " + ui.studio_v2_ui_status_chip("State", palette_status) + " · " + ui.studio_v2_ui_status_chip("Query", "...") + " · " + ui.studio_v2_ui_status_chip("Count", "0"))
            returner palette_panel
        }
        la query: tekst = gui.hent_tekst(query_widget)
        la commands: liste_tekst = studio_v2_gui_palette_filtrert(studio_v2_gui_palette_kommandoer(), query)
            studio_v2_gui_sett_tekst_sikkert(status_widget, ui.studio_v2_ui_deloverskrift("Navigation") + " " + ui.studio_v2_ui_status_chip("State", palette_status) + " · " + ui.studio_v2_ui_status_chip("Query", query) + " · " + ui.studio_v2_ui_status_chip("Count", tekst_fra_heltall(lengde(commands))))
        studio_v2_gui_liste_sett(liste_widget, commands)
    } ellers {
        studio_v2_gui_sett_tekst_sikkert(knapp_widget, "Open Palette")
        studio_v2_gui_sett_tekst_sikkert(status_widget, ui.studio_v2_ui_deloverskrift("Navigation") + " " + ui.studio_v2_ui_status_chip("State", palette_status) + " · " + ui.studio_v2_ui_status_chip("Query", "") + " · " + ui.studio_v2_ui_status_chip("Count", "0"))
    }
    returner palette_panel
}

funksjon studio_v2_gui_kjor_handling_rot(rot: tekst, navn: tekst) -> tekst {
    hvis navn == "technical-guide" eller navn == ui.studio_v2_ui_label_troubleshooting_guide() da {
        returner studio_v2_gui_generer_technical_guide(rot)
    }
    la aktiv_fil: tekst = workspace.studio_v2_state_aktiv_fil(rot)
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la kommando_fil: tekst = actions.studio_v2_actions_kommando_fil(rot)
    hvis navn == "test" da {
        la test_filer: liste_tekst = workspace.studio_v2_state_test_filer(rot)
        la test_koder: liste_tekst = []
        la indeks: heltall = 0
        mens (indeks < lengde(test_filer)) {
            la test_fil: tekst = test_filer[indeks]
            la test_kode: heltall = 2
            hvis ikke studio_v2_gui_test_fil_skipes(test_fil) da {
                la test_kommando: liste_tekst = [kommando_fil, "test", test_fil]
                test_kode = actions.studio_v2_actions_kjor(test_kommando)
            }
            legg_til(test_koder, tekst_fra_heltall(test_kode))
            indeks = indeks + 1
        }
        la stdout_linjer: liste_tekst = studio_v2_gui_test_resultat_linjer(test_filer, test_koder)
        la stderr_linjer: liste_tekst = studio_v2_gui_test_feil_linjer(test_filer, test_koder)
        la exit_code: tekst = "0"
        hvis lengde(stderr_linjer) > 0 da {
            exit_code = "1"
        }
        workspace.studio_v2_state_session_output_skriv_med_tilstand(rot, "test", actions.studio_v2_actions_kommando_tekst([kommando_fil, "test"]), exit_code, stdout_linjer, stderr_linjer)
        la test_sammendrag: tekst = studio_v2_gui_test_sammendrag(rot, test_filer, test_koder)
        workspace.studio_v2_state_session_test_history_skriv_med_tilstand(rot, test_sammendrag)
        returner test_sammendrag
    }
    la resultat: tekst = actions.studio_v2_actions_trygg_kjor(rot, aktiv_fil, navn)
    la run_config: tekst = workspace.studio_v2_state_session_run_config(session_data)
    hvis run_config == "" da {
        run_config = "run"
    }
    la kommando: liste_tekst = actions.studio_v2_actions_kommando_for_navn(rot, aktiv_fil, navn)
    la stdout_linjer: liste_tekst = studio_v2_gui_output_stdout_linjer(rot, aktiv_fil, navn, session_data)
    la stderr_linjer: liste_tekst = studio_v2_gui_output_stderr_linjer(resultat)
    la exit_code: tekst = "1"
    hvis tekst_inneholder(resultat, "-> ok") da {
        exit_code = "0"
    }
    workspace.studio_v2_state_session_output_skriv_med_tilstand(rot, run_config, actions.studio_v2_actions_kommando_tekst(kommando), exit_code, stdout_linjer, stderr_linjer)
    returner resultat
}

funksjon studio_v2_gui_toggle_palette(widget_id: heltall) -> heltall {
    la rot_panel: heltall = gui.foresatt(widget_id)
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la aktiv_fil: tekst = workspace.studio_v2_state_aktiv_fil(rot)
    la aktiv_tab: tekst = workspace.studio_v2_state_session_aktiv_tab(session_data)
    la split_fokus: tekst = workspace.studio_v2_state_session_split_fokus(session_data)
    la tool_window: tekst = workspace.studio_v2_state_session_tool_window(session_data)
    la run_config: tekst = workspace.studio_v2_state_session_run_config(session_data)
    la palette_open: tekst = workspace.studio_v2_state_session_palette_status(session_data)
    la sist_navigasjon: tekst = workspace.studio_v2_state_session_sist_navigasjon(session_data)
    la tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data)
    hvis palette_open == "åpen" da {
        palette_open = "lukket"
    } ellers {
        palette_open = "åpen"
    }
    workspace.studio_v2_state_session_lagre_med_tilstand(rot, aktiv_fil, aktiv_tab, split_fokus, tool_window, run_config, palette_open, sist_navigasjon, tree_fold)
    studio_v2_gui_palette_panel_status(rot_panel, rot)
    returner widget_id
}

funksjon studio_v2_gui_palette_utfør(rot_panel: heltall, kommando: tekst) -> tekst {
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    hvis kommando == ui.studio_v2_ui_label_project() da {
        studio_v2_gui_snarvei_project(rot_panel)
        returner "fokus Project"
    }
    hvis kommando == ui.studio_v2_ui_label_editor() da {
        studio_v2_gui_snarvei_editor(rot_panel)
        returner "fokus Editor"
    }
    hvis kommando == ui.studio_v2_ui_label_inspect() da {
        studio_v2_gui_snarvei_inspect(rot_panel)
        returner "fokus Inspect"
    }
    hvis kommando == ui.studio_v2_ui_label_run() da {
        returner studio_v2_gui_kjor_handling_rot(rot, workspace.studio_v2_state_session_run_config(workspace.studio_v2_state_session_les(rot)))
    }
    hvis kommando == "Check" da {
        returner studio_v2_gui_kjor_handling_rot(rot, "check")
    }
    hvis kommando == "Test" da {
        returner studio_v2_gui_kjor_handling_rot(rot, "test")
    }
    hvis kommando == "Debug" da {
        returner studio_v2_gui_kjor_handling_rot(rot, "debug")
    }
    hvis kommando == "CI" da {
        returner studio_v2_gui_kjor_handling_rot(rot, "runtime-ci")
    }
    hvis kommando == ui.studio_v2_ui_label_troubleshooting_guide() da {
        returner studio_v2_gui_kjor_handling_rot(rot, "technical-guide")
    }
    hvis kommando == "Close Palette" da {
        studio_v2_gui_snarvei_lukk_palette(rot_panel)
        returner "lukket"
    }
    returner "ukjent"
}

funksjon studio_v2_gui_oppdater_palette(widget_id: heltall) -> heltall {
    la valgt_config: tekst = studio_v2_gui_palette_valg(studio_v2_gui_markert_valgt_sikkert(widget_id))
    hvis valgt_config == "" da {
        returner widget_id
    }
    la palette_panel: heltall = gui.foresatt(widget_id)
    la rot_panel: heltall = gui.foresatt(palette_panel)
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la palette_resultat: tekst = studio_v2_gui_palette_utfør(rot_panel, valgt_config)
    la session_data_ny: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la aktiv_fil: tekst = workspace.studio_v2_state_aktiv_fil(rot)
    la aktiv_tab: tekst = workspace.studio_v2_state_session_aktiv_tab(session_data_ny)
    la split_fokus: tekst = workspace.studio_v2_state_session_split_fokus(session_data_ny)
    la tool_window: tekst = workspace.studio_v2_state_session_tool_window(session_data_ny)
    la tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data_ny)
    workspace.studio_v2_state_session_lagre_med_tilstand(rot, aktiv_fil, aktiv_tab, split_fokus, tool_window, workspace.studio_v2_state_session_run_config(session_data_ny), "lukket", workspace.studio_v2_state_session_sist_navigasjon(session_data_ny), tree_fold)
    skriv("Palette: " + palette_resultat)
    studio_v2_gui_palette_panel_status(palette_panel, rot)
    returner widget_id
}

funksjon studio_v2_gui_oppdater_palette_query(widget_id: heltall) -> heltall {
    la palette_panel: heltall = gui.foresatt(widget_id)
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    hvis palette_panel == 0 da {
        returner widget_id
    }
    studio_v2_gui_palette_panel_status(palette_panel, rot)
    la liste_widget: heltall = gui.barn(palette_panel, 4)
    hvis liste_widget > 0 da {
        hvis gui.liste_antall(liste_widget) > 0 da {
            gui.liste_velg(liste_widget, 0)
        }
    }
    returner widget_id
}

funksjon studio_v2_gui_oppdater_palette_fra_query(widget_id: heltall) -> heltall {
    la palette_panel: heltall = gui.foresatt(widget_id)
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    hvis palette_panel == 0 da {
        returner widget_id
    }
    studio_v2_gui_palette_panel_status(palette_panel, rot)
    la liste_widget: heltall = gui.barn(palette_panel, 4)
    hvis liste_widget > 0 da {
        hvis gui.liste_antall(liste_widget) > 0 da {
            gui.liste_velg(liste_widget, 0)
            returner studio_v2_gui_oppdater_palette(liste_widget)
        }
    }
    returner widget_id
}

funksjon studio_v2_gui_oppdater_run_config(widget_id: heltall) -> heltall {
    la valgt_config: tekst = studio_v2_gui_run_config_valg(studio_v2_gui_markert_valgt_sikkert(widget_id))
    hvis valgt_config == "" da {
        returner widget_id
    }
    la rot_panel: heltall = studio_v2_gui_steg_opp(widget_id, 1)
    la run_config_tekst: heltall = gui.barn(rot_panel, 1)
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la aktiv_fil: tekst = workspace.studio_v2_state_aktiv_fil(rot)
    la aktiv_tab: tekst = workspace.studio_v2_state_session_aktiv_tab(session_data)
    la split_fokus: tekst = workspace.studio_v2_state_session_split_fokus(session_data)
    la tool_window: tekst = workspace.studio_v2_state_session_tool_window(session_data)
    la sist_navigasjon: tekst = workspace.studio_v2_state_session_sist_navigasjon(session_data)
    la tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data)
    workspace.studio_v2_state_session_lagre_med_tilstand(rot, aktiv_fil, aktiv_tab, split_fokus, tool_window, valgt_config, workspace.studio_v2_state_session_palette_status(session_data), sist_navigasjon, tree_fold)
    workspace.studio_v2_state_session_run_profile_skriv_med_tilstand(rot, valgt_config, workspace.studio_v2_state_session_run_profile_args(session_data, valgt_config), workspace.studio_v2_state_session_run_profile_cwd(session_data, valgt_config, rot), workspace.studio_v2_state_session_run_profile_env(session_data, valgt_config))
    workspace.studio_v2_state_session_debug_skriv_med_tilstand(rot, valgt_config, workspace.studio_v2_state_session_debug_status(session_data), workspace.studio_v2_state_session_debug_handling(session_data), workspace.studio_v2_state_session_debug_linje(session_data))
    studio_v2_gui_sett_tekst_sikkert(run_config_tekst, ui.studio_v2_ui_deloverskrift("Navigation") + " " + ui.studio_v2_ui_status_chip("Config", valgt_config) + " · " + ui.studio_v2_ui_status_chip("Target", aktiv_fil))
    returner widget_id
}

funksjon studio_v2_gui_oppdater_snarvei(widget_id: heltall) -> heltall {
    skriv("Snarvei valgt: " + gui.liste_valgt(widget_id))
    returner widget_id
}

funksjon studio_v2_gui_output_stdout_linjer(rot: tekst, fil: tekst, navn: tekst, session_data: liste_tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la kommando: liste_tekst = actions.studio_v2_actions_kommando_for_navn(rot, fil, navn)
    legg_til(resultat, "Command: " + actions.studio_v2_actions_kommando_tekst(kommando))
    la run_config: tekst = workspace.studio_v2_state_session_run_config(session_data)
    hvis run_config == "" da {
        run_config = "run"
    }
    legg_til(resultat, "Config: " + run_config)
    legg_til(resultat, "Target: " + fil)
    legg_til(resultat, "Workdir: " + workspace.studio_v2_state_session_run_profile_cwd(session_data, run_config, rot))
    legg_til(resultat, "Args: " + workspace.studio_v2_state_session_run_profile_args(session_data, run_config))
    legg_til(resultat, "Env: " + workspace.studio_v2_state_session_run_profile_env(session_data, run_config))
    returner resultat
}

funksjon studio_v2_gui_output_stderr_linjer(resultat: tekst) -> liste_tekst {
    hvis tekst_inneholder(resultat, "-> ok") da {
        returner []
    }
    returner [resultat]
}

funksjon studio_v2_gui_output_filtrer_linjer(linjer: liste_tekst, query: tekst) -> liste_tekst {
    hvis query == "" da {
        returner linjer
    }
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(linjer)) {
        hvis tekst_inneholder(linjer[indeks], query) da {
            legg_til(resultat, linjer[indeks])
        }
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_output_filter_status(query: tekst, stdout_antall: heltall, stderr_antall: heltall) -> tekst {
    hvis query == "" da {
        returner "Filter: none · Stdout: " + tekst_fra_heltall(stdout_antall) + " · Stderr: " + tekst_fra_heltall(stderr_antall)
    }
    returner "Filter: " + query + " · Stdout: " + tekst_fra_heltall(stdout_antall) + " · Stderr: " + tekst_fra_heltall(stderr_antall)
}

funksjon studio_v2_gui_test_resultat_linje(fil: tekst, kode: heltall) -> tekst {
    hvis kode == 0 da {
        returner "● " + fil + ":1 · ok"
    }
    hvis kode == 2 da {
        returner "↷ " + fil + ":1 · skipped"
    }
    returner "⛔ " + fil + ":1 · " + actions.studio_v2_actions_kommando_status(kode)
}

funksjon studio_v2_gui_test_fil_skipes(fil: tekst) -> bool {
    hvis tekst_inneholder(fil, "skip_") eller tekst_inneholder(fil, "disabled_") da {
        returner sann
    }
    returner usann
}

funksjon studio_v2_gui_output_destinasjon_fra_oppføring(oppføring: tekst) -> liste_tekst {
    la ren: tekst = studio_v2_gui_markert_valg(oppføring)
    hvis tekst_starter_med(ren, "Feil: ") da {
        ren = tekst_erstatt(ren, "Feil: ", "")
    }
    la deler: liste_tekst = tekst_del_på(ren, " · ")
    la primær: tekst = ren
    hvis lengde(deler) > 0 da {
        primær = deler[0]
    }
    hvis tekst_starter_med(primær, "● ") da {
        primær = tekst_erstatt(primær, "● ", "")
    } ellers hvis tekst_starter_med(primær, "⛔ ") da {
        primær = tekst_erstatt(primær, "⛔ ", "")
    } ellers hvis tekst_starter_med(primær, "↷ ") da {
        primær = tekst_erstatt(primær, "↷ ", "")
    }
    la fil: tekst = primær
    la linje: tekst = "1"
    la felt: liste_tekst = tekst_del_på(primær, ":")
    hvis lengde(felt) >= 2 da {
        fil = felt[0]
        linje = felt[1]
    }
    returner [fil, linje]
}

funksjon studio_v2_gui_oppdater_output_navigasjon(widget_id: heltall) -> heltall {
    la valgt: tekst = studio_v2_gui_markert_valgt_sikkert(widget_id)
    la destinasjon: liste_tekst = studio_v2_gui_output_destinasjon_fra_oppføring(valgt)
    hvis lengde(destinasjon) < 2 da {
        returner widget_id
    }
    la fil: tekst = destinasjon[0]
    la linje: heltall = heltall_fra_tekst(destinasjon[1])
    hvis fil == "" da {
        returner widget_id
    }
    hvis linje < 1 da {
        linje = 1
    }
    la rot_panel: heltall = studio_v2_gui_steg_opp(widget_id, 3)
    la midten: heltall = studio_v2_gui_hovedrad_midten_widget(rot_panel)
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    workspace.studio_v2_state_session_lagre_med_tilstand(rot, fil, fil, workspace.studio_v2_state_session_split_fokus(session_data), workspace.studio_v2_state_session_tool_window(session_data), workspace.studio_v2_state_session_run_config(session_data), workspace.studio_v2_state_session_palette_status(session_data), fil, workspace.studio_v2_state_session_tree_fold(session_data))
    studio_v2_gui_oppdater_editor(midten, rot, fil, linje)
    returner widget_id
}

funksjon studio_v2_gui_test_resultat_linjer(filer: liste_tekst, koder: liste_tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(filer) og indeks < lengde(koder)) {
        legg_til(resultat, studio_v2_gui_test_resultat_linje(filer[indeks], heltall_fra_tekst(koder[indeks])))
        indeks = indeks + 1
    }
    hvis lengde(filer) == 0 da {
        legg_til(resultat, ui.studio_v2_ui_tomt_testfiler())
    }
    returner resultat
}

funksjon studio_v2_gui_test_feil_linjer(filer: liste_tekst, koder: liste_tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(filer) og indeks < lengde(koder)) {
        la kode: heltall = heltall_fra_tekst(koder[indeks])
        hvis kode != 0 og kode != 2 da {
            legg_til(resultat, "Feil: " + filer[indeks] + ":1 · " + actions.studio_v2_actions_kommando_status(kode))
        }
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_test_sammendrag(rot: tekst, filer: liste_tekst, koder: liste_tekst) -> tekst {
    la test_kommando_tekst: tekst = actions.studio_v2_actions_kommando_tekst([actions.studio_v2_actions_kommando_fil(rot), "test"])
    hvis lengde(filer) == 0 da {
        returner test_kommando_tekst + " -> ingen testfiler"
    }
    la suksess: heltall = 0
    la hoppet_over: heltall = 0
    la feil: heltall = 0
    la indeks: heltall = 0
    mens (indeks < lengde(filer) og indeks < lengde(koder)) {
        la kode: heltall = heltall_fra_tekst(koder[indeks])
        hvis kode == 0 da {
            suksess = suksess + 1
        } ellers hvis kode == 2 da {
            hoppet_over = hoppet_over + 1
        } ellers {
            feil = feil + 1
        }
        indeks = indeks + 1
    }
    hvis feil == 0 da {
        hvis hoppet_over > 0 da {
            returner test_kommando_tekst + " -> ok (" + tekst_fra_heltall(suksess) + "/" + tekst_fra_heltall(lengde(filer)) + ", skipped " + tekst_fra_heltall(hoppet_over) + ")"
        }
        returner test_kommando_tekst + " -> ok (" + tekst_fra_heltall(suksess) + "/" + tekst_fra_heltall(lengde(filer)) + ")"
    }
    hvis hoppet_over > 0 da {
        returner test_kommando_tekst + " -> feil (kode 1, " + tekst_fra_heltall(suksess) + "/" + tekst_fra_heltall(lengde(filer)) + ", skipped " + tekst_fra_heltall(hoppet_over) + ")"
    }
    returner test_kommando_tekst + " -> feil (kode 1, " + tekst_fra_heltall(suksess) + "/" + tekst_fra_heltall(lengde(filer)) + ")"
}

funksjon studio_v2_gui_vcs_fil_fra_statuslinje(statuslinje: tekst) -> tekst {
    la ren: tekst = studio_v2_gui_markert_valg(statuslinje)
    hvis tekst_starter_med(ren, "?? ") eller tekst_starter_med(ren, "M  ") eller tekst_starter_med(ren, "A  ") eller tekst_starter_med(ren, "D  ") da {
        returner tekst_slice(ren, 3, tekst_lengde(ren))
    }
    hvis tekst_starter_med(ren, "M ") eller tekst_starter_med(ren, "A ") eller tekst_starter_med(ren, "D ") da {
        returner tekst_slice(ren, 2, tekst_lengde(ren))
    }
    returner ren
}

funksjon studio_v2_gui_vcs_status_linje(status: liste_tekst, aktiv_fil: tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(status)) {
        la linje: tekst = status[indeks]
        la fil: tekst = studio_v2_gui_vcs_fil_fra_statuslinje(linje)
        hvis fil == aktiv_fil da {
            legg_til(resultat, "▶ " + linje)
        } ellers {
            legg_til(resultat, "· " + linje)
        }
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_vcs_diff_linje(diff: liste_tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(diff)) {
        legg_til(resultat, "· " + diff[indeks])
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_vcs_commit_linje(commit: liste_tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(commit)) {
        legg_til(resultat, "· " + commit[indeks])
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_vcs_history_linje(history: liste_tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(history)) {
        legg_til(resultat, "· " + history[indeks])
        indeks = indeks + 1
    }
    returner resultat
}

