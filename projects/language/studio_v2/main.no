    la tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data)
    returner workspace.studio_v2_state_session_lagre_med_tilstand(rot, aktiv_fil, aktiv_tab, split_fokus, tool_window, run_config, palette_open, sist_navigasjon, tree_fold)
}

