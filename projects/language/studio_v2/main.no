bruk std.gui som gui
bruk studio_v2.studio_state som workspace
bruk studio_v2.project som project
bruk studio_v2.editor som editor
bruk studio_v2.symbol som symbol
bruk studio_v2.actions som actions
bruk studio_v2.diagnostics som diagnostics
bruk studio_v2.ui som ui

funksjon studio_v2_gui_liste_fyll(widget_id: heltall, elementer: liste_tekst) -> heltall {
    hvis widget_id <= 0 da {
        returner widget_id
    }
    la indeks: heltall = 0
    mens (indeks < lengde(elementer)) {
        gui.liste_legg_til(widget_id, elementer[indeks])
        indeks = indeks + 1
    }
    returner widget_id
}

funksjon studio_v2_gui_liste_tøm(widget_id: heltall) -> heltall {
    hvis widget_id <= 0 da {
        returner widget_id
    }
    gui.liste_tom(widget_id)
    returner widget_id
}

funksjon studio_v2_gui_liste_sett(widget_id: heltall, elementer: liste_tekst) -> heltall {
    hvis widget_id <= 0 da {
        returner widget_id
    }
    la valgt: tekst = gui.liste_valgt(widget_id)
    studio_v2_gui_liste_tøm(widget_id)
    studio_v2_gui_liste_fyll(widget_id, elementer)
    hvis lengde(elementer) > 0 da {
        la valgt_indeks: heltall = studio_v2_gui_liste_indeks_fra_valgt(elementer, valgt)
        hvis valgt_indeks < 0 da {
            valgt_indeks = 0
        }
        gui.liste_velg(widget_id, valgt_indeks)
    }
    returner widget_id
}

funksjon studio_v2_gui_liste_indeks_fra_valgt(elementer: liste_tekst, valgt: tekst) -> heltall {
    la indeks: heltall = 0
    mens (indeks < lengde(elementer)) {
        hvis elementer[indeks] == valgt da {
            returner indeks
        }
        indeks = indeks + 1
    }
    returner -1
}

funksjon studio_v2_gui_liste_foresatt_indeks(indeks: heltall, antall: heltall, delta: heltall) -> heltall {
    hvis antall <= 0 da {
        returner -1
    }
    la resultat: heltall = indeks
    hvis resultat < 0 da {
        hvis delta < 0 da {
            returner antall - 1
        }
        returner 0
    }
    resultat = resultat + delta
    hvis resultat < 0 da {
        returner antall - 1
    }
    hvis resultat >= antall da {
        returner 0
    }
    returner resultat
}

funksjon studio_v2_gui_liste_valgt_indeks(widget_id: heltall) -> heltall {
    la valgt: tekst = gui.liste_valgt(widget_id)
    la antall: heltall = gui.liste_antall(widget_id)
    la indeks: heltall = 0
    mens (indeks < antall) {
        hvis gui.liste_hent(widget_id, indeks) == valgt da {
            returner indeks
        }
        indeks = indeks + 1
    }
    returner -1
}

funksjon studio_v2_gui_liste_velg_relativ(widget_id: heltall, delta: heltall) -> heltall {
    hvis widget_id <= 0 da {
        returner widget_id
    }
    la antall: heltall = gui.liste_antall(widget_id)
    la indeks: heltall = studio_v2_gui_liste_valgt_indeks(widget_id)
    la ny_indeks: heltall = studio_v2_gui_liste_foresatt_indeks(indeks, antall, delta)
    hvis ny_indeks >= 0 da {
        gui.liste_velg(widget_id, ny_indeks)
    }
    returner widget_id
}

funksjon studio_v2_gui_sett_tekst_sikkert(widget_id: heltall, tekst_verdi: tekst) -> heltall {
    hvis widget_id <= 0 da {
        returner widget_id
    }
    gui.sett_tekst(widget_id, tekst_verdi)
    returner widget_id
}

funksjon studio_v2_gui_markert_valgt_sikkert(widget_id: heltall) -> tekst {
    hvis widget_id <= 0 da {
        returner ""
    }
    la valgt: tekst = gui.hent_tekst(widget_id)
    hvis valgt != "" da {
        returner valgt
    }
    returner gui.liste_valgt(widget_id)
}

funksjon studio_v2_gui_liste_velg_neste(widget_id: heltall) -> heltall {
    returner studio_v2_gui_liste_velg_relativ(widget_id, 1)
}

funksjon studio_v2_gui_liste_velg_forrige(widget_id: heltall) -> heltall {
    returner studio_v2_gui_liste_velg_relativ(widget_id, -1)
}

funksjon studio_v2_gui_logg_fil(widget_id: heltall) -> heltall {
    la valgt: tekst = studio_v2_gui_prosjekt_tre_valg(gui.liste_valgt(widget_id))
    hvis valgt != "" da {
        la rot: tekst = workspace.studio_v2_state_rot(argv())
        workspace.studio_v2_state_session_project_tree_anchor_skriv_med_tilstand(rot, valgt)
    }
    skriv("Fil valgt: " + valgt)
    returner widget_id
}

funksjon studio_v2_gui_logg_kommando(widget_id: heltall) -> heltall {
    skriv("Kommando valgt: " + studio_v2_gui_markert_valg(gui.liste_valgt(widget_id)))
    returner widget_id
}

funksjon studio_v2_gui_logg_diagnostikk(widget_id: heltall) -> heltall {
    skriv("Diagnostikk valgt: " + studio_v2_gui_markert_valg(gui.liste_valgt(widget_id)))
    returner widget_id
}

funksjon studio_v2_gui_logg_ai(widget_id: heltall) -> heltall {
    skriv("AI valgt: " + studio_v2_gui_markert_valg(gui.liste_valgt(widget_id)))
    returner widget_id
}

funksjon studio_v2_gui_logg_rename(widget_id: heltall) -> heltall {
    skriv("Rename preview valgt: " + studio_v2_gui_markert_valg(gui.liste_valgt(widget_id)))
    returner widget_id
}

funksjon studio_v2_gui_breakpoint_linjenummer(tekstverdi: tekst) -> heltall {
    la ren: tekst = studio_v2_gui_markert_valg(tekstverdi)
    hvis tekst_starter_med(ren, "● ") da {
        ren = tekst_erstatt(ren, "● ", "")
    } ellers hvis tekst_starter_med(ren, "· ") da {
        ren = tekst_erstatt(ren, "· ", "")
    }
    la deler: liste_tekst = tekst_del_på(ren, ":")
    hvis lengde(deler) > 0 da {
        returner heltall_fra_tekst(tekst_trim(deler[0]))
    }
    returner 0
}

funksjon studio_v2_gui_oppdater_breakpoint(widget_id: heltall) -> heltall {
    la høyre: heltall = gui.foresatt(widget_id)
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la aktiv_fil: tekst = workspace.studio_v2_state_aktiv_fil(rot)
    la valgt: tekst = studio_v2_gui_markert_valg(gui.liste_valgt(widget_id))
    la linje_nummer: heltall = studio_v2_gui_breakpoint_linjenummer(valgt)
    hvis linje_nummer > 0 da {
        workspace.studio_v2_state_session_breakpoint_toggle(rot, aktiv_fil, linje_nummer)
        workspace.studio_v2_state_session_debug_skriv_med_tilstand(rot, workspace.studio_v2_state_session_run_config(session_data), "paused", "breakpoint", linje_nummer)
    }
    returner widget_id
}

funksjon studio_v2_gui_debug_oppdater_fra_handling(widget_id: heltall, handling: tekst) -> heltall {
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la aktiv_fil: tekst = workspace.studio_v2_state_aktiv_fil(rot)
    hvis aktiv_fil == "" da {
        aktiv_fil = workspace.studio_v2_state_session_aktiv_fil(session_data)
    }
    la buffer: liste_tekst = editor.studio_v2_editor_åpne(workspace.studio_v2_state_fil_innhold(rot, aktiv_fil))
    la breakpoints: liste_tekst = workspace.studio_v2_state_session_breakpoints_for_fil(session_data, aktiv_fil)
    la debug_linje: heltall = workspace.studio_v2_state_session_debug_linje(session_data)
    hvis debug_linje < 1 da {
        debug_linje = 1
    }
    la debug_modus: tekst = "paused"
    hvis handling == "step_over" da {
        debug_linje = editor.studio_v2_editor_debug_step_over(buffer, debug_linje)
    } ellers hvis handling == "step_into" da {
        debug_linje = editor.studio_v2_editor_debug_step_into(buffer, debug_linje)
    } ellers hvis handling == "step_out" da {
        debug_linje = editor.studio_v2_editor_debug_step_out(buffer, debug_linje)
    } ellers hvis handling == "resume" da {
        debug_linje = editor.studio_v2_editor_debug_resume(buffer, breakpoints, debug_linje)
        debug_modus = "running"
    }
    hvis debug_linje < 1 da {
        debug_linje = 1
    }
    workspace.studio_v2_state_session_debug_skriv_med_tilstand(rot, workspace.studio_v2_state_session_debug_config(session_data), debug_modus, handling, debug_linje)
    returner widget_id
}

funksjon studio_v2_gui_debug_step_over(widget_id: heltall) -> heltall {
    returner studio_v2_gui_debug_oppdater_fra_handling(widget_id, "step_over")
}

funksjon studio_v2_gui_debug_step_into(widget_id: heltall) -> heltall {
    returner studio_v2_gui_debug_oppdater_fra_handling(widget_id, "step_into")
}

funksjon studio_v2_gui_debug_step_out(widget_id: heltall) -> heltall {
    returner studio_v2_gui_debug_oppdater_fra_handling(widget_id, "step_out")
}

funksjon studio_v2_gui_debug_resume(widget_id: heltall) -> heltall {
    returner studio_v2_gui_debug_oppdater_fra_handling(widget_id, "resume")
}

funksjon studio_v2_gui_oppdater_rename_forhåndsvisning(widget_id: heltall) -> heltall {
    la høyre: heltall = gui.foresatt(widget_id)
    la rename_status: heltall = gui.barn(høyre, 18)
    la rename_liste: heltall = gui.barn(høyre, 19)
    la rename_preview_status: heltall = gui.barn(høyre, 27)
    la rename_from: heltall = gui.barn(høyre, 23)
    la rename_to: heltall = gui.barn(høyre, 25)
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la gammelt: tekst = gui.hent_tekst(rename_from)
    la nytt: tekst = gui.hent_tekst(rename_to)
    la workspace_filer: liste_tekst = workspace.studio_v2_state_workspace_filer(rot)
    la preview: liste_tekst = symbol.studio_v2_symbol_rename_preview_fra_filer(workspace_filer, gammelt, nytt)
    gui.sett_tekst(rename_status, ui.studio_v2_ui_deloverskrift("Navigation") + " " + ui.studio_v2_ui_status_chip("Rename", tekst_fra_heltall(lengde(preview))))
    gui.sett_tekst(rename_preview_status, ui.studio_v2_ui_status_chip("Preview", tekst_fra_heltall(lengde(preview))) + " · " + ui.studio_v2_ui_rename_apply_hint())
    studio_v2_gui_liste_sett(rename_liste, studio_v2_gui_begrens_liste(studio_v2_gui_rename_linje(preview), 6))
    returner widget_id
}

funksjon studio_v2_gui_oppdater_rename_appliser(widget_id: heltall) -> heltall {
    la høyre: heltall = gui.foresatt(widget_id)
    la rename_status: heltall = gui.barn(høyre, 18)
    la rename_liste: heltall = gui.barn(høyre, 19)
    la rename_preview_status: heltall = gui.barn(høyre, 27)
    la rename_from: heltall = gui.barn(høyre, 23)
    la rename_to: heltall = gui.barn(høyre, 25)
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la gammelt: tekst = gui.hent_tekst(rename_from)
    la nytt: tekst = gui.hent_tekst(rename_to)
    la rename_status_nytt: tekst = symbol.studio_v2_symbol_rename_status(rot, gammelt, nytt)
    hvis rename_status_nytt != "klar" da {
        la konflikt: tekst = symbol.studio_v2_symbol_rename_konflikt_fra_indeks(symbol.studio_v2_symbol_indeks_fra_workspace(rot), gammelt, nytt)
        la konflikt_tekst: tekst = rename_status_nytt
        hvis konflikt != "" da {
            konflikt_tekst = konflikt_tekst + " · " + symbol.studio_v2_symbol_oppføring_sted(konflikt)
        }
        gui.sett_tekst(rename_status, ui.studio_v2_ui_status_chip("Rename", konflikt_tekst))
        gui.sett_tekst(rename_preview_status, ui.studio_v2_ui_status_chip("Preview", "blokert") + " · " + ui.studio_v2_ui_rename_apply_hint())
        returner widget_id
    }
    hvis gammelt == "" eller nytt == "" da {
        gui.sett_tekst(rename_status, ui.studio_v2_ui_status_chip("Rename", "fyll inn begge felt"))
        gui.sett_tekst(rename_preview_status, ui.studio_v2_ui_status_chip("Preview", "tom") + " · " + ui.studio_v2_ui_rename_apply_hint())
        returner widget_id
    }
    la workspace_filer: liste_tekst = workspace.studio_v2_state_workspace_filer(rot)
    la preview: liste_tekst = symbol.studio_v2_symbol_rename_preview_fra_filer(workspace_filer, gammelt, nytt)
    gui.sett_tekst(rename_status, ui.studio_v2_ui_status_chip("Rename", tekst_fra_heltall(lengde(preview))))
    gui.sett_tekst(rename_preview_status, ui.studio_v2_ui_status_chip("Preview", tekst_fra_heltall(lengde(preview))) + " · " + ui.studio_v2_ui_rename_apply_hint())
    studio_v2_gui_liste_sett(rename_liste, studio_v2_gui_begrens_liste(studio_v2_gui_rename_linje(preview), 6))
    la antall: heltall = symbol.studio_v2_symbol_rename_appliser_filer(rot, workspace_filer, gammelt, nytt)
    gui.sett_tekst(rename_status, ui.studio_v2_ui_status_chip("Applied", tekst_fra_heltall(antall)) + " · " + ui.studio_v2_ui_rename_apply_hint())
    gui.sett_tekst(rename_preview_status, ui.studio_v2_ui_status_chip("Preview", tekst_fra_heltall(lengde(preview))) + " · " + ui.studio_v2_ui_rename_apply_hint())
    studio_v2_gui_liste_sett(rename_liste, studio_v2_gui_begrens_liste(studio_v2_gui_rename_linje(preview), 6))
    la rot_panel: heltall = studio_v2_gui_steg_opp(widget_id, 2)
    la midten: heltall = studio_v2_gui_hovedrad_midten_widget(rot_panel)
    la aktiv_fil: tekst = workspace.studio_v2_state_aktiv_fil(rot)
    studio_v2_gui_oppdater_editor(midten, rot, aktiv_fil, 1)
    returner widget_id
}

funksjon studio_v2_gui_logg_sok(widget_id: heltall) -> heltall {
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la query: tekst = gui.hent_tekst(widget_id)
    workspace.studio_v2_state_session_search_query_skriv_med_tilstand(rot, query)
    skriv("Søk: " + query)
    returner widget_id
}

funksjon studio_v2_gui_steg_opp(widget_id: heltall, trinn: heltall) -> heltall {
    la teller: heltall = 0
    mens (teller < trinn og widget_id > 0) {
        widget_id = gui.foresatt(widget_id)
        teller = teller + 1
    }
    returner widget_id
}

funksjon studio_v2_gui_trekk_ut_deler(oppføring: tekst) -> liste_tekst {
    returner tekst_del_på(oppføring, "\t")
}

funksjon studio_v2_gui_trekk_ut_fil(oppføring: tekst) -> tekst {
    la deler: liste_tekst = studio_v2_gui_trekk_ut_deler(oppføring)
    hvis lengde(deler) > 0 da {
        returner deler[0]
    }
    returner ""
}

funksjon studio_v2_gui_trekk_ut_linje(oppføring: tekst) -> heltall {
    la deler: liste_tekst = studio_v2_gui_trekk_ut_deler(oppføring)
    hvis lengde(deler) > 1 da {
        returner heltall_fra_tekst(deler[1])
    }
    returner 0
}

funksjon studio_v2_gui_trekk_ut_kolonne(oppføring: tekst) -> heltall {
    la deler: liste_tekst = studio_v2_gui_trekk_ut_deler(oppføring)
    hvis lengde(deler) > 6 da {
        returner heltall_fra_tekst(deler[6])
    }
    returner 0
}

funksjon studio_v2_gui_trekk_ut_melding(oppføring: tekst) -> tekst {
    la deler: liste_tekst = studio_v2_gui_trekk_ut_deler(oppføring)
    hvis lengde(deler) > 3 da {
        returner deler[3]
    }
    returner ""
}

funksjon studio_v2_gui_tab_valg(tab: tekst) -> tekst {
    hvis tekst_starter_med(tab, "● ") da {
        returner tekst_erstatt(tab, "● ", "")
    }
    hvis tekst_starter_med(tab, "▶ ") da {
        returner tekst_erstatt(tab, "▶ ", "")
    }
    hvis tekst_starter_med(tab, "· ") da {
        returner tekst_erstatt(tab, "· ", "")
    }
    returner tab
}

funksjon studio_v2_gui_tab_linje(tabs: liste_tekst, aktiv_tab: tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(tabs)) {
        la tab: tekst = tabs[indeks]
        hvis tab == aktiv_tab da {
            legg_til(resultat, "▶ " + tab)
        } ellers {
            legg_til(resultat, "· " + tab)
        }
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_fil_linje(filer: liste_tekst, aktiv_fil: tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(filer)) {
        la fil: tekst = filer[indeks]
        hvis fil == aktiv_fil da {
            legg_til(resultat, "▶ " + fil)
        } ellers {
            legg_til(resultat, "· " + fil)
        }
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_prosjekt_linje(prosjekter: liste_tekst, aktiv_prosjekt: tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(prosjekter)) {
        la prosjekt: tekst = prosjekter[indeks]
        hvis prosjekt == aktiv_prosjekt da {
            legg_til(resultat, "▶ " + prosjekt)
        } ellers {
            legg_til(resultat, "· " + prosjekt)
        }
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_recent_linje(prosjekter: liste_tekst, aktiv_prosjekt: tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(prosjekter)) {
        la prosjekt: tekst = prosjekter[indeks]
        hvis prosjekt == aktiv_prosjekt da {
            legg_til(resultat, "★ " + prosjekt)
        } ellers {
            legg_til(resultat, "· " + prosjekt)
        }
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_prosjekt_tre_mappe(sti: tekst) -> tekst {
    la deler: liste_tekst = tekst_del_på(sti, "/")
    hvis lengde(deler) > 1 da {
        la mappe: tekst = ""
        la indeks: heltall = 0
        mens (indeks + 1 < lengde(deler)) {
            hvis mappe != "" da {
                mappe = mappe + "/"
            }
            mappe = mappe + deler[indeks]
            indeks = indeks + 1
        }
        returner mappe + "/"
    }
    returner "."
}

funksjon studio_v2_gui_prosjekt_tre_nivå(sti: tekst) -> heltall {
    la mappe: tekst = studio_v2_gui_prosjekt_tre_mappe(sti)
    hvis mappe == "." da {
        returner 0
    }
    la nivå: heltall = 0
    la indeks: heltall = 0
    mens (indeks < tekst_lengde(mappe)) {
        hvis tekst_slice(mappe, indeks, indeks + 1) == "/" da {
            nivå = nivå + 1
        }
        indeks = indeks + 1
    }
    returner nivå
}

funksjon studio_v2_gui_prosjekt_tre_indent(nivå: heltall) -> tekst {
    la resultat: tekst = ""
    la indeks: heltall = 0
    mens (indeks < nivå) {
        resultat = resultat + "  "
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_prosjekt_tre_er_foldet(tree_fold: liste_tekst, mappe: tekst) -> bool {
    la indeks: heltall = 0
    mens (indeks < lengde(tree_fold)) {
        hvis tree_fold[indeks] == mappe da {
            returner sann
        }
        indeks = indeks + 1
    }
    returner usann
}

funksjon studio_v2_gui_prosjekt_tre_antall_foldet(tree_fold: liste_tekst) -> heltall {
    returner lengde(tree_fold)
}

funksjon studio_v2_gui_prosjekt_tre_mappe_valg(tekstverdi: tekst) -> tekst {
    la ren: tekst = studio_v2_gui_markert_valg(tekstverdi)
    mens (tekst_starter_med(ren, "  ")) {
        ren = tekst_slice(ren, 2, tekst_lengde(ren))
    }
    hvis tekst_starter_med(ren, "▸ ") eller tekst_starter_med(ren, "▾ ") da {
        returner tekst_erstatt(tekst_erstatt(ren, "▸ ", ""), "▾ ", "")
    }
    returner ""
}

funksjon studio_v2_gui_prosjekt_tre(filer: liste_tekst, aktiv_fil: tekst, tree_fold: liste_tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la gjeldende_mappe: tekst = ""
    la indeks: heltall = 0
    mens (indeks < lengde(filer)) {
        la fil: tekst = filer[indeks]
        la mappe: tekst = studio_v2_gui_prosjekt_tre_mappe(fil)
        la nivå: heltall = studio_v2_gui_prosjekt_tre_nivå(fil)
        la innrykk: tekst = studio_v2_gui_prosjekt_tre_indent(nivå)
        hvis mappe != gjeldende_mappe da {
            gjeldende_mappe = mappe
            hvis studio_v2_gui_prosjekt_tre_er_foldet(tree_fold, mappe) da {
                legg_til(resultat, innrykk + "▸ " + mappe)
            } ellers {
                legg_til(resultat, innrykk + "▾ " + mappe)
            }
        }
        hvis ikke studio_v2_gui_prosjekt_tre_er_foldet(tree_fold, mappe) da {
            hvis fil == aktiv_fil da {
                legg_til(resultat, innrykk + "  ▶ " + fil)
            } ellers {
                legg_til(resultat, innrykk + "  · " + fil)
            }
        }
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_prosjekt_tre_valg(tekstverdi: tekst) -> tekst {
    la ren: tekst = studio_v2_gui_markert_valg(tekstverdi)
    hvis tekst_starter_med(ren, "  ") da {
        mens (tekst_starter_med(ren, "  ")) {
            ren = tekst_slice(ren, 2, tekst_lengde(ren))
        }
    }
    hvis tekst_starter_med(ren, "▸ ") eller tekst_starter_med(ren, "▾ ") da {
        returner studio_v2_gui_prosjekt_tre_mappe_valg(ren)
    }
    returner ren
}

funksjon studio_v2_gui_prosjekt_aktiv_node(rot: tekst, session: liste_tekst, aktiv_fil: tekst) -> tekst {
    la prosjekt_anker: tekst = workspace.studio_v2_state_session_project_tree_anchor(session)
    hvis prosjekt_anker != "" da {
        la filer: liste_tekst = workspace.studio_v2_state_workspace_filer(rot)
        la indeks: heltall = 0
        mens (indeks < lengde(filer)) {
            hvis filer[indeks] == prosjekt_anker da {
                returner prosjekt_anker
            }
            indeks = indeks + 1
        }
    }
    la sist_navigasjon: tekst = workspace.studio_v2_state_session_sist_navigasjon(session)
    hvis sist_navigasjon != "" da {
        la filer: liste_tekst = workspace.studio_v2_state_workspace_filer(rot)
        la indeks: heltall = 0
        mens (indeks < lengde(filer)) {
            hvis filer[indeks] == sist_navigasjon da {
                returner sist_navigasjon
            }
            indeks = indeks + 1
        }
    }
    returner aktiv_fil
}

funksjon studio_v2_gui_fokus_tekst(fokus: tekst) -> tekst {
    returner "Focus: " + fokus
}

funksjon studio_v2_gui_fokus_etikett(fokus: tekst) -> tekst {
    hvis fokus == ui.studio_v2_ui_label_project() da {
        returner ui.studio_v2_ui_label_project()
    }
    hvis fokus == ui.studio_v2_ui_label_editor() da {
        returner ui.studio_v2_ui_label_editor()
    }
    hvis fokus == ui.studio_v2_ui_label_inspect() da {
        returner ui.studio_v2_ui_label_inspect()
    }
    returner ui.studio_v2_ui_label_editor()
}

funksjon studio_v2_gui_tool_window_etikett(tool_window: tekst) -> tekst {
    hvis tool_window == "Problems" da {
        returner "Problems"
    }
    hvis tool_window == "References" da {
        returner "References"
    }
    hvis tool_window == "Structure" da {
        returner "Structure"
    }
    hvis tool_window == "Terminal" da {
        returner "Terminal"
    }
    hvis tool_window == ui.studio_v2_ui_label_project() da {
        returner ui.studio_v2_ui_label_project()
    }
    hvis tool_window == ui.studio_v2_ui_label_editor() da {
        returner ui.studio_v2_ui_label_editor()
    }
    hvis tool_window == ui.studio_v2_ui_label_inspect() da {
        returner ui.studio_v2_ui_label_inspect()
    }
    returner "none"
}

funksjon studio_v2_gui_tool_window_tekst(tool_window: tekst) -> tekst {
    returner "Tool window: " + studio_v2_gui_tool_window_etikett(tool_window)
}

funksjon studio_v2_gui_fokus_knapp_tekst(navn: tekst, aktivt: tekst) -> tekst {
    hvis navn == aktivt da {
        returner "▶ " + navn
    }
    returner "· " + navn
}

funksjon studio_v2_gui_kompakt_visning(workspace_filer: liste_tekst, recent_projects: liste_tekst, diagnose: liste_tekst, referanser: liste_tekst, tabs: liste_tekst) -> bool {
    hvis lengde(workspace_filer) > 12 da {
        returner sann
    }
    hvis lengde(recent_projects) > 4 da {
        returner sann
    }
    hvis lengde(diagnose) > 6 da {
        returner sann
    }
    hvis lengde(referanser) > 6 da {
        returner sann
    }
    hvis lengde(tabs) > 5 da {
        returner sann
    }
    returner usann
}

funksjon studio_v2_gui_prosjekt_tre_maks_fra_filer(workspace_filer: liste_tekst) -> heltall {
    hvis lengde(workspace_filer) > 12 da {
        returner 4
    }
    returner 6
}

