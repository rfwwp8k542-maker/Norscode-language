funksjon studio_v2_gui_tool_window_status_widget(widget_id: heltall) -> heltall {
    hvis widget_id <= 0 da {
        returner 0
    }
    la rad: heltall = gui.foresatt(widget_id)
    hvis rad <= 0 da {
        returner 0
    }
    returner gui.barn(rad, 4)
}

funksjon studio_v2_gui_tool_window_sett(widget_id: heltall, tool_window: tekst) -> heltall {
    la status_widget: heltall = studio_v2_gui_tool_window_status_widget(widget_id)
    hvis status_widget > 0 da {
        gui.sett_tekst(status_widget, studio_v2_gui_tool_window_tekst(tool_window))
    }
    studio_v2_gui_session_lagre_tool_window(workspace.studio_v2_state_rot(argv()), tool_window)
    returner widget_id
}

