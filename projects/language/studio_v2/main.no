    la settings_keymap_liste: heltall = gui.liste(høyre)
    studio_v2_gui_liste_fyll(settings_keymap_liste, ui.studio_v2_ui_keymap_palett())
    studio_v2_gui_liste_sett(settings_keymap_liste, ui.studio_v2_ui_keymap_palett())
    hvis session_keymap != "" da {
        la settings_keymap_indeks: heltall = studio_v2_gui_liste_indeks_fra_valgt(ui.studio_v2_ui_keymap_palett(), session_keymap)
        hvis settings_keymap_indeks >= 0 da {
            gui.liste_velg(settings_keymap_liste, settings_keymap_indeks)
        }
    }
    gui.på_endring(settings_keymap_liste, "studio_v2_gui_innstillinger_keymap_valg")
    gui.på_tast(settings_keymap_liste, "enter", "studio_v2_gui_innstillinger_keymap_valg")
    la settings_runtime_liste: heltall = gui.liste(høyre)
    studio_v2_gui_liste_fyll(settings_runtime_liste, ui.studio_v2_ui_runtimevalg_palett())
    studio_v2_gui_liste_sett(settings_runtime_liste, ui.studio_v2_ui_runtimevalg_palett())
    hvis session_runtimevalg != "" da {
        la settings_runtime_indeks: heltall = studio_v2_gui_liste_indeks_fra_valgt(ui.studio_v2_ui_runtimevalg_palett(), session_runtimevalg)
        hvis settings_runtime_indeks >= 0 da {
            gui.liste_velg(settings_runtime_liste, settings_runtime_indeks)
        }
    }
    gui.på_endring(settings_runtime_liste, "studio_v2_gui_innstillinger_runtimevalg_valg")
    gui.på_tast(settings_runtime_liste, "enter", "studio_v2_gui_innstillinger_runtimevalg_valg")
    la settings_reset: heltall = gui.knapp(høyre, "Restore Defaults")
    gui.på_klikk(settings_reset, "studio_v2_gui_innstillinger_default")
    gui.tekst(høyre, "Theme, keymap and runtime are saved in the session")
    gui.tekst(høyre, ui.studio_v2_ui_panel_status_overskrift("⚠", ui.studio_v2_ui_label_problems(), "", "Count", tekst_fra_heltall(lengde(diagnose))))
    la diagnose_liste: heltall = gui.liste(høyre)
    studio_v2_gui_liste_fyll(diagnose_liste, studio_v2_gui_begrens_liste(studio_v2_gui_diagnostikk_linjer(diagnose), 4))
    gui.på_endring(diagnose_liste, "studio_v2_gui_oppdater_diagnostikkvalg")
    gui.på_tast(diagnose_liste, "enter", "studio_v2_gui_oppdater_diagnostikkvalg")
    gui.på_tast(diagnose_liste, "tab", "studio_v2_gui_liste_velg_neste")
    gui.på_tast(diagnose_liste, "down", "studio_v2_gui_liste_velg_neste")
    gui.på_tast(diagnose_liste, "shift+tab", "studio_v2_gui_liste_velg_forrige")
    gui.på_tast(diagnose_liste, "up", "studio_v2_gui_liste_velg_forrige")
    la diagnose_detalj: heltall = gui.tekst(høyre, "Velg en problemrad for detaljer")
    gui.tekst(høyre, ui.studio_v2_ui_status_chip("Problems", tekst_fra_heltall(lengde(diagnose))))
    gui.tekst(høyre, ui.studio_v2_ui_panel_status_overskrift("☰", ui.studio_v2_ui_label_structure(), "", "Refs", tekst_fra_heltall(lengde(symbol_referanser))))
    gui.tekst(høyre, ui.studio_v2_ui_structure_hint())
    gui.tekst(høyre, ui.studio_v2_ui_status_chip("References", tekst_fra_heltall(lengde(symbol_referanser))))
    la referanse_liste: heltall = gui.liste(høyre)
    studio_v2_gui_liste_fyll(referanse_liste, studio_v2_gui_begrens_liste(studio_v2_gui_referanse_linje(symbol_referanser, symbol_referanse_valg), 4))
    gui.på_endring(referanse_liste, "studio_v2_gui_oppdater_referansevalg")
    gui.på_tast(referanse_liste, "enter", "studio_v2_gui_oppdater_referansevalg")
    gui.på_tast(referanse_liste, "tab", "studio_v2_gui_liste_velg_neste")
    gui.på_tast(referanse_liste, "down", "studio_v2_gui_liste_velg_neste")
    gui.på_tast(referanse_liste, "shift+tab", "studio_v2_gui_liste_velg_forrige")
    gui.på_tast(referanse_liste, "up", "studio_v2_gui_liste_velg_forrige")
    la høyre_valgt_tekst: tekst = ""
    hvis ikke kompakt_visning da {
        høyre_valgt_tekst = ui.studio_v2_ui_aktiv_chip("Valgt", symbol_referanse_valg)
    }
    gui.tekst(høyre, høyre_valgt_tekst)
    la referanse_detalj: heltall = gui.tekst(høyre, "Velg en referanse for preview")
    gui.tekst(høyre, ui.studio_v2_ui_references_hint())
    gui.tekst(høyre, ui.studio_v2_ui_status_chip("Rename", tekst_fra_heltall(lengde(rename_preview))))
    la rename_liste: heltall = gui.liste(høyre)
    studio_v2_gui_liste_fyll(rename_liste, studio_v2_gui_begrens_liste(studio_v2_gui_rename_linje(rename_preview), 4))
    gui.på_endring(rename_liste, "studio_v2_gui_logg_rename")
    gui.på_tast(rename_liste, "enter", "studio_v2_gui_logg_rename")
    gui.på_tast(rename_liste, "tab", "studio_v2_gui_logg_rename")
    gui.på_tast(rename_liste, "down", "studio_v2_gui_liste_velg_neste")
    gui.på_tast(rename_liste, "shift+tab", "studio_v2_gui_liste_velg_forrige")
    gui.på_tast(rename_liste, "up", "studio_v2_gui_liste_velg_forrige")
    la høyre_rename_hint_tekst: tekst = ""
    la høyre_rename_apply_hint_tekst: tekst = ""
    hvis ikke kompakt_visning da {
        høyre_rename_hint_tekst = ui.studio_v2_ui_rename_hint()
        høyre_rename_apply_hint_tekst = ui.studio_v2_ui_rename_apply_hint()
    }
    gui.tekst(høyre, høyre_rename_hint_tekst)
    gui.tekst(høyre, høyre_rename_apply_hint_tekst)
    gui.tekst(høyre, "Rename from")
    la rename_from: heltall = gui.tekstfelt(høyre, "studio_v2")
    gui.tekst(høyre, "Rename to")
    la rename_to: heltall = gui.tekstfelt(høyre, "studio_v2_v2")
    la rename_apply: heltall = gui.knapp(høyre, "Apply Rename")
    la høyre_preview_tekst: tekst = ""
    hvis ikke kompakt_visning da {
        høyre_preview_tekst = ui.studio_v2_ui_status_chip("Preview", tekst_fra_heltall(lengde(rename_preview)))
    }
    gui.tekst(høyre, høyre_preview_tekst)
    gui.på_tast(rename_from, "enter", "studio_v2_gui_oppdater_rename_appliser")
    gui.på_tast(rename_to, "enter", "studio_v2_gui_oppdater_rename_appliser")
    gui.på_klikk(rename_apply, "studio_v2_gui_oppdater_rename_appliser")
    la tool_window_bar: heltall = gui.rad(rot_panel)
    la tool_window_problems: heltall = gui.knapp(tool_window_bar, studio_v2_gui_fokus_knapp_tekst("Problems", session_tool_window))
    la tool_window_references: heltall = gui.knapp(tool_window_bar, studio_v2_gui_fokus_knapp_tekst("References", session_tool_window))
    la tool_window_structure: heltall = gui.knapp(tool_window_bar, studio_v2_gui_fokus_knapp_tekst("Structure", session_tool_window))
    la tool_window_terminal: heltall = gui.knapp(tool_window_bar, studio_v2_gui_fokus_knapp_tekst("Terminal", session_tool_window))
    gui.tekst(tool_window_bar, studio_v2_gui_tool_window_tekst(session_tool_window))
    gui.på_klikk(tool_window_problems, "studio_v2_gui_tool_window_problems")
    gui.på_klikk(tool_window_references, "studio_v2_gui_tool_window_references")
    gui.på_klikk(tool_window_structure, "studio_v2_gui_tool_window_structure")
    gui.på_klikk(tool_window_terminal, "studio_v2_gui_tool_window_terminal")
    gui.på_tast(tool_window_bar, "tab", "studio_v2_gui_tool_window_neste_rot")
    gui.på_tast(tool_window_bar, "shift+tab", "studio_v2_gui_tool_window_forrige_rot")
    gui.tekst(tool_window_bar, ui.studio_v2_ui_tool_window_hint())
    gui.tekst(høyre, ui.studio_v2_ui_panel_status_overskrift("🛠", ui.studio_v2_ui_label_tools(), "", "Palette", tekst_fra_heltall(lengde(kommandopalett))))
    la høyre_palette_tekst: tekst = ""
    hvis ikke kompakt_visning da {
        høyre_palette_tekst = ui.studio_v2_ui_status_chip("Palette", tekst_fra_heltall(lengde(kommandopalett)))
    }
    gui.tekst(høyre, høyre_palette_tekst)
    gui.tekst(høyre, "Velg konfigurasjon i paletten under")
    la palette_panel: heltall = gui.panel(rot_panel)
    gui.tekst(palette_panel, ui.studio_v2_ui_panel_status_overskrift("⌕", ui.studio_v2_ui_label_command_palette(), "", "State", session_palette_open))
    gui.tekst(palette_panel, ui.studio_v2_ui_aktiv_chip("Config", session_run_config) + " · " + ui.studio_v2_ui_status_chip("State", session_palette_open))
    la palette_knapp_tekst: tekst = "Open Palette"
    hvis session_palette_open == "åpen" da {
        palette_knapp_tekst = "Close Palette"
    }
    la palette_knapp: heltall = gui.knapp(palette_panel, palette_knapp_tekst)
    gui.på_klikk(palette_knapp, "studio_v2_gui_toggle_palette")
    hvis session_palette_open == "åpen" da {
        la palette_query: heltall = gui.tekstfelt(palette_panel, "Filter commands")
        la palette_liste: heltall = gui.liste(palette_panel)
        gui.på_endring(palette_query, "studio_v2_gui_oppdater_palette_query")
        gui.på_endring(palette_liste, "studio_v2_gui_oppdater_palette")
        gui.på_tast(palette_query, "enter", "studio_v2_gui_oppdater_palette_fra_query")
        gui.på_tast(palette_query, "esc", "studio_v2_gui_snarvei_lukk_palette")
        gui.på_tast(palette_liste, "enter", "studio_v2_gui_oppdater_palette")
        gui.på_tast(palette_liste, "tab", "studio_v2_gui_liste_velg_neste")
        gui.på_tast(palette_liste, "down", "studio_v2_gui_liste_velg_neste")
        gui.på_tast(palette_liste, "shift+tab", "studio_v2_gui_liste_velg_forrige")
        gui.på_tast(palette_liste, "up", "studio_v2_gui_liste_velg_forrige")
        gui.tekst(palette_panel, ui.studio_v2_ui_palette_hint())
        studio_v2_gui_palette_panel_status(palette_panel, rot)
    } ellers {
        gui.tekst(palette_panel, ui.studio_v2_ui_palette_lukket_hint())
        studio_v2_gui_palette_panel_status(palette_panel, rot)
    }
    la bottom_tools: heltall = gui.panel(rot_panel)
    la bottom_row: heltall = gui.rad(bottom_tools)
    la bottom_problems: heltall = gui.panel(bottom_row)
    gui.tekst(bottom_problems, ui.studio_v2_ui_panel_status_overskrift("⚠", ui.studio_v2_ui_label_problems(), "", "Count", tekst_fra_heltall(lengde(diagnose))))
    gui.tekst(bottom_problems, ui.studio_v2_ui_brand_chip_linje())
    gui.tekst(bottom_problems, ui.studio_v2_ui_status_chip("Count", tekst_fra_heltall(lengde(diagnose))))
    la bottom_problems_list: heltall = gui.liste(bottom_problems)
    la bottom_problems_linjer: liste_tekst = studio_v2_gui_diagnostikk_linjer(diagnose)
    hvis lengde(bottom_problems_linjer) == 0 da {
        studio_v2_gui_liste_fyll(bottom_problems_list, [studio_v2_gui_diagnostikk_tomtilstand(diagnose)])
    } ellers {
        studio_v2_gui_liste_fyll(bottom_problems_list, studio_v2_gui_begrens_liste(bottom_problems_linjer, 4))
    }
    gui.på_endring(bottom_problems_list, "studio_v2_gui_oppdater_diagnostikkvalg")
    gui.på_tast(bottom_problems_list, "enter", "studio_v2_gui_oppdater_diagnostikkvalg")
    la bottom_problems_detalj: heltall = gui.tekst(bottom_problems, "Velg en problemrad for detaljer")
    gui.tekst(bottom_problems, ui.studio_v2_ui_problems_hint())
    la bottom_references: heltall = gui.panel(bottom_row)
    gui.tekst(bottom_references, ui.studio_v2_ui_panel_status_overskrift("↺", ui.studio_v2_ui_label_references(), "", "Count", tekst_fra_heltall(lengde(symbol_referanser))))
    gui.tekst(bottom_references, ui.studio_v2_ui_brand_chip_linje())
    gui.tekst(bottom_references, ui.studio_v2_ui_status_chip("Count", tekst_fra_heltall(lengde(symbol_referanser))))
    la bottom_references_list: heltall = gui.liste(bottom_references)
    studio_v2_gui_liste_fyll(bottom_references_list, studio_v2_gui_begrens_liste(studio_v2_gui_referanse_linje(symbol_referanser, symbol_referanse_valg), 4))
    gui.på_endring(bottom_references_list, "studio_v2_gui_oppdater_referansevalg")
    gui.på_tast(bottom_references_list, "enter", "studio_v2_gui_oppdater_referansevalg")
    gui.tekst(bottom_references, ui.studio_v2_ui_references_hint())
    la bottom_terminal: heltall = gui.panel(bottom_row)
    gui.tekst(bottom_terminal, ui.studio_v2_ui_panel_status_overskrift("▸", ui.studio_v2_ui_label_terminal(), "", "State", actions.studio_v2_actions_terminal_status(rot)))
    gui.tekst(bottom_terminal, ui.studio_v2_ui_brand_chip_linje())
    gui.tekst(bottom_terminal, ui.studio_v2_ui_aktiv_chip("State", actions.studio_v2_actions_terminal_status(rot)) + " · " + ui.studio_v2_ui_status_chip("Tool", session_tool_window))
    la bottom_terminal_list: heltall = gui.liste(bottom_terminal)
    studio_v2_gui_liste_fyll(bottom_terminal_list, studio_v2_gui_begrens_liste(terminal_kommandoer, 4))
    gui.på_tast(bottom_terminal_list, "enter", "studio_v2_gui_logg_kommando")
    gui.tekst(bottom_terminal, ui.studio_v2_ui_terminal_hint())
    la bunn: heltall = gui.panel(rot_panel)
    gui.tekst(bunn, ui.studio_v2_ui_seksjon_tittel("Ready") + " · " + ui.studio_v2_ui_status_chip("Session", session_status) + " · " + ui.studio_v2_ui_aktiv_chip("Tool", session_tool_window))
    gui.tekst(bunn, ui.studio_v2_ui_status_chip("Problems", tekst_fra_heltall(lengde(diagnose))) + " · " + ui.studio_v2_ui_status_chip("References", tekst_fra_heltall(lengde(symbol_referanser))) + " · " + ui.studio_v2_ui_aktiv_chip("Terminal", actions.studio_v2_actions_terminal_status(rot)))
    gui.vis(vindu_id)
    returner 0
}
