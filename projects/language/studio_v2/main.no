funksjon studio_v2_gui_oppdater_velkomst_recent_restore(widget_id: heltall) -> heltall {
    la recent_liste: heltall = studio_v2_gui_velkomst_recent_liste_widget(widget_id)
    la valgt: tekst = studio_v2_gui_recent_valg(gui.liste_valgt(recent_liste))
    hvis valgt == "" da {
        returner widget_id
    }
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(valgt)
    la aktiv_fil: tekst = workspace.studio_v2_state_aktiv_fil(valgt)
    la aktiv_tab: tekst = workspace.studio_v2_state_session_aktiv_tab(session_data)
    hvis aktiv_tab == "" da {
        aktiv_tab = aktiv_fil
    }
    la split_fokus: tekst = workspace.studio_v2_state_session_split_fokus(session_data)
    la tool_window: tekst = workspace.studio_v2_state_session_tool_window(session_data)
    la run_config: tekst = workspace.studio_v2_state_session_run_config(session_data)
    la palette_open: tekst = workspace.studio_v2_state_session_palette_status(session_data)
    la sist_navigasjon: tekst = workspace.studio_v2_state_session_sist_navigasjon(session_data)
    la tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data)
    workspace.studio_v2_state_session_lagre_med_tilstand(valgt, aktiv_fil, aktiv_tab, split_fokus, tool_window, run_config, palette_open, sist_navigasjon, tree_fold)
    la status_widget: heltall = studio_v2_gui_velkomst_recent_status_widget(recent_liste)
    gui.sett_tekst(status_widget, studio_v2_gui_velkomst_recent_åpnet_tekst(valgt))
    returner widget_id
}

funksjon studio_v2_gui_fokus_sett_fra_rot(widget_id: heltall, fokus: tekst) -> heltall {
    la fokus_rad: heltall = studio_v2_gui_rot_fokusrad_widget(widget_id)
    hvis fokus_rad > 0 da {
        la status_widget: heltall = gui.barn(fokus_rad, 4)
        hvis status_widget > 0 da {
            gui.sett_tekst(status_widget, studio_v2_gui_fokus_tekst(studio_v2_gui_fokus_etikett(fokus)))
        }
    }
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la aktiv_fil: tekst = workspace.studio_v2_state_aktiv_fil(rot)
    la aktiv_tab: tekst = workspace.studio_v2_state_session_aktiv_tab(session_data)
    hvis aktiv_tab == "" da {
        aktiv_tab = aktiv_fil
    }
    la split_fokus: tekst = workspace.studio_v2_state_session_split_fokus(session_data)
    la run_config: tekst = workspace.studio_v2_state_session_run_config(session_data)
    la palette_open: tekst = workspace.studio_v2_state_session_palette_status(session_data)
    la sist_navigasjon: tekst = workspace.studio_v2_state_session_sist_navigasjon(session_data)
    la tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data)
    studio_v2_gui_session_lagre_fokus(rot, fokus)
    returner widget_id
}

