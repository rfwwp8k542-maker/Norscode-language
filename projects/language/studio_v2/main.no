funksjon studio_v2_gui_recent_valg(tekstverdi: tekst) -> tekst {
    hvis tekst_starter_med(tekstverdi, "★ ") da {
        returner tekst_erstatt(tekstverdi, "★ ", "")
    }
    returner studio_v2_gui_markert_valg(tekstverdi)
}

funksjon studio_v2_gui_recent_tab_antall(prosjekt: tekst) -> heltall {
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(prosjekt)
    returner lengde(workspace.studio_v2_state_session_apne_filer(session_data))
}

funksjon studio_v2_gui_recent_linje_med_status(prosjekter: liste_tekst, aktiv_prosjekt: tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(prosjekter)) {
        la prosjekt: tekst = prosjekter[indeks]
        la markør: tekst = "· "
        hvis prosjekt == aktiv_prosjekt da {
            markør = "★ "
        }
        la status: tekst = workspace.studio_v2_state_session_status_for_workspace(prosjekt)
        la tab_antall: heltall = studio_v2_gui_recent_tab_antall(prosjekt)
        legg_til(resultat, markør + prosjekt + " · session " + status + " · tabs " + tekst_fra_heltall(tab_antall))
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_prosjekt_favoritt_linje(favoritter: liste_tekst, aktiv_fil: tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(favoritter)) {
        la fil: tekst = favoritter[indeks]
        hvis fil == aktiv_fil da {
            legg_til(resultat, "★ favorite · " + fil)
        } ellers {
            legg_til(resultat, "· favorite · " + fil)
        }
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_gui_prosjekt_quickaccess_linje(favoritter: liste_tekst, åpne_filer: liste_tekst, recent_projects: liste_tekst, aktiv_fil: tekst, aktiv_workspace: tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    legg_til(resultat, "[Favorites]")
    hvis lengde(favoritter) == 0 da {
        legg_til(resultat, ui.studio_v2_ui_tomt_favoritt())
    } ellers {
        la favoritter_linje: liste_tekst = studio_v2_gui_prosjekt_favoritt_linje(favoritter, aktiv_fil)
        la indeks: heltall = 0
        mens (indeks < lengde(favoritter_linje)) {
            legg_til(resultat, favoritter_linje[indeks])
            indeks = indeks + 1
        }
    }
    legg_til(resultat, "[Open Files]")
    hvis lengde(åpne_filer) == 0 da {
        legg_til(resultat, ui.studio_v2_ui_tomt_apne_filer())
    } ellers {
        la åpne_linje: liste_tekst = studio_v2_gui_fil_linje(åpne_filer, aktiv_fil)
        la indeks2: heltall = 0
        mens (indeks2 < lengde(åpne_linje)) {
            legg_til(resultat, åpne_linje[indeks2])
            indeks2 = indeks2 + 1
        }
    }
    legg_til(resultat, "[Recent Workspaces]")
    hvis lengde(recent_projects) == 0 da {
        legg_til(resultat, ui.studio_v2_ui_tomt_recent())
    } ellers {
        la recent_linje: liste_tekst = studio_v2_gui_recent_linje(recent_projects, aktiv_workspace)
        la indeks3: heltall = 0
        mens (indeks3 < lengde(recent_linje)) {
            legg_til(resultat, recent_linje[indeks3])
            indeks3 = indeks3 + 1
        }
    }
    returner resultat
}

funksjon studio_v2_gui_prosjekt_quickaccess_type(tekstverdi: tekst) -> tekst {
    la ren: tekst = studio_v2_gui_markert_valg(tekstverdi)
    hvis tekst_starter_med(ren, "favorite · ") da {
        returner "favorite"
    }
    hvis tekst_starter_med(ren, "open · ") da {
        returner "open"
    }
    hvis tekst_starter_med(ren, "recent · ") da {
        returner "recent"
    }
    returner ""
}

funksjon studio_v2_gui_prosjekt_quickaccess_valg(tekstverdi: tekst) -> tekst {
    la ren: tekst = studio_v2_gui_markert_valg(tekstverdi)
    hvis tekst_starter_med(ren, "favorite · ") da {
        returner tekst_erstatt(ren, "favorite · ", "")
    }
    hvis tekst_starter_med(ren, "open · ") da {
        returner tekst_erstatt(ren, "open · ", "")
    }
    hvis tekst_starter_med(ren, "recent · ") da {
        returner tekst_erstatt(ren, "recent · ", "")
    }
    returner ""
}

funksjon studio_v2_gui_prosjekt_quickaccess_status(widget_id: heltall) -> heltall {
    la panel: heltall = gui.foresatt(widget_id)
    returner gui.barn(panel, 22)
}

funksjon studio_v2_gui_oppdater_prosjekt_quickaccess(widget_id: heltall) -> heltall {
    la valgt: tekst = gui.liste_valgt(widget_id)
    la type: tekst = studio_v2_gui_prosjekt_quickaccess_type(valgt)
    la verdi: tekst = studio_v2_gui_prosjekt_quickaccess_valg(valgt)
    hvis type == "" eller verdi == "" da {
        returner widget_id
    }
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la rot_panel: heltall = studio_v2_gui_steg_opp(widget_id, 2)
    la venstre_panel: heltall = studio_v2_gui_hovedrad_venstre_widget(rot_panel)
    la midten: heltall = studio_v2_gui_hovedrad_midten_widget(rot_panel)
    la filer_liste: heltall = studio_v2_gui_venstre_filer_liste_widget(venstre_panel)
    la aktiv_tekst: heltall = studio_v2_gui_venstre_aktiv_tekst_widget(venstre_panel)
    la tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data)
    la workspace_filer: liste_tekst = workspace.studio_v2_state_workspace_filer(rot)
    hvis type == "recent" da {
        la session_restore: liste_tekst = workspace.studio_v2_state_session_les(verdi)
        la aktiv_fil_restore: tekst = workspace.studio_v2_state_aktiv_fil(verdi)
        la aktiv_tab_restore: tekst = workspace.studio_v2_state_session_aktiv_tab(session_restore)
        hvis aktiv_tab_restore == "" da {
            aktiv_tab_restore = aktiv_fil_restore
        }
        la split_fokus_restore: tekst = workspace.studio_v2_state_session_split_fokus(session_restore)
        la tool_window_restore: tekst = workspace.studio_v2_state_session_tool_window(session_restore)
        la run_config_restore: tekst = workspace.studio_v2_state_session_run_config(session_restore)
        la palette_open_restore: tekst = workspace.studio_v2_state_session_palette_status(session_restore)
        la sist_navigasjon_restore: tekst = workspace.studio_v2_state_session_sist_navigasjon(session_restore)
        la tree_fold_restore: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_restore)
        workspace.studio_v2_state_session_project_tree_anchor_skriv_med_tilstand(verdi, workspace.studio_v2_state_session_project_tree_anchor(session_restore))
        workspace.studio_v2_state_session_lagre_med_tilstand(verdi, aktiv_fil_restore, aktiv_tab_restore, split_fokus_restore, tool_window_restore, run_config_restore, palette_open_restore, sist_navigasjon_restore, tree_fold_restore)
        gui.sett_tekst(aktiv_tekst, ui.studio_v2_ui_status_chip("Aktiv", aktiv_fil_restore))
        studio_v2_gui_liste_sett(filer_liste, studio_v2_gui_begrens_liste_med_anker(studio_v2_gui_prosjekt_tre(workspace.studio_v2_state_workspace_filer(verdi), aktiv_fil_restore, tree_fold_restore), studio_v2_gui_prosjekt_tre_maks_fra_filer(workspace.studio_v2_state_workspace_filer(verdi)), aktiv_fil_restore))
        studio_v2_gui_oppdater_editor(midten, verdi, aktiv_fil_restore, 1)
        returner widget_id
    }
    hvis type == "favorite" eller type == "open" da {
        workspace.studio_v2_state_session_project_tree_anchor_skriv_med_tilstand(rot, verdi)
        la apne_filer: liste_tekst = workspace.studio_v2_state_apne_filer(rot, verdi)
        la tabs: liste_tekst = editor.studio_v2_editor_tabs_fra_apne_filer(apne_filer)
        la aktiv_tab: tekst = editor.studio_v2_editor_tab_nåværende(tabs, verdi)
        hvis aktiv_tab == "" da {
            aktiv_tab = verdi
        }
        workspace.studio_v2_state_session_lagre_med_tilstand(rot, verdi, aktiv_tab, workspace.studio_v2_state_session_split_fokus(session_data), workspace.studio_v2_state_session_tool_window(session_data), workspace.studio_v2_state_session_run_config(session_data), workspace.studio_v2_state_session_palette_status(session_data), verdi, tree_fold)
        gui.sett_tekst(aktiv_tekst, ui.studio_v2_ui_status_chip("Aktiv", verdi))
        studio_v2_gui_liste_sett(filer_liste, studio_v2_gui_begrens_liste_med_anker(studio_v2_gui_prosjekt_tre(workspace_filer, verdi, tree_fold), studio_v2_gui_prosjekt_tre_maks_fra_filer(workspace_filer), verdi))
        studio_v2_gui_oppdater_editor(midten, rot, verdi, 1)
        returner widget_id
    }
    returner widget_id
}

funksjon studio_v2_gui_oppdater_prosjekt_favoritt_toggle(widget_id: heltall) -> heltall {
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la aktiv_fil: tekst = workspace.studio_v2_state_aktiv_fil(rot)
    hvis aktiv_fil == "" da {
        aktiv_fil = workspace.studio_v2_state_session_aktiv_fil(session_data)
    }
    hvis aktiv_fil == "" da {
        returner widget_id
    }
    workspace.studio_v2_state_session_favoritter_skriv_med_tilstand(rot, aktiv_fil)
    la status_widget: heltall = studio_v2_gui_prosjekt_quickaccess_status(widget_id)
    la session_oppdatert: liste_tekst = workspace.studio_v2_state_session_les(rot)
    gui.sett_tekst(status_widget, ui.studio_v2_ui_status_chip("Favorites", tekst_fra_heltall(lengde(workspace.studio_v2_state_session_favoritter(session_oppdatert)))) + " · " + ui.studio_v2_ui_status_chip("Open", tekst_fra_heltall(lengde(workspace.studio_v2_state_apne_filer(rot, aktiv_fil)))) + " · " + ui.studio_v2_ui_status_chip("Recent", tekst_fra_heltall(lengde(workspace.studio_v2_state_session_recent_for_workspace(rot)))))
    returner widget_id
}

