funksjon studio_v2_gui_vcs_status_valg(widget_id: heltall) -> heltall {
    la venstre_panel: heltall = gui.foresatt(widget_id)
    la detaljer: heltall = gui.barn(venstre_panel, 4)
    la rot_panel: heltall = studio_v2_gui_steg_opp(widget_id, 2)
    la midten: heltall = studio_v2_gui_hovedrad_midten_widget(rot_panel)
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la valgt: tekst = gui.liste_valgt(widget_id)
    la filsti: tekst = studio_v2_gui_vcs_fil_fra_statuslinje(valgt)
    hvis filsti == "" da {
        returner widget_id
    }
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data)
    la workspace_filer: liste_tekst = workspace.studio_v2_state_workspace_filer(rot)
    la apne_filer: liste_tekst = workspace.studio_v2_state_apne_filer(rot, filsti)
    la tabs: liste_tekst = editor.studio_v2_editor_tabs_fra_apne_filer(apne_filer)
    la aktiv_tab: tekst = editor.studio_v2_editor_tab_nåværende(tabs, filsti)
    la linje: heltall = 1
    gui.sett_tekst(detaljer, "VCS: " + filsti)
    studio_v2_gui_liste_sett(studio_v2_gui_venstre_filer_liste_widget(venstre_panel), studio_v2_gui_begrens_liste_med_anker(studio_v2_gui_prosjekt_tre(workspace_filer, filsti, tree_fold), studio_v2_gui_prosjekt_tre_maks_fra_filer(workspace_filer), filsti))
    studio_v2_gui_liste_sett(studio_v2_gui_midten_tabs_liste_widget(midten), studio_v2_gui_tab_linje(tabs, filsti))
    workspace.studio_v2_state_session_lagre_med_tilstand(rot, filsti, aktiv_tab, workspace.studio_v2_state_session_split_fokus(session_data), workspace.studio_v2_state_session_tool_window(session_data), workspace.studio_v2_state_session_run_config(session_data), workspace.studio_v2_state_session_palette_status(session_data), filsti, tree_fold)
    studio_v2_gui_oppdater_editor(midten, rot, filsti, linje)
    returner widget_id
}

funksjon studio_v2_gui_output_panel_widget(widget_id: heltall) -> heltall {
    la run_panel: heltall = studio_v2_gui_steg_opp(widget_id, 2)
    returner gui.barn(run_panel, 11)
}

funksjon studio_v2_gui_output_panel_status(run_panel: heltall, rot: tekst) -> heltall {
    hvis run_panel <= 0 da {
        returner run_panel
    }
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la output_panel: heltall = gui.barn(run_panel, 11)
    hvis output_panel <= 0 da {
        returner run_panel
    }
    la output_summary_widget: heltall = gui.barn(output_panel, 1)
    la output_query_widget: heltall = gui.barn(output_panel, 4)
    la output_query_status_widget: heltall = gui.barn(output_panel, 5)
    la output_stdout_widget: heltall = gui.barn(output_panel, 7)
    la output_stderr_widget: heltall = gui.barn(output_panel, 9)
    la stdout_linjer: liste_tekst = workspace.studio_v2_state_session_output_stdout(session_data)
    la stderr_linjer: liste_tekst = workspace.studio_v2_state_session_output_stderr(session_data)
    la output_config: tekst = workspace.studio_v2_state_session_output_config(session_data)
    la test_history: tekst = workspace.studio_v2_state_session_test_history_siste(session_data)
    la query: tekst = ""
    hvis output_query_widget > 0 da {
        query = gui.hent_tekst(output_query_widget)
    }
    la stdout_filtrert: liste_tekst = studio_v2_gui_output_filtrer_linjer(stdout_linjer, query)
    la stderr_filtrert: liste_tekst = studio_v2_gui_output_filtrer_linjer(stderr_linjer, query)
    hvis output_config == "" da {
        output_config = workspace.studio_v2_state_session_run_config(session_data)
    }
    hvis output_config == "" da {
        output_config = "run"
    }
    hvis lengde(stdout_filtrert) == 0 da {
        stdout_filtrert = [ui.studio_v2_ui_tomt_stdout()]
    }
    hvis lengde(stderr_filtrert) == 0 da {
        stderr_filtrert = [ui.studio_v2_ui_tomt_stderr()]
    }
    hvis test_history == "" da {
        test_history = ui.studio_v2_ui_run_history_hint()
    }
    studio_v2_gui_sett_tekst_sikkert(output_summary_widget, ui.studio_v2_ui_status_chip("Config", output_config) + " · " + ui.studio_v2_ui_status_chip("Command", workspace.studio_v2_state_session_output_command(session_data)) + " · " + ui.studio_v2_ui_status_chip("History", test_history))
    studio_v2_gui_sett_tekst_sikkert(output_query_status_widget, studio_v2_gui_output_filter_status(query, lengde(stdout_filtrert), lengde(stderr_filtrert)))
    studio_v2_gui_liste_sett(output_stdout_widget, stdout_filtrert)
    studio_v2_gui_liste_sett(output_stderr_widget, stderr_filtrert)
    returner run_panel
}

funksjon studio_v2_gui_oppdater_output(widget_id: heltall) -> heltall {
    la output_panel: heltall = gui.foresatt(widget_id)
    hvis output_panel <= 0 da {
        returner widget_id
    }
    la run_panel: heltall = gui.foresatt(output_panel)
    hvis run_panel <= 0 da {
        returner widget_id
    }
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    studio_v2_gui_output_panel_status(run_panel, rot)
    returner widget_id
}

funksjon studio_v2_gui_kommando_status_widget(widget_id: heltall) -> heltall {
    la run_panel: heltall = studio_v2_gui_steg_opp(widget_id, 2)
    returner gui.barn(run_panel, 7)
}

funksjon studio_v2_gui_kommando_output_widget(widget_id: heltall) -> heltall {
    la run_panel: heltall = studio_v2_gui_steg_opp(widget_id, 2)
    returner gui.barn(run_panel, 8)
}

funksjon studio_v2_gui_kjor_handling_fra_knapp(widget_id: heltall, navn: tekst) -> heltall {
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la status_widget: heltall = studio_v2_gui_kommando_status_widget(widget_id)
    la output_widget: heltall = studio_v2_gui_kommando_output_widget(widget_id)
    la run_panel: heltall = studio_v2_gui_steg_opp(widget_id, 2)
    la resultat: tekst = studio_v2_gui_kjor_handling_rot(rot, navn)
    la session_data_ny: liste_tekst = workspace.studio_v2_state_session_les(rot)
    studio_v2_gui_sett_tekst_sikkert(status_widget, "Kommando status: " + resultat)
    studio_v2_gui_sett_tekst_sikkert(output_widget, "Output: " + workspace.studio_v2_state_session_output_sammendrag(session_data_ny))
    studio_v2_gui_output_panel_status(run_panel, rot)
    skriv(resultat)
    returner widget_id
}

funksjon studio_v2_gui_kjor_handling_fra_liste(widget_id: heltall, navn: tekst) -> heltall {
    la run_panel: heltall = gui.foresatt(widget_id)
    la status_widget: heltall = gui.barn(run_panel, 7)
    la output_widget: heltall = gui.barn(run_panel, 8)
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la resultat: tekst = studio_v2_gui_kjor_handling_rot(rot, navn)
    la session_data_ny: liste_tekst = workspace.studio_v2_state_session_les(rot)
    studio_v2_gui_sett_tekst_sikkert(status_widget, "Kommando status: " + resultat)
    studio_v2_gui_sett_tekst_sikkert(output_widget, "Output: " + workspace.studio_v2_state_session_output_sammendrag(session_data_ny))
    studio_v2_gui_output_panel_status(run_panel, rot)
    skriv(resultat)
    returner widget_id
}

funksjon studio_v2_gui_kjor_run_liste(widget_id: heltall) -> heltall {
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la run_config: tekst = workspace.studio_v2_state_session_run_config(session_data)
    hvis run_config == "" da {
        run_config = "run"
    }
    returner studio_v2_gui_kjor_handling_fra_liste(widget_id, run_config)
}

funksjon studio_v2_gui_kjor_run_knapp(widget_id: heltall) -> heltall {
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la run_config: tekst = workspace.studio_v2_state_session_run_config(session_data)
    hvis run_config == "" da {
        run_config = "run"
    }
    returner studio_v2_gui_kjor_handling_fra_knapp(widget_id, run_config)
}

funksjon studio_v2_gui_kjor_run_velkomst(widget_id: heltall) -> heltall {
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la run_config: tekst = workspace.studio_v2_state_session_run_config(session_data)
    hvis run_config == "" da {
        run_config = "run"
    }
    studio_v2_gui_kjor_handling_rot(rot, run_config)
    returner widget_id
}

funksjon studio_v2_gui_kjor_check(widget_id: heltall) -> heltall {
    returner studio_v2_gui_kjor_handling_fra_knapp(widget_id, "check")
}

funksjon studio_v2_gui_kjor_test(widget_id: heltall) -> heltall {
    returner studio_v2_gui_kjor_handling_fra_knapp(widget_id, "test")
}

funksjon studio_v2_gui_kjor_runtime_ci(widget_id: heltall) -> heltall {
    returner studio_v2_gui_kjor_handling_fra_knapp(widget_id, "runtime-ci")
}

funksjon studio_v2_gui_kjor_technical_guide(widget_id: heltall) -> heltall {
    returner studio_v2_gui_kjor_handling_fra_knapp(widget_id, "technical-guide")
}

funksjon studio_v2_gui_kjor_debug(widget_id: heltall) -> heltall {
    la rot: tekst = workspace.studio_v2_state_rot(argv())
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la run_config: tekst = workspace.studio_v2_state_session_run_config(session_data)
    hvis run_config == "" da {
        run_config = "run"
    }
    workspace.studio_v2_state_session_debug_skriv_med_tilstand(rot, run_config, "paused", "debug", 1)
    returner studio_v2_gui_kjor_handling_fra_knapp(widget_id, "debug")
}

funksjon start() -> heltall {
    la args: liste_tekst = argv()
    la rot: tekst = workspace.studio_v2_state_rot(args)
    la workspace_filer: liste_tekst = workspace.studio_v2_state_workspace_filer(rot)
    la aktiv_fil: tekst = workspace.studio_v2_state_aktiv_fil(rot)
    la recent_projects: liste_tekst = workspace.studio_v2_state_session_recent_for_workspace(rot)
    la session_data: liste_tekst = workspace.studio_v2_state_session_les(rot)
    la aktiv_node: tekst = studio_v2_gui_prosjekt_aktiv_node(rot, session_data, aktiv_fil)
    la aktiv_innhold: tekst = workspace.studio_v2_state_fil_innhold(rot, aktiv_fil)
    la session_status: tekst = workspace.studio_v2_state_session_status(rot)
    la session_aktiv_tab: tekst = workspace.studio_v2_state_session_aktiv_tab(session_data)
    la session_split_fokus: tekst = workspace.studio_v2_state_session_split_fokus(session_data)
    la session_tool_window: tekst = workspace.studio_v2_state_session_tool_window(session_data)
    la session_run_config: tekst = workspace.studio_v2_state_session_run_config(session_data)
    la session_tema: tekst = workspace.studio_v2_state_session_tema(session_data)
    la session_keymap: tekst = workspace.studio_v2_state_session_keymap(session_data)
    la session_runtimevalg: tekst = workspace.studio_v2_state_session_runtimevalg(session_data)
    la session_palette_open: tekst = workspace.studio_v2_state_session_palette_status(session_data)
    la session_sist_navigasjon: tekst = workspace.studio_v2_state_session_sist_navigasjon(session_data)
    la session_search_query: tekst = workspace.studio_v2_state_session_search_query(session_data)
    la session_tree_fold: liste_tekst = workspace.studio_v2_state_session_tree_fold(session_data)
    la apne_filer: liste_tekst = workspace.studio_v2_state_apne_filer(rot, aktiv_fil)
    la tabs: liste_tekst = editor.studio_v2_editor_tabs_fra_apne_filer(apne_filer)
    la aktiv_tab: tekst = aktiv_fil
    hvis session_sist_navigasjon != "" og editor.studio_v2_editor_tab_indeks(tabs, session_sist_navigasjon) >= 0 da {
        aktiv_tab = session_sist_navigasjon
    } ellers hvis session_aktiv_tab != "" og editor.studio_v2_editor_tab_indeks(tabs, session_aktiv_tab) >= 0 da {
        aktiv_tab = session_aktiv_tab
    } ellers hvis editor.studio_v2_editor_tab_indeks(tabs, aktiv_fil) >= 0 da {
        aktiv_tab = aktiv_fil
    } ellers hvis lengde(tabs) > 0 da {
        aktiv_tab = tabs[0]
    }
    la neste_tab: tekst = editor.studio_v2_editor_tab_neste(tabs, aktiv_tab)
    la forrige_tab: tekst = editor.studio_v2_editor_tab_forrige(tabs, aktiv_tab)
    la høyre_fokus: tekst = session_split_fokus
    hvis høyre_fokus == "" da {
        høyre_fokus = "høyre"
    }
    workspace.studio_v2_state_session_lagre_med_tilstand(rot, aktiv_fil, aktiv_tab, høyre_fokus, session_tool_window, session_run_config, session_palette_open, session_sist_navigasjon, session_tree_fold)
    la buffer: liste_tekst = editor.studio_v2_editor_åpne(aktiv_innhold)
    la cursor: liste_tekst = editor.studio_v2_cursor_med_posisjon(1, 1)
    la goto_linje_preview: liste_tekst = editor.studio_v2_editor_goto_linje(buffer, 2)
    la symbol_def: tekst = editor.studio_v2_editor_goto_symbol(rot, "studio_v2")
    la symbol_referanser: liste_tekst = editor.studio_v2_editor_referanser(rot, "studio_v2")
    la symbol_referanse_valg: tekst = editor.studio_v2_editor_referanse_valg(rot, "studio_v2", 0)
    la rename_preview: liste_tekst = editor.studio_v2_editor_rename_preview(rot, "studio_v2", "studio_v2_v2")
    la session_breakpoints: liste_tekst = workspace.studio_v2_state_session_breakpoints_for_fil(session_data, aktiv_fil)
    la kommandopalett: liste_tekst = actions.studio_v2_actions_palett()
    la terminal_kommandoer: liste_tekst = actions.studio_v2_actions_terminal(rot, aktiv_fil, session_run_config)
    la diagnose: liste_tekst = [
        "workspace\tNorscode Studio v2\t" + rot,
        "aktivitetsfil\t" + aktiv_fil,
        "åpne_filer\t" + tekst_fra_heltall(lengde(apne_filer)),
        "workspace_filer\t" + tekst_fra_heltall(lengde(workspace_filer)),
        "recent_projects\t" + tekst_fra_heltall(lengde(recent_projects)),
        "symboler\tklar",
        "status\tklar",
        "oppdatering\tinkrementell"
    ]
    la kompakt_visning: bool = studio_v2_gui_kompakt_visning(workspace_filer, recent_projects, diagnose, symbol_referanser, tabs)
    la ui_tema: tekst = session_tema
    skriv(ui.studio_v2_ui_shell())
    skriv("Prosjekt: " + project.studio_v2_prosjektnavn() + " · Workspace: " + rot)
    skriv("Aktiv fil: " + aktiv_fil + " · Tab: " + aktiv_tab + " · Fokus: " + høyre_fokus + " · Tool: " + session_tool_window)
    skriv("Status: " + actions.studio_v2_actions_status(rot) + " · Diagnostikk: " + diagnostics.studio_v2_diagnostics_oppdater_status(rot))

    la vindu_id: heltall = gui.vindu("Norscode Studio v2")
    la rot_panel: heltall = gui.panel(vindu_id)
    la header: heltall = gui.rad(rot_panel)
    gui.tekst(header, ui.studio_v2_ui_logo_banner())
    gui.tekst(header, ui.studio_v2_ui_logo_tagline() + " · " + ui.studio_v2_ui_seksjon_tittel("Norscode Studio v2"))
    gui.tekst(header, ui.studio_v2_ui_brand_chip_linje())
    gui.tekst(header, ui.studio_v2_ui_status_chip("Project", project.studio_v2_prosjektnavn()) + " · " + ui.studio_v2_ui_status_chip("Workspace", rot))
    gui.tekst(header, ui.studio_v2_ui_status_chip("Session", session_status) + " · " + ui.studio_v2_ui_status_chip("Tabs", tekst_fra_heltall(lengde(tabs))) + " · " + ui.studio_v2_ui_status_chip("Tool", session_tool_window))
    la velkomst_panel: heltall = gui.panel(rot_panel)
    gui.tekst(velkomst_panel, ui.studio_v2_ui_panel_status_overskrift("✦", ui.studio_v2_ui_label_welcome(), "", "Open", tekst_fra_heltall(lengde(apne_filer))))
    gui.tekst(velkomst_panel, ui.studio_v2_ui_logo_banner())
    gui.tekst(velkomst_panel, ui.studio_v2_ui_brand_chip_linje())
    gui.tekst(velkomst_panel, ui.studio_v2_ui_velkomst_undertittel(rot, session_status))
    gui.tekst(velkomst_panel, ui.studio_v2_ui_velkomst_oversikt())
    gui.tekst(velkomst_panel, ui.studio_v2_ui_status_chip("Actions", tekst_fra_heltall(lengde(ui.studio_v2_ui_velkomst_handlinger()))) + " · " + ui.studio_v2_ui_status_chip("Open", tekst_fra_heltall(lengde(apne_filer))))
    la velkomst_handlinger: heltall = gui.rad(velkomst_panel)
    la velkomst_project: heltall = gui.knapp(velkomst_handlinger, ui.studio_v2_ui_label_project())
    la velkomst_editor: heltall = gui.knapp(velkomst_handlinger, ui.studio_v2_ui_label_editor())
    la velkomst_inspect: heltall = gui.knapp(velkomst_handlinger, ui.studio_v2_ui_label_inspect())
    la velkomst_palette: heltall = gui.knapp(velkomst_handlinger, ui.studio_v2_ui_label_palette())
    la velkomst_run: heltall = gui.knapp(velkomst_handlinger, ui.studio_v2_ui_label_run())
    gui.på_klikk(velkomst_project, "studio_v2_gui_snarvei_project")
    gui.på_klikk(velkomst_editor, "studio_v2_gui_snarvei_editor")
    gui.på_klikk(velkomst_inspect, "studio_v2_gui_snarvei_inspect")
    gui.på_klikk(velkomst_palette, "studio_v2_gui_snarvei_palette")
    gui.på_klikk(velkomst_run, "studio_v2_gui_kjor_run_velkomst")
    gui.tekst(velkomst_panel, ui.studio_v2_ui_velkomst_recent_tittel())
    gui.tekst(velkomst_panel, ui.studio_v2_ui_velkomst_recent_sammendrag(rot, lengde(recent_projects)))
    gui.tekst(velkomst_panel, ui.studio_v2_ui_velkomst_recent_current(rot))
    gui.tekst(velkomst_panel, ui.studio_v2_ui_velkomst_recent_hint())
    la velkomst_recent_actions_tekst: tekst = ""
    hvis ikke kompakt_visning da {
        velkomst_recent_actions_tekst = ui.studio_v2_ui_velkomst_recent_actions()
    }
    gui.tekst(velkomst_panel, velkomst_recent_actions_tekst)
    gui.tekst(velkomst_panel, ui.studio_v2_ui_status_chip("Restore target", rot) + " · " + ui.studio_v2_ui_status_chip("Ready", actions.studio_v2_actions_status(rot)))
    la velkomst_recent_restore_status_tekst: tekst = ""
    la velkomst_recent_shortcut_tekst: tekst = ""
    hvis ikke kompakt_visning da {
        velkomst_recent_restore_status_tekst = ui.studio_v2_ui_velkomst_recent_restore_status()
        velkomst_recent_shortcut_tekst = ui.studio_v2_ui_velkomst_recent_shortcut()
    }
    gui.tekst(velkomst_panel, velkomst_recent_restore_status_tekst)
    gui.tekst(velkomst_panel, velkomst_recent_shortcut_tekst)
    la velkomst_recent_liste: heltall = gui.liste(velkomst_panel)
    studio_v2_gui_liste_fyll(velkomst_recent_liste, studio_v2_gui_begrens_liste(studio_v2_gui_recent_linje_med_status(recent_projects, rot), 4))
    gui.på_endring(velkomst_recent_liste, "studio_v2_gui_oppdater_velkomst_recent_restore")
    gui.på_tast(velkomst_recent_liste, "enter", "studio_v2_gui_oppdater_velkomst_recent_restore")
    la velkomst_recent_restore: heltall = gui.knapp(velkomst_panel, "Restore Selected Recent")
    gui.på_klikk(velkomst_recent_restore, "studio_v2_gui_oppdater_velkomst_recent_restore")
    la run_panel: heltall = gui.panel(rot_panel)
    gui.tekst(run_panel, ui.studio_v2_ui_panel_status_overskrift("⚙", ui.studio_v2_ui_label_run(), "Configuration + actions", "Config", session_run_config))
    gui.tekst(run_panel, ui.studio_v2_ui_brand_chip_linje())
    la run_config_liste: heltall = gui.liste(run_panel)
    studio_v2_gui_liste_fyll(run_config_liste, studio_v2_gui_run_config_linje(actions.studio_v2_actions_run_konfigurasjoner(), session_run_config))
    gui.på_endring(run_config_liste, "studio_v2_gui_oppdater_run_config")
    gui.på_tast(run_config_liste, "enter", "studio_v2_gui_kjor_run_liste")
    gui.tekst(run_panel, ui.studio_v2_ui_status_chip("Target", aktiv_fil) + " · " + ui.studio_v2_ui_status_chip("Workdir", workspace.studio_v2_state_session_run_profile_cwd(session_data, session_run_config, rot)) + " · " + ui.studio_v2_ui_status_chip("Args", workspace.studio_v2_state_session_run_profile_args(session_data, session_run_config)) + " · " + ui.studio_v2_ui_status_chip("Env", workspace.studio_v2_state_session_run_profile_env(session_data, session_run_config)))
    gui.tekst(run_panel, ui.studio_v2_ui_status_chip("Profile", workspace.studio_v2_state_session_run_profile_sammendrag(session_data, session_run_config, rot)))
    la kommandolinje: heltall = gui.rad(run_panel)
    la run_knapp: heltall = gui.knapp(kommandolinje, ui.studio_v2_ui_label_run())
    la check_knapp: heltall = gui.knapp(kommandolinje, "Check")
    la test_knapp: heltall = gui.knapp(kommandolinje, "Test")
    la debug_knapp: heltall = gui.knapp(kommandolinje, "Debug")
    la runtime_ci_knapp: heltall = gui.knapp(kommandolinje, "CI")
    la guide_knapp: heltall = gui.knapp(kommandolinje, ui.studio_v2_ui_label_troubleshooting_guide())
    gui.tekst(kommandolinje, ui.studio_v2_ui_status_chip("Run", actions.studio_v2_actions_status(rot)) + " · " + ui.studio_v2_ui_status_chip("Config", session_run_config) + " · " + ui.studio_v2_ui_status_chip("Tool", session_tool_window))
    gui.på_klikk(run_knapp, "studio_v2_gui_kjor_run_knapp")
    gui.på_klikk(check_knapp, "studio_v2_gui_kjor_check")
    gui.på_klikk(test_knapp, "studio_v2_gui_kjor_test")
