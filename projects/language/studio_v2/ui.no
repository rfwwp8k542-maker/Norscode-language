# Studio v2 UI foundation.

funksjon studio_v2_ui_shell() -> tekst {
    returner "studio shell"
}

funksjon studio_v2_ui_stil_spacing() -> tekst {
    returner "compact"
}

funksjon studio_v2_ui_stil_titler() -> tekst {
    returner "panel-status-header"
}

funksjon studio_v2_ui_stil_chip() -> tekst {
    returner "status+active"
}

funksjon studio_v2_ui_stil_ikon() -> tekst {
    returner "unicode-icons"
}

funksjon studio_v2_ui_stil_tekst() -> tekst {
    returner "title/subtitle/metadata"
}

funksjon studio_v2_ui_stilguide() -> liste_tekst {
    returner [
        "spacing\t" + studio_v2_ui_stil_spacing(),
        "titles\t" + studio_v2_ui_stil_titler(),
        "chips\t" + studio_v2_ui_stil_chip(),
        "icons\t" + studio_v2_ui_stil_ikon(),
        "text\t" + studio_v2_ui_stil_tekst()
    ]
}

