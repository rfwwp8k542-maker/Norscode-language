funksjon studio_v2_ui_status() -> tekst {
    returner "klar"
}

funksjon studio_v2_ui_tema_lys() -> tekst {
    returner "lys"
}

funksjon studio_v2_ui_tema_mork() -> tekst {
    returner "mørk"
}

funksjon studio_v2_ui_tema_standard() -> tekst {
    returner studio_v2_ui_tema_mork()
}

funksjon studio_v2_ui_tema_status(tema: tekst) -> tekst {
    hvis tema == studio_v2_ui_tema_lys() da {
        returner "aktivt"
    }
    hvis tema == studio_v2_ui_tema_mork() da {
        returner "aktivt"
    }
    returner "ukjent"
}

funksjon studio_v2_ui_tema_palett() -> liste_tekst {
    returner [studio_v2_ui_tema_lys(), studio_v2_ui_tema_mork()]
}

funksjon studio_v2_ui_keymap_standard() -> tekst {
    returner "standard"
}

funksjon studio_v2_ui_keymap_vim() -> tekst {
    returner "vim"
}

funksjon studio_v2_ui_keymap_palett() -> liste_tekst {
    returner [studio_v2_ui_keymap_standard(), studio_v2_ui_keymap_vim()]
}

funksjon studio_v2_ui_runtimevalg_run() -> tekst {
    returner "run"
}

funksjon studio_v2_ui_runtimevalg_check() -> tekst {
    returner "check"
}

funksjon studio_v2_ui_runtimevalg_test() -> tekst {
    returner "test"
}

funksjon studio_v2_ui_runtimevalg_palett() -> liste_tekst {
    returner [studio_v2_ui_runtimevalg_run(), studio_v2_ui_runtimevalg_check(), studio_v2_ui_runtimevalg_test()]
}

funksjon studio_v2_ui_tema_fra_navn(navn: tekst) -> tekst {
    hvis navn == "lys" da {
        returner studio_v2_ui_tema_lys()
    }
    hvis navn == "mørk" eller navn == "mork" da {
        returner studio_v2_ui_tema_mork()
    }
    returner studio_v2_ui_tema_standard()
}

funksjon studio_v2_ui_snarveier() -> liste_tekst {
    returner [
        "Ctrl+O\tåpne",
        "Ctrl+S\tlagre",
        "Ctrl+Enter\tkjør",
        "Ctrl+Shift+C\tcheck",
        "Ctrl+P\tpalett",
        "Ctrl+4\tProblems",
        "Ctrl+5\tReferences",
        "Ctrl+6\tStructure",
        "Ctrl+7\tTerminal",
        "Ctrl+1\tProject",
        "Ctrl+2\tEditor",
        "Ctrl+3\tInspect",
        "Esc\tlukk palette"
    ]
}

funksjon studio_v2_ui_snarvei_forste() -> tekst {
    returner "Ctrl+O\tåpne"
}

funksjon studio_v2_ui_snarveier_status() -> tekst {
    returner "klar"
}

funksjon studio_v2_ui_seksjon_tittel(navn: tekst) -> tekst {
    returner "[" + navn + "]"
}

funksjon studio_v2_ui_panel_overskrift(navn: tekst, undertittel: tekst) -> tekst {
    hvis undertittel == "" da {
        returner "=== " + navn + " ==="
    }
    returner "=== " + navn + " === " + undertittel
}

funksjon studio_v2_ui_panel_ikon_overskrift(ikon: tekst, navn: tekst, undertittel: tekst) -> tekst {
    la grunn: tekst = ikon + " " + navn
    hvis undertittel == "" da {
        returner "=== " + grunn + " ==="
    }
    returner "=== " + grunn + " === " + undertittel
}

funksjon studio_v2_ui_panel_status_overskrift(ikon: tekst, navn: tekst, undertittel: tekst, status_navn: tekst, status_verdi: tekst) -> tekst {
    hvis undertittel == "" da {
        returner studio_v2_ui_panel_ikon_overskrift(ikon, navn, "") + " " + studio_v2_ui_status_chip(status_navn, status_verdi)
    }
    returner studio_v2_ui_panel_ikon_overskrift(ikon, navn, undertittel) + " " + studio_v2_ui_status_chip(status_navn, status_verdi)
}

funksjon studio_v2_ui_deloverskrift(navn: tekst) -> tekst {
    returner "--- " + navn + " ---"
}

funksjon studio_v2_ui_status_chip(navn: tekst, verdi: tekst) -> tekst {
    returner navn + ": " + verdi
}

funksjon studio_v2_ui_aktiv_chip(navn: tekst, verdi: tekst) -> tekst {
    returner "▶ " + navn + ": " + verdi
}

funksjon studio_v2_ui_session_tom() -> liste_tekst {
    returner []
}

funksjon studio_v2_ui_session_fra_workspace(rot: tekst, aktiv_fil: tekst) -> liste_tekst {
    returner [
        "rot\t" + rot,
        "aktiv_fil\t" + aktiv_fil,
        "tema\t" + studio_v2_ui_tema_standard(),
        "keymap\t" + studio_v2_ui_keymap_standard(),
        "runtimevalg\t" + studio_v2_ui_runtimevalg_run(),
        "search_query\t"
    ]
}

funksjon studio_v2_ui_session_restore(session: liste_tekst) -> tekst {
    hvis lengde(session) > 0 da {
        returner "restaurert"
    }
    returner "tom"
}

funksjon studio_v2_ui_session_status(session: liste_tekst) -> tekst {
    hvis lengde(session) > 0 da {
        returner "klar"
    }
    returner "tom"
}

