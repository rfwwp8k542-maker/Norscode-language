funksjon moms(pris: heltall) -> heltall {
    returner pris + 25
}

funksjon rabatt(pris: heltall, avslag: heltall) -> heltall {
    returner pris - avslag
}

funksjon total_med_moms_og_rabatt(pris: heltall, avslag: heltall) -> heltall {
    la etter_rabatt: heltall = rabatt(pris, avslag)
    la total: heltall = moms(etter_rabatt)
    returner total
}
