bruk std.liste som liste

funksjon start() -> heltall {
    la tall: liste_heltall = []
    assert_eq(liste.legg_til_tall(tall, 4), 1)
    assert_eq(liste.legg_til_tall(tall, 8), 2)
    assert_eq(liste.første_tall(tall), 4)
    assert_eq(liste.antall_tall(tall), 2)
    assert_eq(liste.tom_tall(tall), usann)
    assert(liste.inneholder_tall(tall, 4))
    assert_ne(liste.inneholder_tall(tall, 99), sann)
    assert_eq(liste.indeks_for_tall(tall, 4), 0)
    assert_eq(liste.siste_indeks_for_tall(tall, 8), 1)
    assert_eq(liste.siste_tall(tall), 8)
    assert_eq(liste.antall_tall(tall), 1)
    assert_eq(liste.sett_inn_tall(tall, 2, 7), 3)
    la ekstra_tall: liste_heltall = [1, 2]
    assert_eq(liste.legg_til_alle_tall(tall, ekstra_tall), 5)
    assert_eq(liste.antall_tall(tall), 5)
    assert_eq(liste.første_tall(ekstra_tall), 1)
    assert_eq(liste.indeks_for_tall(ekstra_tall, 2), 1)
    la kopi_tall: liste_heltall = liste.kopier_tall(ekstra_tall)
    assert_eq(liste.antall_tall(kopi_tall), 2)
    assert_eq(liste.første_tall(kopi_tall), 1)
    la omvendt_kopi_tall: liste_heltall = liste.omvendt_kopi_tall(ekstra_tall)
    assert_eq(liste.første_tall(omvendt_kopi_tall), 2)
    assert_eq(liste.siste_tall(omvendt_kopi_tall), 1)
    assert_eq(liste.fjern_første_tall(kopi_tall), 1)
    assert_eq(liste.fjern_siste_tall(kopi_tall), 0)
    assert_eq(liste.fjern_tall(tall, 1), 4)
    assert_eq(liste.fjern_verdi_tall(tall, 7), 3)
    assert_eq(liste.fjern_verdi_tall(tall, 99), 3)
    assert_eq(liste.erstatt_verdi_tall(tall, 4, 9), 3)
    assert_eq(liste.indeks_for_tall(tall, 9), 0)
    la alle_tall: liste_heltall = [1, 2, 1, 3, 1]
    assert_eq(liste.erstatt_alle_verdi_tall(alle_tall, 1, 7), 5)
    assert_eq(liste.første_tall(alle_tall), 7)
    assert_eq(liste.indeks_for_tall(alle_tall, 7), 0)
    assert_eq(liste.siste_indeks_for_tall(alle_tall, 7), 4)
    assert(liste.inneholder_alle_tall(alle_tall, [7, 2]))
    assert_ne(liste.inneholder_alle_tall(alle_tall, [7, 99]), sann)
    assert(liste.samme_tall([1, 2, 3], [1, 2, 3]))
    assert_ne(liste.samme_tall([1, 2, 3], [1, 2]), sann)
    assert(liste.er_unik_tall([1, 2, 3]))
    assert_ne(liste.er_unik_tall([1, 2, 1]), sann)
    assert_ne(liste.har_duplikater_tall([1, 2, 3]), sann)
    assert(liste.har_duplikater_tall([1, 2, 1]))
    assert_eq(liste.antall_unike_tall([1, 2, 1, 3, 2]), 3)
    assert_eq(liste.antall_unike_tall([]), 0)
    assert_eq(liste.antall_duplikater_tall([1, 2, 1, 3, 2]), 2)
    assert_eq(liste.antall_duplikater_tall([]), 0)
    assert_eq(liste.gjennomsnitt_tall([2, 4, 6]), 4)
    assert_eq(liste.gjennomsnitt_tall([]), 0)
    assert_eq(liste.sum_tall([1, 2, 3, 4]), 10)
    assert_eq(liste.sum_tall([]), 0)
    assert_eq(liste.produkt_tall([2, 3, 4]), 24)
    assert_eq(liste.produkt_tall([]), 1)
    assert_eq(liste.antall_forekomster_tall([1, 2, 1, 3, 1], 1), 3)
    assert_eq(liste.antall_forekomster_tall([1, 2, 3], 9), 0)
    assert_eq(liste.maks_tall([1, 9, 3, 7]), 9)
    assert_eq(liste.maks_tall([]), 0)
    assert_eq(liste.min_tall([1, 9, 3, 7]), 1)
    assert_eq(liste.min_tall([]), 0)
    la duplikat_tall: liste_heltall = [1, 2, 1, 3, 2]
    assert_eq(liste.fjern_duplikater_tall(duplikat_tall), 3)
    assert(liste.samme_tall(duplikat_tall, [1, 2, 3]))
    la flere_tall: liste_heltall = [9, 1, 9, 2, 9]
    assert_eq(liste.fjern_alle_verdi_tall(flere_tall, 9), 2)
    assert_eq(liste.antall_tall(flere_tall), 2)
    assert_eq(liste.første_tall(flere_tall), 1)

    la tekster: liste_tekst = []
    assert_eq(liste.legg_til_tekst(tekster, "hei"), 1)
    assert_eq(liste.legg_til_tekst(tekster, "verden"), 2)
    assert_eq(liste.første_tekst(tekster), "hei")
    assert_eq(liste.tom_tekst(tekster), usann)
    assert_eq(liste.siste_tekst(tekster), "verden")
    assert_eq(liste.antall_tekst(tekster), 1)
    assert(liste.inneholder_tekst(tekster, "hei"))
    assert_ne(liste.inneholder_tekst(tekster, "ingen"), sann)
    assert_eq(liste.sett_inn_tekst(tekster, 2, "neste"), 3)
    la ekstra_tekster: liste_tekst = ["ett", "to"]
    assert_eq(liste.legg_til_alle_tekst(tekster, ekstra_tekster), 5)
    assert_eq(liste.antall_tekst(tekster), 5)
    assert_eq(liste.første_tekst(ekstra_tekster), "ett")
    assert_eq(liste.indeks_for_tekst(ekstra_tekster, "to"), 1)
    assert_eq(liste.siste_indeks_for_tekst(tekster, "hei"), 0)
    la kopi_tekster: liste_tekst = liste.kopier_tekst(ekstra_tekster)
    assert_eq(liste.antall_tekst(kopi_tekster), 2)
    assert_eq(liste.første_tekst(kopi_tekster), "ett")
    la omvendt_kopi_tekster: liste_tekst = liste.omvendt_kopi_tekst(ekstra_tekster)
    assert_eq(liste.første_tekst(omvendt_kopi_tekster), "to")
    assert_eq(liste.siste_tekst(omvendt_kopi_tekster), "ett")
    assert_eq(liste.fjern_første_tekst(kopi_tekster), 1)
    assert_eq(liste.fjern_siste_tekst(kopi_tekster), 0)
    assert_eq(liste.fjern_tekst(tekster, 0), 4)
    assert_eq(liste.fjern_verdi_tekst(tekster, "neste"), 3)
    assert_eq(liste.fjern_verdi_tekst(tekster, "ingen"), 3)
    assert_eq(liste.erstatt_verdi_tekst(tekster, "", "jorden"), 3)
    assert_eq(liste.indeks_for_tekst(tekster, "jorden"), 0)
    la alle_tekster: liste_tekst = ["hei", "du", "hei", "der"]
    assert_eq(liste.erstatt_alle_verdi_tekst(alle_tekster, "hei", "hallo"), 4)
    assert_eq(liste.første_tekst(alle_tekster), "hallo")
    assert_eq(liste.indeks_for_tekst(alle_tekster, "hallo"), 0)
    assert_eq(liste.siste_indeks_for_tekst(alle_tekster, "hallo"), 2)
    assert(liste.inneholder_alle_tekst(alle_tekster, ["hallo", "du"]))
    assert_ne(liste.inneholder_alle_tekst(alle_tekster, ["hallo", "ingen"]), sann)
    assert(liste.samme_tekst(["a", "b"], ["a", "b"]))
    assert_ne(liste.samme_tekst(["a", "b"], ["a"]), sann)
    assert(liste.er_unik_tekst(["a", "b", "c"]))
    assert_ne(liste.er_unik_tekst(["a", "b", "a"]), sann)
    assert_ne(liste.har_duplikater_tekst(["a", "b", "c"]), sann)
    assert(liste.har_duplikater_tekst(["a", "b", "a"]))
    assert_eq(liste.antall_unike_tekst(["a", "b", "a", "c"]), 3)
    assert_eq(liste.antall_unike_tekst([]), 0)
    assert_eq(liste.antall_duplikater_tekst(["a", "b", "a", "c", "a"]), 2)
    assert_eq(liste.antall_duplikater_tekst([]), 0)
    assert_eq(liste.antall_forekomster_tekst(["hei", "du", "hei"], "hei"), 2)
    assert_eq(liste.antall_forekomster_tekst(["hei", "du"], "ingen"), 0)
    la duplikat_tekster: liste_tekst = ["hei", "du", "hei", "der", "du"]
    assert_eq(liste.fjern_duplikater_tekst(duplikat_tekster), 3)
    assert(liste.samme_tekst(duplikat_tekster, ["hei", "du", "der"]))
    la flere_tekster: liste_tekst = ["hei", "verden", "hei", "neste"]
    assert_eq(liste.fjern_alle_verdi_tekst(flere_tekster, "hei"), 2)
    assert_eq(liste.antall_tekst(flere_tekster), 2)
    assert_eq(liste.første_tekst(flere_tekster), "verden")
    returner 0
}
