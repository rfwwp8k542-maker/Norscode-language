bruk studio_v2.studio_state som workspace
bruk studio_v2.project som project
bruk studio_v2.editor som editor
bruk studio_v2.symbol som symbol
bruk studio_v2.ui som ui
bruk studio_v2.ai_context som ai_context
bruk studio_v2.ai som ai
bruk studio_v2.actions som actions
bruk studio_v2.diagnostics som diagnostics

test "studio v2 foundation" {
    la args: liste_tekst = ["."]
    la session_rot: tekst = "/tmp/norscode-studio-v2-session-test"
    la buffer: liste_tekst = editor.studio_v2_editor_åpne("første linje\nandre linje")
    la cursor: liste_tekst = editor.studio_v2_cursor_med_posisjon(2, 3)
    assert_eq(workspace.studio_v2_state_tittel(), "Norscode Studio v2")
    assert_eq(workspace.studio_v2_state_rot(args), ".")
    assert_eq(workspace.studio_v2_state_rot(["--gui-backend", "tk", "."]), ".")
    assert_eq(workspace.studio_v2_state_session_fil(session_rot), "/tmp/norscode-studio-v2-session-test/.norscode/studio_v2.session")
    assert_eq(workspace.studio_v2_state_session_status(session_rot), "tom")
    assert_eq(workspace.studio_v2_state_session_lagre(session_rot, "studio_v2/main.no"), 1)
    la session_lest: liste_tekst = workspace.studio_v2_state_session_les(session_rot)
    assert_eq(workspace.studio_v2_state_session_workspace(session_lest), session_rot)
    assert_eq(workspace.studio_v2_state_session_aktiv_fil(session_lest), "studio_v2/main.no")
    assert_eq(workspace.studio_v2_state_session_aktiv_tab(session_lest), "studio_v2/main.no")
    assert_eq(workspace.studio_v2_state_session_split_fokus(session_lest), "høyre")
    assert_eq(workspace.studio_v2_state_session_tool_window(session_lest), "Project")
    assert_eq(workspace.studio_v2_state_session_run_config(session_lest), "run")
    assert_eq(workspace.studio_v2_state_session_palette_status(session_lest), "lukket")
    assert_eq(workspace.studio_v2_state_session_sist_navigasjon(session_lest), "studio_v2/main.no")
    assert_eq(lengde(workspace.studio_v2_state_session_tree_fold(session_lest)), 0)
    la session_åpne_filer: liste_tekst = workspace.studio_v2_state_session_apne_filer(session_lest)
    assert_eq(lengde(session_åpne_filer), 3)
    assert_eq(session_åpne_filer[0], "studio_v2/main.no")
    assert_eq(workspace.studio_v2_state_session_lagre_med_tilstand(session_rot, "studio_v2/editor.no", "studio_v2/main.no", "venstre", "Inspect", "test", "studio_v2/studio_state.no", ["studio_v2/"]), 1)
    la session_tilstand: liste_tekst = workspace.studio_v2_state_session_les(session_rot)
    assert_eq(workspace.studio_v2_state_session_aktiv_fil(session_tilstand), "studio_v2/editor.no")
    assert_eq(workspace.studio_v2_state_session_aktiv_tab(session_tilstand), "studio_v2/main.no")
    assert_eq(workspace.studio_v2_state_session_split_fokus(session_tilstand), "venstre")
    assert_eq(workspace.studio_v2_state_session_tool_window(session_tilstand), "Inspect")
    assert_eq(workspace.studio_v2_state_session_run_config(session_tilstand), "test")
    assert_eq(workspace.studio_v2_state_session_palette_status(session_tilstand), "lukket")
    assert_eq(workspace.studio_v2_state_session_sist_navigasjon(session_tilstand), "studio_v2/studio_state.no")
    assert_eq(workspace.studio_v2_state_session_tree_fold_satt(session_tilstand, "studio_v2/"), sann)
    assert_eq(workspace.studio_v2_state_aktiv_fil(session_rot), "studio_v2/main.no")
    assert_eq(lengde(workspace.studio_v2_state_session_recent_for_workspace(session_rot)), 1)
    assert_eq(workspace.studio_v2_state_session_status_for_workspace(session_rot), "klar")
    assert_eq(lengde(workspace.studio_v2_state_apne_filer(session_rot, "studio_v2/main.no")), 3)
    assert_eq(workspace.studio_v2_state_apne_filer("/tmp/studio_v2_empty_test", ""), ["studio_v2/studio_state.no", "studio_v2/editor.no"])
    la robustness_rot: tekst = "/tmp/studio_v2_robustness_test"
    skriv_fil(robustness_rot + "/studio_v2/alpha.no", "funksjon alpha() -> heltall {\n    returner 1\n}")
    workspace.studio_v2_state_session_lagre_med_tilstand(robustness_rot, "studio_v2/missing.no", "studio_v2/missing.no", "høyre", "Project", "run", "lukket", "studio_v2/missing.no", [])
    assert_eq(workspace.studio_v2_state_aktiv_fil(robustness_rot), "studio_v2/alpha.no")
    la workspace_filer: liste_tekst = workspace.studio_v2_state_workspace_filer(".")
    assert(lengde(workspace_filer) > 0)
    assert(tekst_starter_med(workspace.studio_v2_state_workspace_filer_status(workspace_filer), "hurtig"))
    assert_eq(project.studio_v2_prosjektnavn(), "Norscode Studio v2")
    assert_eq(project.studio_v2_prosjektrot(args), ".")
    assert_eq(project.studio_v2_prosjektrot(["--gui-backend", "tk", "."]), ".")
    assert_eq(editor.studio_v2_editor_layout(), "tool-window-stripe | project | editor | inspector | status-bar")
    assert_eq(lengde(editor.studio_v2_editor_kjerne()), 5)
    assert_eq(editor.studio_v2_editor_buffer_antall_linje(buffer), 2)
    assert_eq(editor.studio_v2_editor_lagre(buffer), "første linje\nandre linje")
    assert_eq(lengde(editor.studio_v2_editor_linjeoversikt(buffer)), 2)
    assert_eq(editor.studio_v2_editor_aktiv_linje(buffer, 2), "* 2: andre linje")
    assert_eq(lengde(editor.studio_v2_editor_visningslinjer(buffer, 1, 1)), 1)
    assert_eq(editor.studio_v2_editor_sok(buffer, "linje"), 2)
    assert_eq(editor.studio_v2_editor_sok_status(buffer, "linje"), "funnet")
    assert_eq(editor.studio_v2_editor_telle_forekomster("start startx start", "start"), 3)
    assert_eq(editor.studio_v2_editor_erstatt_tekst("første linje", "linje", "rad"), "første rad")
    assert_eq(editor.studio_v2_editor_erstatt_treff(buffer, "linje"), 2)
    assert_eq(editor.studio_v2_editor_erstatt_status(buffer, "linje"), "klar")
    assert_eq(editor.studio_v2_editor_erstatt_tekst_fra_buffer(buffer, "linje", "rad"), "første rad\nandre rad")
    assert_eq(editor.studio_v2_editor_forste_treff(buffer, "andre"), 2)
    la editor_tabs: liste_tekst = editor.studio_v2_editor_tabs_fra_apne_filer(workspace.studio_v2_state_apne_filer(session_rot, "studio_v2/main.no"))
    assert_eq(lengde(editor_tabs), 3)
    assert_eq(editor.studio_v2_editor_tab_status(editor_tabs), "delt")
    assert_eq(editor.studio_v2_editor_split_status(editor_tabs), "delt")
    assert_eq(lengde(editor.studio_v2_editor_split_visning(editor_tabs)), 2)
    assert_eq(editor.studio_v2_editor_tab_nåværende(editor_tabs, "studio_v2/main.no"), "studio_v2/main.no")
    assert_eq(editor.studio_v2_editor_tab_neste(editor_tabs, "studio_v2/main.no"), "studio_v2/studio_state.no")
    assert_eq(editor.studio_v2_editor_tab_forrige(editor_tabs, "studio_v2/main.no"), "studio_v2/editor.no")
    assert_eq(editor.studio_v2_editor_tab_velg(editor_tabs, 1), "studio_v2/studio_state.no")
    assert_eq(editor.studio_v2_editor_tab_bytt(editor_tabs, "studio_v2/main.no", "neste"), "studio_v2/studio_state.no")
    assert_eq(editor.studio_v2_editor_tab_bytt(editor_tabs, "studio_v2/main.no", "forrige"), "studio_v2/editor.no")
    assert_eq(editor.studio_v2_editor_split_fokus_valgt(editor_tabs, "studio_v2/main.no", "høyre"), "studio_v2/studio_state.no")
    assert_eq(editor.studio_v2_editor_split_fokus_status(editor_tabs, "studio_v2/main.no"), "delt")
    assert_eq(editor.studio_v2_editor_split_fokus_neste(editor_tabs, "studio_v2/main.no"), "studio_v2/studio_state.no")
    assert_eq(editor.studio_v2_editor_split_fokus_forrige(editor_tabs, "studio_v2/main.no"), "studio_v2/main.no")
    la tomme_tabs: liste_tekst = editor.studio_v2_editor_tabs_tom()
    assert_eq(editor.studio_v2_editor_split_fokus_status(tomme_tabs, "studio_v2/main.no"), "tom")
    assert_eq(editor.studio_v2_editor_goto_linje_fra_tekst(buffer, ""), editor.studio_v2_editor_goto_linje(buffer, 1))
    assert(lengde(editor.studio_v2_editor_goto_linje(buffer, 2)) > 0)
    assert(tekst_inneholder(editor.studio_v2_editor_goto_linje(buffer, 2)[0], "andre linje"))
    assert(tekst_inneholder(editor.studio_v2_editor_goto_linje_fra_tekst(buffer, "2")[0], "andre linje"))
    assert(tekst_inneholder(editor.studio_v2_editor_goto_symbol(".", "studio_v2"), "studio_v2"))
    assert(lengde(editor.studio_v2_editor_referanser(".", "studio_v2")) > 0)
    assert(tekst_inneholder(editor.studio_v2_editor_referanse_valg(".", "studio_v2", 0), "studio_v2"))
    assert(lengde(editor.studio_v2_editor_rename_preview(".", "studio_v2", "studio_v2_v2")) > 0)
    la symbol_def_index: liste_tekst = symbol.studio_v2_symbol_indeks_fra_kilde("studio_v2/demo.no", "funksjon a() -> tekst { returner \"\" }\nfunksjon b(navn: tekst) -> tekst { returner navn }")
    assert_eq(lengde(symbol_def_index), 2)
    assert(tekst_inneholder(symbol_def_index[0], "studio_v2/demo.no"))
    assert_eq(symbol.studio_v2_symbol_navn_fra_oppføring(symbol_def_index[0]), "a")
    assert_eq(symbol.studio_v2_symbol_slag_fra_oppføring(symbol_def_index[0]), "funksjon")
    assert(tekst_inneholder(symbol.studio_v2_symbol_signatur_fra_oppføring(symbol_def_index[0]), "funksjon a"))
    assert_eq(symbol.studio_v2_symbol_parametere_fra_oppføring(symbol_def_index[1]), "navn")
    assert(tekst_inneholder(symbol.studio_v2_symbol_indeks_finn(symbol_def_index, "b"), "\tfunksjon\tb\t"))
    la symbol_use_index: liste_tekst = symbol.studio_v2_symbol_bruk_indeks_fra_kilde("studio_v2/demo.no", "funksjon a() -> tekst { returner b }\nfunksjon b() -> tekst { returner \"\" }", "b")
    assert_eq(lengde(symbol_use_index), 1)
    assert(tekst_inneholder(symbol_use_index[0], "\tbruk\tb\t"))
    assert(tekst_inneholder(symbol.studio_v2_symbol_indeks_finn_bruk(symbol_use_index, "b"), "\tbruk\tb\t"))
    la symbol_workspace_index: liste_tekst = symbol.studio_v2_symbol_indeks_fra_filer(workspace_filer)
    assert_eq(lengde(symbol_workspace_index), lengde(symbol.studio_v2_symbol_indeks_fra_workspace(".")))
    assert(symbol.studio_v2_symbol_indeks_antall_definisjoner(symbol_workspace_index) > 0)
    assert(symbol.studio_v2_symbol_indeks_antall_bruk(symbol_workspace_index) > 0)
    assert(tekst_inneholder(symbol.studio_v2_symbol_indeks_finn(symbol_workspace_index, "pluss"), "\tfunksjon\tpluss\t"))
    assert(lengde(symbol.studio_v2_symbol_bruk_indeks_fra_fil(".", "studio_v2/main.no", "studio_v2")) > 0)
    assert(tekst_inneholder(symbol.studio_v2_symbol_indeks_forste(symbol.studio_v2_symbol_bruk_indeks_fra_fil(".", "studio_v2/main.no", "studio_v2")), "\tbruk\tstudio_v2\t"))
    assert(tekst_inneholder(symbol.studio_v2_symbol_quick_jump_fra_filer(workspace_filer, "editor.no"), "editor.no"))
    assert(tekst_inneholder(symbol.studio_v2_symbol_navigasjon_forslag(".", "studio_v2"), "studio_v2"))
    assert_eq(symbol.studio_v2_symbol_oppføring_fil(symbol.studio_v2_symbol_navigasjon_forslag(".", "studio_v2")), "studio_v2/main.no")
    assert(symbol.studio_v2_symbol_oppføring_linje(symbol.studio_v2_symbol_navigasjon_forslag(".", "studio_v2")) > 0)
    assert_eq(symbol.studio_v2_symbol_navigasjon_forslag(".", "ikke_finnes"), "")
    assert_eq(lengde(symbol.studio_v2_symbol_palette(symbol_def_index, 3)), 2)
    la completion_keyword: liste_tekst = symbol.studio_v2_symbol_completion_fra_workspace(".", "ret", 4)
    assert(lengde(completion_keyword) > 0)
    assert_eq(symbol.studio_v2_symbol_completion_type(completion_keyword[0]), "keyword")
    assert_eq(symbol.studio_v2_symbol_completion_navn(completion_keyword[0]), "returner")
    la completion_builtin: liste_tekst = symbol.studio_v2_symbol_completion_fra_workspace(".", "tekst_", 4)
    assert(lengde(completion_builtin) > 0)
    assert_eq(symbol.studio_v2_symbol_completion_type(completion_builtin[0]), "builtin")
    assert(tekst_inneholder(symbol.studio_v2_symbol_completion_detalj(completion_builtin[0]), "stdlib"))
    la completion_symbol: liste_tekst = editor.studio_v2_editor_completion(".", "pluss")
    assert(lengde(completion_symbol) > 0)
    assert_eq(symbol.studio_v2_symbol_completion_type(completion_symbol[0]), "symbol")
    assert_eq(editor.studio_v2_editor_completion_valg(".", "pluss", 0), completion_symbol[0])
    assert(lengde(symbol.studio_v2_symbol_rename_preview_fra_fil(".", "studio_v2/main.no", "studio_v2", "studio_v2_v2")) > 0)
    assert(tekst_inneholder(symbol.studio_v2_symbol_indeks_forste(symbol.studio_v2_symbol_rename_preview_fra_fil(".", "studio_v2/main.no", "studio_v2", "studio_v2_v2")), "studio_v2 -> studio_v2_v2"))
    assert_eq(symbol.studio_v2_symbol_rename_appliser_tekst("abc abc", "abc", "xyz"), "xyz xyz")
    la rename_tmp_rot: tekst = "/tmp"
    la rename_tmp_fil: tekst = "studio_v2_rename_test.no"
    la rename_tmp_sti: tekst = rename_tmp_rot + "/" + rename_tmp_fil
    skriv_fil(rename_tmp_sti, "funksjon alfa() -> tekst {\n    returner alfa\n}")
    assert(symbol.studio_v2_symbol_rename_appliser_fil(rename_tmp_rot, rename_tmp_fil, "alfa", "beta"))
    assert(tekst_inneholder(les_fil(rename_tmp_sti), "funksjon beta()"))
    assert(tekst_inneholder(les_fil(rename_tmp_sti), "returner beta"))
    assert_eq(lengde(actions.studio_v2_actions_palett()), 5)
    assert_eq(actions.studio_v2_actions_status("."), "klar")
    assert_eq(actions.studio_v2_actions_status(""), "tom")
    assert_eq(actions.studio_v2_actions_kommando_tekst(actions.studio_v2_actions_kommando_run(".", "studio_v2/main.no")), "norscode run studio_v2/main.no")
    assert_eq(actions.studio_v2_actions_kommando_for_navn(".", "studio_v2/main.no", "check")[1], "check")
    assert_eq(actions.studio_v2_actions_kommando_for_navn(".", "studio_v2/main.no", "debug")[1], "runtime-status")
    assert_eq(actions.studio_v2_actions_kommando_for_navn(".", "studio_v2/main.no", "runtime-ci")[1], "runtime-ci")
    assert_eq(actions.studio_v2_actions_terminal_status("."), "klar")
    assert_eq(lengde(actions.studio_v2_actions_terminal(".", "studio_v2/main.no", "run")), 5)
    assert(tekst_inneholder(actions.studio_v2_actions_terminal(".", "studio_v2/main.no", "run")[0], "norscode run studio_v2/main.no"))
    assert_eq(actions.studio_v2_actions_kommando_status(0), "ok")
    assert_eq(actions.studio_v2_actions_kommando_args_for_navn(".", "runtime-ci"), "--json")
    assert_eq(actions.studio_v2_actions_kommando_arbeidskatalog("/tmp"), "/tmp")
    assert_eq(actions.studio_v2_actions_kommando_debug(".", "studio_v2/main.no")[1], "runtime-status")
    assert(tekst_inneholder(actions.studio_v2_actions_trygg_kjor(".", "studio_v2/main.no", "ukjent"), "Feil: ukjent kommando"))
    assert_eq(actions.studio_v2_actions_kjor(["python3", "-c", "import sys; sys.exit(0)"]), 0)
    assert(tekst_inneholder(actions.studio_v2_actions_kommando_run(".", "studio_v2/main.no")[1], "main.py"))
    la syntaks_ok: liste_tekst = diagnostics.studio_v2_diagnostics_syntaks_fra_innhold("studio_v2/demo.no", "funksjon a() -> tekst {\n    returner \"ok\"\n}")
    assert_eq(lengde(syntaks_ok), 0)
    la syntaks_feil: liste_tekst = diagnostics.studio_v2_diagnostics_syntaks_fra_innhold("studio_v2/demo.no", "funksjon a( -> tekst {\n    returner \"ok\"\n")
    assert(lengde(syntaks_feil) > 0)
    assert(tekst_inneholder(syntaks_feil[0], "syntax_error"))
    la diagnostics_filer: liste_tekst = diagnostics.studio_v2_diagnostics_fra_workspace_med_filer(".", workspace_filer, lengde(symbol_workspace_index))
    assert(lengde(diagnostics_filer) > 7)
    assert(tekst_inneholder(diagnostics.studio_v2_diagnostics_fra_workspace_med_filer(".", workspace_filer, lengde(symbol_workspace_index))[3], "workspace_filer"))
    assert(tekst_inneholder(diagnostics_filer[4], "syntax_errors"))
    assert(tekst_inneholder(diagnostics_filer[5], "symbol_definisjoner"))
    assert(tekst_inneholder(diagnostics_filer[6], "symbol_bruk"))
    assert_eq(diagnostics.studio_v2_diagnostics_status("."), "klar")
    assert(lengde(diagnostics.studio_v2_diagnostics_oppdater_med_filer(".", workspace_filer, lengde(symbol_workspace_index))) > 8)
    assert_eq(diagnostics.studio_v2_diagnostics_oppdater_status("."), "oppdatert")
    la ai_provider: liste_tekst = ai.studio_v2_ai_provider_fra_modus("lokal", ai.studio_v2_ai_modus_lokal())
    assert_eq(ai.studio_v2_ai_provider_navn(ai_provider), "lokal")
    assert_eq(ai.studio_v2_ai_provider_modus(ai_provider), "local")
    assert(ai.studio_v2_ai_provider_kan_bruke(ai_provider))
    assert_eq(ai.studio_v2_ai_provider_status(ai_provider), "klar")
    la ai_kontekst: liste_tekst = ai_context.studio_v2_ai_kontekst_sammendrag("Norscode Studio v2", ".", "studio_v2/main.no", "funksjon start() -> heltall {\n    returner 0\n}", diagnostics_filer)
    assert_eq(ai_context.studio_v2_ai_kontekst_antall(ai_kontekst), 12)
    assert_eq(ai_context.studio_v2_ai_kontekst_forste(ai_kontekst), "prosjekt\tNorscode Studio v2")
    assert_eq(lengde(ai.studio_v2_ai_handlinger()), 5)
    assert_eq(ai.studio_v2_ai_handlinger_forste(), "forklar-kode")
    assert_eq(ai.studio_v2_ai_handlinger_status(), "preview-first")
    la ai_patch_preview: liste_tekst = ai.studio_v2_ai_patch_previsjon_fra_kontekst(ai_kontekst)
    assert_eq(lengde(ai_patch_preview), 3)
    assert_eq(ai.studio_v2_ai_patch_previsjon_status(ai_patch_preview), "preview")
    assert(tekst_inneholder(ai.studio_v2_ai_patch_previsjon_forste(ai_patch_preview), "forslag"))
    assert_eq(ai.studio_v2_ai_patch_godkjenn(ai_patch_preview), "godkjent")
    assert_eq(ai.studio_v2_ai_patch_avvis(ai_patch_preview), "avvist")
    la ai_opt_in: liste_tekst = ai.studio_v2_ai_opt_in_lag("Norscode Studio v2", usann, sann, sann)
    assert_eq(ai.studio_v2_ai_opt_in_workspace(ai_opt_in), "Norscode Studio v2")
    assert(ai.studio_v2_ai_opt_in_offline_only(ai_opt_in))
    assert_eq(ai.studio_v2_ai_opt_in_status(ai_opt_in), "offline-only")
    assert_eq(ai.studio_v2_ai_personvern_status(), "klar")
    assert_eq(lengde(ai.studio_v2_ai_personvern_policy()), 4)
    la ai_sikker_kontekst: liste_tekst = ai.studio_v2_ai_kontekst_sikker(ai_opt_in, [
        "hemmelig nøkkel",
        "passord er skjult",
        "token bør skjules"
    ])
    assert_eq(lengde(ai_sikker_kontekst), 3)
    assert(tekst_inneholder(ai_sikker_kontekst[0], "[redacted]"))
    assert_eq(ai.studio_v2_ai_kontekst_sikker_status(ai_opt_in), "offline-only")
    assert(ikke ai.studio_v2_ai_personvern_kan_sende(ai_opt_in))
    assert(tekst_inneholder(ai.studio_v2_ai_handling_forklar_kode(ai_kontekst), "Forklar koden:"))
    assert(tekst_inneholder(ai.studio_v2_ai_handling_sammendrag_fil(ai_kontekst), "Oppsummer filen:"))
    assert(tekst_inneholder(ai.studio_v2_ai_handling_refaktorering(ai_kontekst), "Foreslå refaktorering:"))
    assert(tekst_inneholder(ai.studio_v2_ai_handling_testgenerering(ai_kontekst), "Generer tester:"))
    assert(tekst_inneholder(ai.studio_v2_ai_handling_patch_previsjon(ai_kontekst), "Forhåndsvis patch:"))
    assert_eq(editor.studio_v2_cursor_linje(cursor), "2")
    assert_eq(editor.studio_v2_cursor_kolonne(cursor), "3")
    assert_eq(editor.studio_v2_cursor_utvalg_start_linje(cursor), "2")
    assert_eq(editor.studio_v2_cursor_utvalg_start_kolonne(cursor), "3")
    assert_eq(editor.studio_v2_editor_last_om(buffer, "oppdatert"), ["oppdatert"])
    assert_eq(ui.studio_v2_ui_shell(), "studio shell")
    assert_eq(lengde(ui.studio_v2_ui_layout()), 5)
    assert_eq(ui.studio_v2_ui_logo_banner(), "logo.svg · Norscode Studio v2")
    assert_eq(ui.studio_v2_ui_logo_tagline(), "compact IDE shell")
    assert_eq(ui.studio_v2_ui_velkomst_oversikt(), "Open Project · Search Everywhere")
    assert(tekst_starter_med(ui.studio_v2_ui_velkomst_undertittel(".", "klar"), "Workspace: ."))
    assert_eq(lengde(ui.studio_v2_ui_velkomst_handlinger()), 5)
    assert_eq(ui.studio_v2_ui_velkomst_recent_tittel(), "Recent Projects")
    assert_eq(ui.studio_v2_ui_velkomst_recent_status(3), "Recent: 3")
    assert_eq(ui.studio_v2_ui_velkomst_recent_current("studio_v2"), "Current workspace: studio_v2")
    assert_eq(ui.studio_v2_ui_velkomst_recent_sammendrag("studio_v2", 3), "Current workspace: studio_v2 · Recent: 3")
    assert_eq(ui.studio_v2_ui_velkomst_recent_hint(), "Select recent workspace, then restore it")
    assert_eq(ui.studio_v2_ui_velkomst_recent_actions(), "Quick actions: Open · Restore · Search")
    assert_eq(ui.studio_v2_ui_velkomst_recent_restore_status(), "Restore: selected recent")
    assert_eq(ui.studio_v2_ui_velkomst_recent_shortcut(), "Shortcut: Enter restores selected recent")
    assert_eq(ui.studio_v2_ui_run_hint(), "Shortcut: Enter runs selected config")
    assert_eq(ui.studio_v2_ui_run_status_hint(), "Status: klar")
    assert_eq(ui.studio_v2_ui_run_output_hint(), "Output: venter på kjøring")
    assert_eq(ui.studio_v2_ui_run_suite_hint(), "Suite: Run · Check · Test · Debug · CI")
    assert_eq(ui.studio_v2_ui_tool_window_hint(), "Shortcut: choose a tool window (Problems, References, Structure, Terminal)")
    assert_eq(ui.studio_v2_ui_structure_hint(), "Structure: symbol overview")
    assert_eq(ui.studio_v2_ui_search_hint(), "Shortcut: Enter opens selected result")
    assert_eq(ui.studio_v2_ui_palette_hint(), "Shortcut: Enter runs selected command")
    assert_eq(ui.studio_v2_ui_palette_lukket_hint(), "Ctrl+P opens command palette")
    assert_eq(ui.studio_v2_ui_project_hint(), "Shortcut: Enter opens file")
    assert_eq(ui.studio_v2_ui_editor_hint(), "Shortcut: Enter opens tab")
    assert_eq(ui.studio_v2_ui_references_hint(), "Shortcut: Enter opens reference")
    assert_eq(ui.studio_v2_ui_rename_hint(), "Shortcut: Enter previews rename")
    assert_eq(ui.studio_v2_ui_rename_apply_hint(), "Apply Rename writes the change to disk")
    assert_eq(ui.studio_v2_ui_terminal_hint(), "Shortcut: Enter logs command")
    assert_eq(ui.studio_v2_ui_problems_hint(), "Shortcut: Enter logs problem")
    assert_eq(ui.studio_v2_ui_velkomst_spacer(), "")
    assert_eq(ui.studio_v2_ui_tema_standard(), "mørk")
    assert_eq(ui.studio_v2_ui_tema_fra_navn("lys"), "lys")
    assert_eq(ui.studio_v2_ui_tema_status("lys"), "aktivt")
    assert_eq(lengde(ui.studio_v2_ui_tema_palett()), 2)
    assert_eq(ui.studio_v2_ui_snarvei_forste(), "Ctrl+O\tåpne")
    assert_eq(lengde(ui.studio_v2_ui_snarveier()), 9)
    assert_eq(ui.studio_v2_ui_snarveier_status(), "klar")
    assert_eq(ui.studio_v2_ui_seksjon_tittel("Editor"), "[Editor]")
    assert_eq(ui.studio_v2_ui_panel_overskrift("Project", "Files + Recent"), "=== Project === Files + Recent")
    assert_eq(ui.studio_v2_ui_panel_ikon_overskrift("▣", "Project", ""), "=== ▣ Project ===")
    assert_eq(ui.studio_v2_ui_panel_status_overskrift("▣", "Project", "", "Files", "3"), "=== ▣ Project === Files: 3")
    assert_eq(ui.studio_v2_ui_deloverskrift("Status"), "--- Status ---")
    assert_eq(ui.studio_v2_ui_status_chip("Session", "klar"), "Session: klar")
    assert_eq(ui.studio_v2_ui_snarveier()[5], "Ctrl+1\tProject")
    assert_eq(studio_v2_gui_run_config_linje(["run", "check", "debug"], "run")[0], "▶ run")
    assert_eq(studio_v2_gui_run_config_valg("· check\tSjekk aktiv fil"), "check")
    assert_eq(studio_v2_gui_run_config_valg("· debug\tUndersøk runtime"), "debug")
    assert_eq(actions.studio_v2_actions_run_konfigurasjoner()[0], "run\tKjør aktiv fil")
    assert_eq(actions.studio_v2_actions_run_konfigurasjoner()[3], "debug\tUndersøk runtime")
    assert_eq(studio_v2_gui_palette_linje(["run", "check"], "check")[1], "▶ check")
    assert_eq(studio_v2_gui_palette_filtrert(["run", "check", "test"], "t")[0], "test")
    assert_eq(lengde(studio_v2_gui_palette_kommandoer()), 9)
    assert_eq(studio_v2_gui_palette_kommandoer()[6], "Debug")
    assert_eq(studio_v2_gui_palette_filtrert(studio_v2_gui_palette_kommandoer(), "Run")[0], "Run")
    assert_eq(lengde(studio_v2_gui_palette_kommandoer()), 9)
    assert_eq(studio_v2_gui_palette_valg("▶ run"), "run")
    assert_eq(actions.studio_v2_actions_kommando_args_for_navn(".", "runtime-ci"), "--json")
    assert_eq(actions.studio_v2_actions_kommando_arbeidskatalog("/tmp"), "/tmp")
    la ui_session: liste_tekst = ui.studio_v2_ui_session_fra_workspace(".", "studio_v2/main.no")
    assert_eq(ui.studio_v2_ui_session_restore(ui_session), "restaurert")
    assert_eq(ui.studio_v2_ui_session_status(ui_session), "klar")
    assert_eq(studio_v2_gui_fokus_tekst("Editor"), "Focus: Editor")
    assert_eq(studio_v2_gui_fokus_knapp_tekst("Project", "Project"), "▶ Project")
    assert_eq(studio_v2_gui_fokus_knapp_tekst("Editor", "Project"), "· Editor")
    assert_eq(studio_v2_gui_markert_valg("▶ studio_v2"), "studio_v2")
    assert_eq(studio_v2_gui_recent_valg("★ studio_v2"), "studio_v2")
    assert_eq(studio_v2_gui_velkomst_recent_valgt_tekst("studio_v2"), "Selected recent workspace: studio_v2")
    assert_eq(studio_v2_gui_velkomst_recent_åpnet_tekst("studio_v2"), "Opened recent workspace: studio_v2")
    assert_eq(studio_v2_gui_sok_status("", ""), "Search Everywhere: skriv for å hoppe")
    assert_eq(studio_v2_gui_sok_status("studio_v2", "studio_v2/main.no\t12"), "Search Everywhere: studio_v2/main.no:12")
    assert_eq(studio_v2_gui_sok_resultat_valg("· file · studio_v2/main.no"), "studio_v2/main.no")
    assert_eq(studio_v2_gui_sok_resultat_valg("· symbol · studio_v2/main.no:12"), "studio_v2/main.no\t12")
    assert_eq(studio_v2_gui_sok_resultat_type("· command · run"), "command")
    assert_eq(studio_v2_gui_sok_resultat_verdi("· command · run"), "run")
    la sok_resultater: liste_tekst = studio_v2_gui_sok_resultater(".", "main.no")
    assert(tekst_inneholder(sok_resultater[0], "file"))
    assert(tekst_inneholder(studio_v2_gui_sok_resultat_sammendrag(sok_resultater), "Files: 1"))
    assert(tekst_inneholder(studio_v2_gui_sok_resultat_sammendrag(sok_resultater), "Symbols: 1"))
    assert(tekst_inneholder(studio_v2_gui_sok_resultat_sammendrag(["· command · run"]), "Commands: 1"))
    assert_eq(studio_v2_gui_sok_resultat_linje(["· command · run"])[0], "· run · command")
    la command_resultater: liste_tekst = studio_v2_gui_sok_resultater(".", "runtime-ci")
    assert(tekst_inneholder(command_resultater[0], "command"))
    assert_eq(ui.studio_v2_ui_status_chip("Valgt", ""), "Valgt: ")
    assert_eq(studio_v2_gui_markert_valg("▶ studio_v2/main.no"), "studio_v2/main.no")
    assert_eq(studio_v2_gui_prosjekt_linje(["a", "b"], "a")[0], "▶ a")
    assert_eq(studio_v2_gui_recent_linje(["a", "b"], "a")[0], "★ a")
    assert(tekst_starter_med(studio_v2_gui_recent_linje_med_status(["a", "b"], "a")[0], "★ a · session tom · tabs "))
    assert_eq(studio_v2_gui_prosjekt_tre_mappe("studio_v2/sub/test.no"), "studio_v2/sub/")
    assert_eq(studio_v2_gui_prosjekt_tre_nivå("studio_v2/sub/test.no"), 2)
    assert_eq(studio_v2_gui_prosjekt_tre(["studio_v2/main.no", "studio_v2/editor.no"], "studio_v2/main.no", ["studio_v2/"])[0], "  ▸ studio_v2/")
    assert_eq(studio_v2_gui_begrens_liste_med_anker(["a", "b", "c", "d", "e"], 3, "c")[0], "b")
    assert_eq(studio_v2_gui_prosjekt_tre_valg("  ▶ studio_v2/main.no"), "studio_v2/main.no")
    assert_eq(studio_v2_gui_prosjekt_tre_valg("  ▸ studio_v2/"), "studio_v2/")
    assert_eq(studio_v2_gui_prosjekt_aktiv_node(".", ["workspace\t.", "sist_navigasjon\tstudio_v2/editor.no"], "studio_v2/main.no"), "studio_v2/editor.no")
    assert_eq(studio_v2_gui_prosjekt_tre_antall_foldet(["studio_v2/"]), 1)
    assert_eq(studio_v2_gui_fil_linje(["a", "b"], "a")[0], "▶ a")
    assert_eq(studio_v2_gui_referanse_linje(["a", "b"], "a")[0], "▶ a")
    assert_eq(studio_v2_gui_rename_linje(["linje 1", "linje 2"])[0], "▶ linje 1")
    assert_eq(lengde(studio_v2_gui_begrens_liste(["a", "b", "c"], 2)), 2)
    la tab_linje: liste_tekst = ["studio_v2/main.no", "studio_v2/editor.no"]
    assert_eq(lengde(tab_linje), 2)
    assert_eq(studio_v2_gui_tab_linje(tab_linje, "studio_v2/main.no")[0], "▶ studio_v2/main.no")
    assert_eq(studio_v2_gui_tab_valg("▶ studio_v2/main.no"), "studio_v2/main.no")
    assert_eq(studio_v2_gui_tab_valg("· studio_v2/editor.no"), "studio_v2/editor.no")
    assert_eq(studio_v2_gui_split_mål(tab_linje, "studio_v2/main.no", "høyre"), "studio_v2/editor.no")
    assert_eq(studio_v2_gui_split_mål(tab_linje, "studio_v2/main.no", "venstre"), "studio_v2/main.no")
    assert_eq(studio_v2_gui_recent_tab_antall("."), 0)
    assert_eq(studio_v2_gui_kompakt_visning(["a"], ["a"], ["a"], ["a"], ["a"]), usann)
    assert_eq(studio_v2_gui_kompakt_visning(["a", "b", "c", "d", "e", "f", "g", "h", "i", "j", "k", "l", "m"], ["a"], ["a"], ["a"], ["a"]), sann)
    assert_eq(ai.studio_v2_ai_modus(), "disabled")
    assert_eq(lengde(ai.studio_v2_ai_kontrakt()), 5)
}

funksjon start() -> heltall {
    skriv("Studio v2 foundation-test er klar")
    returner 0
}
