bruk studio_v2.studio_state som workspace
bruk studio_v2.project som project
bruk studio_v2.editor som editor
bruk studio_v2.symbol som symbol
bruk studio_v2.ui som ui
bruk studio_v2.ai_context som ai_context
bruk studio_v2.ai som ai
bruk studio_v2.actions som actions
bruk studio_v2.diagnostics som diagnostics

test "studio v2 foundation" {
    la args: liste_tekst = ["."]
    la session_rot: tekst = "/tmp/norscode-studio-v2-session-test"
    la buffer: liste_tekst = editor.studio_v2_editor_åpne("første linje\nandre linje")
    la cursor: liste_tekst = editor.studio_v2_cursor_med_posisjon(2, 3)
    assert_eq(workspace.studio_v2_state_tittel(), "Norscode Studio v2")
    assert_eq(workspace.studio_v2_state_rot(args), ".")
    assert_eq(workspace.studio_v2_state_rot(["--gui-backend", "tk", "."]), ".")
    assert_eq(workspace.studio_v2_state_session_fil(session_rot), "/tmp/norscode-studio-v2-session-test/.norscode/studio_v2.session")
    assert_eq(workspace.studio_v2_state_session_status(session_rot), "tom")
    assert_eq(workspace.studio_v2_state_session_lagre(session_rot, "studio_v2/main.no"), 1)
    la session_lest: liste_tekst = workspace.studio_v2_state_session_les(session_rot)
    assert_eq(workspace.studio_v2_state_session_workspace(session_lest), session_rot)
    assert_eq(workspace.studio_v2_state_session_aktiv_fil(session_lest), "studio_v2/main.no")
    assert_eq(workspace.studio_v2_state_session_aktiv_tab(session_lest), "studio_v2/main.no")
    assert_eq(workspace.studio_v2_state_session_split_fokus(session_lest), "høyre")
    assert_eq(workspace.studio_v2_state_session_tool_window(session_lest), "Project")
    assert_eq(workspace.studio_v2_state_session_run_config(session_lest), "run")
    assert_eq(workspace.studio_v2_state_session_tema(session_lest), "mørk")
    assert_eq(workspace.studio_v2_state_session_keymap(session_lest), "standard")
    assert_eq(workspace.studio_v2_state_session_runtimevalg(session_lest), "run")
    assert_eq(workspace.studio_v2_state_session_search_query(session_lest), "")
    assert_eq(workspace.studio_v2_state_session_project_tree_anchor(session_lest), "")
    assert_eq(lengde(workspace.studio_v2_state_session_innstillinger(session_lest)), 3)
    assert_eq(workspace.studio_v2_state_session_palette_status(session_lest), "lukket")
    assert_eq(workspace.studio_v2_state_session_sist_navigasjon(session_lest), "studio_v2/main.no")
    assert_eq(lengde(workspace.studio_v2_state_session_tree_fold(session_lest)), 0)
    la session_åpne_filer: liste_tekst = workspace.studio_v2_state_session_apne_filer(session_lest)
    assert_eq(lengde(session_åpne_filer), 3)
    assert_eq(session_åpne_filer[0], "studio_v2/main.no")
    assert_eq(workspace.studio_v2_state_session_lagre_med_tilstand(session_rot, "studio_v2/editor.no", "studio_v2/main.no", "venstre", "Inspect", "test", "studio_v2/studio_state.no", ["studio_v2/"]), 1)
    la session_tilstand: liste_tekst = workspace.studio_v2_state_session_les(session_rot)
    assert_eq(workspace.studio_v2_state_session_aktiv_fil(session_tilstand), "studio_v2/editor.no")
    assert_eq(workspace.studio_v2_state_session_aktiv_tab(session_tilstand), "studio_v2/main.no")
    assert_eq(workspace.studio_v2_state_session_split_fokus(session_tilstand), "venstre")
    assert_eq(workspace.studio_v2_state_session_tool_window(session_tilstand), "Inspect")
    assert_eq(workspace.studio_v2_state_session_run_config(session_tilstand), "test")
    assert_eq(workspace.studio_v2_state_session_tema(session_tilstand), "mørk")
    assert_eq(workspace.studio_v2_state_session_keymap(session_tilstand), "standard")
    assert_eq(workspace.studio_v2_state_session_runtimevalg(session_tilstand), "run")
    assert_eq(workspace.studio_v2_state_session_search_query(session_tilstand), "studio_v2")
    assert_eq(workspace.studio_v2_state_session_palette_status(session_tilstand), "lukket")
    assert_eq(workspace.studio_v2_state_session_sist_navigasjon(session_tilstand), "studio_v2/studio_state.no")
    assert_eq(workspace.studio_v2_state_session_tree_fold_satt(session_tilstand, "studio_v2/"), sann)
    assert_eq(workspace.studio_v2_state_session_breakpoints(session_tilstand), [])
    assert_eq(workspace.studio_v2_state_session_breakpoints_for_fil(session_tilstand, "studio_v2/editor.no"), [])
    assert_eq(workspace.studio_v2_state_session_output(session_tilstand), [])
    assert_eq(workspace.studio_v2_state_session_output_status(session_tilstand), "tom")
    assert_eq(studio_v2_gui_output_stderr_linjer("norscode run -> ok"), [])
    assert_eq(studio_v2_gui_output_stderr_linjer("Feil: ukjent kommando"), ["Feil: ukjent kommando"])
    assert_eq(workspace.studio_v2_state_session_run_profiles(session_tilstand), [])
    assert_eq(workspace.studio_v2_state_aktiv_fil(session_rot), "studio_v2/main.no")
    assert_eq(lengde(workspace.studio_v2_state_session_recent_for_workspace(session_rot)), 1)
    assert_eq(workspace.studio_v2_state_session_status_for_workspace(session_rot), "klar")
    assert_eq(lengde(workspace.studio_v2_state_apne_filer(session_rot, "studio_v2/main.no")), 3)
    assert_eq(workspace.studio_v2_state_apne_filer("/tmp/studio_v2_empty_test", ""), ["studio_v2/studio_state.no", "studio_v2/editor.no"])
    workspace.studio_v2_state_session_run_profile_skriv_med_tilstand(session_rot, "test", "--native-only", "/tmp", "A=1")
    la run_profile_session: liste_tekst = workspace.studio_v2_state_session_les(session_rot)
    assert_eq(workspace.studio_v2_state_session_run_profile_args(run_profile_session, "test"), "--native-only")
    assert_eq(workspace.studio_v2_state_session_run_profile_cwd(run_profile_session, "test", "."), "/tmp")
    assert_eq(workspace.studio_v2_state_session_run_profile_env(run_profile_session, "test"), "A=1")
    assert_eq(lengde(workspace.studio_v2_state_session_run_profiles(run_profile_session)), 3)
    assert(tekst_inneholder(workspace.studio_v2_state_session_run_profile_sammendrag(run_profile_session, "test", "."), "cwd=/tmp"))
    workspace.studio_v2_state_session_output_skriv_med_tilstand(session_rot, "test", "norscode test", ["Command: norscode test", "Target: studio_v2/main.no"], ["Ingen stderr"])
    la output_session: liste_tekst = workspace.studio_v2_state_session_les(session_rot)
    assert_eq(workspace.studio_v2_state_session_output_config(output_session), "test")
    assert_eq(workspace.studio_v2_state_session_output_command(output_session), "norscode test")
    assert_eq(workspace.studio_v2_state_session_output_code(output_session), "1")
    assert_eq(workspace.studio_v2_state_session_output_stdout(output_session), ["Command: norscode test", "Target: studio_v2/main.no"])
    assert_eq(workspace.studio_v2_state_session_output_stderr(output_session), ["Ingen stderr"])
    assert_eq(workspace.studio_v2_state_session_output_status(output_session), "klar")
    workspace.studio_v2_state_session_project_tree_anchor_skriv_med_tilstand(session_rot, "studio_v2/editor.no")
    la anchor_session: liste_tekst = workspace.studio_v2_state_session_les(session_rot)
    assert_eq(workspace.studio_v2_state_session_project_tree_anchor(anchor_session), "studio_v2/editor.no")
    assert(tekst_inneholder(workspace.studio_v2_state_session_output_sammendrag(output_session), "Stdout: 2"))
    assert_eq(workspace.studio_v2_state_session_test_history(output_session), [])
    workspace.studio_v2_state_session_test_history_skriv_med_tilstand(session_rot, "norscode test -> ok (1/1)")
    la history_session_1: liste_tekst = workspace.studio_v2_state_session_les(session_rot)
    assert_eq(workspace.studio_v2_state_session_test_history_siste(history_session_1), "norscode test -> ok (1/1)")
    workspace.studio_v2_state_session_test_history_skriv_med_tilstand(session_rot, "norscode test -> feil (kode 1, 0/1)")
    la history_session_2: liste_tekst = workspace.studio_v2_state_session_les(session_rot)
    assert_eq(workspace.studio_v2_state_session_test_history_siste(history_session_2), "norscode test -> feil (kode 1, 0/1)")
    assert_eq(lengde(workspace.studio_v2_state_session_test_history(history_session_2)), 2)
    workspace.studio_v2_state_session_innstillinger_skriv_med_tilstand(session_rot, "lys", "vim", "test")
    la settings_session_1: liste_tekst = workspace.studio_v2_state_session_les(session_rot)
    assert_eq(workspace.studio_v2_state_session_tema(settings_session_1), "lys")
    assert_eq(workspace.studio_v2_state_session_keymap(settings_session_1), "vim")
    assert_eq(workspace.studio_v2_state_session_runtimevalg(settings_session_1), "test")
    assert_eq(workspace.studio_v2_state_session_innstillinger(settings_session_1)[0], "lys")
    workspace.studio_v2_state_session_tema_skriv_med_tilstand(session_rot, "mørk")
    workspace.studio_v2_state_session_keymap_skriv_med_tilstand(session_rot, "standard")
    workspace.studio_v2_state_session_runtimevalg_skriv_med_tilstand(session_rot, "run")
    workspace.studio_v2_state_session_search_query_skriv_med_tilstand(session_rot, "studio_v2")
    la settings_session_2: liste_tekst = workspace.studio_v2_state_session_les(session_rot)
    assert_eq(workspace.studio_v2_state_session_tema(settings_session_2), "mørk")
    assert_eq(workspace.studio_v2_state_session_keymap(settings_session_2), "standard")
    assert_eq(workspace.studio_v2_state_session_runtimevalg(settings_session_2), "run")
    assert_eq(workspace.studio_v2_state_session_search_query(settings_session_2), "studio_v2")
    workspace.studio_v2_state_session_favoritter_skriv_med_tilstand(session_rot, "studio_v2/main.no")
    la favorite_session_1: liste_tekst = workspace.studio_v2_state_session_les(session_rot)
    assert_eq(workspace.studio_v2_state_session_favoritter(favorite_session_1), ["studio_v2/main.no"])
    workspace.studio_v2_state_session_favoritter_skriv_med_tilstand(session_rot, "studio_v2/editor.no")
    la favorite_session_2: liste_tekst = workspace.studio_v2_state_session_les(session_rot)
    assert_eq(workspace.studio_v2_state_session_favoritter(favorite_session_2), ["studio_v2/main.no", "studio_v2/editor.no"])
    workspace.studio_v2_state_session_favoritter_skriv_med_tilstand(session_rot, "studio_v2/main.no")
    la favorite_session_3: liste_tekst = workspace.studio_v2_state_session_les(session_rot)
    assert_eq(workspace.studio_v2_state_session_favoritter(favorite_session_3), ["studio_v2/editor.no"])
    la vcs_rot: tekst = "/tmp/studio_v2_vcs_test"
    la vcs_repo: tekst = vcs_rot + "/repo"
    la vcs_fil: tekst = vcs_repo + "/demo.no"
    actions.studio_v2_actions_kjor(["sh", "-lc", "rm -rf " + vcs_repo + " && mkdir -p " + vcs_repo + " && cd " + vcs_repo + " && git init -q && git config user.email test@example.com && git config user.name tester"])
    skriv_fil(vcs_fil, "funksjon demo() -> tekst {\n    returner \"ok\"\n}")
    actions.studio_v2_actions_kjor(["sh", "-lc", "cd " + vcs_repo + " && git add demo.no && git commit -q -m init"])
    skriv_fil(vcs_fil, "funksjon demo() -> tekst {\n    returner \"nei\"\n}")
    la vcs_status: liste_tekst = project.studio_v2_prosjekt_vcs_status(vcs_repo)
    la vcs_diff: liste_tekst = project.studio_v2_prosjekt_vcs_diff_stat(vcs_repo)
    la vcs_branch: tekst = project.studio_v2_prosjekt_vcs_branch(vcs_repo)
    la vcs_commit: liste_tekst = project.studio_v2_prosjekt_vcs_commit(vcs_repo)
    la vcs_history: liste_tekst = project.studio_v2_prosjekt_vcs_history(vcs_repo)
    assert(symbol.studio_v2_symbol_indeks_finn_navn(symbol.studio_v2_symbol_indeks_fra_kilde("studio_v2/demo.no", "funksjon demo() -> tekst {\n    returner \"ok\"\n}"), "demo") != "")
    assert(lengde(vcs_status) > 0)
    assert(tekst_inneholder(vcs_status[0], "demo.no"))
    assert(lengde(vcs_diff) > 0)
    assert(tekst_inneholder(vcs_diff[0], "demo.no"))
    assert(lengde(vcs_branch) > 0)
    assert(lengde(vcs_commit) > 0)
    assert(tekst_inneholder(vcs_commit[0], "init"))
    assert(lengde(vcs_history) > 0)
    assert(tekst_inneholder(vcs_history[0], "init"))
    project.studio_v2_prosjekt_vcs_stage(vcs_repo, "demo.no")
    la vcs_status_stage: liste_tekst = project.studio_v2_prosjekt_vcs_status(vcs_repo)
    assert(tekst_starter_med(vcs_status_stage[0], "M  "))
    project.studio_v2_prosjekt_vcs_unstage(vcs_repo, "demo.no")
    la vcs_status_unstage: liste_tekst = project.studio_v2_prosjekt_vcs_status(vcs_repo)
    assert(tekst_starter_med(vcs_status_unstage[0], " M"))
    assert_eq(project.studio_v2_prosjekt_vcs_changed_filer(vcs_repo), ["demo.no"])
    assert_eq(project.studio_v2_prosjekt_vcs_antall(vcs_repo), lengde(vcs_status))
    assert_eq(studio_v2_gui_vcs_fil_fra_statuslinje("M  demo.no"), "demo.no")
    assert_eq(studio_v2_gui_vcs_fil_fra_statuslinje("?? demo.no"), "demo.no")
    assert(tekst_inneholder(studio_v2_gui_vcs_status_linje(["M  demo.no"], "demo.no")[0], "▶"))
    assert(tekst_inneholder(studio_v2_gui_vcs_diff_linje([" demo.no | 2 +-"])[0], "demo.no"))
    assert(tekst_inneholder(studio_v2_gui_vcs_commit_linje(["init commit"])[0], "init commit"))
    assert(tekst_inneholder(studio_v2_gui_vcs_history_linje(["init commit"])[0], "init commit"))
    assert_eq(studio_v2_gui_output_filtrer_linjer(["alpha", "beta", "gamma"], "et"), ["beta"])
    assert_eq(studio_v2_gui_output_filter_status("", 2, 1), "Filter: none · Stdout: 2 · Stderr: 1")
    assert_eq(studio_v2_gui_output_filter_status("beta", 1, 0), "Filter: beta · Stdout: 1 · Stderr: 0")
    la output_stdout_linjer: liste_tekst = studio_v2_gui_output_stdout_linjer(".", "studio_v2/main.no", "run", session_tilstand)
    assert(tekst_starter_med(output_stdout_linjer[0], "Command: "))
    assert(tekst_inneholder(output_stdout_linjer[1], "Config: test"))
    la f1_2_rot: tekst = "/tmp/studio_v2_f1_2_run_test"
    actions.studio_v2_actions_kjor(["sh", "-lc", "mkdir -p " + f1_2_rot + "/.norscode"])
    workspace.studio_v2_state_session_lagre_med_tilstand(f1_2_rot, "studio_v2/main.no", "studio_v2/main.no", "høyre", "Inspect", "run", "mørk", "standard", "run", "", ["studio_v2/"])
    workspace.studio_v2_state_session_output_skriv_med_tilstand(f1_2_rot, "run", "norscode run studio_v2/main.no", ["Command: norscode run", "Target: studio_v2/main.no"], [])
    la f1_2_run_session: liste_tekst = workspace.studio_v2_state_session_les(f1_2_rot)
    assert_eq(workspace.studio_v2_state_session_output_config(f1_2_run_session), "run")
    assert_eq(workspace.studio_v2_state_session_output_command(f1_2_run_session), "norscode run studio_v2/main.no")
    assert_eq(workspace.studio_v2_state_session_output_status(f1_2_run_session), "klar")
    assert_eq(workspace.studio_v2_state_session_run_config(f1_2_run_session), "run")
    workspace.studio_v2_state_session_output_skriv_med_tilstand(f1_2_rot, "test", "norscode test studio_v2/main.no", ["Command: norscode test", "Target: studio_v2/main.no"], ["Ingen stderr"])
    la f1_2_test_session: liste_tekst = workspace.studio_v2_state_session_les(f1_2_rot)
    assert_eq(workspace.studio_v2_state_session_output_config(f1_2_test_session), "test")
    assert_eq(workspace.studio_v2_state_session_output_command(f1_2_test_session), "norscode test studio_v2/main.no")
    assert_eq(workspace.studio_v2_state_session_run_config(f1_2_test_session), "run")
    assert_eq(workspace.studio_v2_state_session_output_status(f1_2_test_session), "klar")
    assert(tekst_inneholder(workspace.studio_v2_state_session_output_sammendrag(f1_2_test_session), "Stdout: 2"))
    la f2_4_2_rot: tekst = "/tmp/studio_v2_f2_4_2_run_test_flow"
    la f2_4_2_kommando: tekst = f2_4_2_rot + "/dist/norscode"
    actions.studio_v2_actions_kjor(["sh", "-lc", "mkdir -p " + f2_4_2_rot + "/dist " + f2_4_2_rot + "/.norscode && printf '%s\n' '#!/bin/sh' 'echo mock-command \"$@\"' 'exit 0' > " + f2_4_2_kommando + " && chmod +x " + f2_4_2_kommando + " && printf 'funksjon demo() -> tekst {\\n    returner \"ok\"\\n}\\n' > " + f2_4_2_rot + "/main.no"])
    workspace.studio_v2_state_session_lagre_med_tilstand(f2_4_2_rot, "main.no", "main.no", "høyre", "Project", "run", "mørk", "standard", "run", "", [])
    la f2_4_2_run_kommando: liste_tekst = actions.studio_v2_actions_kommando_for_navn(f2_4_2_rot, "main.no", "run")
    la f2_4_2_test_kommando: liste_tekst = actions.studio_v2_actions_kommando_for_navn(f2_4_2_rot, "main.no", "test")
    assert_eq(studio_v2_gui_kjor_handling_rot(f2_4_2_rot, "run"), actions.studio_v2_actions_kommando_tekst(f2_4_2_run_kommando) + " -> ok")
    la f2_4_2_run_session: liste_tekst = workspace.studio_v2_state_session_les(f2_4_2_rot)
    assert_eq(workspace.studio_v2_state_session_output_config(f2_4_2_run_session), "run")
    assert_eq(workspace.studio_v2_state_session_output_command(f2_4_2_run_session), actions.studio_v2_actions_kommando_tekst(f2_4_2_run_kommando))
    assert_eq(workspace.studio_v2_state_session_output_status(f2_4_2_run_session), "klar")
    la f2_4_2_forventet_test_resultat: tekst = actions.studio_v2_actions_kommando_tekst(f2_4_2_test_kommando) + " -> ingen testfiler"
    assert_eq(studio_v2_gui_kjor_handling_rot(f2_4_2_rot, "test"), f2_4_2_forventet_test_resultat)
    la f2_4_2_test_session: liste_tekst = workspace.studio_v2_state_session_les(f2_4_2_rot)
    assert_eq(workspace.studio_v2_state_session_output_config(f2_4_2_test_session), "test")
    assert_eq(workspace.studio_v2_state_session_output_command(f2_4_2_test_session), actions.studio_v2_actions_kommando_tekst(f2_4_2_test_kommando))
    assert_eq(workspace.studio_v2_state_session_output_status(f2_4_2_test_session), "klar")
    assert_eq(workspace.studio_v2_state_session_run_config(f2_4_2_test_session), "run")
    assert_eq(workspace.studio_v2_state_session_test_history_siste(f2_4_2_test_session), f2_4_2_forventet_test_resultat)
    la f1_3_rot: tekst = "/tmp/studio_v2_f1_3_keyboard"
    actions.studio_v2_actions_kjor(["sh", "-lc", "mkdir -p " + f1_3_rot + "/.norscode"])
    workspace.studio_v2_state_session_lagre_med_tilstand(f1_3_rot, "studio_v2/main.no", "studio_v2/main.no", "høyre", "Project", "run", "lukket", "studio_v2/main.no", [])
    la f1_3_baseline: liste_tekst = workspace.studio_v2_state_session_les(f1_3_rot)
    assert_eq(workspace.studio_v2_state_session_palette_status(f1_3_baseline), "lukket")
    assert_eq(workspace.studio_v2_state_session_search_query(f1_3_baseline), "")
    assert_eq(workspace.studio_v2_state_session_tool_window(f1_3_baseline), "Project")
    assert_eq(workspace.studio_v2_state_session_run_config(f1_3_baseline), "run")
    workspace.studio_v2_state_session_lagre_med_tilstand(f1_3_rot, "studio_v2/main.no", "studio_v2/main.no", "høyre", "Project", "run", "åpen", "studio_v2/main.no", [])
    la f1_3_palette: liste_tekst = workspace.studio_v2_state_session_les(f1_3_rot)
    assert_eq(workspace.studio_v2_state_session_palette_status(f1_3_palette), "åpen")
    assert_eq(workspace.studio_v2_state_session_tool_window(f1_3_palette), "Project")
    assert_eq(workspace.studio_v2_state_session_run_config(f1_3_palette), "run")
    workspace.studio_v2_state_session_search_query_skriv_med_tilstand(f1_3_rot, "main")
    la f1_3_after_search: liste_tekst = workspace.studio_v2_state_session_les(f1_3_rot)
    assert_eq(workspace.studio_v2_state_session_search_query(f1_3_after_search), "main")
    assert_eq(workspace.studio_v2_state_session_palette_status(f1_3_after_search), "åpen")
    assert_eq(workspace.studio_v2_state_session_tool_window(f1_3_after_search), "Project")
    assert_eq(workspace.studio_v2_state_session_run_config(f1_3_after_search), "run")
    la f1_3_sok_resultat: liste_tekst = studio_v2_gui_sok_resultater(".", "main.no")
    assert(lengde(f1_3_sok_resultat) > 0)
