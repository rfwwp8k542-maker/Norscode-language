    assert_eq(diagnostics.studio_v2_diagnostics_alvorlighet_fra_slag("syntax_error"), "error")
    assert_eq(diagnostics.studio_v2_diagnostics_alvorlighet_fra_slag("warning"), "warning")
    assert_eq(diagnostics.studio_v2_diagnostics_alvorlighet_fra_slag("info"), "info")
    assert_eq(diagnostics.studio_v2_diagnostics_alvorlighet_fra_slag("annet"), "unknown")
    assert(diagnostics.studio_v2_diagnostics_er_fatal("syntax_error"))
    assert(ikke diagnostics.studio_v2_diagnostics_er_fatal("info"))
    assert_eq(diagnostics.studio_v2_diagnostics_antall_fatal(["syntax_error\tstudio_v2/demo.no\t7\tmangler returtype med ->", "warning\tstudio_v2/demo.no\t8\tnoe", "info\tstudio_v2/demo.no\t9\tinfo"]), 1)
    assert_eq(diagnostics.studio_v2_diagnostics_antall_gjenvinnbare(["syntax_error\tstudio_v2/demo.no\t7\tmangler returtype med ->", "warning\tstudio_v2/demo.no\t8\tnoe", "info\tstudio_v2/demo.no\t9\tinfo"]), 2)
    la diagnose_severity_linjer: liste_tekst = studio_v2_gui_diagnostikk_linjer(["syntax_error\tstudio_v2/demo.no\t7\tmangler returtype med ->", "warning\tstudio_v2/demo.no\t8\tnoe"])
    assert_eq(diagnose_severity_linjer[0], "⛔ syntax_error\tstudio_v2/demo.no\t7\tmangler returtype med ->")
    assert_eq(diagnose_severity_linjer[1], "⚠ warning\tstudio_v2/demo.no\t8\tnoe")
    assert_eq(studio_v2_gui_diagnostikk_tomtilstand([]), "No problems yet")
    assert_eq(studio_v2_gui_diagnostikk_tomtilstand(["syntax_error\tstudio_v2/demo.no\t7\tmangler returtype med ->"]), "Shortcut: Enter logs problem")
    assert_eq(studio_v2_gui_markert_valg("⛔ syntax_error\tstudio_v2/demo.no\t7\tmangler"), "syntax_error\tstudio_v2/demo.no\t7\tmangler")
    assert_eq(studio_v2_gui_diagnostikk_detalj("⛔ syntax_error\tstudio_v2/demo.no\t7\tmangler returtype med -> @kolonne 3"), "error · studio_v2/demo.no:7 · mangler returtype med -> @kolonne 3")
    la diagnostics_entry: tekst = diagnostics.studio_v2_diagnostics_tekst_oppføring("syntax_error", "studio_v2/demo.no", 7, "mangler returtype med ->")
    assert_eq(studio_v2_gui_trekk_ut_fil(diagnostics_entry), "studio_v2/demo.no")
    assert_eq(studio_v2_gui_trekk_ut_linje(diagnostics_entry), 7)
    assert_eq(studio_v2_gui_trekk_ut_melding(diagnostics_entry), "mangler returtype med ->")
    la diagnostics_update_rot: tekst = "/tmp"
    la diagnostics_update_fil: tekst = diagnostics_update_rot + "/studio_v2_diagnostics_update_test.no"
    skriv_fil(diagnostics_update_fil, "funksjon demo() -> tekst {\n    returner \"ok\"\n}")
    la diagnostics_update_god: liste_tekst = diagnostics.studio_v2_diagnostics_fra_workspace_med_filer(diagnostics_update_rot, [diagnostics_update_fil], 1)
    assert(tekst_inneholder(diagnostics.studio_v2_diagnostics_finn_oppføring(diagnostics_update_god, "syntax_errors"), "0"))
    assert(tekst_inneholder(diagnostics.studio_v2_diagnostics_finn_oppføring(diagnostics_update_god, "syntax_errors_fatal"), "0"))
    assert(tekst_inneholder(diagnostics.studio_v2_diagnostics_finn_oppføring(diagnostics_update_god, "syntax_errors_gjenvinnbare"), "0"))
    skriv_fil(diagnostics_update_fil, "funksjon demo( -> tekst {\n    returner \"ok\"\n")
    la diagnostics_update_feil: liste_tekst = diagnostics.studio_v2_diagnostics_fra_workspace_med_filer(diagnostics_update_rot, [diagnostics_update_fil], 1)
    assert(tekst_inneholder(diagnostics.studio_v2_diagnostics_finn_oppføring(diagnostics_update_feil, "syntax_errors"), "1"))
    assert(tekst_inneholder(diagnostics.studio_v2_diagnostics_finn_oppføring(diagnostics_update_feil, "syntax_errors_fatal"), "1"))
    assert(tekst_inneholder(diagnostics.studio_v2_diagnostics_finn_oppføring(diagnostics_update_feil, "syntax_errors_gjenvinnbare"), "0"))
    la diagnostics_filer: liste_tekst = diagnostics.studio_v2_diagnostics_fra_workspace_med_filer(".", workspace_filer, lengde(symbol_workspace_index))
    assert(lengde(diagnostics_filer) > 14)
    assert(tekst_inneholder(diagnostics.studio_v2_diagnostics_fra_workspace_med_filer(".", workspace_filer, lengde(symbol_workspace_index))[3], "workspace_filer"))
    assert(tekst_inneholder(diagnostics_filer[4], "workspace_sammendrag"))
    assert(tekst_inneholder(diagnostics_filer[5], "syntax_errors"))
    assert(tekst_inneholder(diagnostics_filer[6], "syntax_errors_fatal"))
    assert(tekst_inneholder(diagnostics_filer[7], "syntax_errors_gjenvinnbare"))
    assert(tekst_inneholder(diagnostics_filer[8], "symbol_definisjoner"))
    assert(tekst_inneholder(diagnostics_filer[9], "symbol_bruk"))
    assert(tekst_inneholder(diagnostics_filer[lengde(diagnostics_filer) - 2], "symbol_importer"))
    assert(tekst_inneholder(diagnostics_filer[lengde(diagnostics_filer) - 1], "symbol_lokale"))
    assert_eq(diagnostics.studio_v2_diagnostics_status("."), "klar")
    assert(lengde(diagnostics.studio_v2_diagnostics_oppdater_med_filer(".", workspace_filer, lengde(symbol_workspace_index))) > 13)
    assert_eq(diagnostics.studio_v2_diagnostics_oppdater_status("."), "oppdatert")
    la ai_provider: liste_tekst = ai.studio_v2_ai_provider_fra_modus("lokal", ai.studio_v2_ai_modus_lokal())
    assert_eq(ai.studio_v2_ai_provider_navn(ai_provider), "lokal")
    assert_eq(ai.studio_v2_ai_provider_modus(ai_provider), "local")
    assert(ai.studio_v2_ai_provider_kan_bruke(ai_provider))
    assert_eq(ai.studio_v2_ai_provider_status(ai_provider), "klar")
    la ai_kontekst: liste_tekst = ai_context.studio_v2_ai_kontekst_sammendrag("Norscode Studio v2", ".", "studio_v2/main.no", "funksjon start() -> heltall {\n    returner 0\n}", diagnostics_filer)
    assert_eq(ai_context.studio_v2_ai_kontekst_antall(ai_kontekst), 12)
    assert_eq(ai_context.studio_v2_ai_kontekst_forste(ai_kontekst), "prosjekt\tNorscode Studio v2")
    assert_eq(lengde(ai.studio_v2_ai_handlinger()), 5)
    assert_eq(ai.studio_v2_ai_handlinger_forste(), "forklar-kode")
    assert_eq(ai.studio_v2_ai_handlinger_status(), "preview-first")
    la ai_patch_preview: liste_tekst = ai.studio_v2_ai_patch_previsjon_fra_kontekst(ai_kontekst)
    assert_eq(lengde(ai_patch_preview), 3)
    assert_eq(ai.studio_v2_ai_patch_previsjon_status(ai_patch_preview), "preview")
    assert(tekst_inneholder(ai.studio_v2_ai_patch_previsjon_forste(ai_patch_preview), "forslag"))
    assert_eq(ai.studio_v2_ai_patch_godkjenn(ai_patch_preview), "godkjent")
    assert_eq(ai.studio_v2_ai_patch_avvis(ai_patch_preview), "avvist")
    la ai_opt_in: liste_tekst = ai.studio_v2_ai_opt_in_lag("Norscode Studio v2", usann, sann, sann)
    assert_eq(ai.studio_v2_ai_opt_in_workspace(ai_opt_in), "Norscode Studio v2")
    assert(ai.studio_v2_ai_opt_in_offline_only(ai_opt_in))
    assert_eq(ai.studio_v2_ai_opt_in_status(ai_opt_in), "offline-only")
    assert_eq(ai.studio_v2_ai_personvern_status(), "klar")
    assert_eq(lengde(ai.studio_v2_ai_personvern_policy()), 4)
    la ai_sikker_kontekst: liste_tekst = ai.studio_v2_ai_kontekst_sikker(ai_opt_in, [
        "hemmelig nøkkel",
        "passord er skjult",
        "token bør skjules"
    ])
    assert_eq(lengde(ai_sikker_kontekst), 3)
    assert(tekst_inneholder(ai_sikker_kontekst[0], "[redacted]"))
    assert_eq(ai.studio_v2_ai_kontekst_sikker_status(ai_opt_in), "offline-only")
    assert(ikke ai.studio_v2_ai_personvern_kan_sende(ai_opt_in))
    assert(tekst_inneholder(ai.studio_v2_ai_handling_forklar_kode(ai_kontekst), "Forklar koden:"))
    assert(tekst_inneholder(ai.studio_v2_ai_handling_sammendrag_fil(ai_kontekst), "Oppsummer filen:"))
