    assert_eq(studio_v2_gui_test_resultat_linjer(["tests/test_studio_v2.no"], ["0"]), ["● tests/test_studio_v2.no:1 · ok"])
    assert(tekst_inneholder(studio_v2_gui_test_resultat_linjer(["tests/test_studio_v2.no", "tests/test_other.no"], ["0", "1"])[1], "feil (kode 1)"))
    assert(tekst_inneholder(studio_v2_gui_test_resultat_linjer(["tests/test_studio_v2.no"], ["2"])[0], "skipped"))
    assert_eq(studio_v2_gui_test_feil_linjer(["tests/test_studio_v2.no"], ["0"]), [])
    assert_eq(studio_v2_gui_test_feil_linjer(["tests/test_studio_v2.no"], ["2"]), [])
    assert(tekst_inneholder(studio_v2_gui_test_feil_linjer(["tests/test_studio_v2.no"], ["1"])[0], "Feil: tests/test_studio_v2.no:1"))
    assert(tekst_inneholder(studio_v2_gui_test_sammendrag(["tests/test_studio_v2.no"], ["0"]), "ok (1/1)"))
    assert(tekst_inneholder(studio_v2_gui_test_sammendrag(["tests/test_studio_v2.no"], ["2"]), "skipped 1"))
    assert(tekst_inneholder(studio_v2_gui_test_sammendrag(["tests/test_studio_v2.no", "tests/test_other.no"], ["0", "1"]), "feil"))
    assert_eq(studio_v2_gui_output_destinasjon_fra_oppføring("● tests/test_studio_v2.no:1 · ok"), ["tests/test_studio_v2.no", "1"])
    assert_eq(studio_v2_gui_output_destinasjon_fra_oppføring("Feil: tests/test_studio_v2.no:1 · feil (kode 1)"), ["tests/test_studio_v2.no", "1"])
