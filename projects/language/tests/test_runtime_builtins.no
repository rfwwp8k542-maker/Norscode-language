funksjon start() -> heltall {
    assert(fil_eksisterer("tests/test_runtime_builtins.no"))

    la path_verdi: tekst = les_miljo("PATH")
    assert(tekst_lengde(path_verdi) > 0)

    la input_verdi: tekst = les_input("Skriv noe")
    assert_eq(input_verdi, "")

    assert_eq(tekst_lengde("Hei verden"), 10)
    assert_eq(tekst_fra_heltall(42), "42")
    assert_eq(tekst_fra_bool(sann), "sann")
    assert_eq(tekst_til_små("Hei Norscode"), "hei norscode")
    assert_eq(tekst_til_store("Hei Norscode"), "HEI NORSCODE")
    assert_eq(tekst_til_tittel("hei norscode"), "Hei Norscode")
    assert_eq(tekst_omvendt("Hei Norscode"), "edocsroN ieH")
    assert_eq(lengde(del_på("a,b,c", ",")), 3)
    assert_eq(del_på("a,b,c", ",")[0], "a")
    assert_eq(del_på("a,b,c", ",")[1], "b")
    assert_eq(del_på("a,b,c", ",")[2], "c")
    assert_eq(lengde(del_på("abc", "")), 1)
    assert_eq(del_på("abc", "")[0], "abc")
    assert_eq(heltall_fra_tekst(" 17 "), 17)
    assert_eq(tekst_slutter_med("Hei verden", "verden"), sann)
    assert_eq(tekst_trim("  hei  "), "hei")
    assert_eq(tekst_slice("Hei verden", 4, 10), "verden")
    assert(tekst_starter_med("Feil: noe gikk galt", "Feil:"))
    assert(tekst_inneholder("Hei verden", "ver"))
    assert_eq(tekst_erstatt("Hei verden", "verden", "Norscode"), "Hei Norscode")
    assert_eq(lengde(del_ord("hei   verden")), 2)
    la enkle_tokens = tokeniser_enkel("abc # kommentar\ndef-g")
    assert_eq(lengde(enkle_tokens), 2)
    assert_eq(enkle_tokens[0], "abc")
    assert_eq(enkle_tokens[1], "def-g")

    la uttrykk_tokens = tokeniser_uttrykk("la x = 10 + y")
    assert_eq(lengde(uttrykk_tokens), 6)
    assert_eq(uttrykk_tokens[0], "la")
    assert_eq(uttrykk_tokens[1], "x")
    assert_eq(uttrykk_tokens[2], "=")
    assert_eq(uttrykk_tokens[3], "10")
    assert_eq(uttrykk_tokens[4], "+")
    assert_eq(uttrykk_tokens[5], "y")
    assert_eq(sass_til_css("$farge: red;\n.knapp {\n  color: $farge;\n}"), ".knapp { color: red; }\n")
    assert(tekst_er_ordtegn("a"))
    assert_ne(tekst_er_ordtegn("-"), sann)
    assert_eq(lengde(del_linjer("linje 1\nlinje 2")), 2)

    returner 0
}
