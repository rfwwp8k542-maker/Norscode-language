bruk std.math
bruk std.tekst som t

funksjon start() -> heltall {
    # Heltall
    assert_eq(2 + 3, 5)

    la sum: heltall = math.pluss(10, 20)
    assert_eq(sum, 30)

    # Tekst
    la h: tekst = t.hilsen("Jan")
    assert_eq(h, "Hei Jan")

    # Bool
    assert_eq(sann, sann)

    skriv("test_assert_eq OK")
    returner 0
}
