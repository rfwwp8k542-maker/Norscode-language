# Web-standardbibliotek for Bootstrap, CSS, Sass og en enkel HTTP-kjerne

funksjon http_status_tekst(kode: heltall) -> tekst {
    hvis kode == 200 da {
        returner "OK"
    } ellers hvis kode == 201 da {
        returner "Created"
    } ellers hvis kode == 202 da {
        returner "Accepted"
    } ellers hvis kode == 204 da {
        returner "No Content"
    } ellers hvis kode == 301 da {
        returner "Moved Permanently"
    } ellers hvis kode == 302 da {
        returner "Found"
    } ellers hvis kode == 400 da {
        returner "Bad Request"
    } ellers hvis kode == 401 da {
        returner "Unauthorized"
    } ellers hvis kode == 403 da {
        returner "Forbidden"
    } ellers hvis kode == 404 da {
        returner "Not Found"
    } ellers hvis kode == 405 da {
        returner "Method Not Allowed"
    } ellers hvis kode == 409 da {
        returner "Conflict"
    } ellers hvis kode == 415 da {
        returner "Unsupported Media Type"
    } ellers hvis kode == 422 da {
        returner "Unprocessable Content"
    } ellers hvis kode == 500 da {
        returner "Internal Server Error"
    } ellers hvis kode == 502 da {
        returner "Bad Gateway"
    }
    returner "Unknown Status"
}

funksjon http_statuslinje(kode: heltall) -> tekst {
    la status: tekst = ""
    hvis kode == 200 da {
        status = "OK"
    } ellers hvis kode == 201 da {
        status = "Created"
    } ellers hvis kode == 202 da {
        status = "Accepted"
    } ellers hvis kode == 204 da {
        status = "No Content"
    } ellers hvis kode == 301 da {
        status = "Moved Permanently"
    } ellers hvis kode == 302 da {
        status = "Found"
    } ellers hvis kode == 400 da {
        status = "Bad Request"
    } ellers hvis kode == 401 da {
        status = "Unauthorized"
    } ellers hvis kode == 403 da {
        status = "Forbidden"
    } ellers hvis kode == 404 da {
        status = "Not Found"
    } ellers hvis kode == 405 da {
        status = "Method Not Allowed"
    } ellers hvis kode == 409 da {
        status = "Conflict"
    } ellers hvis kode == 415 da {
        status = "Unsupported Media Type"
    } ellers hvis kode == 422 da {
        status = "Unprocessable Content"
    } ellers hvis kode == 500 da {
        status = "Internal Server Error"
    } ellers hvis kode == 502 da {
        status = "Bad Gateway"
    } ellers {
        status = "Unknown Status"
    }
    returner "HTTP/1.1 " + tekst_fra_heltall(kode) + " " + status
}

funksjon http_header_tekst(navn: tekst, verdi: tekst) -> tekst {
    returner navn + ": " + verdi
}

funksjon http_content_type_html() -> tekst {
    returner "text/html; charset=utf-8"
}

funksjon http_content_type_json() -> tekst {
    returner "application/json; charset=utf-8"
}

funksjon http_content_type_text() -> tekst {
    returner "text/plain; charset=utf-8"
}

funksjon http_respons_tekst(kode: heltall, content_type: tekst, body: tekst) -> tekst {
    la status: tekst = ""
    hvis kode == 200 da {
        status = "OK"
    } ellers hvis kode == 201 da {
        status = "Created"
    } ellers hvis kode == 202 da {
        status = "Accepted"
    } ellers hvis kode == 204 da {
        status = "No Content"
    } ellers hvis kode == 301 da {
        status = "Moved Permanently"
    } ellers hvis kode == 302 da {
        status = "Found"
    } ellers hvis kode == 400 da {
        status = "Bad Request"
    } ellers hvis kode == 401 da {
        status = "Unauthorized"
    } ellers hvis kode == 403 da {
        status = "Forbidden"
    } ellers hvis kode == 404 da {
        status = "Not Found"
    } ellers hvis kode == 405 da {
        status = "Method Not Allowed"
    } ellers hvis kode == 409 da {
        status = "Conflict"
    } ellers hvis kode == 415 da {
        status = "Unsupported Media Type"
    } ellers hvis kode == 422 da {
        status = "Unprocessable Content"
    } ellers hvis kode == 500 da {
        status = "Internal Server Error"
    } ellers hvis kode == 502 da {
        status = "Bad Gateway"
    } ellers {
        status = "Unknown Status"
    }
    la respons: tekst = "HTTP/1.1 " + tekst_fra_heltall(kode) + " " + status + "\r\n"
    respons = respons + "Content-Type: " + content_type + "\r\n"
    respons = respons + "Content-Length: " + tekst_fra_heltall(tekst_lengde(body)) + "\r\n"
    respons = respons + "\r\n"
    returner respons + body
}

funksjon http_json_respons(body: tekst) -> tekst {
    la respons: tekst = "HTTP/1.1 200 OK\r\n"
    respons = respons + "Content-Type: " + http_content_type_json() + "\r\n"
    respons = respons + "Content-Length: " + tekst_fra_heltall(tekst_lengde(body)) + "\r\n"
    respons = respons + "\r\n"
    returner respons + body
}

funksjon http_html_respons(body: tekst) -> tekst {
    la respons: tekst = "HTTP/1.1 200 OK\r\n"
    respons = respons + "Content-Type: " + http_content_type_html() + "\r\n"
    respons = respons + "Content-Length: " + tekst_fra_heltall(tekst_lengde(body)) + "\r\n"
    respons = respons + "\r\n"
    returner respons + body
}

funksjon http_tekst_respons(body: tekst) -> tekst {
    la respons: tekst = "HTTP/1.1 200 OK\r\n"
    respons = respons + "Content-Type: " + http_content_type_text() + "\r\n"
    respons = respons + "Content-Length: " + tekst_fra_heltall(tekst_lengde(body)) + "\r\n"
    respons = respons + "\r\n"
    returner respons + body
}

funksjon http_omdirigering_respons(lokasjon: tekst) -> tekst {
    la respons: tekst = "HTTP/1.1 302 Found\r\n"
    respons = respons + "Location: " + lokasjon + "\r\n"
    respons = respons + "Content-Type: " + http_content_type_text() + "\r\n"
    respons = respons + "Content-Length: 0\r\n"
    respons = respons + "\r\n"
    returner respons
}

funksjon http_request_tekst(method: tekst, path: tekst, host: tekst, content_type: tekst, body: tekst) -> tekst {
    la request: tekst = method + " " + path + " HTTP/1.1\r\n"
    request = request + "Host: " + host + "\r\n"
    request = request + "Content-Type: " + content_type + "\r\n"
    request = request + "Content-Length: " + tekst_fra_heltall(tekst_lengde(body)) + "\r\n"
    request = request + "\r\n"
    returner request + body
}

funksjon http_server_start(ruter: liste_tekst, host: tekst, port: heltall) -> heltall {
    returner web_server_start(ruter, host, port)
}

funksjon router_tom() -> liste_tekst {
    returner []
}

funksjon router_registrer(ruter: liste_tekst, metode: tekst, mønster: tekst, navn: tekst) -> heltall {
    legg_til(ruter, metode + "\t" + mønster + "\t" + navn)
    returner lengde(ruter)
}

funksjon router_path_match(mønster: tekst, sti: tekst) -> bool {
    la mønster_deler: liste_tekst = tekst_del_på(mønster, "/")
    la sti_deler: liste_tekst = tekst_del_på(sti, "/")
    la mønster_segmenter: liste_tekst = []
    la sti_segmenter: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(mønster_deler)) {
        hvis mønster_deler[i] != "" da {
            legg_til(mønster_segmenter, mønster_deler[i])
        }
        i = i + 1
    }
    i = 0
    mens (i < lengde(sti_deler)) {
        hvis sti_deler[i] != "" da {
            legg_til(sti_segmenter, sti_deler[i])
        }
        i = i + 1
    }
    hvis lengde(mønster_segmenter) != lengde(sti_segmenter) da {
        returner usann
    }
    i = 0
    mens (i < lengde(mønster_segmenter)) {
        la mønster_segment: tekst = mønster_segmenter[i]
        la sti_segment: tekst = sti_segmenter[i]
        hvis ikke (tekst_starter_med(mønster_segment, "{") og tekst_slutter_med(mønster_segment, "}")) og mønster_segment != sti_segment da {
            returner usann
        }
        i = i + 1
    }
    returner sann
}

funksjon router_path_param(mønster: tekst, sti: tekst, navn: tekst) -> tekst {
    la mønster_deler: liste_tekst = tekst_del_på(mønster, "/")
    la sti_deler: liste_tekst = tekst_del_på(sti, "/")
    la mønster_segmenter: liste_tekst = []
    la sti_segmenter: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(mønster_deler)) {
        hvis mønster_deler[i] != "" da {
            legg_til(mønster_segmenter, mønster_deler[i])
        }
        i = i + 1
    }
    i = 0
    mens (i < lengde(sti_deler)) {
        hvis sti_deler[i] != "" da {
            legg_til(sti_segmenter, sti_deler[i])
        }
        i = i + 1
    }
    hvis lengde(mønster_segmenter) != lengde(sti_segmenter) da {
        returner ""
    }
    i = 0
    mens (i < lengde(mønster_segmenter)) {
        la mønster_segment: tekst = mønster_segmenter[i]
        la sti_segment: tekst = sti_segmenter[i]
        hvis tekst_starter_med(mønster_segment, "{") og tekst_slutter_med(mønster_segment, "}") da {
            la segment_navn: tekst = tekst_slice(mønster_segment, 1, tekst_lengde(mønster_segment) - 1)
            hvis segment_navn == navn da {
                returner sti_segment
            }
        }
        i = i + 1
    }
    returner ""
}

funksjon router_query_param(query: tekst, navn: tekst) -> tekst {
    la ren_query: tekst = query
    hvis tekst_starter_med(ren_query, "?") da {
        ren_query = tekst_slice(ren_query, 1, tekst_lengde(ren_query))
    }
    la deler: liste_tekst = tekst_del_på(ren_query, "&")
    la i: heltall = 0
    mens (i < lengde(deler)) {
        la par: tekst = deler[i]
        hvis par != "" da {
            la par_deler: liste_tekst = tekst_del_på(par, "=")
            hvis lengde(par_deler) >= 1 og par_deler[0] == navn da {
                hvis lengde(par_deler) >= 2 da {
                    returner par_deler[1]
                }
                returner ""
            }
        }
        i = i + 1
    }
    returner ""
}

funksjon router_join_path(prefix: tekst, sti: tekst) -> tekst {
    hvis prefix == "" da {
        returner sti
    }
    hvis sti == "" da {
        returner prefix
    }
    la prefix_slutter_med_skråstrek: bool = tekst_slutter_med(prefix, "/")
    la sti_starter_med_skråstrek: bool = tekst_starter_med(sti, "/")
    hvis prefix_slutter_med_skråstrek og sti_starter_med_skråstrek da {
        returner prefix + tekst_slice(sti, 1, tekst_lengde(sti))
    }
    hvis prefix_slutter_med_skråstrek eller sti_starter_med_skråstrek da {
        returner prefix + sti
    }
    returner prefix + "/" + sti
}

funksjon router_match_rute(ruter: liste_tekst, metode: tekst, sti: tekst) -> tekst {
    la i: heltall = 0
    mens (i < lengde(ruter)) {
        la rute: tekst = ruter[i]
        la deler: liste_tekst = tekst_del_på(rute, "\t")
        hvis lengde(deler) >= 3 og deler[0] == metode da {
            la mønster_deler: liste_tekst = tekst_del_på(deler[1], "/")
            la sti_deler: liste_tekst = tekst_del_på(sti, "/")
            la mønster_segmenter: liste_tekst = []
            la sti_segmenter: liste_tekst = []
            la j: heltall = 0
            mens (j < lengde(mønster_deler)) {
                hvis mønster_deler[j] != "" da {
                    legg_til(mønster_segmenter, mønster_deler[j])
                }
                j = j + 1
            }
            j = 0
            mens (j < lengde(sti_deler)) {
                hvis sti_deler[j] != "" da {
                    legg_til(sti_segmenter, sti_deler[j])
                }
                j = j + 1
            }
            hvis lengde(mønster_segmenter) == lengde(sti_segmenter) da {
                la match: bool = sann
                j = 0
                mens (j < lengde(mønster_segmenter)) {
                    la mønster_segment: tekst = mønster_segmenter[j]
                    la sti_segment: tekst = sti_segmenter[j]
                    hvis ikke (tekst_starter_med(mønster_segment, "{") og tekst_slutter_med(mønster_segment, "}")) og mønster_segment != sti_segment da {
                        match = usann
                    }
                    j = j + 1
                }
                hvis match da {
                    returner deler[2]
                }
            }
        }
        i = i + 1
    }
    returner ""
}

funksjon http_query_felt_tekst(query: tekst, navn: tekst) -> tekst {
    la ren_query: tekst = query
    hvis tekst_starter_med(ren_query, "?") da {
        ren_query = tekst_slice(ren_query, 1, tekst_lengde(ren_query))
    }
    la deler: liste_tekst = tekst_del_på(ren_query, "&")
    la i: heltall = 0
    mens (i < lengde(deler)) {
        la par: tekst = tekst_trim(deler[i])
        hvis par != "" da {
            la par_deler: liste_tekst = tekst_del_på(par, "=")
            hvis lengde(par_deler) >= 1 og tekst_trim(par_deler[0]) == navn da {
                hvis lengde(par_deler) >= 2 da {
                    returner tekst_trim(par_deler[1])
                }
                returner ""
            }
        }
        i = i + 1
    }
    returner ""
}

funksjon http_query_felt_heltall(query: tekst, navn: tekst) -> heltall {
    la ren_query: tekst = query
    hvis tekst_starter_med(ren_query, "?") da {
        ren_query = tekst_slice(ren_query, 1, tekst_lengde(ren_query))
    }
    la deler: liste_tekst = tekst_del_på(ren_query, "&")
    la i: heltall = 0
    mens (i < lengde(deler)) {
        la par: tekst = tekst_trim(deler[i])
        hvis par != "" da {
            la par_deler: liste_tekst = tekst_del_på(par, "=")
            hvis lengde(par_deler) >= 1 og tekst_trim(par_deler[0]) == navn da {
                hvis lengde(par_deler) >= 2 da {
                    la verdi: tekst = tekst_trim(par_deler[1])
                    hvis tekst_starter_med(verdi, "\"") og tekst_slutter_med(verdi, "\"") da {
                        verdi = tekst_slice(verdi, 1, tekst_lengde(verdi) - 1)
                    }
                    returner heltall_fra_tekst(verdi)
                }
                returner 0
            }
        }
        i = i + 1
    }
    returner 0
}

funksjon http_query_felt_bool(query: tekst, navn: tekst) -> bool {
    la ren_query: tekst = query
    hvis tekst_starter_med(ren_query, "?") da {
        ren_query = tekst_slice(ren_query, 1, tekst_lengde(ren_query))
    }
    la deler: liste_tekst = tekst_del_på(ren_query, "&")
    la i: heltall = 0
    mens (i < lengde(deler)) {
        la par: tekst = tekst_trim(deler[i])
        hvis par != "" da {
            la par_deler: liste_tekst = tekst_del_på(par, "=")
            hvis lengde(par_deler) >= 1 og tekst_trim(par_deler[0]) == navn da {
                hvis lengde(par_deler) >= 2 da {
                    la verdi: tekst = tekst_til_små(tekst_trim(par_deler[1]))
                    hvis tekst_starter_med(verdi, "\"") og tekst_slutter_med(verdi, "\"") da {
                        verdi = tekst_slice(verdi, 1, tekst_lengde(verdi) - 1)
                    }
                    hvis verdi == "sann" eller verdi == "true" eller verdi == "1" eller verdi == "ja" da {
                        returner sann
                    }
                }
                returner usann
            }
        }
        i = i + 1
    }
    returner usann
}

