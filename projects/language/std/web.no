    la mønster_deler: liste_tekst = tekst_del_på(mønster, "/")
    la sti_deler: liste_tekst = tekst_del_på(sti, "/")
    la mønster_segmenter: liste_tekst = []
    la sti_segmenter: liste_tekst = []
    la i: heltall = 0
    mens (i < lengde(mønster_deler)) {
        hvis mønster_deler[i] != "" da {
            legg_til(mønster_segmenter, mønster_deler[i])
        }
        i = i + 1
    }
    i = 0
    mens (i < lengde(sti_deler)) {
        hvis sti_deler[i] != "" da {
            legg_til(sti_segmenter, sti_deler[i])
        }
        i = i + 1
    }
    hvis lengde(mønster_segmenter) != lengde(sti_segmenter) da {
        returner ""
    }
    i = 0
    mens (i < lengde(mønster_segmenter)) {
        la mønster_segment: tekst = mønster_segmenter[i]
        la sti_segment: tekst = sti_segmenter[i]
        hvis tekst_starter_med(mønster_segment, "{") og tekst_slutter_med(mønster_segment, "}") da {
            la segment_navn: tekst = tekst_slice(mønster_segment, 1, tekst_lengde(mønster_segment) - 1)
            hvis segment_navn == navn da {
                returner sti_segment
            }
        }
        i = i + 1
    }
    returner ""
}

