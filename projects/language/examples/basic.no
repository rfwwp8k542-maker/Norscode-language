

bruk std.math
bruk std.tekst som t

funksjon start() -> heltall {
    la a: heltall = 10
    la b: heltall = 20

    la sum: heltall = math.pluss(a, b)

    skriv("Sum:")
    skriv(tekst_fra_heltall(sum))

    la melding: tekst = t.hilsen("Jan")
    skriv(melding)

    # Enkle tester
    assert_eq(sum, 30, "Feil i pluss")
    assert_ne(sum, 0)

    returner 0
}