{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Norscode",
  "scopeName": "source.norscode",
  "fileTypes": [
    "no"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#function-declaration"
    },
    {
      "include": "#variable-declaration"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.norscode",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.norscode",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.norscode"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.norscode"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.norscode",
              "match": "\\\\(?:[ntr\"\\\\])"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.norscode",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.norscode",
          "match": "\\b(?:bruk|som|funksjon|la|skriv|hvis|da|ellers|mens|for|til|steg|i|bryt|fortsett|returner|assert|assert_eq|assert_ne|test)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.norscode",
          "match": "\\b(?:heltall|bool|tekst|liste_heltall|liste_tekst)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.norscode",
          "match": "\\b(?:sann|usann)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.norscode",
          "match": "\\b(?:og|eller|ikke)\\b"
        },
        {
          "name": "keyword.operator.assignment.norscode",
          "match": "(?:\\+=|-=|\\*=|/=|%=|==|!=|>=|<=|=|\\+|-|\\*|/|%|>|<)"
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "name": "meta.function.norscode",
          "match": "\\bfunksjon\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.function.norscode"
            }
          }
        }
      ]
    },
    "variable-declaration": {
      "patterns": [
        {
          "name": "meta.variable.norscode",
          "match": "\\bla\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "variable.other.readwrite.norscode"
            }
          }
        }
      ]
    }
  }
}
