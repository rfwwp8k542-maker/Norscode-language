{
  "name": "norscode-language-support",
  "displayName": "Norscode Language Support",
  "description": "Syntax highlighting and editor support for Norscode (.no) files.",
  "version": "0.1.0",
  "publisher": "jansteinarsaetre",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:norscode",
    "onCommand:norscode.runCurrentFile",
    "onCommand:norscode.checkCurrentFile"
  ],
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "norscode",
    "norwegian",
    "language",
    "syntax highlighting"
  ],
  "contributes": {
    "commands": [
      {
        "command": "norscode.runCurrentFile",
        "title": "Norscode: Run Current File",
        "category": "Norscode"
      },
      {
        "command": "norscode.checkCurrentFile",
        "title": "Norscode: Check Current File",
        "category": "Norscode"
      }
    ],
    "keybindings": [
      {
        "command": "norscode.runCurrentFile",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "editorTextFocus && editorLangId == norscode"
      },
      {
        "command": "norscode.checkCurrentFile",
        "key": "ctrl+alt+shift+c",
        "mac": "cmd+alt+shift+c",
        "when": "editorTextFocus && editorLangId == norscode"
      }
    ],
    "configuration": {
      "title": "Norscode",
      "properties": {
        "norscode.norscodePath": {
          "type": "string",
          "default": "norscode",
          "description": "Path to the norscode executable used by the Run Current File command."
        }
      }
    },
    "languages": [
      {
        "id": "norscode",
        "aliases": [
          "Norscode",
          "norscode"
        ],
        "extensions": [
          ".no"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "norscode",
        "scopeName": "source.norscode",
        "path": "./syntaxes/norscode.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "norscode",
        "path": "./snippets/norscode.json"
      }
    ]
  }
}
