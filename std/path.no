# Sti-hjelpere

funksjon join(først: tekst, andre: tekst) -> tekst {
    returner sti_join(først, andre)
}

funksjon basename(sti: tekst) -> tekst {
    returner sti_basename(sti)
}

funksjon dirname(sti: tekst) -> tekst {
    returner sti_dirname(sti)
}

funksjon exists(sti: tekst) -> bool {
    returner sti_exists(sti)
}

funksjon stem(sti: tekst) -> tekst {
    returner sti_stem(sti)
}
