{
  "Funksjon": {
    "prefix": "funksjon",
    "body": [
      "funksjon ${1:navn}(${2:parametre}) -> ${3:heltall} {",
      "\t$0",
      "}"
    ],
    "description": "Sett inn en funksjon"
  },
  "Start-funksjon": {
    "prefix": "start",
    "body": [
      "funksjon start() -> heltall {",
      "\t$0",
      "\treturner 0",
      "}"
    ],
    "description": "Sett inn en standard start-funksjon"
  },
  "Hvis ellers": {
    "prefix": "hvis",
    "body": [
      "hvis (${1:betingelse}) {",
      "\t$0",
      "} ellers {",
      "\t",
      "}"
    ],
    "description": "Sett inn en hvis/ellers-blokk"
  },
  "For-løkke": {
    "prefix": "for",
    "body": [
      "for ${1:i} i ${2:0} til ${3:10} steg ${4:1} {",
      "\t$0",
      "}"
    ],
    "description": "Sett inn en for-løkke"
  },
  "Mens-løkke": {
    "prefix": "mens",
    "body": [
      "mens (${1:betingelse}) {",
      "\t$0",
      "}"
    ],
    "description": "Sett inn en mens-løkke"
  }
}
