bruk std.env
bruk std.fil
bruk std.http som http
bruk std.json

funksjon _hent_tekst(nokkel: tekst, fallback: tekst) -> tekst {
    la verdi = env.hent(nokkel)
    hvis (verdi == "") {
        returner fallback
    }
    returner verdi
}

funksjon _tom_tekst(verdi: tekst) -> bool {
    returner verdi == ""
}

funksjon _hent_kode(sti: tekst) -> tekst {
    hvis (ikke fil_finnes(sti)) {
        returner ""
    }
    returner fil_les(sti)
}

funksjon _json_escape(verdi: tekst) -> tekst {
    la resultat = tekst_erstatt(verdi, "\\", "\\\\")
    resultat = tekst_erstatt(resultat, "\"", "\\\"")
    resultat = tekst_erstatt(resultat, "\n", "\\n")
    resultat = tekst_erstatt(resultat, "\r", "\\r")
    resultat = tekst_erstatt(resultat, "\t", "\\t")
    returner resultat
}

funksjon _json_resultat(kommando: tekst, provider: tekst, ok: bool, tekst_melding: tekst, rå_data: tekst) -> tekst {
    la svar: ordbok_tekst = {}
    hvis (ok) {
        svar["ok"] = "sann"
    } ellers {
        svar["ok"] = "usann"
    }
    svar["command"] = kommando
    svar["provider"] = provider
    svar["text"] = tekst_melding
    svar["raw"] = rå_data
    skriv(json.stringify(svar))
    returner 0
}

funksjon _byg_gemini_payload(system_melding: tekst, prompt: tekst, kode: tekst) -> tekst {
    la melding = system_melding + "\n\n" + prompt + "\n\nKildekode:\n" + kode
    la escaping = _json_escape(melding)
    returner "{\"contents\":[{\"parts\":[{\"text\":\"" + escaping + "\"}]}],\"generationConfig\":{\"temperature\":0.2,\"maxOutputTokens\":1536}}"
}

funksjon _byg_codex_payload(system_melding: tekst, prompt: tekst, kode: tekst, model: tekst) -> tekst {
    la melding = system_melding + "\n\n" + prompt + "\n\nKildekode:\n" + kode
    la escaping = _json_escape(melding)
    la modell = _json_escape(model)
    returner "{\"model\":\"" + modell + "\",\"messages\":[{\"role\":\"system\",\"content\":\"" + escaping + "\"}],\"temperature\":0.2,\"max_tokens\":1800}"
}

funksjon _sett_codex_status(kommando: tekst, provider: tekst, request_kode: tekst) -> heltall {
    la headers: ordbok_tekst = {}
    la api_key = _hent_tekst("CODEX_API_KEY", "")
    hvis (_tom_tekst(api_key)) {
        api_key = _hent_tekst("OPENAI_API_KEY", "")
    }
    hvis (_tom_tekst(api_key)) {
        la feil: tekst = "Mangler CODEX_API_KEY/OPENAI_API_KEY"
        _json_resultat(kommando, provider, usann, feil, "")
        returner 1
    }
    la model = _hent_tekst("CODEX_MODEL", "gpt-4o-mini")
    la api_url = _hent_tekst("CODEX_API_URL", "https://api.openai.com/v1/chat/completions")
    headers["Content-Type"] = "application/json"
    headers["Authorization"] = "Bearer " + api_key

    la respons = http.request_full("POST", api_url, headers, {}, request_kode, 60000)
    la status = http.response_status(respons)
    la innhold = http.response_text(respons)
    hvis (status < 200 eller status >= 300) {
        la feilmelding = "Codex-returnerte HTTP " + tekst_fra_heltall(status)
        _json_resultat(kommando, provider, usann, feilmelding, innhold)
        returner 1
    }
    _json_resultat(kommando, provider, sann, innhold, innhold)
    returner 0
}

funksjon _sett_gemini_status(kommando: tekst, provider: tekst, request_kode: tekst) -> heltall {
    la api_key = _hent_tekst("GEMINI_API_KEY", "")
    hvis (_tom_tekst(api_key)) {
        la feil: tekst = "Mangler GEMINI_API_KEY"
        _json_resultat(kommando, provider, usann, feil, "")
        returner 1
    }

    la model = _hent_tekst("GEMINI_MODEL", "gemini-1.5-flash")
    la api_url = "https://generativelanguage.googleapis.com/v1beta/models/" + model + ":generateContent?key=" + api_key
    la headers: ordbok_tekst = {}
    headers["Content-Type"] = "application/json"

    la respons = http.request_full("POST", api_url, headers, {}, request_kode, 60000)
    la status = http.response_status(respons)
    la innhold = http.response_text(respons)
    hvis (status < 200 eller status >= 300) {
        la feilmelding = "Gemini-returnerte HTTP " + tekst_fra_heltall(status)
        _json_resultat(kommando, provider, usann, feilmelding, innhold)
        returner 1
    }
    _json_resultat(kommando, provider, sann, innhold, innhold)
    returner 0
}

funksjon start() -> heltall {
    la kommando = _hent_tekst("NORSCODE_STUDIO_CMD", "")
    la provider = _hent_tekst("NORSCODE_STUDIO_PROVIDER", "codex")
    la kildesti = _hent_tekst("NORSCODE_STUDIO_SOURCE_PATH", "")
    la prompt_sti = _hent_tekst("NORSCODE_STUDIO_PROMPT", "")
    la prompt = _hent_kode(prompt_sti)
    la source = _hent_kode(kildesti)
    la system_tekst = "Du er en Norscode Studio-assistent. Svar på norsk, kort og presist."

    hvis (kommando != "ask" og kommando != "refactor") {
        _json_resultat("ukjent", provider, usann, "Ukjent kommando: " + kommando, "")
        returner 1
    }

    hvis (kommando == "ask") {
        hvis (provider == "codex") {
            la codex_model = _hent_tekst("CODEX_MODEL", "gpt-4o-mini")
            la payload = _byg_codex_payload(system_tekst, prompt, source, codex_model)
            returner _sett_codex_status(kommando, provider, payload)
        }
        la _ = _hent_tekst("GEMINI_MODEL", "gemini-1.5-flash")
        la payload = _byg_gemini_payload(system_tekst, prompt, source)
        returner _sett_gemini_status(kommando, provider, payload)
    }

    hvis (provider == "codex") {
        la payload = _byg_codex_payload(
            system_tekst,
            "Refaktor koden for bedre struktur og lesbarhet. " +
                "Returner kun forbedret kode, uten kommentarer og uten forklaring.",
            source,
            _hent_tekst("CODEX_MODEL", "gpt-4o-mini")
        )
        returner _sett_codex_status(kommando, provider, payload)
    }

    la payload = _byg_gemini_payload(
        system_tekst,
        "Refaktor koden for bedre struktur og lesbarhet. " +
            "Returner kun forbedret kode, uten kommentarer og uten forklaring.",
        source
    )
    returner _sett_gemini_status(kommando, provider, payload)
}
