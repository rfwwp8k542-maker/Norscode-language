bruk std.web som web

funksjon start() -> heltall {
    la ctx = web.request_context("get", "/", {}, {"cookie": "session=abc"}, "")
    la cookie = web.cookie_header("session", "abc123")
    la respons = web.response_set_cookie(
        web.response_builder(200, {"content-type": "text/plain"}, web.request_cookie(ctx, "session")),
        cookie
    )
    skriv(web.request_cookie(ctx, "session"))
    skriv(web.response_header(respons, "set-cookie"))
    returner 0
}
