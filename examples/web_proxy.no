bruk std.web som web

funksjon proxy(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /proxy")
    la proto = web.request_header(ctx, "x-forwarded-proto")
    la host = web.request_header(ctx, "x-forwarded-host")
    la ip = web.request_header(ctx, "x-forwarded-for")
    la url = web.request_header(ctx, "x-external-url")
    returner web.response_builder(200, {"content-type": "text/plain"}, proto + "|" + host + "|" + ip + "|" + url)
}

funksjon start() -> heltall {
    returner 0
}
