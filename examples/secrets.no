bruk std.secrets som sikkerhet
bruk std.env som env

funksjon start() -> heltall {
    la lagret = sikkerhet.passord_hash("hemmelig", "salt123")
    skriv(lagret)
    skriv(sikkerhet.passord_verifiser("hemmelig", lagret))

    env.sett("NORSCODE_DEMO_SECRET", "versjon-42")
    skriv(sikkerhet.hemmelighet_hent("NORSCODE_DEMO_SECRET"))
    returner 0
}
