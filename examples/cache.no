bruk std.cache som cache

funksjon start() -> heltall {
    la c = cache.opprett()
    cache.sett(c, "side", "hjem")
    cache.sett_tall(c, "treff", 12)
    cache.sett_bool(c, "klar", sann)

    skriv(cache.hent(c, "side"))
    skriv(tekst_fra_heltall(cache.hent_tall(c, "treff")))
    skriv(cache.hent_eller(c, "mangler", "fallback"))
    skriv(tekst_fra_bool(cache.hent_bool(c, "klar")))
    returner 0
}
