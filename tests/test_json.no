bruk std.json som json

funksjon start() -> heltall {
    la payload = "{\"navn\":\"Norscode\",\"alder\":2,\"aktiv\":true,\"teller\":[],\"metadata\":{\"status\":\"ok\"}}"
    la parsed = json.parse(payload)

    assert_eq(parsed["navn"], "Norscode")
    assert_eq(parsed["alder"], "2")
    assert_eq(parsed["aktiv"], "true")
    assert_eq(parsed["teller"], "[]")
    assert_eq(parsed["metadata"], "{\"status\":\"ok\"}")

    assert_eq(json.stringify(parsed), "{\"navn\":\"Norscode\",\"alder\":2,\"aktiv\":true,\"teller\":[],\"metadata\":{\"status\":\"ok\"}}")
    skriv("test_json OK")
    returner 0
}
