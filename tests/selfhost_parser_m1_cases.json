{
  "expressions": [
    {
      "name": "arith_precedence",
      "source": "2+3*4",
      "expected_lines": [
        "0: PUSH 2",
        "1: PUSH 3",
        "2: PUSH 4",
        "3: MUL",
        "4: ADD",
        "5: PRINT",
        "6: HALT"
      ]
    },
    {
      "name": "arith_grouped",
      "source": "(2+3)*4",
      "expected_lines": [
        "0: PUSH 2",
        "1: PUSH 3",
        "2: ADD",
        "3: PUSH 4",
        "4: MUL",
        "5: PRINT",
        "6: HALT"
      ]
    },
    {
      "name": "brace_grouped",
      "source": "{2+3}*4",
      "expected_lines": [
        "0: PUSH 2",
        "1: PUSH 3",
        "2: ADD",
        "3: PUSH 4",
        "4: MUL",
        "5: PRINT",
        "6: HALT"
      ]
    },
    {
      "name": "bracket_grouped",
      "source": "[2+3]*4",
      "expected_lines": [
        "0: PUSH 2",
        "1: PUSH 3",
        "2: ADD",
        "3: PUSH 4",
        "4: MUL",
        "5: PRINT",
        "6: HALT"
      ]
    },
    {
      "name": "bool_and_cmp",
      "source": "5>3&&2<4",
      "expected_lines": [
        "0: PUSH 5",
        "1: PUSH 3",
        "2: GT",
        "3: PUSH 2",
        "4: PUSH 4",
        "5: LT",
        "6: AND",
        "7: PRINT",
        "8: HALT"
      ]
    },
    {
      "name": "implies_alias",
      "source": "1 implies 0",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 0",
        "2: SWAP",
        "3: NOT",
        "4: SWAP",
        "5: OR",
        "6: PRINT",
        "7: HALT"
      ]
    },
    {
      "name": "implied_by_alias",
      "source": "1 implied_by 0",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 0",
        "2: NOT",
        "3: OR",
        "4: PRINT",
        "5: HALT"
      ]
    },
    {
      "name": "iff_alias",
      "source": "1 iff 1",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 1",
        "2: EQ",
        "3: PRINT",
        "4: HALT"
      ]
    },
    {
      "name": "unary_minus_plus",
      "source": "-3+5",
      "expected_lines": [
        "0: PUSH 3",
        "1: PUSH 0",
        "2: SWAP",
        "3: SUB",
        "4: PUSH 5",
        "5: ADD",
        "6: PRINT",
        "7: HALT"
      ]
    },
    {
      "name": "if_expression",
      "source": "hvis 1==1 da 7 ellers 9",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 1",
        "2: EQ",
        "3: JZ 6",
        "4: PUSH 7",
        "5: JMP 8",
        "6: LABEL 6",
        "7: PUSH 9",
        "8: LABEL 8",
        "9: PRINT",
        "10: HALT"
      ]
    },
    {
      "name": "neq_or_eq",
      "source": "7!=7||2==2",
      "expected_lines": [
        "0: PUSH 7",
        "1: PUSH 7",
        "2: EQ",
        "3: NOT",
        "4: PUSH 2",
        "5: PUSH 2",
        "6: EQ",
        "7: OR",
        "8: PRINT",
        "9: HALT"
      ]
    },
    {
      "name": "not_equal_angle",
      "source": "7<>8",
      "expected_lines": [
        "0: PUSH 7",
        "1: PUSH 8",
        "2: EQ",
        "3: NOT",
        "4: PRINT",
        "5: HALT"
      ]
    },
    {
      "name": "less_or_equal",
      "source": "3 <= 4",
      "expected_lines": [
        "0: PUSH 3",
        "1: PUSH 4",
        "2: GT",
        "3: NOT",
        "4: PRINT",
        "5: HALT"
      ]
    },
    {
      "name": "error_trailing_operator",
      "source": "2 +",
      "expected_error": "/* feil: uttrykket avsluttes med operator ved token 1 */"
    },
    {
      "name": "error_unknown_name",
      "source": "foo+1",
      "expected_error": "/* feil: ukjent token/navn i uttrykk foo ved token 0 */"
    },
    {
      "name": "error_missing_paren",
      "source": "(2+3",
      "expected_error": "/* feil: mangler ) i uttrykk ved token 0 */"
    },
    {
      "name": "map_lookup_literal",
      "source": "{\"en\": 1, \"to\": 2}[\"to\"]",
      "expected_error": "/* feil: ukjent token/navn i uttrykk \" ved token 1 */"
    }
  ],
  "scripts": [
    {
      "name": "constant_fold_chain",
      "source": "x=2+3;y=x*4;y+1",
      "expected_lines": [
        "0: PUSH 20",
        "1: PUSH 1",
        "2: ADD",
        "3: PRINT",
        "4: HALT"
      ]
    },
    {
      "name": "empty_statements",
      "source": ";;la x=2;;x+1;;",
      "expected_lines": [
        "0: PUSH 2",
        "1: PUSH 1",
        "2: ADD",
        "3: PRINT",
        "4: HALT"
      ]
    },
    {
      "name": "if_before_final_return",
      "source": "la x=1;hvis x==1 da 10 ellers 20;returner x+2",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 2",
        "2: ADD",
        "3: PRINT",
        "4: HALT"
      ]
    },
    {
      "name": "if_return_expression",
      "source": "la x=0;returner hvis x==1 da 10 ellers 20",
      "expected_lines": [
        "0: PUSH 0",
        "1: PUSH 1",
        "2: EQ",
        "3: JZ 6",
        "4: PUSH 10",
        "5: JMP 8",
        "6: LABEL 6",
        "7: PUSH 20",
        "8: LABEL 8",
        "9: PRINT",
        "10: HALT"
      ]
    },
    {
      "name": "set_assignment",
      "source": "la x=2;sett x=x+3;returner x",
      "expected_lines": [
        "0: PUSH 5",
        "1: PRINT",
        "2: HALT"
      ]
    },
    {
      "name": "compound_assignment",
      "source": "la x=2;x+=3;x*=2;returner x",
      "expected_lines": [
        "0: PUSH 10",
        "1: PRINT",
        "2: HALT"
      ]
    },
    {
      "name": "alias_assign_return",
      "source": "let x=2;assign x=x+3;return x",
      "expected_lines": [
        "0: PUSH 5",
        "1: PRINT",
        "2: HALT"
      ]
    },
    {
      "name": "if_then_else_alias",
      "source": "la x=1;if x==1 then 10 else 20",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 1",
        "2: EQ",
        "3: JZ 6",
        "4: PUSH 10",
        "5: JMP 8",
        "6: LABEL 6",
        "7: PUSH 20",
        "8: LABEL 8",
        "9: PRINT",
        "10: HALT"
      ]
    },
    {
      "name": "return_semicolon",
      "source": "la x=2;returner x+3;",
      "expected_lines": [
        "0: PUSH 2",
        "1: PUSH 3",
        "2: ADD",
        "3: PRINT",
        "4: HALT"
      ]
    },
    {
      "name": "script_implied_by",
      "source": "returner 1 implied_by 0",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 0",
        "2: NOT",
        "3: OR",
        "4: PRINT",
        "5: HALT"
      ]
    },
    {
      "name": "error_missing_separator_after_assign",
      "source": "x=2+3",
      "expected_error": "/* feil: mangler ';', ',' eller ':' etter assignment til x ved token 0 */"
    },
    {
      "name": "error_missing_final_expression",
      "source": "x=2+3;",
      "expected_error": "/* feil: skriptet mangler sluttuttrykk */"
    },
    {
      "name": "error_sett_without_declaration",
      "source": "sett x=1;returner 0",
      "expected_error": "/* feil: variabel 'x' er ikke deklarert (bruk 'la') ved token 0 */"
    },
    {
      "name": "error_if_missing_da",
      "source": "hvis 1==1 10 ellers 20",
      "expected_error": "/* feil: hvis-uttrykk mangler 'da' ved token 0 */"
    },
    {
      "name": "map_mutation_script",
      "source": "la tall: ordbok_heltall = {\"en\": 1}; tall[\"to\"] = 2; returner tall[\"en\"] + tall[\"to\"]",
      "expected_error": "/* feil: ugyldig deklarasjon etter 'la' ved token 0 */"
    },
    {
      "name": "match_wildcard_case",
      "source": "match 2 { case 1 { 10 } case _ { 20 } }",
      "expected_lines": [
        "0: PUSH 2",
        "1: PUSH 1",
        "2: EQ",
        "3: JZ 6",
        "4: PUSH 10",
        "5: JMP 7",
        "6: LABEL 6",
        "7: LABEL 7",
        "8: PRINT",
        "9: HALT"
      ]
    }
  ]
}
