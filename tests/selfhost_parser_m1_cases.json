{
  "expressions": [
    {
      "name": "arith_precedence",
      "source": "2+3*4",
      "expected_lines": [
        "0: PUSH 2",
        "1: PUSH 3",
        "2: PUSH 4",
        "3: MUL",
        "4: ADD",
        "5: PRINT",
        "6: HALT"
      ]
    },
    {
      "name": "arith_grouped",
      "source": "(2+3)*4",
      "expected_lines": [
        "0: PUSH 2",
        "1: PUSH 3",
        "2: ADD",
        "3: PUSH 4",
        "4: MUL",
        "5: PRINT",
        "6: HALT"
      ]
    },
    {
      "name": "bool_and_cmp",
      "source": "5>3&&2<4",
      "expected_lines": [
        "0: PUSH 5",
        "1: PUSH 3",
        "2: GT",
        "3: PUSH 2",
        "4: PUSH 4",
        "5: LT",
        "6: AND",
        "7: PRINT",
        "8: HALT"
      ]
    },
    {
      "name": "implies_alias",
      "source": "1 implies 0",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 0",
        "2: SWAP",
        "3: NOT",
        "4: SWAP",
        "5: OR",
        "6: PRINT",
        "7: HALT"
      ]
    },
    {
      "name": "implied_by_alias",
      "source": "1 implied_by 0",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 0",
        "2: NOT",
        "3: OR",
        "4: PRINT",
        "5: HALT"
      ]
    },
    {
      "name": "iff_alias",
      "source": "1 iff 1",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 1",
        "2: EQ",
        "3: PRINT",
        "4: HALT"
      ]
    },
    {
      "name": "unary_minus_plus",
      "source": "-3+5",
      "expected_lines": [
        "0: PUSH 3",
        "1: PUSH 0",
        "2: SWAP",
        "3: SUB",
        "4: PUSH 5",
        "5: ADD",
        "6: PRINT",
        "7: HALT"
      ]
    },
    {
      "name": "if_expression",
      "source": "hvis 1==1 da 7 ellers 9",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 1",
        "2: EQ",
        "3: JZ 6",
        "4: PUSH 7",
        "5: JMP 8",
        "6: LABEL 6",
        "7: PUSH 9",
        "8: LABEL 8",
        "9: PRINT",
        "10: HALT"
      ]
    },
    {
      "name": "error_trailing_operator",
      "source": "2 +",
      "expected_error": "/* feil: uttrykket avsluttes med operator ved token 1 */"
    },
    {
      "name": "error_missing_paren",
      "source": "(2+3",
      "expected_error": "/* feil: mangler ) i uttrykk ved token 0 */"
    }
  ],
  "scripts": [
    {
      "name": "constant_fold_chain",
      "source": "x=2+3;y=x*4;y+1",
      "expected_lines": [
        "0: PUSH 20",
        "1: PUSH 1",
        "2: ADD",
        "3: PRINT",
        "4: HALT"
      ]
    },
    {
      "name": "if_before_final_return",
      "source": "la x=1;hvis x==1 da 10 ellers 20;returner x+2",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 2",
        "2: ADD",
        "3: PRINT",
        "4: HALT"
      ]
    },
    {
      "name": "set_assignment",
      "source": "la x=2;sett x=x+3;returner x",
      "expected_lines": [
        "0: PUSH 5",
        "1: PRINT",
        "2: HALT"
      ]
    },
    {
      "name": "compound_assignment",
      "source": "la x=2;x+=3;x*=2;returner x",
      "expected_lines": [
        "0: PUSH 10",
        "1: PRINT",
        "2: HALT"
      ]
    },
    {
      "name": "alias_assign_return",
      "source": "let x=2;assign x=x+3;return x",
      "expected_lines": [
        "0: PUSH 5",
        "1: PRINT",
        "2: HALT"
      ]
    },
    {
      "name": "if_then_else_alias",
      "source": "la x=1;if x==1 then 10 else 20",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 1",
        "2: EQ",
        "3: JZ 6",
        "4: PUSH 10",
        "5: JMP 8",
        "6: LABEL 6",
        "7: PUSH 20",
        "8: LABEL 8",
        "9: PRINT",
        "10: HALT"
      ]
    },
    {
      "name": "script_implied_by",
      "source": "returner 1 implied_by 0",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 0",
        "2: NOT",
        "3: OR",
        "4: PRINT",
        "5: HALT"
      ]
    },
    {
      "name": "error_missing_separator_after_assign",
      "source": "x=2+3",
      "expected_error": "/* feil: mangler ';', ',' eller ':' etter assignment til x ved token 0 */"
    },
    {
      "name": "error_missing_final_expression",
      "source": "x=2+3;",
      "expected_error": "/* feil: skriptet mangler sluttuttrykk */"
    },
    {
      "name": "error_if_missing_da",
      "source": "hvis 1==1 10 ellers 20",
      "expected_error": "/* feil: hvis-uttrykk mangler 'da' ved token 0 */"
    }
  ]
}
