bruk std.feil som feil
bruk std.fil som fil
bruk std.tekst som t

funksjon start() -> heltall {
    la konstruktør: tekst = feil.io("mangler fil")
    la fanget: tekst = ""

    assert_eq(konstruktør, "IOFeil: mangler fil")

    prøv {
        fil.les("/private/tmp/norscode_missing_io_error_test.txt")
    } fang (feiltekst) {
        fanget = feiltekst
    }

    assert(t.starter_med(fanget, "IOFeil:"))
    assert(t.inneholder(fanget, "lese fil"))
    returner 0
}
