bruk std.math

funksjon start() -> heltall {
    # Grunnleggende aritmetikk
    assert_eq(2 + 3, 5)
    assert_eq(10 - 4, 6)
    assert_eq(3 * 4, 12)
    assert_eq(8 / 2, 4)

    # std.math
    la s: heltall = math.pluss(10, 20)
    assert_eq(s, 30)

    la m: heltall = math.minus(50, 8)
    assert_eq(m, 42)

    # sammenligning
    assert(5 > 3)
    assert(3 < 5)
    assert_eq(5 >= 5, sann)
    assert_eq(4 <= 5, sann)

    skriv("test_math OK")
    returner 0
}
