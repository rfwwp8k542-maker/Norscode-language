bruk std.web som web
bruk std.tekst som t

funksjon v1_brukere(ctx: ordbok_tekst) -> ordbok_tekst {
    web.subrouter("/api/v1")
    web.route("GET /brukere")
    returner web.response_builder(200, {"content-type": "application/json"}, "{\"versjon\":\"v1\"}")
}

funksjon v2_brukere(ctx: ordbok_tekst) -> ordbok_tekst {
    web.subrouter("/api/v2")
    web.route("GET /brukere")
    returner web.response_builder(200, {"content-type": "application/json"}, "{\"versjon\":\"v2\",\"navn\":\"Ada\"}")
}

funksjon start() -> heltall {
    la v1 = web.handle_request(web.request_context("get", "/api/v1/brukere", {}, {}, ""))
    la v2 = web.handle_request(web.request_context("get", "/api/v2/brukere", {}, {}, ""))
    assert_eq(web.response_body(v1), "{\"versjon\":\"v1\"}")
    assert_eq(web.response_body(v2), "{\"versjon\":\"v2\",\"navn\":\"Ada\"}")

    la openapi_v1 = web.openapi_json("Bruker API", "1.0.0")
    la openapi_v2 = web.openapi_json("Bruker API", "2.0.0")
    assert(t.inneholder(openapi_v1, "\"version\":\"1.0.0\""))
    assert(t.inneholder(openapi_v2, "\"version\":\"2.0.0\""))
    assert(t.inneholder(openapi_v1, "\"/api/v1/brukere\""))
    assert(t.inneholder(openapi_v2, "\"/api/v2/brukere\""))
    returner 0
}
