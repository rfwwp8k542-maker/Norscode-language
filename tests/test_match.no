funksjon start() -> heltall {
    la tall: heltall = 2
    la tall_resultat: heltall = 0
    match tall {
        case 1 {
            tall_resultat = 10
        }
        case 2 {
            tall_resultat = 20
        }
        case _ {
            tall_resultat = 30
        }
    }

    la ord: tekst = "hei"
    la ord_resultat: heltall = 0
    match ord {
        case "nope" {
            ord_resultat = 40
        }
        ellers {
            ord_resultat = 50
        }
    }

    la flagg: bool = sann
    la bool_resultat: heltall = 0
    match flagg {
        case usann {
            bool_resultat = 60
        }
        case sann {
            bool_resultat = 70
        }
    }

    assert_eq(tall_resultat, 20)
    assert_eq(ord_resultat, 50)
    assert_eq(bool_resultat, 70)
    returner 0
}
