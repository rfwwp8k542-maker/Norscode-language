bruk std.csrf som csrf
bruk std.web som web

funksjon skriv_side(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("POST /innhold")
    hvis (ikke csrf.require(ctx, "token-123")) {
        returner web.response_error(403, "Mangler eller ugyldig CSRF-token")
    }
    returner web.response_builder(200, {"content-type": "text/plain"}, csrf.token(ctx))
}

funksjon start() -> heltall {
    la mangler = web.handle_request(web.request_context("post", "/innhold", {}, {}, ""))
    assert_eq(web.response_status(mangler), 403)

    la feil = web.handle_request(web.request_context("post", "/innhold", {}, {"x-csrf-token": "feil"}, ""))
    assert_eq(web.response_status(feil), 403)

    la ok = web.handle_request(web.request_context("post", "/innhold", {}, {"x-csrf-token": "token-123"}, ""))
    assert_eq(web.response_status(ok), 200)
    assert_eq(web.response_body(ok), "token-123")

    la token = web.request_context("post", "/innhold", {}, {"x-xsrf-token": "abc"}, "")
    assert_eq(csrf.token(token), "abc")

    returner 0
}
