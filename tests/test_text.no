bruk std.tekst som t

funksjon start() -> heltall {
    # Test hilsen
    la melding: tekst = t.hilsen("Jan")
    assert_eq(melding, "Hei Jan")

    # Test rop
    la rop_melding: tekst = t.rop("hei")
    assert_eq(rop_melding, "hei!")

    # Test sammenkobling
    la kombi: tekst = "Hei " + "Verden"
    assert_eq(kombi, "Hei Verden")

    skriv("test_text OK")
    returner 0
}