bruk std.web som web
bruk std.tekst som t

funksjon bruker(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("POST /brukere/{id:int}")
    la side = web.request_query_int(ctx, "side")
    la navn = web.request_json_field_or(ctx, "navn", "ukjent")
    la alder = web.request_json_field_int(ctx, "alder")
    la aktiv = web.request_json_field_bool(ctx, "aktiv")
    skriv(navn)
    skriv(tekst_fra_heltall(alder))
    skriv(tekst_fra_bool(aktiv))
    returner web.response_builder(200, {"content-type": "text/plain"}, tekst_fra_heltall(side))
}

funksjon start() -> heltall {
    la openapi = web.openapi_json("Demo API", "1.2.3")
    assert(t.inneholder(openapi, "\"openapi\":\"3.0.3\""))
    assert(t.inneholder(openapi, "\"title\":\"Demo API\""))
    assert(t.inneholder(openapi, "\"version\":\"1.2.3\""))
    assert(t.inneholder(openapi, "\"/brukere/{id}\""))
    assert(t.inneholder(openapi, "\"side\""))
    assert(t.inneholder(openapi, "\"navn\""))
    assert(t.inneholder(openapi, "\"alder\""))
    assert(t.inneholder(openapi, "\"aktiv\""))
    assert(t.inneholder(openapi, "\"requestBody\""))

    la docs = web.docs_html("Demo API", "1.2.3")
    assert(t.inneholder(docs, "<h1>Demo API</h1>"))
    assert(t.inneholder(docs, "<pre>"))
    assert(t.inneholder(docs, "\"paths\""))
    assert(t.inneholder(docs, "/brukere/{id}"))

    returner 0
}
