bruk std.web som web

funksjon start() -> heltall {
    la ctx = web.request_context("get", "/", {}, {"cookie": "session=abc; theme=dark"}, "")
    assert_eq(web.request_cookie(ctx, "session"), "abc")
    assert_eq(web.request_cookie_or(ctx, "missing", "fallback"), "fallback")

    la cookie = web.cookie_header("session", "abc123")
    assert_starter_med(cookie, "session=abc123;")
    assert_inneholder(cookie, "HttpOnly")
    assert_inneholder(cookie, "Secure")
    assert_inneholder(cookie, "SameSite=Lax")

    la response = web.response_set_cookie(
        web.response_builder(200, {"content-type": "text/plain"}, "ok"),
        cookie
    )
    assert_inneholder(web.response_header(response, "set-cookie"), "session=abc123")
    returner 0
}
