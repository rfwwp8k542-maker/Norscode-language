bruk std.trace som trace
bruk std.log som logg
bruk std.web som web

funksjon start() -> heltall {
    la ctx = web.request_context("get", "/hjem", {}, {}, "")
    la spor = trace.start("handler", "trace-1", "root")
    assert_eq(trace.koble_request(spor, web.request_id(ctx), web.request_method(ctx), web.request_path(ctx)), 10)
    assert_eq(trace.event(spor, "db", "started"), 1)
    assert_eq(trace.felt_tekst(spor, "route", "GET /hjem"), 11)
    assert_eq(trace.felt_tall(spor, "status", 200), 11)
    la sluttet = trace.slutt_ok(spor)
    assert_eq(sluttet["status"], "ok")
    assert_eq(sluttet["event_count"], "1")
    assert_inneholder(sluttet["events"], "\"name\":\"db\"")

    la loggverd = trace.til_logg(sluttet)
    assert_eq(loggverd["trace_id"], "trace-1")
    assert_eq(loggverd["request_id"], "req-1")
    assert_eq(loggverd["path"], "/hjem")
    assert_eq(logg.emit(loggverd), logg.emit(loggverd))

    returner 0
}
