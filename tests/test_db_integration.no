bruk std.db som db
bruk std.env som env
bruk std.path som path

funksjon tmpsti(navn: tekst) -> tekst {
    hvis env.finnes("TMPDIR") {
        returner path.join(env.hent("TMPDIR"), navn)
    }
    hvis env.finnes("TEMP") {
        returner path.join(env.hent("TEMP"), navn)
    }
    hvis env.finnes("TMP") {
        returner path.join(env.hent("TMP"), navn)
    }
    returner path.join(".", navn)
}

funksjon start() -> heltall {
    la fil = tmpsti("norscode_db_integration_test.db")

    la første = db.open(fil)
    assert(db.ping(første))
    db.execute(første, "DROP TABLE IF EXISTS events")
    assert_eq(db.execute(første, "CREATE TABLE events (id INTEGER PRIMARY KEY, navn TEXT)"), 0)
    assert_eq(db.execute(første, "INSERT INTO events (navn) VALUES ('første')"), 1)
    assert_eq(db.query_int(første, "SELECT COUNT(*) FROM events"), 1)
    assert(db.close(første))

    la andre = db.open(fil)
    assert(db.ping(andre))
    assert_eq(db.query_text(andre, "SELECT navn FROM events WHERE id = 1"), "første")
    assert_eq(db.execute(andre, "INSERT INTO events (navn) VALUES ('andre')"), 1)
    assert_eq(db.query_int(andre, "SELECT COUNT(*) FROM events"), 2)
    assert(db.close(andre))

    returner 0
}
