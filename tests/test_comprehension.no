bruk std.liste som liste
bruk std.tekst som txt

funksjon start() -> heltall {
    la tall = [1, 2, 3, 4]
    la doble = [x * 2 for x i tall hvis x > 2]
    assert_eq(doble[0], 6)
    assert_eq(doble[1], 8)

    la ord = ["a", "bb", "ccc"]
    la lange = [txt.trim(x) for x i ord hvis x != "a"]
    assert_eq(lange[0], "bb")
    assert_eq(lange[1], "ccc")
    returner 0
}
