funksjon start() -> heltall {
    la outer = {"grupper": {"admin": 1, "bruker": 2}}
    assert_eq(outer["grupper"]["admin"], 1)
    assert_eq(outer["grupper"]["bruker"], 2)

    la grupper: ordbok_heltall = outer["grupper"]
    grupper["admin"] = 3
    assert_eq(outer["grupper"]["admin"], 3)

    la nested = {"team": {"leder": "hans"}}
    assert_eq(nested["team"]["leder"], "hans")
    la team = nested["team"]
    team["leder"] = "siri"
    assert_eq(nested["team"]["leder"], "siri")

    assert_eq(lengde(outer), 1)
    assert_eq(lengde(outer["grupper"]), 2)

    skriv("test_nested_map OK")
    returner 0
}
