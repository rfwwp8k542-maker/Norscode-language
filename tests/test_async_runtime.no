async funksjon indre(x: heltall) -> heltall {
    returner x + 1
}

async funksjon dobbel_async(x: heltall) -> heltall {
    la a = await indre(x)
    la b = await indre(a)
    returner b * 2
}

funksjon start() -> heltall {
    la verdi = await dobbel_async(20)
    assert_eq(verdi, 44)
    returner 0
}
