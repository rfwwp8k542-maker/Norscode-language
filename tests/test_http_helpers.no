bruk std.http som http
bruk std.tekst som t

funksjon start() -> heltall {
    la respons = "{\"status\":201,\"body\":\"{\\\"navn\\\":\\\"Norscode\\\",\\\"ok\\\":true}\",\"headers\":{\"content-type\":\"application/json\",\"x-id\":\"abc123\"}}"

    assert_eq(http.response_status(respons), 201)
    assert_eq(http.response_text(respons), "{\"navn\":\"Norscode\",\"ok\":true}")
    assert_eq(http.response_header(respons, "x-id"), "abc123")
    assert_eq(http.response_header_or(respons, "mangler", "fallback"), "fallback")
    assert(http.response_ok(respons))

    la json = http.response_json_checked(respons)
    assert_eq(json["navn"], "Norscode")
    assert_eq(json["ok"], "true")

    prøv {
        la ugyldig = "{\"status\":200,\"body\":\"{}\",\"headers\":{\"content-type\":\"text/plain\"}}"
        http.response_json_checked(ugyldig)
        returner 99
    } fang (feil) {
        assert(t.inneholder(feil, "TypeFeil: forventet JSON-respons"))
    }

    returner 0
}
