bruk std.web som web
bruk std.tekst som t

funksjon bruker(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /brukere/{id:int}")
    returner web.response_builder(200, {"content-type": "text/plain"}, tekst_fra_heltall(web.request_param_int(ctx, "id")))
}

funksjon start() -> heltall {
    la query_ctx = web.request_context("get", "/sok", {"side": "2"}, {}, "")
    assert_eq(web.request_query_int(query_ctx, "side"), 2)

    la query_fanget = ""
    prøv {
        web.request_query_required(query_ctx, "filter")
    } fang(feil) {
        query_fanget = feil
    }
    assert(t.starter_med(query_fanget, "ValideringsFeil:"))
    assert(t.inneholder(query_fanget, "query-felt 'filter'"))

    la body_ctx = web.request_context("post", "/brukere", {}, {}, "{\"navn\":\"Ada\",\"aktiv\":true,\"alder\":7}")
    la json = web.request_json(body_ctx)
    assert_eq(web.request_json_field(body_ctx, "navn"), "Ada")
    assert_eq(web.request_json_field_or(body_ctx, "mangler", "fallback"), "fallback")
    assert_eq(web.request_json_field_int(body_ctx, "alder"), 7)
    assert(web.request_json_field_bool(body_ctx, "aktiv"))
    assert_eq(json.navn, "Ada")

    la body_fanget = ""
    prøv {
        web.request_json_field_int(web.request_context("post", "/lagre", {}, {}, "[]"), "alder")
    } fang(feil) {
        body_fanget = feil
    }
    assert(t.starter_med(body_fanget, "ValideringsFeil:"))
    assert(t.inneholder(body_fanget, "body forventet JSON-objekt"))

    la respons = web.handle_request(web.request_context("get", "/brukere/42", {}, {}, ""))
    assert_eq(web.response_body(respons), "42")

    returner 0
}
