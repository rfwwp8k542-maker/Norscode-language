bruk std.log som logg
bruk std.json som json

funksjon start() -> heltall {
    la e = logg.info("server startet")
    assert_eq(json.hent_tekst(e, "level"), "info")
    assert_eq(json.hent_tekst(e, "message"), "server startet")

    assert_eq(logg.felt_tekst(e, "request_id", "req-123"), 3)
    assert_eq(logg.felt_tall(e, "status", 200), 4)
    assert_eq(logg.felt_bool(e, "ok", sann), 5)

    assert_eq(json.hent_tekst(e, "request_id"), "req-123")
    assert_eq(json.hent_tall(e, "status"), 200)
    assert_eq(json.hent_bool(e, "ok"), sann)
    assert(logg.emit(e) != "")

    returner 0
}
