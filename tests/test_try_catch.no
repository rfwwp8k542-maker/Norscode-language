funksjon kast_fra_funksjon() -> tekst {
    kast("inner feil")
}

funksjon start() -> heltall {
    la melding: tekst = ""
    la funnet: heltall = 0
    la uten_var: heltall = 0
    la outer_teller: heltall = 0

    prøv {
        kast("direkte")
    } fang (e) {
        melding = e
        funnet = 1
    }

    assert_eq(melding, "direkte")
    assert_eq(funnet, 1)

    prøv {
        kast_fra_funksjon()
    } fang (feil) {
        melding = feil
    }

    assert_eq(melding, "inner feil")

    prøv {
        kast("ukjent")
    } fang {
        uten_var = 1
    }

    assert_eq(uten_var, 1)

    prøv {
        prøv {
            kast("nested")
        } fang (e) {
            kast(e)
        }
    } fang (feil) {
        outer_teller = 1
        melding = feil
    }

    assert_eq(outer_teller, 1)
    assert_eq(melding, "nested")
    returner 0
}
