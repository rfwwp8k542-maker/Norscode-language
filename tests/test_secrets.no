bruk std.secrets som sikkerhet
bruk std.env som env
bruk std.tekst som t

funksjon start() -> heltall {
    la lagret = sikkerhet.passord_hash("hemmelig", "salt123")
    assert(sikkerhet.passord_verifiser("hemmelig", lagret))
    assert(ikke sikkerhet.passord_verifiser("feil", lagret))
    assert(t.starter_med(lagret, "salt123$"))

    env.sett("NORSCODE_TEST_SECRET", "superhemmelig")
    assert(sikkerhet.hemmelighet_finnes("NORSCODE_TEST_SECRET"))
    assert_eq(sikkerhet.hemmelighet_hent("NORSCODE_TEST_SECRET"), "superhemmelig")

    returner 0
}
