bruk std.path som path
bruk std.env som env

funksjon start() -> heltall {
    assert_eq(path.join("docs", "README.md"), "docs/README.md")
    assert_eq(path.basename("docs/README.md"), "README.md")
    assert_eq(path.dirname("docs/README.md"), "docs")
    assert_eq(path.stem("docs/README.md"), "README")
    assert(path.exists("README.md"))

    la nøkkel = "NORSCODE_TEST_ENV_PATH"
    assert_eq(env.sett(nøkkel, "klar"), "klar")
    assert(env.finnes(nøkkel))
    assert_eq(env.hent(nøkkel), "klar")
    returner 0
}
