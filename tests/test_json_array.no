bruk std.json som json

funksjon start() -> heltall {
    la payload = "[10,20,30]"
    la parsed = json.parse(payload)

    assert_eq(parsed["0"], "10")
    assert_eq(parsed["1"], "20")
    assert_eq(parsed["2"], "30")

    la empty_array = "[]"
    la empty = json.parse(empty_array)
    assert_eq(lengde(empty), 0)

    la tom_map = json.parse("{}")
    assert_eq(lengde(tom_map), 0)
    skriv("test_json_array OK")
    returner 0
}
