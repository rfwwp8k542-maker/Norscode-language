bruk std.ordbok som ordbok

funksjon start() -> heltall {
    la priser: ordbok_heltall = {"basis": 100}
    assert_eq(ordbok.antall_tall(priser), 1)
    assert_eq(ordbok.har_tall(priser, "basis"), sann)
    assert_eq(ordbok.hent_tall(priser, "basis"), 100)

    ordbok.sett_tall(priser, "basis", 200)
    ordbok.sett_tall(priser, "pro", 500)
    assert_eq(ordbok.antall_tall(priser), 2)
    assert_eq(ordbok.hent_tall(priser, "basis"), 200)
    assert_eq(ordbok.har_tall(priser, "mangler"), usann)

    la meta: ordbok_tekst = {"navn": "Norscode"}
    assert_eq(ordbok.har_tekst(meta, "navn"), sann)
    assert_eq(ordbok.hent_tekst(meta, "navn"), "Norscode")

    la flags: ordbok_bool = {}
    ordbok.sett_bool(flags, "klar", sann)
    assert_eq(ordbok.har_bool(flags, "klar"), sann)
    assert_eq(ordbok.hent_bool(flags, "klar"), sann)
    assert_eq(ordbok.fjern_bool(flags, "klar"), 0)
    assert_eq(ordbok.har_bool(flags, "klar"), usann)

    skriv("test_map_std OK")
    returner 0
}
