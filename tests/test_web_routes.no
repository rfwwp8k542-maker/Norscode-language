bruk std.web som web

funksjon eksakt(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /brukere/42")
    returner web.response_builder(200, {"content-type": "text/plain"}, "eksakt")
}

funksjon bruker(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /brukere/{id:int}")
    returner web.response_builder(200, {"content-type": "text/plain"}, web.request_param(ctx, "id"))
}

funksjon start() -> heltall {
    la eksakt_respons = web.handle_request(web.request_context("get", "/brukere/42", {}, {}, ""))
    assert_eq(web.response_status(eksakt_respons), 200)
    assert_eq(web.response_body(eksakt_respons), "eksakt")

    la param_respons = web.handle_request(web.request_context("get", "/brukere/7", {}, {}, ""))
    assert_eq(web.response_status(param_respons), 200)
    assert_eq(web.response_body(param_respons), "7")

    la mangler = web.handle_request(web.request_context("get", "/ukjent", {}, {}, ""))
    assert_eq(web.response_status(mangler), 404)

    la feil_metode = web.handle_request(web.request_context("post", "/brukere/42", {}, {}, ""))
    assert_eq(web.response_status(feil_metode), 405)

    returner 0
}
