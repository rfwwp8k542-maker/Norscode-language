bruk std.web som web
bruk std.tekst som t

funksjon api_guard(ctx: ordbok_tekst) -> bool {
    web.guard()
    returner web.require_bearer(ctx, "superhemmelig")
}

funksjon hemmelig(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("api_guard")
    web.route("GET /hemmelig")
    returner web.response_builder(200, {"content-type": "text/plain"}, "ok")
}

funksjon start() -> heltall {
    la openapi = web.openapi_json("Auth API", "9.9.9")
    assert(t.inneholder(openapi, "\"securitySchemes\""))
    assert(t.inneholder(openapi, "\"bearerAuth\""))
    assert(t.inneholder(openapi, "\"security\":"))
    assert(t.inneholder(openapi, "\"401\""))
    assert(t.inneholder(openapi, "\"403\""))
    assert(t.inneholder(openapi, "\"/hemmelig\""))
    returner 0
}
