bruk std.cache som cache

funksjon start() -> heltall {
    la c = cache.opprett()

    assert_eq(cache.antall(c), 0)
    assert(ikke cache.har(c, "bruker"))

    assert_eq(cache.sett(c, "bruker", "Ada"), 1)
    assert(cache.har(c, "bruker"))
    assert_eq(cache.hent(c, "bruker"), "Ada")
    assert_eq(cache.hent_eller(c, "mangler", "fallback"), "fallback")

    assert_eq(cache.sett_tall(c, "antall", 7), 2)
    assert_eq(cache.hent_tall(c, "antall"), 7)

    assert_eq(cache.sett_bool(c, "aktiv", sann), 3)
    assert_eq(cache.hent_bool(c, "aktiv"), sann)

    assert_eq(cache.fjern(c, "bruker"), 2)
    assert(ikke cache.har(c, "bruker"))
    assert_eq(cache.antall(c), 2)

    returner 0
}
