    assert_eq(script_norsk_ops_true_false, "0: PUSH 1\n1: PUSH 1\n2: AND\n3: PRINT\n4: HALT\n")

    la script_norsk_ops_ikkje: tekst = sh.disasm_skript("x=sann;y=ikkje usann;x og y")
