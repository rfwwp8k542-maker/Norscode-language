    assert_eq(script_norsk_multipliserer_med_underscore, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la script_norsk_multiplisert_med: tekst = sh.disasm_skript("la x=3;la y=4;returner x multiplisert med y")
    assert_eq(script_norsk_multiplisert_med, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la script_norsk_multiplisert_med_underscore: tekst = sh.disasm_skript("la x=3;la y=4;returner x multiplisert_med y")
    assert_eq(script_norsk_multiplisert_med_underscore, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la script_norsk_multipliseres_med: tekst = sh.disasm_skript("la x=3;la y=4;returner x multipliseres med y")
    assert_eq(script_norsk_multipliseres_med, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la script_norsk_multipliseres_med_underscore: tekst = sh.disasm_skript("la x=3;la y=4;returner x multipliseres_med y")
    assert_eq(script_norsk_multipliseres_med_underscore, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la script_norsk_delt_med: tekst = sh.disasm_skript("la x=8;la y=2;returner x delt med y")
    assert_eq(script_norsk_delt_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_delt_med_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x delt_med y")
    assert_eq(script_norsk_delt_med_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_divider_med: tekst = sh.disasm_skript("la x=8;la y=2;returner x divider med y")
    assert_eq(script_norsk_divider_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_divider_med_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x divider_med y")
    assert_eq(script_norsk_divider_med_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividerer_med: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividerer med y")
    assert_eq(script_norsk_dividerer_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividerer_med_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividerer_med y")
    assert_eq(script_norsk_dividerer_med_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividert_med: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividert med y")
    assert_eq(script_norsk_dividert_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dividert_med_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x dividert_med y")
    assert_eq(script_norsk_dividert_med_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_divideres_med: tekst = sh.disasm_skript("la x=8;la y=2;returner x divideres med y")
    assert_eq(script_norsk_divideres_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_divideres_med_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x divideres_med y")
    assert_eq(script_norsk_divideres_med_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_deles_med: tekst = sh.disasm_skript("la x=8;la y=2;returner x deles med y")
    assert_eq(script_norsk_deles_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_deles_med_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x deles_med y")
    assert_eq(script_norsk_deles_med_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_del_med: tekst = sh.disasm_skript("la x=8;la y=2;returner x del med y")
    assert_eq(script_norsk_del_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_del_med_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x del_med y")
    assert_eq(script_norsk_del_med_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dele_med: tekst = sh.disasm_skript("la x=8;la y=2;returner x dele med y")
    assert_eq(script_norsk_dele_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dele_med_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x dele_med y")
    assert_eq(script_norsk_dele_med_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dele_paa_utf8: tekst = sh.disasm_skript("la x=8;la y=2;returner x dele på y")
    assert_eq(script_norsk_dele_paa_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dele_paa_ascii: tekst = sh.disasm_skript("la x=8;la y=2;returner x dele pa y")
    assert_eq(script_norsk_dele_paa_ascii, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_dele_paa_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x dele_pa y")
    assert_eq(script_norsk_dele_paa_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_delt_paa_utf8: tekst = sh.disasm_skript("la x=8;la y=2;returner x delt på y")
    assert_eq(script_norsk_delt_paa_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_delt_paa_underscore_utf8: tekst = sh.disasm_skript("la x=8;la y=2;returner x delt_på y")
    assert_eq(script_norsk_delt_paa_underscore_utf8, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_delt_paa_underscore_ascii: tekst = sh.disasm_skript("la x=8;la y=2;returner x delt_pa y")
    assert_eq(script_norsk_delt_paa_underscore_ascii, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_delt_paa_double_a_phrase: tekst = sh.disasm_skript("la x=8;la y=2;returner x delt paa y")
    assert_eq(script_norsk_delt_paa_double_a_phrase, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_delt_paa_double_a_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x delt_paa y")
    assert_eq(script_norsk_delt_paa_double_a_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_deler_pa: tekst = sh.disasm_skript("la x=8;la y=2;returner x deler pa y")
    assert_eq(script_norsk_deler_pa, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_deler_med: tekst = sh.disasm_skript("la x=8;la y=2;returner x deler med y")
    assert_eq(script_norsk_deler_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_deler_pa_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x deler_pa y")
    assert_eq(script_norsk_deler_pa_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_norsk_deler_med_underscore: tekst = sh.disasm_skript("la x=8;la y=2;returner x deler_med y")
    assert_eq(script_norsk_deler_med_underscore, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_c: tekst = sh.kompiler_skript_til_c("x=2;y=x+5;y*2")
    assert_ne(script_c, "")

    la script_err1: tekst = sh.disasm_skript("x=2+3")
    assert_eq(script_err1, "/* feil: mangler ';' etter assignment til x ved token 0 */")

    la script_skip_empty: tekst = sh.disasm_skript("x=2;;x+1")
    assert_eq(script_skip_empty, "0: PUSH 2\n1: PUSH 1\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_err3: tekst = sh.disasm_skript("x=2+3;")
    assert_eq(script_err3, "/* feil: skriptet mangler sluttuttrykk */")

    la script_err4: tekst = sh.disasm_skript("la ;x+1")
    assert_eq(script_err4, "/* feil: 'la' må etterfølges av variabelnavn ved token 0 */")

    la script_err5: tekst = sh.disasm_skript("la x;x+1")
    assert_eq(script_err5, "/* feil: ugyldig deklarasjon etter 'la' ved token 0 */")

    la script_err6: tekst = sh.disasm_skript("1+1; y=2; y")
    assert_eq(script_err6, "/* feil: kun siste statement kan være uttrykk (token 4) */")

    la script_err7: tekst = sh.disasm_skript("la x=1;returner")
    assert_eq(script_err7, "/* feil: 'returner' må etterfølges av uttrykk ved token 5 */")

    la script_err8: tekst = sh.disasm_skript("sett x=1;returner 0")
    assert_eq(script_err8, "/* feil: variabel 'x' er ikke deklarert (bruk 'la') ved token 0 */")

    la script_err9: tekst = sh.disasm_skript("la x=1;la x=2;returner x")
    assert_eq(script_err9, "/* feil: variabel 'x' er allerede deklarert ved token 5 */")

    la script_err12: tekst = sh.disasm_skript("la x+=1;returner x")
    assert_eq(script_err12, "/* feil: 'la' støtter kun '=' ved token 0 */")

    la script_err13: tekst = sh.disasm_skript("x+=1;returner x")
    assert_eq(script_err13, "/* feil: variabel 'x' er ikke deklarert for '+=' ved token 0 */")

    la script_err10: tekst = sh.disasm_skript("hvis 1==1 10 ellers 20")
    assert_eq(script_err10, "/* feil: hvis-uttrykk mangler 'da' ved token 0 */")

    la script_err11: tekst = sh.disasm_skript("hvis 1==1 da 10")
    assert_eq(script_err11, "/* feil: hvis-uttrykk mangler 'ellers' ved token 4 */")

    la script_err14: tekst = sh.disasm_skript("hvis (1==1 da 10 ellers 20")
    assert_eq(script_err14, "/* feil: mangler ) i hvis-uttrykk ved token 1 */")

    la linjer: liste_tekst = ["", "PUSH", "11", "PUSH", "4", "SUB", "PRINT", "HALT"]
    la c3: tekst = sh.kompiler_fra_linjer(linjer)
    assert_ne(c3, "")

    la kilde: tekst = "# kommentar\nPUSH 10;\nPUSH 32\nADD\nPRINT\nHALT"
    la c4: tekst = sh.kompiler_fra_kilde(kilde)
    assert_eq(c4, demo)

    returner 0
}
