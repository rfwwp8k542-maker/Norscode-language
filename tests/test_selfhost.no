bruk selfhost.compiler som sh

funksjon start() -> heltall {
    la push_linje: tekst = sh.instruksjon_til_c("PUSH", 42)
    assert_eq(push_linje, "stack[sp++] = 42;")

    la add_linje: tekst = sh.instruksjon_til_c("ADD", 0)
    assert_eq(add_linje, "stack[sp-2] = stack[sp-2] + stack[sp-1]; sp = sp - 1;")

    la halt_linje: tekst = sh.instruksjon_til_c("HALT", 0)
    assert_eq(halt_linje, "return 0;")

    la label_linje: tekst = sh.instruksjon_til_c("LABEL", 7)
    assert_eq(label_linje, "L7:;")

    la jmp_linje: tekst = sh.instruksjon_til_c("JMP", 7)
    assert_eq(jmp_linje, "goto L7;")

    la jz_linje: tekst = sh.instruksjon_til_c("JZ", 7)
    assert_eq(jz_linje, "if (stack[sp-1] == 0) goto L7;")

    la call_linje: tekst = sh.instruksjon_til_c("CALL", 7)
    assert_eq(call_linje, "ret_stack[rsp++] = 0; goto L7;")

    la ret_linje: tekst = sh.instruksjon_til_c("RET", 0)
    assert_eq(ret_linje, "goto *labels[0];")

    la store_linje: tekst = sh.instruksjon_til_c("STORE", 3)
    assert_eq(store_linje, "mem[3] = stack[sp-1]; sp = sp - 1;")

    la load_linje: tekst = sh.instruksjon_til_c("LOAD", 3)
    assert_eq(load_linje, "stack[sp++] = mem[3];")

    la eq_linje: tekst = sh.instruksjon_til_c("EQ", 0)
    assert_eq(eq_linje, "stack[sp-2] = (stack[sp-2] == stack[sp-1]); sp = sp - 1;")

    la gt_linje: tekst = sh.instruksjon_til_c("GT", 0)
    assert_eq(gt_linje, "stack[sp-2] = (stack[sp-2] > stack[sp-1]); sp = sp - 1;")

    la lt_linje: tekst = sh.instruksjon_til_c("LT", 0)
    assert_eq(lt_linje, "stack[sp-2] = (stack[sp-2] < stack[sp-1]); sp = sp - 1;")

    la mod_linje: tekst = sh.instruksjon_til_c("MOD", 0)
    assert_eq(mod_linje, "stack[sp-2] = stack[sp-2] % stack[sp-1]; sp = sp - 1;")

    la and_linje: tekst = sh.instruksjon_til_c("AND", 0)
    assert_eq(and_linje, "stack[sp-2] = (stack[sp-2] && stack[sp-1]); sp = sp - 1;")

    la or_linje: tekst = sh.instruksjon_til_c("OR", 0)
    assert_eq(or_linje, "stack[sp-2] = (stack[sp-2] || stack[sp-1]); sp = sp - 1;")

    la not_linje: tekst = sh.instruksjon_til_c("NOT", 0)
    assert_eq(not_linje, "stack[sp-1] = !stack[sp-1];")

    la dup_linje: tekst = sh.instruksjon_til_c("DUP", 0)
    assert_eq(dup_linje, "stack[sp] = stack[sp-1]; sp = sp + 1;")

    la pop_linje: tekst = sh.instruksjon_til_c("POP", 0)
    assert_eq(pop_linje, "sp = sp - 1;")

    la swap_linje: tekst = sh.instruksjon_til_c("SWAP", 0)
    assert_eq(swap_linje, "tmp = stack[sp-1]; stack[sp-1] = stack[sp-2]; stack[sp-2] = tmp;")

    la over_linje: tekst = sh.instruksjon_til_c("OVER", 0)
    assert_eq(over_linje, "stack[sp] = stack[sp-2]; sp = sp + 1;")

    la demo: tekst = sh.demo_program()
    assert_ne(demo, "")

    la ops: liste_tekst = ["PUSH", "PUSH", "MUL", "PRINT", "HALT"]
    la verdier: liste_heltall = [6, 7, 0, 0, 0]
    la c: tekst = sh.kompiler_til_c(ops, verdier)
    assert_ne(c, "")

    la tokens: liste_tekst = ["PUSH", "8", "PUSH", "9", "ADD", "PRINT", "HALT"]
    la c2: tekst = sh.kompiler_fra_tokens(tokens)
    assert_ne(c2, "")

    la tokens_jmp: liste_tekst = ["PUSH", "0", "JZ", "1", "PUSH", "99", "PRINT", "LABEL", "1", "HALT"]
    la c2b: tekst = sh.kompiler_fra_tokens(tokens_jmp)
    assert_ne(c2b, "")

    la tokens_cmp_jz: liste_tekst = ["PUSH", "4", "PUSH", "4", "EQ", "JZ", "2", "PUSH", "1", "PRINT", "LABEL", "2", "HALT"]
    la c2c: tekst = sh.kompiler_fra_tokens(tokens_cmp_jz)
    assert_ne(c2c, "")

    la tokens_stack: liste_tekst = ["PUSH", "5", "DUP", "ADD", "POP", "HALT"]
    la c2d: tekst = sh.kompiler_fra_tokens(tokens_stack)
    assert_ne(c2d, "")

    la tokens_stack2: liste_tekst = ["PUSH", "2", "PUSH", "9", "SWAP", "OVER", "ADD", "HALT"]
    la c2e: tekst = sh.kompiler_fra_tokens(tokens_stack2)
    assert_ne(c2e, "")

    la tokens_mod: liste_tekst = ["PUSH", "17", "PUSH", "5", "MOD", "PRINT", "HALT"]
    la c2f: tekst = sh.kompiler_fra_tokens(tokens_mod)
    assert_ne(c2f, "")

    la tokens_bool: liste_tekst = ["PUSH", "1", "PUSH", "0", "AND", "NOT", "PRINT", "HALT"]
    la c2g: tekst = sh.kompiler_fra_tokens(tokens_bool)
    assert_ne(c2g, "")

    la tokens_mem: liste_tekst = ["PUSH", "42", "STORE", "0", "LOAD", "0", "PUSH", "1", "ADD", "PRINT", "HALT"]
    la c2h: tekst = sh.kompiler_fra_tokens(tokens_mem)
    assert_ne(c2h, "")

    la tokens_call: liste_tekst = ["CALL", "3", "HALT", "LABEL", "3", "PUSH", "99", "RET"]
    la c2i: tekst = sh.kompiler_fra_tokens(tokens_call)
    assert_ne(c2i, "")

    la tokens_bad_jump: liste_tekst = ["JMP", "9", "HALT"]
    la c_bad: tekst = sh.kompiler_fra_tokens(tokens_bad_jump)
    assert_eq(c_bad, "/* feil: ugyldig hopp-target 9 */")

    la tokens_underflow: liste_tekst = ["ADD", "HALT"]
    la c_underflow: tekst = sh.kompiler_fra_tokens(tokens_underflow)
    assert_eq(c_underflow, "/* feil: stack-underflow ved indeks 0 (ADD) */")

    la tokens_bad_mem: liste_tekst = ["PUSH", "1", "STORE", "999", "HALT"]
    la c_bad_mem: tekst = sh.kompiler_fra_tokens(tokens_bad_mem)
    assert_eq(c_bad_mem, "/* feil: minneindeks utenfor range 999 */")

    la tokens_dis: liste_tekst = ["PUSH", "3", "PUSH", "4", "ADD", "HALT"]
    la dis: tekst = sh.disasm_fra_tokens(tokens_dis)
    assert_eq(dis, "0: PUSH 3\n1: PUSH 4\n2: ADD\n3: HALT\n")

    la dis_src: tekst = sh.disasm_fra_kilde("# c\nPUSH 3;\nPUSH 4\nADD\nHALT")
    assert_eq(dis_src, "0: PUSH 3\n1: PUSH 4\n2: ADD\n3: HALT\n")

    la dis_src_strict: tekst = sh.disasm_fra_kilde_strict("PUSH 3\nPUSH 4\nADD\nHALT")
    assert_eq(dis_src_strict, "0: PUSH 3\n1: PUSH 4\n2: ADD\n3: HALT\n")

    la dis_src_bad: tekst = sh.disasm_fra_kilde_strict("PUSH x\nHALT")
    assert_eq(dis_src_bad, "/* feil: ugyldig heltallsargument x ved token 1 */")

    la dis_src_bad_opcode: tekst = sh.disasm_fra_kilde_strict("PUHS 1\nHALT")
    assert_eq(dis_src_bad_opcode, "/* feil: ukjent opcode PUHS ved token 0 */")

    la c_src_bad: tekst = sh.kompiler_fra_kilde_strict("PUSH 2\nPUSH q\nADD\nHALT")
    assert_eq(c_src_bad, "/* feil: ugyldig heltallsargument q ved token 3 */")

    la expr_dis: tekst = sh.disasm_uttrykk("2+3*4")
    assert_eq(expr_dis, "0: PUSH 2\n1: PUSH 3\n2: PUSH 4\n3: MUL\n4: ADD\n5: PRINT\n6: HALT\n")

    la expr_dis_paren: tekst = sh.disasm_uttrykk("(2+3)*4")
    assert_eq(expr_dis_paren, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PUSH 4\n4: MUL\n5: PRINT\n6: HALT\n")

    la expr_c: tekst = sh.kompiler_uttrykk_til_c("10 + 32")
    assert_ne(expr_c, "")

    la expr_cmp: tekst = sh.disasm_uttrykk("5>3&&2<4")
    assert_eq(expr_cmp, "0: PUSH 5\n1: PUSH 3\n2: GT\n3: PUSH 2\n4: PUSH 4\n5: LT\n6: AND\n7: PRINT\n8: HALT\n")

    la expr_eq: tekst = sh.disasm_uttrykk("7!=7||2==2")
    assert_eq(expr_eq, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: NOT\n4: PUSH 2\n5: PUSH 2\n6: EQ\n7: OR\n8: PRINT\n9: HALT\n")

    la expr_le: tekst = sh.disasm_uttrykk("3 <= 4")
    assert_eq(expr_le, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_ge: tekst = sh.disasm_uttrykk("4 >= 3")
    assert_eq(expr_ge, "0: PUSH 4\n1: PUSH 3\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_unary_not: tekst = sh.disasm_uttrykk("!0||0")
    assert_eq(expr_unary_not, "0: PUSH 0\n1: NOT\n2: PUSH 0\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_unary_minus: tekst = sh.disasm_uttrykk("-3+5")
    assert_eq(expr_unary_minus, "0: PUSH 3\n1: PUSH 0\n2: SWAP\n3: SUB\n4: PUSH 5\n5: ADD\n6: PRINT\n7: HALT\n")

    la expr_unary_plus: tekst = sh.disasm_uttrykk("+3+5")
    assert_eq(expr_unary_plus, "0: PUSH 3\n1: PUSH 5\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_arith: tekst = sh.disasm_uttrykk("2 pluss 3 ganger 4")
    assert_eq(expr_norsk_arith, "0: PUSH 2\n1: PUSH 3\n2: PUSH 4\n3: MUL\n4: ADD\n5: PRINT\n6: HALT\n")

    la expr_norsk_div: tekst = sh.disasm_uttrykk("8 delt pa 2")
    assert_eq(expr_norsk_div, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_mod: tekst = sh.disasm_uttrykk("17 mod 5")
    assert_eq(expr_norsk_mod, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_modulo: tekst = sh.disasm_uttrykk("17 modulo 5")
    assert_eq(expr_norsk_modulo, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_ganget_med: tekst = sh.disasm_uttrykk("3 ganget med 4")
    assert_eq(expr_norsk_ganget_med, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_delt_med: tekst = sh.disasm_uttrykk("8 delt med 2")
    assert_eq(expr_norsk_delt_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_bool_literals: tekst = sh.disasm_uttrykk("sann&&usann||!usann")
    assert_eq(expr_bool_literals, "0: PUSH 1\n1: PUSH 0\n2: AND\n3: PUSH 0\n4: NOT\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_norsk_ops: tekst = sh.disasm_uttrykk("sann og ikke usann eller usann")
    assert_eq(expr_norsk_ops, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: AND\n4: PUSH 0\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_norsk_cmp: tekst = sh.disasm_uttrykk("7 er 7 og 3 mindre_enn 4")
    assert_eq(expr_norsk_cmp, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PUSH 3\n4: PUSH 4\n5: LT\n6: AND\n7: PRINT\n8: HALT\n")

    la expr_norsk_cmp2: tekst = sh.disasm_uttrykk("7 ikke_er 8 og 4 storre_eller_lik 4")
    assert_eq(expr_norsk_cmp2, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PUSH 4\n5: PUSH 4\n6: LT\n7: NOT\n8: AND\n9: PRINT\n10: HALT\n")

    la expr_norsk_cmp_phrase: tekst = sh.disasm_uttrykk("7 er 7 og 3 mindre enn 4")
    assert_eq(expr_norsk_cmp_phrase, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PUSH 3\n4: PUSH 4\n5: LT\n6: AND\n7: PRINT\n8: HALT\n")

    la expr_norsk_cmp_phrase2: tekst = sh.disasm_uttrykk("7 ikke er 8 og 4 storre eller lik 4")
    assert_eq(expr_norsk_cmp_phrase2, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PUSH 4\n5: PUSH 4\n6: LT\n7: NOT\n8: AND\n9: PRINT\n10: HALT\n")

    la expr_norsk_cmp_phrase3: tekst = sh.disasm_uttrykk("7 er ikke 8 og 4 storre eller lik 4")
    assert_eq(expr_norsk_cmp_phrase3, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PUSH 4\n5: PUSH 4\n6: LT\n7: NOT\n8: AND\n9: PRINT\n10: HALT\n")

    la expr_norsk_cmp_phrase4: tekst = sh.disasm_uttrykk("7 er lik 7 og 3 mindre enn 4")
    assert_eq(expr_norsk_cmp_phrase4, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PUSH 3\n4: PUSH 4\n5: LT\n6: AND\n7: PRINT\n8: HALT\n")

    la expr_norsk_cmp_phrase5: tekst = sh.disasm_uttrykk("7 er ikke lik 8 og 4 storre eller lik 4")
    assert_eq(expr_norsk_cmp_phrase5, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PUSH 4\n5: PUSH 4\n6: LT\n7: NOT\n8: AND\n9: PRINT\n10: HALT\n")

    la expr_norsk_cmp_phrase6: tekst = sh.disasm_uttrykk("3 er mindre enn 4")
    assert_eq(expr_norsk_cmp_phrase6, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_phrase7: tekst = sh.disasm_uttrykk("4 er storre eller lik 4")
    assert_eq(expr_norsk_cmp_phrase7, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase8: tekst = sh.disasm_uttrykk("7 ikke lik 8")
    assert_eq(expr_norsk_cmp_phrase8, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase9: tekst = sh.disasm_uttrykk("7 ulik 8")
    assert_eq(expr_norsk_cmp_phrase9, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase10: tekst = sh.disasm_uttrykk("7 er ulik 8")
    assert_eq(expr_norsk_cmp_phrase10, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase11: tekst = sh.disasm_uttrykk("4 storre enn eller lik 4")
    assert_eq(expr_norsk_cmp_phrase11, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase12: tekst = sh.disasm_uttrykk("4 er storre enn eller lik 4")
    assert_eq(expr_norsk_cmp_phrase12, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase13: tekst = sh.disasm_uttrykk("7 er lik med 7")
    assert_eq(expr_norsk_cmp_phrase13, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_phrase14: tekst = sh.disasm_uttrykk("7 ikke lik med 8")
    assert_eq(expr_norsk_cmp_phrase14, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase15: tekst = sh.disasm_uttrykk("7 er ikke lik med 8")
    assert_eq(expr_norsk_cmp_phrase15, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase16: tekst = sh.disasm_uttrykk("7 lik 7")
    assert_eq(expr_norsk_cmp_phrase16, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_phrase17: tekst = sh.disasm_uttrykk("7 ulik med 8")
    assert_eq(expr_norsk_cmp_phrase17, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase18: tekst = sh.disasm_uttrykk("3 mindre lik 4")
    assert_eq(expr_norsk_cmp_phrase18, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase19: tekst = sh.disasm_uttrykk("4 storre lik 4")
    assert_eq(expr_norsk_cmp_phrase19, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase20: tekst = sh.disasm_uttrykk("4 er storre lik 4")
    assert_eq(expr_norsk_cmp_phrase20, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase21: tekst = sh.disasm_uttrykk("3 mindre enn lik 4")
    assert_eq(expr_norsk_cmp_phrase21, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_norsk_cmp_phrase22: tekst = sh.disasm_uttrykk("4 er storre enn lik 4")
    assert_eq(expr_norsk_cmp_phrase22, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la env_navn: liste_tekst = ["x", "y"]
    la env_verdier: liste_heltall = [7, 3]
    la expr_env: tekst = sh.disasm_uttrykk_med_miljo("x*2+y", env_navn, env_verdier)
    assert_eq(expr_env, "0: PUSH 7\n1: PUSH 2\n2: MUL\n3: PUSH 3\n4: ADD\n5: PRINT\n6: HALT\n")

    la expr_env_c: tekst = sh.kompiler_uttrykk_til_c_med_miljo("x+y", env_navn, env_verdier)
    assert_ne(expr_env_c, "")

    la expr_hvis: tekst = sh.disasm_uttrykk("hvis 1==1 da 7 ellers 9")
    assert_eq(expr_hvis, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 7\n5: JMP 8\n6: LABEL 6\n7: PUSH 9\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la expr_hvis_env: tekst = sh.disasm_uttrykk_med_miljo("hvis x>y da x ellers y", env_navn, env_verdier)
    assert_eq(expr_hvis_env, "0: PUSH 7\n1: PUSH 3\n2: GT\n3: JZ 6\n4: PUSH 7\n5: JMP 8\n6: LABEL 6\n7: PUSH 3\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la expr_hvis_c: tekst = sh.kompiler_uttrykk_til_c("hvis 1==1 da 7 ellers 9")
    assert_ne(expr_hvis_c, "")

    la expr_err: tekst = sh.disasm_uttrykk("2 +")
    assert_eq(expr_err, "/* feil: uttrykket avsluttes med operator ved token 1 */")

    la expr_err2: tekst = sh.disasm_uttrykk("2 + )")
    assert_eq(expr_err2, "/* feil: mangler verdi før ) ved token 2 */")

    la expr_err3: tekst = sh.disasm_uttrykk("2+$")
    assert_eq(expr_err3, "/* feil: ukjent token/navn i uttrykk $ ved token 2 */")

    la expr_err4: tekst = sh.disasm_uttrykk("foo+1")
    assert_eq(expr_err4, "/* feil: ukjent token/navn i uttrykk foo ved token 0 */")

    la expr_env_err: tekst = sh.disasm_uttrykk_med_miljo("z+1", env_navn, env_verdier)
    assert_eq(expr_env_err, "/* feil: ukjent token/navn i uttrykk z ved token 0 */")

    la env_navn_kort: liste_tekst = ["x"]
    la env_verdier_lang: liste_heltall = [1, 2]
    la expr_env_err2: tekst = sh.disasm_uttrykk_med_miljo("x+1", env_navn_kort, env_verdier_lang)
    assert_eq(expr_env_err2, "/* feil: navn/miljø-verdier må ha samme lengde */")

    la expr_err5: tekst = sh.disasm_uttrykk("(2+3")
    assert_eq(expr_err5, "/* feil: mangler ) i uttrykk ved token 0 */")

    la script_dis: tekst = sh.disasm_skript("x=2+3;y=x*4;y+1")
    assert_eq(script_dis, "0: PUSH 20\n1: PUSH 1\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_la_dis: tekst = sh.disasm_skript("la x=2+3;la y=x*4;y+1")
    assert_eq(script_la_dis, "0: PUSH 20\n1: PUSH 1\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_trailing_semicolon: tekst = sh.disasm_skript("x=2;y=3;x+y;")
    assert_eq(script_trailing_semicolon, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_empty_statements: tekst = sh.disasm_skript(";;la x=2;;x+1;;")
    assert_eq(script_empty_statements, "0: PUSH 2\n1: PUSH 1\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_returner: tekst = sh.disasm_skript("la x=2;returner x+3")
    assert_eq(script_returner, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_returner_semicolon: tekst = sh.disasm_skript("la x=2;returner x+3;")
    assert_eq(script_returner_semicolon, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_sett_ok: tekst = sh.disasm_skript("la x=2;sett x=x+3;returner x")
    assert_eq(script_sett_ok, "0: PUSH 5\n1: PRINT\n2: HALT\n")

    la script_compound_ok: tekst = sh.disasm_skript("la x=2;x+=3;x*=2;returner x")
    assert_eq(script_compound_ok, "0: PUSH 10\n1: PRINT\n2: HALT\n")

    la script_hvis_assignment: tekst = sh.disasm_skript("la x=hvis 1==1 da 7 ellers 9;returner x+1")
    assert_eq(script_hvis_assignment, "0: PUSH 7\n1: PUSH 1\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_hvis: tekst = sh.disasm_skript("la x=1;hvis x==1 da 10 ellers 20")
    assert_eq(script_hvis, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 10\n5: JMP 8\n6: LABEL 6\n7: PUSH 20\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_returner_hvis: tekst = sh.disasm_skript("la x=0;returner hvis x==1 da 10 ellers 20")
    assert_eq(script_returner_hvis, "0: PUSH 0\n1: PUSH 1\n2: EQ\n3: JZ 6\n4: PUSH 10\n5: JMP 8\n6: LABEL 6\n7: PUSH 20\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_nested_hvis: tekst = sh.disasm_skript("la x=1;hvis x==1 da hvis x==1 da 10 ellers 11 ellers 20")
    assert_eq(script_nested_hvis, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: JZ 14\n4: PUSH 1\n5: PUSH 1\n6: EQ\n7: JZ 10\n8: PUSH 10\n9: JMP 12\n10: LABEL 10\n11: PUSH 11\n12: LABEL 12\n13: JMP 16\n14: LABEL 14\n15: PUSH 20\n16: LABEL 16\n17: PRINT\n18: HALT\n")

    la script_norsk_ops: tekst = sh.disasm_skript("x=sann;y=ikke usann;x og y")
    assert_eq(script_norsk_ops, "0: PUSH 1\n1: PUSH 1\n2: AND\n3: PRINT\n4: HALT\n")

    la script_norsk_cmp: tekst = sh.disasm_skript("la x=3;la y=4;hvis x mindre_enn y da 1 ellers 0")
    assert_eq(script_norsk_cmp, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: JZ 6\n4: PUSH 1\n5: JMP 8\n6: LABEL 6\n7: PUSH 0\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_norsk_cmp_phrase: tekst = sh.disasm_skript("la x=3;la y=4;hvis x mindre enn y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: JZ 6\n4: PUSH 1\n5: JMP 8\n6: LABEL 6\n7: PUSH 0\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_norsk_cmp_phrase2: tekst = sh.disasm_skript("la x=3;la y=4;hvis x er ikke y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase2, "0: PUSH 3\n1: PUSH 4\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_phrase3: tekst = sh.disasm_skript("la x=3;la y=3;hvis x er lik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase3, "0: PUSH 3\n1: PUSH 3\n2: EQ\n3: JZ 6\n4: PUSH 1\n5: JMP 8\n6: LABEL 6\n7: PUSH 0\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_norsk_cmp_phrase4: tekst = sh.disasm_skript("la x=3;la y=4;hvis x er mindre enn y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase4, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: JZ 6\n4: PUSH 1\n5: JMP 8\n6: LABEL 6\n7: PUSH 0\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_norsk_cmp_phrase5: tekst = sh.disasm_skript("la x=3;la y=4;hvis x ikke lik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase5, "0: PUSH 3\n1: PUSH 4\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_phrase6: tekst = sh.disasm_skript("la x=3;la y=4;hvis x er ulik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase6, "0: PUSH 3\n1: PUSH 4\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_phrase7: tekst = sh.disasm_skript("la x=4;la y=4;hvis x storre enn eller lik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase7, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_phrase8: tekst = sh.disasm_skript("la x=7;la y=8;hvis x er ikke lik med y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase8, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_phrase9: tekst = sh.disasm_skript("la x=7;la y=7;hvis x lik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase9, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: JZ 6\n4: PUSH 1\n5: JMP 8\n6: LABEL 6\n7: PUSH 0\n8: LABEL 8\n9: PRINT\n10: HALT\n")

    la script_norsk_cmp_phrase10: tekst = sh.disasm_skript("la x=7;la y=8;hvis x ulik med y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase10, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_phrase11: tekst = sh.disasm_skript("la x=3;la y=4;hvis x mindre lik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase11, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_phrase12: tekst = sh.disasm_skript("la x=4;la y=4;hvis x er storre lik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase12, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_phrase13: tekst = sh.disasm_skript("la x=3;la y=4;hvis x storre enn lik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase13, "0: PUSH 3\n1: PUSH 4\n2: LT\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_norsk_cmp_phrase14: tekst = sh.disasm_skript("la x=4;la y=4;hvis x er storre enn lik y da 1 ellers 0")
    assert_eq(script_norsk_cmp_phrase14, "0: PUSH 4\n1: PUSH 4\n2: LT\n3: NOT\n4: JZ 7\n5: PUSH 1\n6: JMP 9\n7: LABEL 7\n8: PUSH 0\n9: LABEL 9\n10: PRINT\n11: HALT\n")

    la script_unary_plus: tekst = sh.disasm_skript("la x=2;returner +x")
    assert_eq(script_unary_plus, "0: PUSH 2\n1: PRINT\n2: HALT\n")

    la script_norsk_arith: tekst = sh.disasm_skript("la x=2;la y=3;returner x pluss y ganger 4")
    assert_eq(script_norsk_arith, "0: PUSH 2\n1: PUSH 3\n2: PUSH 4\n3: MUL\n4: ADD\n5: PRINT\n6: HALT\n")

    la script_norsk_mod: tekst = sh.disasm_skript("la x=17;la y=5;returner x mod y")
    assert_eq(script_norsk_mod, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la script_norsk_ganget_med: tekst = sh.disasm_skript("la x=3;la y=4;returner x ganget med y")
    assert_eq(script_norsk_ganget_med, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la script_norsk_delt_med: tekst = sh.disasm_skript("la x=8;la y=2;returner x delt med y")
    assert_eq(script_norsk_delt_med, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la script_c: tekst = sh.kompiler_skript_til_c("x=2;y=x+5;y*2")
    assert_ne(script_c, "")

    la script_err1: tekst = sh.disasm_skript("x=2+3")
    assert_eq(script_err1, "/* feil: mangler ';' etter assignment til x ved token 0 */")

    la script_skip_empty: tekst = sh.disasm_skript("x=2;;x+1")
    assert_eq(script_skip_empty, "0: PUSH 2\n1: PUSH 1\n2: ADD\n3: PRINT\n4: HALT\n")

    la script_err3: tekst = sh.disasm_skript("x=2+3;")
    assert_eq(script_err3, "/* feil: skriptet mangler sluttuttrykk */")

    la script_err4: tekst = sh.disasm_skript("la ;x+1")
    assert_eq(script_err4, "/* feil: 'la' må etterfølges av variabelnavn ved token 0 */")

    la script_err5: tekst = sh.disasm_skript("la x;x+1")
    assert_eq(script_err5, "/* feil: ugyldig deklarasjon etter 'la' ved token 0 */")

    la script_err6: tekst = sh.disasm_skript("1+1; y=2; y")
    assert_eq(script_err6, "/* feil: kun siste statement kan være uttrykk (token 4) */")

    la script_err7: tekst = sh.disasm_skript("la x=1;returner")
    assert_eq(script_err7, "/* feil: 'returner' må etterfølges av uttrykk ved token 5 */")

    la script_err8: tekst = sh.disasm_skript("sett x=1;returner 0")
    assert_eq(script_err8, "/* feil: variabel 'x' er ikke deklarert (bruk 'la') ved token 0 */")

    la script_err9: tekst = sh.disasm_skript("la x=1;la x=2;returner x")
    assert_eq(script_err9, "/* feil: variabel 'x' er allerede deklarert ved token 5 */")

    la script_err12: tekst = sh.disasm_skript("la x+=1;returner x")
    assert_eq(script_err12, "/* feil: 'la' støtter kun '=' ved token 0 */")

    la script_err13: tekst = sh.disasm_skript("x+=1;returner x")
    assert_eq(script_err13, "/* feil: variabel 'x' er ikke deklarert for '+=' ved token 0 */")

    la script_err10: tekst = sh.disasm_skript("hvis 1==1 10 ellers 20")
    assert_eq(script_err10, "/* feil: hvis-uttrykk mangler 'da' ved token 0 */")

    la script_err11: tekst = sh.disasm_skript("hvis 1==1 da 10")
    assert_eq(script_err11, "/* feil: hvis-uttrykk mangler 'ellers' ved token 4 */")

    la script_err14: tekst = sh.disasm_skript("hvis (1==1 da 10 ellers 20")
    assert_eq(script_err14, "/* feil: mangler ) i hvis-uttrykk ved token 1 */")

    la linjer: liste_tekst = ["", "PUSH", "11", "PUSH", "4", "SUB", "PRINT", "HALT"]
    la c3: tekst = sh.kompiler_fra_linjer(linjer)
    assert_ne(c3, "")

    la kilde: tekst = "# kommentar\nPUSH 10;\nPUSH 32\nADD\nPRINT\nHALT"
    la c4: tekst = sh.kompiler_fra_kilde(kilde)
    assert_eq(c4, demo)

    returner 0
}
