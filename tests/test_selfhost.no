    la script_norsk_multipliser_med: tekst = sh.disasm_skript("la x=3;la y=4;returner x multipliser med y")
    assert_eq(script_norsk_multipliser_med, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

