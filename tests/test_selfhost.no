bruk selfhost.compiler som sh

funksjon start() -> heltall {
    la push_linje: tekst = sh.instruksjon_til_c("PUSH", 42)
    assert_eq(push_linje, "stack[sp++] = 42;")

    la add_linje: tekst = sh.instruksjon_til_c("ADD", 0)
    assert_eq(add_linje, "stack[sp-2] = stack[sp-2] + stack[sp-1]; sp = sp - 1;")

    la halt_linje: tekst = sh.instruksjon_til_c("HALT", 0)
    assert_eq(halt_linje, "return 0;")

    la label_linje: tekst = sh.instruksjon_til_c("LABEL", 7)
    assert_eq(label_linje, "L7:;")

    la jmp_linje: tekst = sh.instruksjon_til_c("JMP", 7)
    assert_eq(jmp_linje, "goto L7;")

    la jz_linje: tekst = sh.instruksjon_til_c("JZ", 7)
    assert_eq(jz_linje, "if (stack[sp-1] == 0) goto L7;")

    la call_linje: tekst = sh.instruksjon_til_c("CALL", 7)
    assert_eq(call_linje, "ret_stack[rsp++] = 0; goto L7;")

    la ret_linje: tekst = sh.instruksjon_til_c("RET", 0)
    assert_eq(ret_linje, "goto *labels[0];")

    la store_linje: tekst = sh.instruksjon_til_c("STORE", 3)
    assert_eq(store_linje, "mem[3] = stack[sp-1]; sp = sp - 1;")

    la load_linje: tekst = sh.instruksjon_til_c("LOAD", 3)
    assert_eq(load_linje, "stack[sp++] = mem[3];")

    la eq_linje: tekst = sh.instruksjon_til_c("EQ", 0)
    assert_eq(eq_linje, "stack[sp-2] = (stack[sp-2] == stack[sp-1]); sp = sp - 1;")

    la gt_linje: tekst = sh.instruksjon_til_c("GT", 0)
    assert_eq(gt_linje, "stack[sp-2] = (stack[sp-2] > stack[sp-1]); sp = sp - 1;")

    la lt_linje: tekst = sh.instruksjon_til_c("LT", 0)
    assert_eq(lt_linje, "stack[sp-2] = (stack[sp-2] < stack[sp-1]); sp = sp - 1;")

    la mod_linje: tekst = sh.instruksjon_til_c("MOD", 0)
    assert_eq(mod_linje, "stack[sp-2] = stack[sp-2] % stack[sp-1]; sp = sp - 1;")

    la and_linje: tekst = sh.instruksjon_til_c("AND", 0)
    assert_eq(and_linje, "stack[sp-2] = (stack[sp-2] && stack[sp-1]); sp = sp - 1;")

    la or_linje: tekst = sh.instruksjon_til_c("OR", 0)
    assert_eq(or_linje, "stack[sp-2] = (stack[sp-2] || stack[sp-1]); sp = sp - 1;")

    la not_linje: tekst = sh.instruksjon_til_c("NOT", 0)
    assert_eq(not_linje, "stack[sp-1] = !stack[sp-1];")

    la dup_linje: tekst = sh.instruksjon_til_c("DUP", 0)
    assert_eq(dup_linje, "stack[sp] = stack[sp-1]; sp = sp + 1;")

    la pop_linje: tekst = sh.instruksjon_til_c("POP", 0)
    assert_eq(pop_linje, "sp = sp - 1;")

    la swap_linje: tekst = sh.instruksjon_til_c("SWAP", 0)
    assert_eq(swap_linje, "tmp = stack[sp-1]; stack[sp-1] = stack[sp-2]; stack[sp-2] = tmp;")

    la over_linje: tekst = sh.instruksjon_til_c("OVER", 0)
    assert_eq(over_linje, "stack[sp] = stack[sp-2]; sp = sp + 1;")

    la demo: tekst = sh.demo_program()
    assert_ne(demo, "")

    la ops: liste_tekst = ["PUSH", "PUSH", "MUL", "PRINT", "HALT"]
    la verdier: liste_heltall = [6, 7, 0, 0, 0]
    la c: tekst = sh.kompiler_til_c(ops, verdier)
    assert_ne(c, "")

    la tokens: liste_tekst = ["PUSH", "8", "PUSH", "9", "ADD", "PRINT", "HALT"]
    la c2: tekst = sh.kompiler_fra_tokens(tokens)
    assert_ne(c2, "")

    la tokens_jmp: liste_tekst = ["PUSH", "0", "JZ", "1", "PUSH", "99", "PRINT", "LABEL", "1", "HALT"]
    la c2b: tekst = sh.kompiler_fra_tokens(tokens_jmp)
    assert_ne(c2b, "")

    la tokens_cmp_jz: liste_tekst = ["PUSH", "4", "PUSH", "4", "EQ", "JZ", "2", "PUSH", "1", "PRINT", "LABEL", "2", "HALT"]
    la c2c: tekst = sh.kompiler_fra_tokens(tokens_cmp_jz)
    assert_ne(c2c, "")

    la tokens_stack: liste_tekst = ["PUSH", "5", "DUP", "ADD", "POP", "HALT"]
    la c2d: tekst = sh.kompiler_fra_tokens(tokens_stack)
    assert_ne(c2d, "")

    la tokens_stack2: liste_tekst = ["PUSH", "2", "PUSH", "9", "SWAP", "OVER", "ADD", "HALT"]
    la c2e: tekst = sh.kompiler_fra_tokens(tokens_stack2)
    assert_ne(c2e, "")

    la tokens_mod: liste_tekst = ["PUSH", "17", "PUSH", "5", "MOD", "PRINT", "HALT"]
    la c2f: tekst = sh.kompiler_fra_tokens(tokens_mod)
    assert_ne(c2f, "")

    la tokens_bool: liste_tekst = ["PUSH", "1", "PUSH", "0", "AND", "NOT", "PRINT", "HALT"]
    la c2g: tekst = sh.kompiler_fra_tokens(tokens_bool)
    assert_ne(c2g, "")

    la tokens_mem: liste_tekst = ["PUSH", "42", "STORE", "0", "LOAD", "0", "PUSH", "1", "ADD", "PRINT", "HALT"]
    la c2h: tekst = sh.kompiler_fra_tokens(tokens_mem)
    assert_ne(c2h, "")

    la tokens_call: liste_tekst = ["CALL", "3", "HALT", "LABEL", "3", "PUSH", "99", "RET"]
    la c2i: tekst = sh.kompiler_fra_tokens(tokens_call)
    assert_ne(c2i, "")

    la tokens_bad_jump: liste_tekst = ["JMP", "9", "HALT"]
    la c_bad: tekst = sh.kompiler_fra_tokens(tokens_bad_jump)
    assert_eq(c_bad, "/* feil: ugyldig hopp-target 9 */")

    la tokens_underflow: liste_tekst = ["ADD", "HALT"]
    la c_underflow: tekst = sh.kompiler_fra_tokens(tokens_underflow)
    assert_eq(c_underflow, "/* feil: stack-underflow ved indeks 0 (ADD) */")

    la tokens_bad_mem: liste_tekst = ["PUSH", "1", "STORE", "999", "HALT"]
    la c_bad_mem: tekst = sh.kompiler_fra_tokens(tokens_bad_mem)
    assert_eq(c_bad_mem, "/* feil: minneindeks utenfor range 999 */")

    la tokens_dis: liste_tekst = ["PUSH", "3", "PUSH", "4", "ADD", "HALT"]
    la dis: tekst = sh.disasm_fra_tokens(tokens_dis)
    assert_eq(dis, "0: PUSH 3\n1: PUSH 4\n2: ADD\n3: HALT\n")

    la dis_src: tekst = sh.disasm_fra_kilde("# c\nPUSH 3;\nPUSH 4\nADD\nHALT")
    assert_eq(dis_src, "0: PUSH 3\n1: PUSH 4\n2: ADD\n3: HALT\n")

    la dis_src_strict: tekst = sh.disasm_fra_kilde_strict("PUSH 3\nPUSH 4\nADD\nHALT")
    assert_eq(dis_src_strict, "0: PUSH 3\n1: PUSH 4\n2: ADD\n3: HALT\n")

    la dis_src_bad: tekst = sh.disasm_fra_kilde_strict("PUSH x\nHALT")
    assert_eq(dis_src_bad, "/* feil: ugyldig heltallsargument x ved token 1 */")

    la dis_src_bad_opcode: tekst = sh.disasm_fra_kilde_strict("PUHS 1\nHALT")
    assert_eq(dis_src_bad_opcode, "/* feil: ukjent opcode PUHS ved token 0 */")

    la c_src_bad: tekst = sh.kompiler_fra_kilde_strict("PUSH 2\nPUSH q\nADD\nHALT")
    assert_eq(c_src_bad, "/* feil: ugyldig heltallsargument q ved token 3 */")

    la expr_dis: tekst = sh.disasm_uttrykk("2+3*4")
    assert_eq(expr_dis, "0: PUSH 2\n1: PUSH 3\n2: PUSH 4\n3: MUL\n4: ADD\n5: PRINT\n6: HALT\n")

    la expr_dis_paren: tekst = sh.disasm_uttrykk("(2+3)*4")
    assert_eq(expr_dis_paren, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PUSH 4\n4: MUL\n5: PRINT\n6: HALT\n")

    la expr_c: tekst = sh.kompiler_uttrykk_til_c("10 + 32")
    assert_ne(expr_c, "")

    la expr_cmp: tekst = sh.disasm_uttrykk("5>3&&2<4")
    assert_eq(expr_cmp, "0: PUSH 5\n1: PUSH 3\n2: GT\n3: PUSH 2\n4: PUSH 4\n5: LT\n6: AND\n7: PRINT\n8: HALT\n")

    la expr_eq: tekst = sh.disasm_uttrykk("7!=7||2==2")
    assert_eq(expr_eq, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: NOT\n4: PUSH 2\n5: PUSH 2\n6: EQ\n7: OR\n8: PRINT\n9: HALT\n")

    la expr_le: tekst = sh.disasm_uttrykk("3 <= 4")
    assert_eq(expr_le, "0: PUSH 3\n1: PUSH 4\n2: GT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_ge: tekst = sh.disasm_uttrykk("4 >= 3")
    assert_eq(expr_ge, "0: PUSH 4\n1: PUSH 3\n2: LT\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_unary_not: tekst = sh.disasm_uttrykk("!0||0")
    assert_eq(expr_unary_not, "0: PUSH 0\n1: NOT\n2: PUSH 0\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_unary_minus: tekst = sh.disasm_uttrykk("-3+5")
    assert_eq(expr_unary_minus, "0: PUSH 3\n1: PUSH 0\n2: SWAP\n3: SUB\n4: PUSH 5\n5: ADD\n6: PRINT\n7: HALT\n")

    la expr_norsk_minus_med: tekst = sh.disasm_uttrykk("10 minus med 3")
    assert_eq(expr_norsk_minus_med, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_minus_med_underscore: tekst = sh.disasm_uttrykk("10 minus_med 3")
    assert_eq(expr_norsk_minus_med_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_minuseres_med: tekst = sh.disasm_uttrykk("10 minuseres med 3")
    assert_eq(expr_norsk_minuseres_med, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_minuseres_med_underscore: tekst = sh.disasm_uttrykk("10 minuseres_med 3")
    assert_eq(expr_norsk_minuseres_med_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraher_med: tekst = sh.disasm_uttrykk("10 subtraher med 3")
    assert_eq(expr_norsk_subtraher_med, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraher_med_underscore: tekst = sh.disasm_uttrykk("10 subtraher_med 3")
    assert_eq(expr_norsk_subtraher_med_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraherer_med: tekst = sh.disasm_uttrykk("10 subtraherer med 3")
    assert_eq(expr_norsk_subtraherer_med, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraherer_med_underscore: tekst = sh.disasm_uttrykk("10 subtraherer_med 3")
    assert_eq(expr_norsk_subtraherer_med_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraheres_med: tekst = sh.disasm_uttrykk("10 subtraheres med 3")
    assert_eq(expr_norsk_subtraheres_med, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_subtraheres_med_underscore: tekst = sh.disasm_uttrykk("10 subtraheres_med 3")
    assert_eq(expr_norsk_subtraheres_med_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_unary_plus: tekst = sh.disasm_uttrykk("+3+5")
    assert_eq(expr_unary_plus, "0: PUSH 3\n1: PUSH 5\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_arith: tekst = sh.disasm_uttrykk("2 pluss 3 ganger 4")
    assert_eq(expr_norsk_arith, "0: PUSH 2\n1: PUSH 3\n2: PUSH 4\n3: MUL\n4: ADD\n5: PRINT\n6: HALT\n")

    la expr_norsk_legg_til: tekst = sh.disasm_uttrykk("2 legg til 3")
    assert_eq(expr_norsk_legg_til, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_legg_til_underscore: tekst = sh.disasm_uttrykk("2 legg_til 3")
    assert_eq(expr_norsk_legg_til_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_legg_sammen: tekst = sh.disasm_uttrykk("2 legg sammen 3")
    assert_eq(expr_norsk_legg_sammen, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_legg_sammen_underscore: tekst = sh.disasm_uttrykk("2 legg_sammen 3")
    assert_eq(expr_norsk_legg_sammen_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_pluss_med: tekst = sh.disasm_uttrykk("2 pluss med 3")
    assert_eq(expr_norsk_pluss_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_pluss_med_underscore: tekst = sh.disasm_uttrykk("2 pluss_med 3")
    assert_eq(expr_norsk_pluss_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plusser_med: tekst = sh.disasm_uttrykk("2 plusser med 3")
    assert_eq(expr_norsk_plusser_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plusser_med_underscore: tekst = sh.disasm_uttrykk("2 plusser_med 3")
    assert_eq(expr_norsk_plusser_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plusses_med: tekst = sh.disasm_uttrykk("2 plusses med 3")
    assert_eq(expr_norsk_plusses_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_plusses_med_underscore: tekst = sh.disasm_uttrykk("2 plusses_med 3")
    assert_eq(expr_norsk_plusses_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_adder_med: tekst = sh.disasm_uttrykk("2 adder med 3")
    assert_eq(expr_norsk_adder_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_adder_med_underscore: tekst = sh.disasm_uttrykk("2 adder_med 3")
    assert_eq(expr_norsk_adder_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_adderer_med: tekst = sh.disasm_uttrykk("2 adderer med 3")
    assert_eq(expr_norsk_adderer_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_adderer_med_underscore: tekst = sh.disasm_uttrykk("2 adderer_med 3")
    assert_eq(expr_norsk_adderer_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_adderes_med: tekst = sh.disasm_uttrykk("2 adderes med 3")
    assert_eq(expr_norsk_adderes_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_adderes_med_underscore: tekst = sh.disasm_uttrykk("2 adderes_med 3")
    assert_eq(expr_norsk_adderes_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_summer_med: tekst = sh.disasm_uttrykk("2 summer med 3")
    assert_eq(expr_norsk_summer_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_summer_med_underscore: tekst = sh.disasm_uttrykk("2 summer_med 3")
    assert_eq(expr_norsk_summer_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_summerer_med: tekst = sh.disasm_uttrykk("2 summerer med 3")
    assert_eq(expr_norsk_summerer_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_summerer_med_underscore: tekst = sh.disasm_uttrykk("2 summerer_med 3")
    assert_eq(expr_norsk_summerer_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_summeres_med: tekst = sh.disasm_uttrykk("2 summeres med 3")
    assert_eq(expr_norsk_summeres_med, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_summeres_med_underscore: tekst = sh.disasm_uttrykk("2 summeres_med 3")
    assert_eq(expr_norsk_summeres_med_underscore, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekk_fra: tekst = sh.disasm_uttrykk("10 trekk fra 3")
    assert_eq(expr_norsk_trekk_fra, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekk_fra_underscore: tekst = sh.disasm_uttrykk("10 trekk_fra 3")
    assert_eq(expr_norsk_trekk_fra_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekke_fra_underscore: tekst = sh.disasm_uttrykk("10 trekke_fra 3")
    assert_eq(expr_norsk_trekke_fra_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekkes_fra: tekst = sh.disasm_uttrykk("10 trekkes fra 3")
    assert_eq(expr_norsk_trekkes_fra, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_trekkes_fra_underscore: tekst = sh.disasm_uttrykk("10 trekkes_fra 3")
    assert_eq(expr_norsk_trekkes_fra_underscore, "0: PUSH 10\n1: PUSH 3\n2: SUB\n3: PRINT\n4: HALT\n")

    la expr_norsk_div: tekst = sh.disasm_uttrykk("8 delt pa 2")
    assert_eq(expr_norsk_div, "0: PUSH 8\n1: PUSH 2\n2: DIV\n3: PRINT\n4: HALT\n")

    la expr_norsk_mod: tekst = sh.disasm_uttrykk("17 mod 5")
    assert_eq(expr_norsk_mod, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_modulo: tekst = sh.disasm_uttrykk("17 modulo 5")
    assert_eq(expr_norsk_modulo, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_rest: tekst = sh.disasm_uttrykk("17 rest 5")
    assert_eq(expr_norsk_rest, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_resten_av: tekst = sh.disasm_uttrykk("17 resten_av 5")
    assert_eq(expr_norsk_resten_av, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_resten_av_phrase: tekst = sh.disasm_uttrykk("17 resten av 5")
    assert_eq(expr_norsk_resten_av_phrase, "0: PUSH 17\n1: PUSH 5\n2: MOD\n3: PRINT\n4: HALT\n")

    la expr_norsk_ganget_med: tekst = sh.disasm_uttrykk("3 ganget med 4")
    assert_eq(expr_norsk_ganget_med, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_ganget_med_underscore: tekst = sh.disasm_uttrykk("3 ganget_med 4")
    assert_eq(expr_norsk_ganget_med_underscore, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_gange_med: tekst = sh.disasm_uttrykk("3 gange med 4")
    assert_eq(expr_norsk_gange_med, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_gange_med_underscore: tekst = sh.disasm_uttrykk("3 gange_med 4")
    assert_eq(expr_norsk_gange_med_underscore, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_ganger_med: tekst = sh.disasm_uttrykk("3 ganger med 4")
    assert_eq(expr_norsk_ganger_med, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_ganger_med_underscore: tekst = sh.disasm_uttrykk("3 ganger_med 4")
    assert_eq(expr_norsk_ganger_med_underscore, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_ganges_med: tekst = sh.disasm_uttrykk("3 ganges med 4")
    assert_eq(expr_norsk_ganges_med, "0: PUSH 3\n1: PUSH 4\n2: MUL\n3: PRINT\n4: HALT\n")

    la expr_norsk_ganges_med_underscore: tekst = sh.disasm_uttrykk("3 ganges_med 4")
