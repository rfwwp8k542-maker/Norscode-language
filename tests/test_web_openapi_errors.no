bruk std.web som web
bruk std.tekst som t

funksjon feil(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /feil")
    returner web.response_error(404, "Ikke funnet")
}

funksjon start() -> heltall {
    la openapi = web.openapi_json("Error API", "1.0.0")
    assert(t.inneholder(openapi, "\"/feil\""))
    assert(t.inneholder(openapi, "\"404\""))
    assert(t.inneholder(openapi, "\"error\""))
    assert(t.inneholder(openapi, "\"Ikke funnet\""))

    la respons = web.handle_request(web.request_context("get", "/feil", {}, {}, ""))
    assert_eq(web.response_status(respons), 404)
    assert(t.inneholder(web.response_body(respons), "\"error\""))
    assert(t.inneholder(web.response_body(respons), "Ikke funnet"))
    returner 0
}
