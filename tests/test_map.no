funksjon start() -> heltall {
    la tallkart = {"en": 1, "to": 2}
    assert_eq(lengde(tallkart), 2)
    assert_eq(tallkart["en"], 1)

    tallkart["en"] = 5
    assert_eq(tallkart["en"], 5)

    la tekster: ordbok_tekst = {"navn": "Norscode"}
    assert_eq(tekster["navn"], "Norscode")

    la flagg: ordbok_bool = {"ok": sann}
    assert_eq(flagg["ok"], sann)

    la tom: ordbok_heltall = {}
    assert_eq(lengde(tom), 0)
    tom["ny"] = 7
    assert_eq(tom["ny"], 7)

    skriv("test_map OK")
    returner 0
}
