bruk std.web som web

funksjon admin_guard(ctx: ordbok_tekst) -> bool {
    web.guard()
    returner web.request_header(ctx, "x-api-key") == "secret"
}

funksjon admin(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("admin_guard")
    web.route("GET /admin")
    returner web.response_builder(200, {"content-type": "text/plain"}, "admin ok")
}

funksjon start() -> heltall {
    la nektet = web.handle_request(web.request_context("get", "/admin", {}, {}, ""))
    assert_eq(web.response_status(nektet), 403)

    la tillatt = web.handle_request(web.request_context("get", "/admin", {}, {"x-api-key": "secret"}, ""))
    assert_eq(web.response_status(tillatt), 200)
    assert_eq(web.response_body(tillatt), "admin ok")

    returner 0
}
