bruk std.web som web
bruk std.tekst som t

funksjon hjem(ctx: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /hjem")
    returner web.response_builder(200, {"content-type": "text/plain"}, "hei")
}

funksjon start() -> heltall {
    la head_respons = web.handle_request(web.request_context("head", "/hjem", {}, {}, ""))
    assert_eq(web.response_status(head_respons), 200)
    assert_eq(web.response_body(head_respons), "")

    la options_respons = web.handle_request(web.request_context("options", "/hjem", {}, {}, ""))
    assert_eq(web.response_status(options_respons), 204)
    la allow_header = web.response_header(options_respons, "allow")
    assert(allow_header == "GET, HEAD, OPTIONS")

    la feil_metode = web.handle_request(web.request_context("post", "/hjem", {}, {}, ""))
    assert_eq(web.response_status(feil_metode), 405)
    assert(t.inneholder(web.response_header(feil_metode, "allow"), "GET"))

    returner 0
}
