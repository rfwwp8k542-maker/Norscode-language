{
  "expressions": [
    {
      "name": "xor_alias",
      "source": "1 xor 0",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 0",
        "2: EQ",
        "3: NOT",
        "4: PRINT",
        "5: HALT"
      ]
    },
    {
      "name": "xnor_alias",
      "source": "1 xnor 1",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 1",
        "2: EQ",
        "3: PRINT",
        "4: HALT"
      ]
    },
    {
      "name": "premise_condition_alias",
      "source": "1 premise_condition 0",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 0",
        "2: NOT",
        "3: OR",
        "4: PRINT",
        "5: HALT"
      ]
    },
    {
      "name": "greater_or_equal",
      "source": "4 >= 3",
      "expected_lines": [
        "0: PUSH 4",
        "1: PUSH 3",
        "2: LT",
        "3: NOT",
        "4: PRINT",
        "5: HALT"
      ]
    },
    {
      "name": "unary_not_or",
      "source": "!0||0",
      "expected_lines": [
        "0: PUSH 0",
        "1: NOT",
        "2: PUSH 0",
        "3: OR",
        "4: PRINT",
        "5: HALT"
      ]
    },
    {
      "name": "modulo_of_phrase",
      "source": "17 modulo of 5",
      "expected_lines": [
        "0: PUSH 17",
        "1: PUSH 5",
        "2: MOD",
        "3: PRINT",
        "4: HALT"
      ]
    },
    {
      "name": "error_missing_operand_before_close",
      "source": "2 + )",
      "expected_error": "/* feil: mangler verdi før ) ved token 2 */"
    }
  ],
  "scripts": [
    {
      "name": "bool_alias_and_or",
      "source": "la x=sann;la y=usann;returner x and not y or usann",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 0",
        "2: NOT",
        "3: AND",
        "4: PUSH 0",
        "5: OR",
        "6: PRINT",
        "7: HALT"
      ]
    },
    {
      "name": "const_alias",
      "source": "const x=2;return x+3",
      "expected_lines": [
        "0: PUSH 2",
        "1: PUSH 3",
        "2: ADD",
        "3: PRINT",
        "4: HALT"
      ]
    },
    {
      "name": "script_this_implies",
      "source": "returner 1 this_implies 0",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 0",
        "2: SWAP",
        "3: NOT",
        "4: SWAP",
        "5: OR",
        "6: PRINT",
        "7: HALT"
      ]
    },
    {
      "name": "script_premise_condition",
      "source": "returner 1 premise_condition 0",
      "expected_lines": [
        "0: PUSH 1",
        "1: PUSH 0",
        "2: NOT",
        "3: OR",
        "4: PRINT",
        "5: HALT"
      ]
    },
    {
      "name": "script_divided_by_phrase",
      "source": "let x=8;let y=2;return x divided by y",
      "expected_lines": [
        "0: PUSH 8",
        "1: PUSH 2",
        "2: DIV",
        "3: PRINT",
        "4: HALT"
      ]
    },
    {
      "name": "error_la_missing_name",
      "source": "la ;x+1",
      "expected_error": "/* feil: 'la' må etterfølges av variabelnavn ved token 0 */"
    },
    {
      "name": "error_la_invalid_decl",
      "source": "la x;x+1",
      "expected_error": "/* feil: ugyldig deklarasjon etter 'la' ved token 0 */"
    },
    {
      "name": "error_return_missing_expr",
      "source": "la x=1;returner",
      "expected_error": "/* feil: 'returner' må etterfølges av uttrykk ved token 5 */"
    }
  ]
}
