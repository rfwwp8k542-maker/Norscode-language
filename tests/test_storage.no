bruk std.lagring som lagring

funksjon start() -> heltall {
    la sti = "/private/tmp/norscode_lagring_test.json"
    la data: ordbok_tekst = {}

    lagring.sett_tekst(data, "navn", "Ada")
    lagring.sett_tall(data, "antall", 3)
    lagring.sett_bool(data, "klar", sann)

    assert_eq(lagring.lagre(sti, data), 3)

    la lastet = lagring.last(sti)
    assert_eq(lagring.hent_tekst(lastet, "navn"), "Ada")
    assert_eq(lagring.hent_tall(lastet, "antall"), 3)
    assert_eq(lagring.hent_bool(lastet, "klar"), sann)
    assert(lagring.finnes(sti))

    assert_eq(lagring.fjern(lastet, "klar"), 2)
    assert_eq(lagring.lagre(sti, lastet), 2)

    la lastet2 = lagring.last(sti)
    assert(ikke har_nokkel(lastet2, "klar"))
    assert_eq(lagring.hent_tekst(lastet2, "navn"), "Ada")

    returner 0
}
