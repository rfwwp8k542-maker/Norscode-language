bruk std.audit som audit
bruk std.web som web

funksjon start() -> heltall {
    la e = audit.auth_fail("anon", "/admin")
    assert_eq(e["level"], "warn")
    assert_eq(e["type"], "audit")
    assert_eq(e["category"], "security")
    assert_eq(e["action"], "auth_fail")
    assert_eq(e["status"], "avvist")
    assert_eq(e["user"], "anon")
    assert_eq(e["resource"], "/admin")

    assert_eq(audit.felt_tekst(e, "request_id", web.request_id(web.request_context("get", "/admin", {}, {}, ""))), 8)
    assert_eq(audit.felt_bool(e, "blocked", sann), 9)
    assert_inneholder(audit.emit(e), "\"category\":\"security\"")
    assert_inneholder(audit.emit(e), "\"blocked\":true")

    la den = audit.sensitive_read("system", "NORSCODE_API_KEY")
    assert_eq(den["action"], "sensitive_read")
    assert_eq(den["status"], "registrert")
    returner 0
}
