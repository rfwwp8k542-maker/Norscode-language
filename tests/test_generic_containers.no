funksjon summer(xs: liste<heltall>) -> heltall {
    la total = 0
    for x i xs {
        total = total + x
    }
    returner total
}

funksjon start() -> heltall {
    la tall: liste<heltall> = [1, 2, 3]
    la ord: liste<tekst> = ["a", "b", "c"]
    la m: ordbok<tekst, heltall> = {}
    m["antall"] = lengde(tall)
    m["sum"] = summer(tall)

    assert_eq(lengde(ord), 3)
    assert_eq(m["antall"], 3)
    assert_eq(m["sum"], 6)
    returner 0
}
