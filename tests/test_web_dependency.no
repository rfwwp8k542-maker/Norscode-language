bruk std.web som web

funksjon config(ctx: ordbok_tekst) -> ordbok_tekst {
    web.dependency("config")
    returner {"app": "Norscode", "miljo": "test"}
}

funksjon auth(ctx: ordbok_tekst) -> ordbok_tekst {
    web.dependency("auth")
    la config = web.request_dependency(ctx, "config")
    returner {"bruker": "Ada", "app": config.app}
}

funksjon hjem(ctx: ordbok_tekst, config: ordbok_tekst, auth: ordbok_tekst) -> ordbok_tekst {
    web.route("GET /")
    web.use_dependency("config")
    web.use_dependency("auth")
    returner web.response_builder(200, {"content-type": "text/plain"}, config.app + ":" + auth.bruker + ":" + auth.app)
}

funksjon start() -> heltall {
    la ctx = web.request_context("GET", "/", {}, {}, "")
    la respons = web.handle_request(ctx)
    assert_eq(web.response_body(respons), "Norscode:Ada:Norscode")
    assert_eq(web.response_status(respons), 200)
    assert_eq(web.request_dependency(ctx, "config").app, "Norscode")
    returner 0
}
