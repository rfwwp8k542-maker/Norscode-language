bruk std.db som db
bruk std.env som env
bruk std.path som path

funksjon tmpsti(navn: tekst) -> tekst {
    hvis env.finnes("TMPDIR") {
        returner path.join(env.hent("TMPDIR"), navn)
    }
    hvis env.finnes("TEMP") {
        returner path.join(env.hent("TEMP"), navn)
    }
    hvis env.finnes("TMP") {
        returner path.join(env.hent("TMP"), navn)
    }
    returner path.join(".", navn)
}

funksjon start() -> heltall {
    la handle = db.open(":memory:")
    assert(db.ping(handle))

    assert_eq(db.migrate(handle, "CREATE TABLE users (id INTEGER PRIMARY KEY, navn TEXT); INSERT INTO users (navn) VALUES ('Ada');"), 1)
    assert_eq(db.query_text(handle, "SELECT navn FROM users WHERE id = 1"), "Ada")
    assert_eq(db.query_int(handle, "SELECT COUNT(*) FROM users"), 1)

    assert(db.begin(handle))
    assert_eq(db.execute(handle, "INSERT INTO users (navn) VALUES ('Bob')"), 1)
    assert(db.rollback(handle))
    assert_eq(db.query_int(handle, "SELECT COUNT(*) FROM users"), 1)

    assert(db.begin(handle))
    assert_eq(db.execute(handle, "INSERT INTO users (navn) VALUES ('Eli')"), 1)
    assert(db.commit(handle))
    assert_eq(db.query_int(handle, "SELECT COUNT(*) FROM users"), 2)

    assert_eq(db.migrate(handle, "INSERT INTO users (navn) VALUES ('Zoe');"), 1)
    assert_eq(db.query_int(handle, "SELECT COUNT(*) FROM users"), 3)
    assert_eq(db.migrate(handle, "INSERT INTO users (navn) VALUES ('Zoe');"), 0)

    assert_eq(db.transaction(handle, "INSERT INTO users (navn) VALUES ('Lin');"), 1)
    assert_eq(db.query_int(handle, "SELECT COUNT(*) FROM users"), 4)
    assert_eq(db.transaction(handle, "INSRT INTO users (navn) VALUES ('Broken');"), 0)
    assert_eq(db.query_int(handle, "SELECT COUNT(*) FROM users"), 4)

    la pool_sti = tmpsti("norscode_pool_test.db")
    la pool = db.pool(pool_sti, 2)
    assert_eq(db.pool_size(pool), 1)
    la pooled1 = db.pool_acquire(pool)
    assert_eq(db.pool_size(pool), 0)
    assert_eq(db.execute(pooled1, "DROP TABLE IF EXISTS cachetest"), 0)
    assert_eq(db.execute(pooled1, "CREATE TABLE cachetest (verdi TEXT)"), 0)
    assert_eq(db.execute(pooled1, "INSERT INTO cachetest (verdi) VALUES ('A')"), 1)
    assert(db.close(pooled1))
    assert_eq(db.pool_size(pool), 1)
    la pooled2 = db.pool_acquire(pool)
    assert_eq(db.query_int(pooled2, "SELECT COUNT(*) FROM cachetest"), 1)
    assert(db.close(pooled2))
    assert(db.pool_close(pool))

    assert(db.close(handle))
    returner 0
}
