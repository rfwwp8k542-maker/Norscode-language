bruk std.metrics som metrics

funksjon start() -> heltall {
    la m = metrics.opprett()

    assert_eq(metrics.hent(m, "requests"), 0)
    assert_eq(metrics.tell(m, "requests"), 1)
    assert_eq(metrics.øk(m, "requests", 4), 5)
    assert_eq(metrics.sett(m, "active", 7), 7)
    assert(metrics.har(m, "active"))
    assert_eq(metrics.hent(m, "active"), 7)

    assert_eq(metrics.histogram(m, "latency_ms", 12), 1)
    assert_eq(metrics.histogram(m, "latency_ms", 5), 2)
    assert_eq(metrics.histogram(m, "latency_ms", 20), 3)
    assert_eq(metrics.histogram_count(m, "latency_ms"), 3)
    assert_eq(metrics.histogram_sum(m, "latency_ms"), 37)
    assert_eq(metrics.histogram_min(m, "latency_ms"), 5)
    assert_eq(metrics.histogram_max(m, "latency_ms"), 20)

    returner 0
}
