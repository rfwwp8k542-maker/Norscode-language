funksjon start() -> heltall {
    la s = "abcdef"
    assert_eq(s[1:4], "bcd")
    assert_eq(s[:3], "abc")
    assert_eq(s[3:], "def")

    la tall: liste_heltall = [1, 2, 3, 4, 5]
    la del_tall = tall[1:4]
    assert_eq(lengde(del_tall), 3)
    assert_eq(del_tall[0], 2)
    assert_eq(del_tall[2], 4)

    la ord: liste_tekst = ["a", "b", "c", "d"]
    la del_ord = ord[:2]
    assert_eq(lengde(del_ord), 2)
    assert_eq(del_ord[1], "b")
    returner 0
}
