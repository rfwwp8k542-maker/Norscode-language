funksjon start() -> heltall {
    la sum = 0
    la tall = [1, 2, 3]
    for x i tall {
        sum += x
    }
    la bonus = hvis sum == 6 da 4 ellers 0
    la resultat = hvis bonus == 4 da sum + bonus ellers 0
    assert_eq(sum, 6)
    assert_eq(bonus, 4)
    assert_eq(resultat, 10)
    returner 0
}
