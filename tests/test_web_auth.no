bruk std.web som web
bruk std.tekst som t

funksjon api_guard(ctx: ordbok_tekst) -> bool {
    web.guard()
    returner web.require_bearer(ctx, "superhemmelig")
}

funksjon brukerprofil(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("api_guard")
    web.route("GET /profil")
    returner web.response_builder(200, {"content-type": "text/plain"}, web.bearer_token(ctx))
}

funksjon start() -> heltall {
    la nektet = web.handle_request(web.request_context("get", "/profil", {}, {}, ""))
    assert_eq(web.response_status(nektet), 403)

    la lovet = web.handle_request(web.request_context("get", "/profil", {}, {"authorization": "Bearer superhemmelig"}, ""))
    assert_eq(web.response_status(lovet), 200)
    assert_eq(web.response_body(lovet), "superhemmelig")
    assert_eq(web.auth_header(web.request_context("get", "/", {}, {"authorization": "Bearer superhemmelig"}, "")), "Bearer superhemmelig")

    returner 0
}
