bruk std.liste som liste

funksjon start() -> heltall {
    la tall: liste_heltall = [1, 2, 3, 5]
    la ord: liste_tekst = ["per", "anna", "per"]

    assert_eq(liste.første_tall(tall), 1)
    assert_eq(liste.første_tekst(ord), "per")
    assert_eq(liste.inneholder_tall(tall, 3), sann)
    assert_eq(liste.inneholder_tall(tall, 9), usann)
    assert_eq(liste.inneholder_tekst(ord, "anna"), sann)
    assert_eq(liste.inneholder_tekst(ord, "ida"), usann)

    la usortert: liste_heltall = [5, 1, 4, 2, 3]
    assert_eq(liste.sorter_tall(usortert), 5)
    assert_eq(usortert[0], 1)
    assert_eq(usortert[1], 2)
    assert_eq(usortert[2], 3)
    assert_eq(usortert[3], 4)
    assert_eq(usortert[4], 5)

    la tekstliste: liste_tekst = ["z", "b", "a", "c"]
    assert_eq(liste.sorter_tekst(tekstliste), 4)
    assert_eq(tekstliste[0], "a")
    assert_eq(tekstliste[1], "b")
    assert_eq(tekstliste[2], "c")
    assert_eq(tekstliste[3], "z")

    la tall2: liste_heltall = [4, 1, 9, 2]
    assert_eq(liste.summer_tall(tall2), 16)
    assert_eq(liste.maks_tall(tall2), 9)
    assert_eq(liste.min_tall(tall2), 1)
    assert_eq(liste.omvendt_tall(tall2), 4)
    assert_eq(tall2[0], 2)
    assert_eq(tall2[1], 9)
    assert_eq(tall2[2], 1)
    assert_eq(tall2[3], 4)

    la søk_tall: liste_heltall = [7, 4, 9, 4, 1]
    la søk_tekst: liste_tekst = ["rød", "grønn", "blå", "grønn"]
    assert_eq(liste.finn_indeks_tall(søk_tall, 9), 2)
    assert_eq(liste.finn_indeks_tall(søk_tall, 6), -1)
    assert_eq(liste.finn_indeks_tekst(søk_tekst, "grønn"), 1)
    assert_eq(liste.finn_indeks_tekst(søk_tekst, "gul"), -1)

    assert_eq(liste.fjern_alle_tall(søk_tall, 4), 3)
    assert_eq(søk_tall[0], 7)
    assert_eq(søk_tall[1], 9)
    assert_eq(søk_tall[2], 1)

    assert_eq(liste.fjern_alle_tekst(søk_tekst, "grønn"), 2)
    assert_eq(søk_tekst[0], "rød")
    assert_eq(søk_tekst[1], "blå")

    la tom_tall: liste_heltall = []
    la tom_tekst: liste_tekst = []
    assert_eq(liste.første_tall(tom_tall), 0)
    assert_eq(liste.første_tekst(tom_tekst), "")
    assert_eq(liste.inneholder_tall(tom_tall, 1), usann)
    assert_eq(liste.inneholder_tekst(tom_tekst, "x"), usann)

    skriv("test_list_std OK")
    returner 0
}
