bruk std.lagring som lagring
bruk std.tekst som t

funksjon start() -> heltall {
    la sti: tekst = "."

    prøv {
        la data: ordbok_tekst = {}
        lagring.lagre(sti, data)
        returner 99
    } fang (feiltekst) {
        assert(t.starter_med(feiltekst, "IOFeil:"))
        assert(t.inneholder(feiltekst, "lagring.lagre feilet"))
        assert(t.inneholder(feiltekst, "skrive"))
    }

    returner 0
}
