bruk std.json som json
bruk std.liste som liste

funksjon start() -> heltall {
    la payload = "{\"navn\":\"Norscode\",\"alder\":42,\"aktiv\":true,\"tags\":[\"alpha\",\"beta\"],\"punkter\":[10,20,30],\"objekt\":{\"status\":\"ok\"}}"
    la parsed = json.parse(payload)

    assert_eq(json.hent_tekst(parsed, "navn"), "Norscode")
    assert_eq(json.hent_tall(parsed, "alder"), 42)
    assert_eq(json.hent_bool(parsed, "aktiv"), sann)

    la tags = json.hent_array_tekst(parsed, "tags")
    assert_eq(liste.antall_tekst(tags), 2)
    assert_eq(tags[0], "alpha")
    assert_eq(tags[1], "beta")

    la punkter = json.hent_array_tall(parsed, "punkter")
    assert_eq(liste.antall_tall(punkter), 3)
    assert_eq(punkter[0], 10)
    assert_eq(punkter[2], 30)

    assert_eq(json.hent_tekst(json.parse("{\"ok\": true}"), "ok"), "true")
    assert_eq(json.hent_bool(json.parse("{\"ok\": false}"), "ok"), usann)
    returner 0
}
