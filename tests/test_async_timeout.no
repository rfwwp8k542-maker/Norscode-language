async funksjon leverer(x: heltall) -> heltall {
    returner x + 1
}

funksjon start() -> heltall {
    la tidsstyrt = vent.timeout(leverer(1), 0)
    vent.sov(1)
    assert(vent.er_timeoutet(tidsstyrt))

    prøv {
        la _ = await tidsstyrt
        assert(usann)
    } fang(feil) {
        assert_inneholder(feil, "TimeoutFeil")
    }

    la kansellert = vent.kanseller(leverer(2))
    assert(vent.er_kansellert(kansellert))

    prøv {
        la _ = await kansellert
        assert(usann)
    } fang(feil) {
        assert_inneholder(feil, "AvbruttFeil")
    }

    returner 0
}
