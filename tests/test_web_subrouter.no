bruk std.web som web

funksjon api_status(ctx: ordbok_tekst) -> ordbok_tekst {
    web.subrouter("/api")
    web.route("GET /status")
    returner web.response_builder(200, {"content-type": "text/plain"}, "ok")
}

funksjon api_bruker(ctx: ordbok_tekst) -> ordbok_tekst {
    web.router("/api/v1")
    web.route("GET /brukere/{id:int}")
    returner web.response_builder(200, {"content-type": "text/plain"}, web.request_param(ctx, "id"))
}

funksjon start() -> heltall {
    la status_respons = web.handle_request(web.request_context("get", "/api/status", {}, {}, ""))
    assert_eq(web.response_status(status_respons), 200)
    assert_eq(web.response_body(status_respons), "ok")

    la bruker_respons = web.handle_request(web.request_context("get", "/api/v1/brukere/7", {}, {}, ""))
    assert_eq(web.response_status(bruker_respons), 200)
    assert_eq(web.response_body(bruker_respons), "7")

    la mangler = web.handle_request(web.request_context("get", "/status", {}, {}, ""))
    assert_eq(web.response_status(mangler), 404)

    returner 0
}
