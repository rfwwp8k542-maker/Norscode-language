bruk std.web som web
bruk std.tekst som t

funksjon brukerprofil(ctx: ordbok_tekst) -> ordbok<tekst, ordbok<tekst, tekst>> {
    web.route("GET /profil")
    returner {"meta": {"rolle": "admin"}, "info": {"team": "core"}}
}

funksjon start() -> heltall {
    la openapi = web.openapi_json("Schema API", "1.0.0")
    assert(t.inneholder(openapi, "\"/profil\""))
    assert(t.inneholder(openapi, "\"additionalProperties\": {\"type\": \"object\", \"additionalProperties\": {\"type\": \"string\"}}"))
    assert(t.inneholder(openapi, "\"example\": {\"verdi\": {\"verdi\": \"eksempel\"}}"))
    returner 0
}
