funksjon start() -> heltall {
    la person = {navn: "Ada", rolle: "utvikler"}
    assert_eq(person.navn, "Ada")
    assert_eq(person.rolle, "utvikler")

    la poeng = {python: 10, norscode: 20}
    assert_eq(poeng.python, 10)
    assert_eq(poeng["norscode"], 20)
    poeng["python"] = 11
    assert_eq(poeng.python, 11)

    la melding: ordbok_tekst = {hilsen: "hei", tittel: "Norscode"}
    assert_eq(melding.hilsen, "hei")
    assert_eq(melding.tittel, "Norscode")

    skriv("test_struct_literal OK")
    returner 0
}
