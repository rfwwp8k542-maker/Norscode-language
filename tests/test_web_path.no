bruk std.web som web

funksjon start() -> heltall {
    assert(web.path_match("/brukere/{id}", "/brukere/42"))
    assert(ikke web.path_match("/brukere/{id:int}", "/brukere/abc"))
    assert(web.path_match("/brukere/{id:int}", "/brukere/42"))

    la params = web.path_params("/brukere/{id}/poster/{slug}", "/brukere/42/poster/hei-verden")
    assert_eq(params.id, "42")
    assert_eq(params.slug, "hei-verden")
    assert_eq(web.path_param(params, "slug"), "hei-verden")
    assert_eq(web.path_param_or(params, "mangler", "fallback"), "fallback")

    la routes: ordbok_tekst = {
        "hjem": "GET /",
        "bruker": "GET /brukere/{id}",
        "poster": "POST /brukere/{id}/poster/{slug}"
    }

    assert(web.route_match(routes["bruker"], "GET", "/brukere/42"))
    assert_eq(web.dispatch(routes, "GET", "/brukere/42"), "bruker")
    la dispatch_params = web.dispatch_params(routes, "POST", "/brukere/42/poster/hei-verden")
    assert_eq(dispatch_params.id, "42")
    assert_eq(dispatch_params.slug, "hei-verden")

    returner 0
}
