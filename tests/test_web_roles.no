bruk std.web som web
bruk std.tekst som t

funksjon tilgang_guard(ctx: ordbok_tekst) -> bool {
    web.guard()
    returner web.require_role(ctx, "admin") og web.require_permission(ctx, "reports.read")
}

funksjon dashboard(ctx: ordbok_tekst) -> ordbok_tekst {
    web.use_guard("tilgang_guard")
    web.route("GET /dashboard")
    returner web.response_builder(
        200,
        {"content-type": "text/plain"},
        web.role(ctx) + "|" + t.bool_til_tekst(web.has_role(ctx, "admin")) + "|" + t.bool_til_tekst(web.has_permission(ctx, "reports.write"))
    )
}

funksjon start() -> heltall {
    la tillatt = web.handle_request(
        web.request_context("get", "/dashboard", {}, {"x-roles": "editor, admin", "x-permissions": "reports.read"}, "")
    )
    assert_eq(web.response_status(tillatt), 200)
    assert_eq(web.response_body(tillatt), "editor|sann|usann")

    la lovet = web.handle_request(
        web.request_context("get", "/dashboard", {}, {"x-role": "admin", "x-permissions": "reports.read, reports.write"}, "")
    )
    assert_eq(web.response_status(lovet), 200)
    assert_eq(web.response_body(lovet), "admin|sann|sann")

    la avvist = web.handle_request(
        web.request_context("get", "/dashboard", {}, {"x-role": "bruker", "x-permissions": "reports.read"}, "")
    )
    assert_eq(web.response_status(avvist), 403)

    returner 0
}
