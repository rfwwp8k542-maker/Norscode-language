bruk selfhost.compiler som sh
funksjon start() -> heltall {
    la a = sh.disasm_uttrykk("7 equal_to 7")
    skriv(a)
    la b = sh.disasm_uttrykk("7 equal to 7")
    skriv(b)
    la c = sh.disasm_uttrykk("7 not_equal_to 8")
    skriv(c)
    la d = sh.disasm_uttrykk("7 not equal to 8")
    skriv(d)
    returner 0
}
