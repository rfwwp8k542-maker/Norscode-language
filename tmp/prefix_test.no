    la expr_norsk_cmp_phrase13_likmed_kompakt: tekst = sh.disasm_uttrykk("7 likmed 7")
    assert_eq(expr_norsk_cmp_phrase13_likmed_kompakt, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_norsk_cmp_phrase14: tekst = sh.disasm_uttrykk("7 ikke lik med 8")
