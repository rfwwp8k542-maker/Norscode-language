bruk selfhost.compiler som sh

funksjon start() -> heltall {
    la push_linje: tekst = sh.instruksjon_til_c("PUSH", 42)
    assert_eq(push_linje, "stack[sp++] = 42;")

    la add_linje: tekst = sh.instruksjon_til_c("ADD", 0)
    assert_eq(add_linje, "stack[sp-2] = stack[sp-2] + stack[sp-1]; sp = sp - 1;")

    la halt_linje: tekst = sh.instruksjon_til_c("HALT", 0)
    assert_eq(halt_linje, "return 0;")

    la label_linje: tekst = sh.instruksjon_til_c("LABEL", 7)
    assert_eq(label_linje, "L7:;")

    la jmp_linje: tekst = sh.instruksjon_til_c("JMP", 7)
    assert_eq(jmp_linje, "goto L7;")

    la jz_linje: tekst = sh.instruksjon_til_c("JZ", 7)
    assert_eq(jz_linje, "if (stack[sp-1] == 0) goto L7;")

    la call_linje: tekst = sh.instruksjon_til_c("CALL", 7)
    assert_eq(call_linje, "ret_stack[rsp++] = 0; goto L7;")

    la ret_linje: tekst = sh.instruksjon_til_c("RET", 0)
    assert_eq(ret_linje, "goto *labels[0];")

    la store_linje: tekst = sh.instruksjon_til_c("STORE", 3)
    assert_eq(store_linje, "mem[3] = stack[sp-1]; sp = sp - 1;")

    la load_linje: tekst = sh.instruksjon_til_c("LOAD", 3)
    assert_eq(load_linje, "stack[sp++] = mem[3];")

    la eq_linje: tekst = sh.instruksjon_til_c("EQ", 0)
    assert_eq(eq_linje, "stack[sp-2] = (stack[sp-2] == stack[sp-1]); sp = sp - 1;")

    la gt_linje: tekst = sh.instruksjon_til_c("GT", 0)
    assert_eq(gt_linje, "stack[sp-2] = (stack[sp-2] > stack[sp-1]); sp = sp - 1;")

    la lt_linje: tekst = sh.instruksjon_til_c("LT", 0)
    assert_eq(lt_linje, "stack[sp-2] = (stack[sp-2] < stack[sp-1]); sp = sp - 1;")

    la mod_linje: tekst = sh.instruksjon_til_c("MOD", 0)
    assert_eq(mod_linje, "stack[sp-2] = stack[sp-2] % stack[sp-1]; sp = sp - 1;")

    la and_linje: tekst = sh.instruksjon_til_c("AND", 0)
    assert_eq(and_linje, "stack[sp-2] = (stack[sp-2] && stack[sp-1]); sp = sp - 1;")

    la or_linje: tekst = sh.instruksjon_til_c("OR", 0)
    assert_eq(or_linje, "stack[sp-2] = (stack[sp-2] || stack[sp-1]); sp = sp - 1;")

    la not_linje: tekst = sh.instruksjon_til_c("NOT", 0)
    assert_eq(not_linje, "stack[sp-1] = !stack[sp-1];")

    la dup_linje: tekst = sh.instruksjon_til_c("DUP", 0)
    assert_eq(dup_linje, "stack[sp] = stack[sp-1]; sp = sp + 1;")

    la pop_linje: tekst = sh.instruksjon_til_c("POP", 0)
    assert_eq(pop_linje, "sp = sp - 1;")

    la swap_linje: tekst = sh.instruksjon_til_c("SWAP", 0)
    assert_eq(swap_linje, "tmp = stack[sp-1]; stack[sp-1] = stack[sp-2]; stack[sp-2] = tmp;")

    la over_linje: tekst = sh.instruksjon_til_c("OVER", 0)
    assert_eq(over_linje, "stack[sp] = stack[sp-2]; sp = sp + 1;")

    la demo: tekst = sh.demo_program()
    assert_ne(demo, "")

    la ops: liste_tekst = ["PUSH", "PUSH", "MUL", "PRINT", "HALT"]
    la verdier: liste_heltall = [6, 7, 0, 0, 0]
    la c: tekst = sh.kompiler_til_c(ops, verdier)
    assert_ne(c, "")

    la tokens: liste_tekst = ["PUSH", "8", "PUSH", "9", "ADD", "PRINT", "HALT"]
    la c2: tekst = sh.kompiler_fra_tokens(tokens)
    assert_ne(c2, "")

    la tokens_jmp: liste_tekst = ["PUSH", "0", "JZ", "1", "PUSH", "99", "PRINT", "LABEL", "1", "HALT"]
    la c2b: tekst = sh.kompiler_fra_tokens(tokens_jmp)
    assert_ne(c2b, "")

    la tokens_cmp_jz: liste_tekst = ["PUSH", "4", "PUSH", "4", "EQ", "JZ", "2", "PUSH", "1", "PRINT", "LABEL", "2", "HALT"]
    la c2c: tekst = sh.kompiler_fra_tokens(tokens_cmp_jz)
    assert_ne(c2c, "")

    la tokens_stack: liste_tekst = ["PUSH", "5", "DUP", "ADD", "POP", "HALT"]
    la c2d: tekst = sh.kompiler_fra_tokens(tokens_stack)
    assert_ne(c2d, "")

    la tokens_stack2: liste_tekst = ["PUSH", "2", "PUSH", "9", "SWAP", "OVER", "ADD", "HALT"]
    la c2e: tekst = sh.kompiler_fra_tokens(tokens_stack2)
    assert_ne(c2e, "")

    la tokens_mod: liste_tekst = ["PUSH", "17", "PUSH", "5", "MOD", "PRINT", "HALT"]
    la c2f: tekst = sh.kompiler_fra_tokens(tokens_mod)
    assert_ne(c2f, "")

    la tokens_bool: liste_tekst = ["PUSH", "1", "PUSH", "0", "AND", "NOT", "PRINT", "HALT"]
    la c2g: tekst = sh.kompiler_fra_tokens(tokens_bool)
    assert_ne(c2g, "")

    la tokens_mem: liste_tekst = ["PUSH", "42", "STORE", "0", "LOAD", "0", "PUSH", "1", "ADD", "PRINT", "HALT"]
    la c2h: tekst = sh.kompiler_fra_tokens(tokens_mem)
    assert_ne(c2h, "")

    la tokens_call: liste_tekst = ["CALL", "3", "HALT", "LABEL", "3", "PUSH", "99", "RET"]
    la c2i: tekst = sh.kompiler_fra_tokens(tokens_call)
    assert_ne(c2i, "")

    la tokens_bad_jump: liste_tekst = ["JMP", "9", "HALT"]
    la c_bad: tekst = sh.kompiler_fra_tokens(tokens_bad_jump)
    assert_eq(c_bad, "/* feil: ugyldig hopp-target 9 */")

    la tokens_underflow: liste_tekst = ["ADD", "HALT"]
    la c_underflow: tekst = sh.kompiler_fra_tokens(tokens_underflow)
    assert_eq(c_underflow, "/* feil: stack-underflow ved indeks 0 (ADD) */")

    la tokens_bad_mem: liste_tekst = ["PUSH", "1", "STORE", "999", "HALT"]
    la c_bad_mem: tekst = sh.kompiler_fra_tokens(tokens_bad_mem)
    assert_eq(c_bad_mem, "/* feil: minneindeks utenfor range 999 */")

    la tokens_dis: liste_tekst = ["PUSH", "3", "PUSH", "4", "ADD", "HALT"]
    la dis: tekst = sh.disasm_fra_tokens(tokens_dis)
    assert_eq(dis, "0: PUSH 3\n1: PUSH 4\n2: ADD\n3: HALT\n")

    la dis_src: tekst = sh.disasm_fra_kilde("# c\nPUSH 3;\nPUSH 4\nADD\nHALT")
    assert_eq(dis_src, "0: PUSH 3\n1: PUSH 4\n2: ADD\n3: HALT\n")

    la dis_src_strict: tekst = sh.disasm_fra_kilde_strict("PUSH 3\nPUSH 4\nADD\nHALT")
    assert_eq(dis_src_strict, "0: PUSH 3\n1: PUSH 4\n2: ADD\n3: HALT\n")

    la dis_src_bad: tekst = sh.disasm_fra_kilde_strict("PUSH x\nHALT")
    assert_eq(dis_src_bad, "/* feil: ugyldig heltallsargument x ved token 1 */")

    la dis_src_bad_opcode: tekst = sh.disasm_fra_kilde_strict("PUHS 1\nHALT")
    assert_eq(dis_src_bad_opcode, "/* feil: ukjent opcode PUHS ved token 0 */")

    la c_src_bad: tekst = sh.kompiler_fra_kilde_strict("PUSH 2\nPUSH q\nADD\nHALT")
    assert_eq(c_src_bad, "/* feil: ugyldig heltallsargument q ved token 3 */")

    la expr_dis: tekst = sh.disasm_uttrykk("2+3*4")
    assert_eq(expr_dis, "0: PUSH 2\n1: PUSH 3\n2: PUSH 4\n3: MUL\n4: ADD\n5: PRINT\n6: HALT\n")

    la expr_dis_paren: tekst = sh.disasm_uttrykk("(2+3)*4")
    assert_eq(expr_dis_paren, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PUSH 4\n4: MUL\n5: PRINT\n6: HALT\n")

    la expr_dis_brace_group: tekst = sh.disasm_uttrykk("{2+3}*4")
    assert_eq(expr_dis_brace_group, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PUSH 4\n4: MUL\n5: PRINT\n6: HALT\n")

    la expr_dis_bracket_group: tekst = sh.disasm_uttrykk("[2+3]*4")
    assert_eq(expr_dis_bracket_group, "0: PUSH 2\n1: PUSH 3\n2: ADD\n3: PUSH 4\n4: MUL\n5: PRINT\n6: HALT\n")

    la expr_c: tekst = sh.kompiler_uttrykk_til_c("10 + 32")
    assert_ne(expr_c, "")

    la expr_cmp: tekst = sh.disasm_uttrykk("5>3&&2<4")
    assert_eq(expr_cmp, "0: PUSH 5\n1: PUSH 3\n2: GT\n3: PUSH 2\n4: PUSH 4\n5: LT\n6: AND\n7: PRINT\n8: HALT\n")

    la expr_eq: tekst = sh.disasm_uttrykk("7!=7||2==2")
    assert_eq(expr_eq, "0: PUSH 7\n1: PUSH 7\n2: EQ\n3: NOT\n4: PUSH 2\n5: PUSH 2\n6: EQ\n7: OR\n8: PRINT\n9: HALT\n")

    la expr_not_equal_angle_alias: tekst = sh.disasm_uttrykk("7<>8")
    assert_eq(expr_not_equal_angle_alias, "0: PUSH 7\n1: PUSH 8\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_xor_alias: tekst = sh.disasm_uttrykk("1 xor 0")
    assert_eq(expr_xor_alias, "0: PUSH 1\n1: PUSH 0\n2: EQ\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_xnor_alias: tekst = sh.disasm_uttrykk("1 xnor 1")
    assert_eq(expr_xnor_alias, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_norsk_xeller_ikke_alias: tekst = sh.disasm_uttrykk("1 xeller_ikke 1")
    assert_eq(expr_norsk_xeller_ikke_alias, "0: PUSH 1\n1: PUSH 1\n2: EQ\n3: PRINT\n4: HALT\n")

    la expr_nand_operator: tekst = sh.disasm_uttrykk("1 nand 1")
    assert_eq(expr_nand_operator, "0: PUSH 1\n1: PUSH 1\n2: AND\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_nand_alias_and_not: tekst = sh.disasm_uttrykk("1 and_not 1")
    assert_eq(expr_nand_alias_and_not, "0: PUSH 1\n1: PUSH 1\n2: AND\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_nand_alias_og_ikke: tekst = sh.disasm_uttrykk("1 og_ikke 1")
    assert_eq(expr_nand_alias_og_ikke, "0: PUSH 1\n1: PUSH 1\n2: AND\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_nor_operator: tekst = sh.disasm_uttrykk("0 nor 0")
    assert_eq(expr_nor_operator, "0: PUSH 0\n1: PUSH 0\n2: OR\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_nor_alias_or_not: tekst = sh.disasm_uttrykk("0 or_not 0")
    assert_eq(expr_nor_alias_or_not, "0: PUSH 0\n1: PUSH 0\n2: OR\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_nor_alias_eller_ikke: tekst = sh.disasm_uttrykk("0 eller_ikke 0")
    assert_eq(expr_nor_alias_eller_ikke, "0: PUSH 0\n1: PUSH 0\n2: OR\n3: NOT\n4: PRINT\n5: HALT\n")

    la expr_implies_operator: tekst = sh.disasm_uttrykk("1 implies 0")
    assert_eq(expr_implies_operator, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_implies_that_alias: tekst = sh.disasm_uttrykk("1 implies_that 0")
    assert_eq(expr_implies_that_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_this_implies_alias: tekst = sh.disasm_uttrykk("1 this_implies 0")
    assert_eq(expr_this_implies_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_dette_impliserer_alias: tekst = sh.disasm_uttrykk("1 dette_impliserer 0")
    assert_eq(expr_dette_impliserer_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_impliserer_at_alias: tekst = sh.disasm_uttrykk("1 impliserer_at 0")
    assert_eq(expr_impliserer_at_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_norsk_impliserer_operator: tekst = sh.disasm_uttrykk("1 impliserer 0")
    assert_eq(expr_norsk_impliserer_operator, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_norsk_medforer_alias: tekst = sh.disasm_uttrykk("1 medforer 0")
    assert_eq(expr_norsk_medforer_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_impl_alias: tekst = sh.disasm_uttrykk("1 impl 0")
    assert_eq(expr_impl_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_impliser_alias: tekst = sh.disasm_uttrykk("1 impliser 0")
    assert_eq(expr_impliser_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_follows_alias: tekst = sh.disasm_uttrykk("1 follows 0")
    assert_eq(expr_follows_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_folger_av_alias: tekst = sh.disasm_uttrykk("1 folger_av 0")
    assert_eq(expr_folger_av_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_it_follows_that_alias: tekst = sh.disasm_uttrykk("1 it_follows_that 0")
    assert_eq(expr_it_follows_that_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_det_folger_at_alias: tekst = sh.disasm_uttrykk("1 det_folger_at 0")
    assert_eq(expr_det_folger_at_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_therefore_alias: tekst = sh.disasm_uttrykk("1 therefore 0")
    assert_eq(expr_therefore_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_derfor_alias: tekst = sh.disasm_uttrykk("1 derfor 0")
    assert_eq(expr_derfor_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_hence_alias: tekst = sh.disasm_uttrykk("1 hence 0")
    assert_eq(expr_hence_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_altsa_alias: tekst = sh.disasm_uttrykk("1 altsa 0")
    assert_eq(expr_altsa_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_thus_alias: tekst = sh.disasm_uttrykk("1 thus 0")
    assert_eq(expr_thus_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_dermed_alias: tekst = sh.disasm_uttrykk("1 dermed 0")
    assert_eq(expr_dermed_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_consequently_alias: tekst = sh.disasm_uttrykk("1 consequently 0")
    assert_eq(expr_consequently_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_folgelig_alias: tekst = sh.disasm_uttrykk("1 folgelig 0")
    assert_eq(expr_folgelig_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_thereby_alias: tekst = sh.disasm_uttrykk("1 thereby 0")
    assert_eq(expr_thereby_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_derved_alias: tekst = sh.disasm_uttrykk("1 derved 0")
    assert_eq(expr_derved_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_thereupon_alias: tekst = sh.disasm_uttrykk("1 thereupon 0")
    assert_eq(expr_thereupon_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_derpa_alias: tekst = sh.disasm_uttrykk("1 derpa 0")
    assert_eq(expr_derpa_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_ergo_alias: tekst = sh.disasm_uttrykk("1 ergo 0")
    assert_eq(expr_ergo_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_saledes_alias: tekst = sh.disasm_uttrykk("1 saledes 0")
    assert_eq(expr_saledes_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_infer_alias: tekst = sh.disasm_uttrykk("1 infer 0")
    assert_eq(expr_infer_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_derav_alias: tekst = sh.disasm_uttrykk("1 derav 0")
    assert_eq(expr_derav_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_as_consequence_alias: tekst = sh.disasm_uttrykk("1 as_consequence 0")
    assert_eq(expr_as_consequence_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_som_konsekvens_alias: tekst = sh.disasm_uttrykk("1 som_konsekvens 0")
    assert_eq(expr_som_konsekvens_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_as_a_result_alias: tekst = sh.disasm_uttrykk("1 as_a_result 0")
    assert_eq(expr_as_a_result_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_som_resultat_alias: tekst = sh.disasm_uttrykk("1 som_resultat 0")
    assert_eq(expr_som_resultat_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_only_if_alias: tekst = sh.disasm_uttrykk("1 only_if 0")
    assert_eq(expr_only_if_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_kun_hvis_alias: tekst = sh.disasm_uttrykk("1 kun_hvis 0")
    assert_eq(expr_kun_hvis_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_requires_alias: tekst = sh.disasm_uttrykk("1 requires 0")
    assert_eq(expr_requires_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_krever_alias: tekst = sh.disasm_uttrykk("1 krever 0")
    assert_eq(expr_krever_alias, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_arrow_implies_operator: tekst = sh.disasm_uttrykk("1 -> 0")
    assert_eq(expr_arrow_implies_operator, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_fat_arrow_implies_operator: tekst = sh.disasm_uttrykk("1 => 0")
    assert_eq(expr_fat_arrow_implies_operator, "0: PUSH 1\n1: PUSH 0\n2: SWAP\n3: NOT\n4: SWAP\n5: OR\n6: PRINT\n7: HALT\n")

    la expr_left_arrow_implied_by_operator: tekst = sh.disasm_uttrykk("1 <- 0")
    assert_eq(expr_left_arrow_implied_by_operator, "0: PUSH 1\n1: PUSH 0\n2: NOT\n3: OR\n4: PRINT\n5: HALT\n")

    la expr_implied_by_alias: tekst = sh.disasm_uttrykk("1 implied_by 0")
