    la tokens: liste_tekst = tokeniser_uttrykk(kilde)
    la ops: liste_tekst = [""]
    la verdier: liste_heltall = [0]
    la feil: tekst = ""

    fjern_indeks(ops, 0)
    fjern_indeks(verdier, 0)

    hvis (lengde(tokens) > 0 og normaliser_norsk_token(tokens[0]) == "hvis") {
        la navn: liste_tekst = [""]
        la miljo_verdier: liste_heltall = [0]
        fjern_indeks(navn, 0)
        fjern_indeks(miljo_verdier, 0)
        feil = bygg_hvis_da_ellers_ops_med_miljo(tokens, navn, miljo_verdier, ops, verdier)
    } ellers {
        feil = uttrykk_til_ops_og_verdier(tokens, ops, verdier)
    }
    hvis (feil != "") {
        returner feil
    }

    legg_til(ops, "PRINT")
    legg_til(verdier, 0)
    legg_til(ops, "HALT")
    legg_til(verdier, 0)

    returner kompiler_til_c(ops, verdier)
}

funksjon skript_til_ops_og_verdier(tokens: liste_tekst, navn: liste_tekst, miljo_verdier: liste_heltall, out_ops: liste_tekst, out_verdier: liste_heltall) -> tekst {
    la i: heltall = 0
    la fant_sluttuttrykk: bool = usann

    fjern_indeks(out_ops, 0)
    fjern_indeks(out_verdier, 0)

    mens (i < lengde(tokens)) {
        la stmt_tokens: liste_tekst = [""]
        la stmt_start: heltall = i
        la stmt_has_semicolon: bool = usann

        fjern_indeks(stmt_tokens, 0)
        mens (i < lengde(tokens) og tokens[i] != ";") {
            hvis (tokens[i] != "") {
                legg_til(stmt_tokens, tokens[i])
            }
            i = i + 1
        }
        hvis (i < lengde(tokens) og tokens[i] == ";") {
            stmt_has_semicolon = sann
            i = i + 1
        }

        hvis (lengde(stmt_tokens) == 0) {
            fortsett
        }

        la ass_start: heltall = 0
        la har_la: bool = usann
        la har_sett: bool = usann
        la stmt_head: tekst = normaliser_norsk_token(stmt_tokens[ass_start])

        hvis (stmt_head == "la") {
            har_la = sann
            ass_start = ass_start + 1
        } ellers hvis (stmt_head == "sett") {
            har_sett = sann
            ass_start = ass_start + 1
        }

        hvis ((har_la eller har_sett) og ass_start >= lengde(stmt_tokens)) {
            hvis (har_la) {
                returner "/* feil: 'la' må etterfølges av variabelnavn ved " + token_pos(stmt_start) + " */"
            }
            returner "/* feil: 'sett' må etterfølges av variabelnavn ved " + token_pos(stmt_start) + " */"
        }

        hvis (ass_start + 1 < lengde(stmt_tokens) og er_navn_token(stmt_tokens[ass_start]) og er_assignment_op(stmt_tokens[ass_start + 1])) {
            la varnavn: tekst = stmt_tokens[ass_start]
            la ass_op: tekst = stmt_tokens[ass_start + 1]
            la expr_tokens: liste_tekst = [""]
            la expr_ops: liste_tekst = [""]
            la expr_verdier: liste_heltall = [0]
            la eval_resultat: liste_heltall = [0]
            la feil: tekst = ""
            la j: heltall = ass_start + 2

            fjern_indeks(expr_tokens, 0)
            fjern_indeks(expr_ops, 0)
            fjern_indeks(expr_verdier, 0)
            fjern_indeks(eval_resultat, 0)

            mens (j < lengde(stmt_tokens)) {
                legg_til(expr_tokens, stmt_tokens[j])
                j = j + 1
            }

            hvis (lengde(expr_tokens) == 0) {
                returner "/* feil: tomt uttrykk i assignment til " + varnavn + " ved " + token_pos(stmt_start) + " */"
            }
            hvis (stmt_has_semicolon == usann) {
                returner "/* feil: mangler ';' etter assignment til " + varnavn + " ved " + token_pos(stmt_start) + " */"
            }

            hvis (har_la og ass_op != "=") {
                returner "/* feil: 'la' støtter kun '=' ved " + token_pos(stmt_start) + " */"
            }

            la idx_pre: heltall = finn_navn_indeks(navn, varnavn)
            hvis (ass_op != "=" og idx_pre < 0) {
                returner "/* feil: variabel '" + varnavn + "' er ikke deklarert for '" + ass_op + "' ved " + token_pos(stmt_start) + " */"
            }
            hvis (ass_op != "=") {
                la binop: tekst = assignment_op_til_binop(ass_op)
                la rhs_copy: liste_tekst = [""]
                la t: heltall = 0
                fjern_indeks(rhs_copy, 0)
                mens (t < lengde(expr_tokens)) {
                    legg_til(rhs_copy, expr_tokens[t])
                    t = t + 1
                }
                fjern_indeks(expr_tokens, 0)
                legg_til(expr_tokens, varnavn)
                legg_til(expr_tokens, binop)
                t = 0
                mens (t < lengde(rhs_copy)) {
                    legg_til(expr_tokens, rhs_copy[t])
                    t = t + 1
                }
            }

            hvis (lengde(expr_tokens) > 0 og normaliser_norsk_token(expr_tokens[0]) == "hvis") {
                feil = bygg_hvis_da_ellers_ops_med_miljo(expr_tokens, navn, miljo_verdier, expr_ops, expr_verdier)
            } ellers {
                feil = uttrykk_til_ops_og_verdier_med_miljo(expr_tokens, navn, miljo_verdier, expr_ops, expr_verdier)
            }
            hvis (feil != "") {
                returner feil
            }

            feil = eval_ops_til_verdi(expr_ops, expr_verdier, eval_resultat)
            hvis (feil != "") {
                returner feil
            }

            la idx: heltall = finn_navn_indeks(navn, varnavn)
            hvis (har_la og idx >= 0) {
                returner "/* feil: variabel '" + varnavn + "' er allerede deklarert ved " + token_pos(stmt_start) + " */"
            }
            hvis (har_sett og idx < 0) {
                returner "/* feil: variabel '" + varnavn + "' er ikke deklarert (bruk 'la') ved " + token_pos(stmt_start) + " */"
            }

            hvis (idx >= 0) {
                sett_inn(miljo_verdier, idx, eval_resultat[0])
            } ellers {
                legg_til(navn, varnavn)
                legg_til(miljo_verdier, eval_resultat[0])
            }
            fortsett
        }

        hvis (har_la) {
            returner "/* feil: ugyldig deklarasjon etter 'la' ved " + token_pos(stmt_start) + " */"
        }
        hvis (har_sett) {
            returner "/* feil: ugyldig assignment etter 'sett' ved " + token_pos(stmt_start) + " */"
        }

        la final_tokens: liste_tekst = [""]
        fjern_indeks(final_tokens, 0)
        hvis (normaliser_norsk_token(stmt_tokens[0]) == "returner") {
            la r: heltall = 1
            mens (r < lengde(stmt_tokens)) {
                legg_til(final_tokens, stmt_tokens[r])
                r = r + 1
            }
            hvis (lengde(final_tokens) == 0) {
                returner "/* feil: 'returner' må etterfølges av uttrykk ved " + token_pos(stmt_start) + " */"
            }
        } ellers {
            la r2: heltall = 0
            mens (r2 < lengde(stmt_tokens)) {
                legg_til(final_tokens, stmt_tokens[r2])
                r2 = r2 + 1
            }
        }

        la stmt_ops: liste_tekst = [""]
        la stmt_verdier: liste_heltall = [0]
        la final_feil: tekst = ""
        fjern_indeks(stmt_ops, 0)
        fjern_indeks(stmt_verdier, 0)

        hvis (lengde(final_tokens) > 0 og normaliser_norsk_token(final_tokens[0]) == "hvis") {
            final_feil = bygg_hvis_da_ellers_ops_med_miljo(final_tokens, navn, miljo_verdier, stmt_ops, stmt_verdier)
        } ellers {
            final_feil = uttrykk_til_ops_og_verdier_med_miljo(final_tokens, navn, miljo_verdier, stmt_ops, stmt_verdier)
        }
        hvis (final_feil != "") {
            returner final_feil
        }

        hvis (stmt_has_semicolon) {
            la bare_tomme_etter: bool = sann
            la sjekk_i: heltall = i
            mens (sjekk_i < lengde(tokens)) {
                hvis (tokens[sjekk_i] != ";" og tokens[sjekk_i] != "") {
                    bare_tomme_etter = usann
                    bryt
                }
                sjekk_i = sjekk_i + 1
            }

            hvis (i >= lengde(tokens) eller bare_tomme_etter) {
                la kopier_feil_slutt: tekst = append_ops(out_ops, out_verdier, stmt_ops, stmt_verdier)
                hvis (kopier_feil_slutt != "") {
                    returner kopier_feil_slutt
                }
                fant_sluttuttrykk = sann
                i = lengde(tokens)
                bryt
            }

            hvis (normaliser_norsk_token(stmt_tokens[0]) == "returner") {
                la kopier_feil: tekst = append_ops(out_ops, out_verdier, stmt_ops, stmt_verdier)
                hvis (kopier_feil != "") {
                    returner kopier_feil
                }
                fant_sluttuttrykk = sann
                mens (i < lengde(tokens)) {
                    hvis (tokens[i] != ";" og tokens[i] != "") {
                        returner "/* feil: kun ';' er tillatt etter 'returner' (token " + tekst_fra_heltall(i) + ") */"
                    }
                    i = i + 1
                }
                bryt
            }

            la stmt_eval: liste_heltall = [0]
            fjern_indeks(stmt_eval, 0)
            final_feil = eval_ops_til_verdi(stmt_ops, stmt_verdier, stmt_eval)
            hvis (final_feil != "") {
                returner final_feil
            }
            fortsett
        }

        la kopier_feil2: tekst = append_ops(out_ops, out_verdier, stmt_ops, stmt_verdier)
        hvis (kopier_feil2 != "") {
            returner kopier_feil2
        }
        fant_sluttuttrykk = sann

        mens (i < lengde(tokens)) {
            hvis (tokens[i] != ";" og tokens[i] != "") {
                returner "/* feil: kun siste statement kan være uttrykk (token " + tekst_fra_heltall(i) + ") */"
            }
            i = i + 1
        }
        bryt
    }

    hvis (fant_sluttuttrykk == usann) {
        returner "/* feil: skriptet mangler sluttuttrykk */"
    }
    returner ""
}

funksjon disasm_skript(kilde: tekst) -> tekst {
    la tokens: liste_tekst = tokeniser_uttrykk(kilde)
    la navn: liste_tekst = [""]
    la miljo_verdier: liste_heltall = [0]
    la ops: liste_tekst = [""]
    la verdier: liste_heltall = [0]
    la feil: tekst = ""

    fjern_indeks(navn, 0)
    fjern_indeks(miljo_verdier, 0)

    feil = skript_til_ops_og_verdier(tokens, navn, miljo_verdier, ops, verdier)
    hvis (feil != "") {
        returner feil
    }

    legg_til(ops, "PRINT")
    legg_til(verdier, 0)
    legg_til(ops, "HALT")
    legg_til(verdier, 0)
    returner disasm_program(ops, verdier)
}

funksjon kompiler_skript_til_c(kilde: tekst) -> tekst {
    la tokens: liste_tekst = tokeniser_uttrykk(kilde)
    la navn: liste_tekst = [""]
