funksjon append_linje(kilde: tekst, linje: tekst) -> tekst {
    returner kilde + linje + "\n"
}

funksjon instruksjon_til_tekst(op: tekst, verdi: heltall) -> tekst {
    hvis (op == "PUSH" eller op == "LABEL" eller op == "JMP" eller op == "JZ" eller op == "CALL" eller op == "STORE" eller op == "LOAD") {
        returner op + " " + tekst_fra_heltall(verdi)
    }
    returner op
}

funksjon disasm_program(ops: liste_tekst, verdier: liste_heltall) -> tekst {
    la out: tekst = ""
    la i: heltall = 0

    hvis (lengde(ops) != lengde(verdier)) {
        returner "/* feil: ops og verdier må ha samme lengde */"
    }

    mens (i < lengde(ops)) {
        out = append_linje(out, tekst_fra_heltall(i) + ": " + instruksjon_til_tekst(ops[i], verdier[i]))
        i = i + 1
    }
    returner out
}

funksjon op_krever_arg(op: tekst) -> bool {
    hvis (op == "PUSH" eller op == "LABEL" eller op == "JMP" eller op == "JZ" eller op == "CALL" eller op == "STORE" eller op == "LOAD") {
        returner sann
    }
    returner usann
}

funksjon op_kjent(op: tekst) -> bool {
    hvis (op_krever_arg(op)) {
        returner sann
    }
    hvis (op == "ADD" eller op == "SUB" eller op == "MUL" eller op == "DIV" eller op == "MOD") {
        returner sann
    }
    hvis (op == "EQ" eller op == "GT" eller op == "LT" eller op == "AND" eller op == "OR") {
        returner sann
    }
    hvis (op == "NOT" eller op == "DUP" eller op == "POP" eller op == "SWAP" eller op == "OVER") {
        returner sann
    }
    hvis (op == "PRINT" eller op == "HALT" eller op == "RET") {
        returner sann
    }
    returner usann
}

funksjon er_heltall_token(tok: tekst) -> bool {
    la n: heltall = heltall_fra_tekst(tok)
    returner tekst_fra_heltall(n) == tok
}

funksjon normaliser_norsk_token(tok: tekst) -> tekst {
    hvis (tok == "let") {
        returner "la"
    }
    hvis (tok == "const") {
        returner "la"
    }
    hvis (tok == "var") {
        returner "la"
    }
    hvis (tok == "declare") {
        returner "la"
    }
    hvis (tok == "set") {
        returner "sett"
    }
    hvis (tok == "assign") {
        returner "sett"
    }
    hvis (tok == "return") {
        returner "returner"
    }
    hvis (tok == "if") {
        returner "hvis"
    }
    hvis (tok == "then") {
        returner "da"
    }
    hvis (tok == "else") {
        returner "ellers"
    }
    hvis (tok == "elseif" eller tok == "elsif") {
        returner "ellers_hvis"
    }
    hvis (tok == "and") {
