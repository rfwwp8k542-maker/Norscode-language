    }
    hvis (tok == "dividerer_seg_på" eller tok == "dividerer_seg_paa") {
        returner "dividerer_seg_pa"
    }
    hvis (tok == "divider_på" eller tok == "divider_paa") {
        returner "divider_pa"
    }
    hvis (tok == "dividere_på" eller tok == "dividere_paa") {
        returner "dividere_pa"
    }
    hvis (tok == "dividerer_på" eller tok == "dividerer_paa") {
        returner "dividerer_pa"
    }
    hvis (tok == "dividert_på" eller tok == "dividert_paa") {
        returner "dividert_pa"
    }
    hvis (tok == "divideres_på" eller tok == "divideres_paa") {
        returner "divideres_pa"
    }
    hvis (tok == "større") {
        returner "storre"
    }
    hvis (tok == "større_enn" eller tok == "størreenn" eller tok == "storreenn") {
        returner "storre_enn"
    }
    hvis (tok == "er_større_enn" eller tok == "er_storre_enn" eller tok == "erstørreenn" eller tok == "erstorreenn") {
        returner "storre_enn"
    }
    hvis (tok == "større_eller_lik" eller tok == "størreellerlik" eller tok == "storreellerlik") {
        returner "storre_eller_lik"
    }
    hvis (tok == "større_lik" eller tok == "storre_lik" eller tok == "størrelik" eller tok == "storrelik" eller tok == "er_større_lik" eller tok == "er_storre_lik" eller tok == "erstørrelik" eller tok == "erstorrelik") {
        returner "storre_eller_lik"
    }
    hvis (tok == "er_større_eller_lik" eller tok == "er_storre_eller_lik" eller tok == "erstørreellerlik" eller tok == "erstorreellerlik") {
        returner "storre_eller_lik"
    }
    hvis (tok == "større_enn_eller_lik" eller tok == "storre_enn_eller_lik" eller tok == "størreennellerlik" eller tok == "storreennellerlik") {
        returner "storre_eller_lik"
    }
    hvis (tok == "er_større_enn_eller_lik" eller tok == "er_storre_enn_eller_lik" eller tok == "erstørreennellerlik" eller tok == "erstorreennellerlik") {
        returner "storre_eller_lik"
    }
    hvis (tok == "er_mindre_enn" eller tok == "ermindreenn") {
        returner "mindre_enn"
    }
    hvis (tok == "mindre_enn" eller tok == "mindreenn") {
        returner "mindre_enn"
    }
    hvis (tok == "er_mindre_eller_lik" eller tok == "er_mindre_enn_eller_lik" eller tok == "ermindreellerlik" eller tok == "ermindreennellerlik") {
        returner "mindre_eller_lik"
    }
    hvis (tok == "mindre_enn_eller_lik" eller tok == "mindreennellerlik") {
        returner "mindre_eller_lik"
    }
    hvis (tok == "mindre_lik" eller tok == "mindrelik" eller tok == "mindreellerlik" eller tok == "er_mindre_lik" eller tok == "ermindrelik") {
        returner "mindre_eller_lik"
    }
    hvis (tok == "ikke_lik" eller tok == "ikke_lik_med" eller tok == "ikkelikmed" eller tok == "er_ikke" eller tok == "erikke" eller tok == "er_ulik" eller tok == "er_ulik_med" eller tok == "erulik" eller tok == "erulikmed" eller tok == "erikkelik" eller tok == "erikkelikmed" eller tok == "ulik_med" eller tok == "ulikmed"
        eller tok == "ikkje_lik" eller tok == "ikkje_lik_med" eller tok == "ikkjelikmed" eller tok == "ikkje_er" eller tok == "er_ikkje" eller tok == "erikkje" eller tok == "erikkjelik" eller tok == "erikkjelikmed") {
        returner "ikke_er"
    }
    hvis (tok == "ikkje") {
        returner "ikke"
    }
    hvis (tok == "sant") {
        returner "sann"
    }
    hvis (tok == "on") {
        returner "sann"
    }
    hvis (tok == "true") {
        returner "sann"
    }
    hvis (tok == "ja") {
        returner "sann"
    }
    hvis (tok == "yes") {
        returner "sann"
    }
    hvis (tok == "enabled") {
        returner "sann"
    }
    hvis (tok == "active") {
        returner "sann"
    }
    hvis (tok == "usant") {
        returner "usann"
    }
    hvis (tok == "off") {
        returner "usann"
    }
    hvis (tok == "false") {
        returner "usann"
    }
    hvis (tok == "nei") {
