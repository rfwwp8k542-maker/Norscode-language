    hvis (tok == "not_equal" eller tok == "not_equals" eller tok == "not_equal_to" eller tok == "notequal" eller tok == "notequals") {
        returner "ikke_er"
    }
    hvis (tok == "equals" eller tok == "equal" eller tok == "equal_to") {
