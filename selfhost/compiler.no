    fjern_indeks(navn, 0)
    fjern_indeks(miljo_verdier, 0)

    feil = skript_til_ops_og_verdier(tokens, navn, miljo_verdier, ops, verdier)
    hvis (feil != "") {
        returner feil
    }

    legg_til(ops, "PRINT")
    legg_til(verdier, 0)
    legg_til(ops, "HALT")
    legg_til(verdier, 0)
    returner kompiler_til_c(ops, verdier)
}

funksjon kompiler_uttrykk_til_c_med_miljo(kilde: tekst, navn: liste_tekst, miljo_verdier: liste_heltall) -> tekst {
    la tokens: liste_tekst = tokeniser_uttrykk(kilde)
    la ops: liste_tekst = [""]
    la verdier: liste_heltall = [0]
    la feil: tekst = ""

    fjern_indeks(ops, 0)
    fjern_indeks(verdier, 0)

    hvis (lengde(tokens) > 0 og normaliser_norsk_token(tokens[0]) == "hvis") {
        feil = bygg_hvis_da_ellers_ops_med_miljo(tokens, navn, miljo_verdier, ops, verdier)
    } ellers {
        feil = uttrykk_til_ops_og_verdier_med_miljo(tokens, navn, miljo_verdier, ops, verdier)
    }
    hvis (feil != "") {
        returner feil
    }

    legg_til(ops, "PRINT")
    legg_til(verdier, 0)
    legg_til(ops, "HALT")
    legg_til(verdier, 0)

    returner kompiler_til_c(ops, verdier)
}
