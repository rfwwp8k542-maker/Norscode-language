bruk std.lagring som lagring

funksjon start() -> heltall {
    la data: ordbok_tekst = {}
    assert_eq(lagring.sett_tekst(data, "navn", "Ada"), 1)
    assert_eq(lagring.sett_tall(data, "antall", 3), 2)
    assert_eq(lagring.sett_bool(data, "klar", sann), 3)
    assert_eq(lengde(data), 3)
    skriv(tekst_fra_heltall(lagring.lagre("/private/tmp/norscode_lagring_test.json", data)))
    returner 0
}
