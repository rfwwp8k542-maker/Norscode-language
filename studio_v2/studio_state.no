# Studio v2 workspace foundation.

funksjon studio_v2_state_tittel() -> tekst {
    returner "Norscode Studio v2"
}

funksjon studio_v2_state_session_fil(rot: tekst) -> tekst {
    returner rot + "/.norscode/studio_v2.session"
}

funksjon studio_v2_state_session_tom() -> liste_tekst {
    returner []
}

funksjon studio_v2_state_session_les(rot: tekst) -> liste_tekst {
    la sti: tekst = studio_v2_state_session_fil(rot)
    hvis ikke fil_eksisterer(sti) da {
        returner studio_v2_state_session_tom()
    }
    returner del_linjer(les_fil(sti))
}

funksjon studio_v2_state_session_verdi(session: liste_tekst, nøkkel: tekst) -> tekst {
    la indeks: heltall = 0
    mens (indeks < lengde(session)) {
        la deler: liste_tekst = tekst_del_på(session[indeks], "\t")
        hvis lengde(deler) >= 2 og deler[0] == nøkkel da {
            returner deler[1]
        }
        indeks = indeks + 1
    }
    returner ""
}

funksjon studio_v2_state_session_recent_prosjekter(session: liste_tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(session)) {
        la deler: liste_tekst = tekst_del_på(session[indeks], "\t")
        hvis lengde(deler) >= 2 og deler[0] == "recent_project" da {
            legg_til(resultat, deler[1])
        }
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_state_session_apne_filer(session: liste_tekst) -> liste_tekst {
    la resultat: liste_tekst = []
    la indeks: heltall = 0
    mens (indeks < lengde(session)) {
        la deler: liste_tekst = tekst_del_på(session[indeks], "\t")
        hvis lengde(deler) >= 2 og deler[0] == "open_file" da {
            legg_til(resultat, deler[1])
        }
        indeks = indeks + 1
    }
    returner resultat
}

funksjon studio_v2_state_session_aktiv_tab(session: liste_tekst) -> tekst {
    returner studio_v2_state_session_verdi(session, "aktiv_tab")
}

funksjon studio_v2_state_session_split_fokus(session: liste_tekst) -> tekst {
    la verdi: tekst = studio_v2_state_session_verdi(session, "split_fokus")
    hvis verdi != "" da {
        returner verdi
    }
    returner "høyre"
}

funksjon studio_v2_state_session_tool_window(session: liste_tekst) -> tekst {
    la verdi: tekst = studio_v2_state_session_verdi(session, "tool_window")
    hvis verdi != "" da {
        returner verdi
    }
    returner "Project"
}

funksjon studio_v2_state_session_tema(session: liste_tekst) -> tekst {
    la verdi: tekst = studio_v2_state_session_verdi(session, "tema")
    hvis verdi != "" da {
        returner verdi
    }
    returner "mørk"
}

funksjon studio_v2_state_session_keymap(session: liste_tekst) -> tekst {
    la verdi: tekst = studio_v2_state_session_verdi(session, "keymap")
    hvis verdi != "" da {
        returner verdi
    }
    returner "standard"
}

funksjon studio_v2_state_session_runtimevalg(session: liste_tekst) -> tekst {
    la verdi: tekst = studio_v2_state_session_verdi(session, "runtimevalg")
